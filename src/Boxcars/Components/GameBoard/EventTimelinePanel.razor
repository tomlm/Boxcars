@using Boxcars.Data
@using MudBlazor

<MudStack Spacing="0">
    @if (Items.Count == 0)
    {
        <MudText Typo="Typo.body2">No events recorded yet.</MudText>
    }
    else
    {
        <select class="event-timeline-listbox" size="12" aria-label="Activity log">
            @foreach (var item in Items)
            {
                <option>@FormatTimelineText(item)</option>
            }
        </select>
    }
</MudStack>

@code {
    [Parameter]
    public IReadOnlyList<EventTimelineItem> Items { get; set; } = [];

    private static string FormatTimelineText(EventTimelineItem item)
    {
        return $"{item.OccurredUtc.LocalDateTime:t}  {item.Description}";
    }
}
