@using MudBlazor

<MudPaper Class="pa-4" Outlined="true">
    <MudStack Spacing="2">
        <MudText Typo="Typo.h6">Turn Actions</MudText>

        @if (!IsCurrentUserActivePlayer)
        {
            <MudAlert Severity="Severity.Info" Dense="true">
                @ObserverMessage
            </MudAlert>
        }

        <MudButton Variant="Variant.Filled"
               Color="MudBlazor.Color.Primary"
                   Disabled="@(!CanPrimaryAction)"
                   OnClick="OnPrimaryAction">
            @PrimaryActionLabel
        </MudButton>

        @if (ShowSecondaryAction)
        {
            <MudButton Variant="Variant.Text"
                       Color="MudBlazor.Color.Default"
                       Disabled="@(!CanSecondaryAction)"
                       OnClick="OnSecondaryAction">
                @SecondaryActionLabel
            </MudButton>
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter]
    public string PrimaryActionLabel { get; set; } = "Action";

    [Parameter]
    public bool CanPrimaryAction { get; set; } = true;

    [Parameter]
    public EventCallback OnPrimaryAction { get; set; }

    [Parameter]
    public bool ShowSecondaryAction { get; set; }

    [Parameter]
    public string SecondaryActionLabel { get; set; } = string.Empty;

    [Parameter]
    public bool CanSecondaryAction { get; set; } = true;

    [Parameter]
    public EventCallback OnSecondaryAction { get; set; }

    [Parameter]
    public bool IsCurrentUserActivePlayer { get; set; }

    [Parameter]
    public string ObserverMessage { get; set; } = "Waiting for the active player to complete their turn.";
}