@using Boxcars.Data
@using MudBlazor

<MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="2" Class="turn-status-panel">
    @if (!IsPurchasePhase && !SuppressRollAndFeeDetails)
    {
        @if (IsBonusMove)
        {
            <MudText Typo="Typo.body2">Bonus: @State.RedDie</MudText>
            <MudText Typo="Typo.body2">Move: @GetMovesTaken(State)/@State.MovementAllowance</MudText>
        }
        else
        {
            <MudText Typo="Typo.body2">Roll: @FormatRoll(State)</MudText>
            <MudText Typo="Typo.body2">Move: @GetMovesTaken(State)/@State.MovementAllowance</MudText>
        }
    }
    @if (State.IsActivePlayerAtDestination && !string.IsNullOrWhiteSpace(State.ActivePlayerDestinationCity))
    {
        <MudText Typo="Typo.body2">At destination: @State.ActivePlayerDestinationCity</MudText>
    }
    @if (!IsPurchasePhase && !SuppressRollAndFeeDetails)
    {
        <MudText Typo="Typo.body2">Fees: @FormatCurrency(State.PreviewFee)</MudText>
    }
</MudStack>

@code {
    [Parameter]
    public BoardTurnViewState State { get; set; } = new();

    [Parameter]
    public bool SuppressRollAndFeeDetails { get; set; }

    private bool IsPurchasePhase => string.Equals(State.TurnPhase, "Purchase", StringComparison.OrdinalIgnoreCase);
    private bool IsBonusMove => State.RedDie.HasValue && State.WhiteDieOne <= 0 && State.WhiteDieTwo <= 0;

    private string DisplayPhase => string.IsNullOrWhiteSpace(State.TurnPhase) ? "Unknown" : State.TurnPhase;

    private static string FormatCurrency(int value)
    {
        return $"${Math.Max(0, value):N0}";
    }

    private static string FormatRoll(BoardTurnViewState state)
    {
        if (state.WhiteDieOne > 0 && state.WhiteDieTwo > 0)
        {
            if (state.RedDie.HasValue)
            {
                return $"{state.WhiteDieOne} + {state.WhiteDieTwo} + ({state.RedDie.Value})";
            }

            if (state.BonusRollAvailable)
            {
                return $"{state.WhiteDieOne}+{state.WhiteDieTwo} + (Bonus)";
            }

            return $"{state.WhiteDieOne}+{state.WhiteDieTwo}";
        }

        return state.CurrentRollTotal > 0
            ? state.CurrentRollTotal.ToString()
            : "-";
    }

    private static int GetMovesTaken(BoardTurnViewState state)
    {
        return Math.Max(0, state.MovementAllowance - state.MovementRemaining);
    }
}