@using Boxcars.Data
@using MudBlazor

@if (Report is null)
    {
        <MudAlert Severity="Severity.Info" Dense="true">
            Map analysis is not available yet.
        </MudAlert>
    }
    else
    {
        <MudStack Spacing="3">
            <MudStack Spacing="0">
                <MudText Typo="Typo.h6">@SectionHeading</MudText>
                <MudText Typo="Typo.body2">@Report.MapName</MudText>
            </MudStack>

            @if (View == PurchaseExperienceTab.Railroads)
            {
                <div style="display: grid; gap: 0.75rem; width: fit-content; max-width: 100%">
                    <div style="width: fit-content; max-width: 100%; min-width: 0">
                        <MudTable T="RailroadAnalysisRow" Items="UnownedRailroadRows" Dense="true" Hover="true">
                            <HeaderContent>
                                <MudTh><MudTableSortLabel T="RailroadAnalysisRow" SortBy="@(row => row.FullName)"><strong>Railroad</strong></MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel T="RailroadAnalysisRow" SortBy="@(row => row.PurchasePrice)"><strong>Price</strong></MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel T="RailroadAnalysisRow" SortBy="@(row => row.CitiesServedCount)"><strong>Cities</strong></MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel T="RailroadAnalysisRow" SortBy="@(row => row.ServicePercentage)"><strong>Access %</strong></MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel T="RailroadAnalysisRow" SortBy="@(row => row.MonopolyPercentage)"><strong>Monopoly %</strong></MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel T="RailroadAnalysisRow" SortBy="@(row => GetPlayerAccessDelta(row))"><strong>Player Access</strong></MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel T="RailroadAnalysisRow" SortBy="@(row => GetPlayerMonopolyDelta(row))"><strong>Player Monopoly</strong></MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel T="RailroadAnalysisRow" SortBy="@(row => row.ConnectionCount)"><strong>Connections</strong></MudTableSortLabel></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>
                                    <span>@context.FullName</span>
                                </MudTd>
                                <MudTd>
                                    <span style="@GetRailroadPriceStyle(context)">@FormatCurrency(context.PurchasePrice)</span>
                                </MudTd>
                                <MudTd>@context.CitiesServedCount</MudTd>
                                <MudTd>@FormatRailroadPercent(context.ServicePercentage)</MudTd>
                                <MudTd>@FormatRailroadPercent(context.MonopolyPercentage)</MudTd>
                                <MudTd>@FormatSignedOptionalPercent(GetPlayerAccessDelta(context))</MudTd>
                                <MudTd>@FormatSignedOptionalPercent(GetPlayerMonopolyDelta(context))</MudTd>
                                <MudTd>@context.ConnectionCount</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </div>
                </div>
            }
            else if (View == PurchaseExperienceTab.Regions)
            {
                <MudPaper Class="pa-3" Style="width: 100%; max-width: 100%" Outlined="true">
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(16rem, max-content)); gap: 0.75rem; align-items: start">
                        @foreach (var regionGroup in RegionCityGroups)
                        {
                            <div style="width: fit-content; max-width: 100%; min-width: 0">
                                <MudText Typo="Typo.h6" Style="margin-bottom: 0.2rem">@regionGroup.RegionName</MudText>
                                <MudText Typo="Typo.caption" Style="display: block; margin-bottom: 0.6rem">Map Probability: @FormatPercent(regionGroup.RegionProbabilityPercentage)</MudText>
                                <MudTable T="CityAccessRow" Items="regionGroup.Cities" Dense="true" Hover="true">
                                    <HeaderContent>
                                        <MudTh><MudTableSortLabel T="CityAccessRow" SortBy="@(row => row.CityName)"><strong>City</strong></MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel T="CityAccessRow" SortBy="@(row => row.WithinRegionPercentage)"><strong>Region %</strong></MudTableSortLabel></MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>@context.CityName</MudTd>
                                        <MudTd>@FormatCityPercent(context.WithinRegionPercentage)</MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </div>
                        }
                    </div>
                </MudPaper>
            }
            else if (View == PurchaseExperienceTab.Cities)
            {
                <MudPaper Class="pa-3" Style="width: 100%; max-width: 100%" Outlined="true">
                    <MudText Typo="Typo.subtitle2" Style="margin-bottom: 0.75rem; font-weight: 700">Map City Access</MudText>

                    <div style="--purchase-analysis-city-rows: 14; display: grid; grid-auto-flow: column; grid-template-rows: repeat(var(--purchase-analysis-city-rows), minmax(0, auto)); grid-auto-columns: minmax(14rem, 1fr); gap: 0.5rem 1rem; width: 100%; max-width: 100%; overflow-x: auto; align-content: start">
                        @foreach (var city in SortedCityRows)
                        {
                            <MudPaper Outlined="true" Style="display: grid; gap: 0.2rem; min-width: 0; padding: 0.45rem 0.6rem; background: color-mix(in srgb, var(--mud-palette-surface) 86%, white 14%)">
                                <MudText Typo="Typo.body2" Style="font-weight: 600">@city.CityName</MudText>
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="min-width: 0">
                                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary)">@city.RegionCode</MudText>
                                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-primary); font-weight: 600">@FormatCityPercent(city.GlobalAccessPercentage)</MudText>
                                </MudStack>
                            </MudPaper>
                        }
                    </div>
                </MudPaper>
            }

            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                <MudChip T="string">Avg Trip Length: @Report.AverageTripLengthDots.ToString("N1")</MudChip>
                <MudChip T="string">Avg Payoff: @FormatCurrency((int)Math.Round(Report.AveragePayoff))</MudChip>
                <MudChip T="string">Avg Payoff/Dot: @Report.AveragePayoffPerDot.ToString("N2")</MudChip>
            </MudStack>
        </MudStack>
    }

@code {
    [Parameter]
    public MapAnalysisReport? Report { get; set; }

    [Parameter]
    public RecommendationInputSet? RecommendationInputs { get; set; }

    [Parameter]
    public PurchaseExperienceTab View { get; set; } = PurchaseExperienceTab.Railroads;

    private string SectionHeading => View switch
    {
        PurchaseExperienceTab.Regions => "Region Analysis",
        PurchaseExperienceTab.Cities => "City Analysis",
        _ => "Railroad Analysis"
    };

    private IReadOnlyList<RailroadAnalysisRow> UnownedRailroadRows => (Report?.RailroadRows ?? Array.Empty<RailroadAnalysisRow>())
        .Where(IsUnownedRailroad)
        .ToArray();

    private IReadOnlyList<CityAccessRow> SortedCityRows => Report?.CityAccessRows
        .OrderByDescending(row => row.GlobalAccessPercentage)
        .ThenByDescending(row => row.WithinRegionPercentage)
        .ThenBy(row => row.CityName, StringComparer.OrdinalIgnoreCase)
        .ToArray()
        ?? [];

    private IReadOnlyList<RegionCityGroup> RegionCityGroups => (Report?.RegionProbabilityRows ?? Array.Empty<RegionProbabilityRow>())
        .Select(region => new RegionCityGroup(
            region.RegionCode,
            region.RegionName,
            region.ProbabilityPercentage,
            (Report?.CityAccessRows ?? Array.Empty<CityAccessRow>())
                .Where(city => string.Equals(city.RegionCode, region.RegionCode, StringComparison.OrdinalIgnoreCase))
                .OrderByDescending(city => city.WithinRegionPercentage)
                .ThenBy(city => city.CityName, StringComparer.OrdinalIgnoreCase)
                .ToArray()))
        .ToArray();

    private static string FormatCurrency(int value)
    {
        return $"${Math.Max(0, value):N0}";
    }

    private static string FormatPercent(decimal value)
    {
        return $"{value:N1}%";
    }

    private static string FormatRailroadPercent(decimal value)
    {
        return $"{value:N2}%";
    }

    private static string FormatOptionalPercent(decimal? value)
    {
        return value.HasValue ? $"{value.Value:N1}%" : "-";
    }

    private static string FormatSignedOptionalPercent(decimal? value)
    {
        if (!value.HasValue)
        {
            return "-";
        }

        return value.Value >= 0m ? $"+{value.Value:N1}%" : $"{value.Value:N1}%";
    }

    private static string FormatCityPercent(decimal value)
    {
        return $"{value:N1}%";
    }

    private sealed record RegionCityGroup(
        string RegionCode,
        string RegionName,
        decimal RegionProbabilityPercentage,
        IReadOnlyList<CityAccessRow> Cities);

    private NetworkCoverageSnapshot? GetPlayerCoverage(RailroadAnalysisRow row)
    {
        if (RecommendationInputs?.ProjectedCoverageByRailroad is null)
        {
            return null;
        }

        return RecommendationInputs.ProjectedCoverageByRailroad.TryGetValue(row.RailroadIndex, out var coverage)
            ? coverage
            : null;
    }

    private decimal? GetPlayerAccessDelta(RailroadAnalysisRow row)
    {
        var projectedCoverage = GetPlayerCoverage(row);
        var currentCoverage = RecommendationInputs?.CurrentCoverage;
        if (projectedCoverage is null || currentCoverage is null)
        {
            return null;
        }

        return Math.Round(projectedCoverage.AccessibleDestinationPercent - currentCoverage.AccessibleDestinationPercent, 1, MidpointRounding.AwayFromZero);
    }

    private decimal? GetPlayerMonopolyDelta(RailroadAnalysisRow row)
    {
        var projectedCoverage = GetPlayerCoverage(row);
        var currentCoverage = RecommendationInputs?.CurrentCoverage;
        if (projectedCoverage is null || currentCoverage is null)
        {
            return null;
        }

        return Math.Round(projectedCoverage.MonopolyDestinationPercent - currentCoverage.MonopolyDestinationPercent, 1, MidpointRounding.AwayFromZero);
    }

    private bool IsUnownedRailroad(RailroadAnalysisRow row)
    {
        return RecommendationInputs?.UnownedRailroadIndices.Contains(row.RailroadIndex) == true;
    }

    private bool IsAffordableRailroad(RailroadAnalysisRow row)
    {
        return RecommendationInputs?.AffordableRailroadIndices.Contains(row.RailroadIndex) == true;
    }

    private string GetRailroadPriceStyle(RailroadAnalysisRow row)
    {
        return IsAffordableRailroad(row)
            ? "color: var(--mud-palette-success); font-weight: 700"
            : "color: var(--mud-palette-error); font-weight: 700";
    }
}
