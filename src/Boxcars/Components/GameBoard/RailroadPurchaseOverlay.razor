@using Boxcars.Data
@using MudBlazor
@using System.Globalization

@if (Overlay is not null)
{
    <MudPaper Elevation="2" Class="pa-3" Outlined="true"
              Style="width: fit-content; min-width: 18rem; max-width: min(36rem, calc(100vw - 2rem)); max-height: calc(100dvh - 2rem); overflow: auto"
              @onclick="OnDismissRequestedAsync">
        <MudStack Spacing="1">
            <MudText Typo="Typo.subtitle2">@Overlay.RailroadName</MudText>
            @if (!string.IsNullOrWhiteSpace(Overlay.ContextLabel))
            {
                <MudText Typo="Typo.body2">@Overlay.ContextLabel</MudText>
            }
            <MudText Typo="Typo.body2" Color="@OverlayPriceColor" Style="@OverlayPriceStyle">@Overlay.ValueLabel: @FormatCurrency(Overlay.PurchasePrice)</MudText>

            @if (VisibleMetricRows.Count > 0)
            {
                <MudTable T="RailroadOverlayMetricRow" Items="VisibleMetricRows" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh><strong>Area</strong></MudTh>
                        <MudTh><strong>Access</strong></MudTh>
                        <MudTh><strong>Monopoly</strong></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><MudText Typo="Typo.body2" Style="font-weight: 700">@context.Label</MudText></MudTd>
                        <MudTd>
                            @if (context.AccessDeltaPercent == 0m)
                            {
                                <MudText Typo="Typo.body2">@FormatPercent(context.AccessPercent, showSign: false)</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Inline="true">@FormatPercent(context.AccessPercent, showSign: false)</MudText>
                                <MudText Typo="Typo.body2" Inline="true" Color="Color.Secondary"> =&gt; </MudText>
                                <MudText Typo="Typo.body2" Inline="true" Color="@GetDeltaColor(context.AccessDeltaPercent)" Style="font-weight: 700">@FormatPercent(context.ProjectedAccessPercent, showSign: false)</MudText>
                                <MudText Typo="Typo.body2" Inline="true" Color="@GetDeltaColor(context.AccessDeltaPercent)"> (@FormatPercent(context.AccessDeltaPercent, showSign: true))</MudText>
                            }
                        </MudTd>
                        <MudTd>
                            @if (context.MonopolyDeltaPercent == 0m)
                            {
                                <MudText Typo="Typo.body2">@FormatPercent(context.MonopolyPercent, showSign: false)</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Inline="true">@FormatPercent(context.MonopolyPercent, showSign: false)</MudText>
                                <MudText Typo="Typo.body2" Inline="true" Color="Color.Secondary"> =&gt; </MudText>
                                <MudText Typo="Typo.body2" Inline="true" Color="@GetDeltaColor(context.MonopolyDeltaPercent)" Style="font-weight: 700">@FormatPercent(context.ProjectedMonopolyPercent, showSign: false)</MudText>
                                <MudText Typo="Typo.body2" Inline="true" Color="@GetDeltaColor(context.MonopolyDeltaPercent)"> (@FormatPercent(context.MonopolyDeltaPercent, showSign: true))</MudText>
                            }
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else if (Overlay?.MetricRows.Count > 0)
            {
                <MudText Typo="Typo.body2">No change to your network.</MudText>
            }
        </MudStack>
    </MudPaper>
}

@code {
    [Parameter]
    public RailroadOverlayInfo? Overlay { get; set; }

    [Parameter]
    public EventCallback DismissRequested { get; set; }

    private IReadOnlyList<RailroadOverlayMetricRow> VisibleMetricRows => Overlay?.MetricRows
        .Where(row => row.AccessDeltaPercent != 0m || row.MonopolyDeltaPercent != 0m)
        .ToArray()
        ?? [];

    private Color OverlayPriceColor => Overlay?.ValueKind switch
    {
        RailroadOverlayValueKind.TooExpensive => Color.Error,
        RailroadOverlayValueKind.Sale => Color.Success,
        _ => Overlay?.IsAffordable == false ? Color.Error : Color.Success
    };

    private string OverlayPriceStyle => "font-weight: 700";

    private static string FormatCurrency(int value)
    {
        return $"${Math.Max(0, value):N0}";
    }

    private static string FormatPercent(decimal value, bool showSign)
    {
        var formattedValue = value.ToString("0.#", CultureInfo.InvariantCulture);
        return showSign && value >= 0m ? $"+{formattedValue}%" : $"{formattedValue}%";
    }

    private static Color GetDeltaColor(decimal value)
    {
        if (value > 0m)
        {
            return Color.Success;
        }

        if (value < 0m)
        {
            return Color.Error;
        }

        return Color.Default;
    }

    private Task OnDismissRequestedAsync()
    {
        return DismissRequested.InvokeAsync();
    }
}