@using Boxcars.Data
@using MudBlazor

@if (Overlay is not null)
{
    <div class="railroad-purchase-overlay-scope">
        <MudPaper Class="railroad-purchase-overlay pa-3" Outlined="true" Elevation="2">
            <MudStack Spacing="1">
                <MudText Typo="Typo.subtitle2">@Overlay.RailroadName</MudText>
                <MudText Typo="Typo.body2">Price: @FormatCurrency(Overlay.PurchasePrice)</MudText>

                @if (VisibleMetricRows.Count > 0)
                {
                    <MudTable T="RailroadOverlayMetricRow" Items="VisibleMetricRows" Dense="true" Hover="true" Class="railroad-purchase-overlay-table">
                        <HeaderContent>
                            <MudTh>Area</MudTh>
                            <MudTh>Access Old</MudTh>
                            <MudTh>Access New</MudTh>
                            <MudTh>Access +/-</MudTh>
                            <MudTh>Monopoly Old</MudTh>
                            <MudTh>Monopoly New</MudTh>
                            <MudTh>Monopoly +/-</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Label</MudTd>
                            <MudTd>@FormatPercent(context.AccessPercent, showSign: false)</MudTd>
                            <MudTd>@FormatPercent(context.ProjectedAccessPercent, showSign: false)</MudTd>
                            <MudTd><span class="@GetDeltaClass(context.AccessDeltaPercent)">@FormatPercent(context.AccessDeltaPercent, showSign: true)</span></MudTd>
                            <MudTd>@FormatPercent(context.MonopolyPercent, showSign: false)</MudTd>
                            <MudTd>@FormatPercent(context.ProjectedMonopolyPercent, showSign: false)</MudTd>
                            <MudTd><span class="@GetDeltaClass(context.MonopolyDeltaPercent)">@FormatPercent(context.MonopolyDeltaPercent, showSign: true)</span></MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudStack>
        </MudPaper>
    </div>
}

@code {
    [Parameter]
    public RailroadOverlayInfo? Overlay { get; set; }

    private IReadOnlyList<RailroadOverlayMetricRow> VisibleMetricRows => Overlay?.MetricRows ?? [];

    private static string FormatCurrency(int value)
    {
        return $"${Math.Max(0, value):N0}";
    }

    private static string FormatPercent(decimal value, bool showSign)
    {
        return showSign && value >= 0m ? $"+{value:N1}%" : $"{value:N1}%";
    }

    private static string GetDeltaClass(decimal value)
    {
        if (value > 0m)
        {
            return "railroad-purchase-overlay-delta-positive";
        }

        if (value < 0m)
        {
            return "railroad-purchase-overlay-delta-negative";
        }

        return "railroad-purchase-overlay-delta-neutral";
    }
}