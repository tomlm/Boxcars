@using Boxcars.Data
@using MudBlazor

<MudPaper Class="pa-3" Outlined="true" Style="width: 100%">
    <MudStack Spacing="2">
        <MudText Typo="Typo.h4">Purchase Opportunity</MudText>
        @if (!string.IsNullOrWhiteSpace(DelegatedControlLabel))
        {
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Style="font-style: italic; font-weight: 600">
                @DelegatedControlLabel
            </MudText>
        }

        <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="2">
            <MudSelect T="string" Value="SelectedOptionKey" ValueChanged="OnSelectedOptionChangedAsync" Dense="true" Placeholder="Select a railroad or engine" Style="min-width: 18rem; white-space: nowrap" Disabled="TaskbarState.Options.Count == 0 || IsBusy">
                @foreach (var option in TaskbarState.Options)
                {
                    <MudSelectItem T="string" Value="@option.OptionKey">
                        <MudText Typo="Typo.body1" Inline="true" Style="white-space: nowrap">@option.DisplayName</MudText>
                        <MudText Typo="Typo.body2" Inline="true" Color="@GetOptionPriceColor(option)" Style="font-weight: 700; white-space: nowrap"> (@FormatCurrency(option.PurchasePrice))</MudText>
                    </MudSelectItem>
                }
            </MudSelect>

            <MudButtonGroup OverrideStyles="false">
                <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" Disabled="!TaskbarState.CanBuy || IsBusy" OnClick="OnBuyRequestedAsync">
                    BUY
                </MudButton>
                <MudButton Variant="Variant.Text" Color="MudBlazor.Color.Default" Disabled="IsBusy" OnClick="OnDeclineRequestedAsync">
                    DECLINE
                </MudButton>
            </MudButtonGroup>
        </MudStack>
    </MudStack>

</MudPaper>

@code {
    [Parameter]
    public PurchaseTaskbarState TaskbarState { get; set; } = new();

    [Parameter]
    public string? SelectedOptionKey { get; set; }

    [Parameter]
    public EventCallback<string?> SelectedOptionKeyChanged { get; set; }

    [Parameter]
    public EventCallback BuyRequested { get; set; }

    [Parameter]
    public EventCallback DeclineRequested { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public NetworkCoverageSnapshot? CurrentCoverage { get; set; }

    [Parameter]
    public NetworkCoverageSnapshot? ProjectedCoverage { get; set; }

    [Parameter]
    public EngineUpgradeOption? SelectedEngineOption { get; set; }

    [Parameter]
    public string DelegatedControlLabel { get; set; } = string.Empty;

    private async Task OnSelectedOptionChangedAsync(string? optionKey)
    {
        await SelectedOptionKeyChanged.InvokeAsync(optionKey);
    }

    private async Task OnBuyRequestedAsync()
    {
        await BuyRequested.InvokeAsync();
    }

    private async Task OnDeclineRequestedAsync()
    {
        await DeclineRequested.InvokeAsync();
    }

    private static string FormatCurrency(int value)
    {
        return $"${Math.Max(0, value):N0}";
    }

    private static Color GetOptionPriceColor(PurchaseOptionModel option)
    {
        return option.IsAffordable ? Color.Success : Color.Error;
    }

    private static string FormatPercent(decimal? value)
    {
        return value.HasValue ? $"{value.Value:N1}%" : "-";
    }

}
