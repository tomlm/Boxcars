@using Boxcars.Data
@using MudBlazor

<MudPaper Outlined="true" Class="pa-4" Style="width: min(100%, 62rem); margin: 0 auto">
    <MudStack Spacing="2">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h6">Choose Destination Region</MudText>
            <MudText Typo="Typo.body2">
                @Phase.PlayerName is in @Phase.CurrentCityName, @Phase.CurrentRegionName. Choose any eligible destination region. If the redraw lands on the current city, the turn is lost.
            </MudText>
        </MudStack>

        <MudTable T="DestinationRegionOption" Items="Phase.Options" Dense="true" Hover="true" Bordered="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh><MudTableSortLabel T="DestinationRegionOption" SortBy="@(option => option.RegionName)"><strong>Region</strong></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="DestinationRegionOption" SortBy="@(option => option.RegionProbabilityPercent)"><strong>Region %</strong></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="DestinationRegionOption" SortBy="@(option => option.AccessibleDestinationPercent)"><strong>Access %</strong></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="DestinationRegionOption" SortBy="@(option => option.MonopolyDestinationPercent)"><strong>Monopoly %</strong></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="DestinationRegionOption" SortBy="@(option => option.AverageDistance)"><strong>Avg Distance</strong></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="DestinationRegionOption" SortBy="@(option => option.AveragePayout)"><strong>Avg Payout</strong></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="DestinationRegionOption" SortBy="@(option => option.EligibleCityCount)"><strong>Cities</strong></MudTableSortLabel></MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Region">@context.RegionName</MudTd>
                <MudTd DataLabel="Region %">@FormatPercent(context.RegionProbabilityPercent)</MudTd>
                <MudTd DataLabel="Access %">@FormatPercent(context.AccessibleDestinationPercent)</MudTd>
                <MudTd DataLabel="Monopoly %">@FormatPercent(context.MonopolyDestinationPercent)</MudTd>
                <MudTd DataLabel="Avg Distance">@FormatAverageDistance(context.AverageDistance)</MudTd>
                <MudTd DataLabel="Avg Payout">@FormatCurrency(context.AveragePayout)</MudTd>
                <MudTd DataLabel="Cities">@context.EligibleCityCount</MudTd>
                <MudTd DataLabel="Select">
                    <MudButton Variant="@(IsSelected(context.RegionCode) ? Variant.Filled : Variant.Outlined)"
                               Color="MudBlazor.Color.Primary"
                               Disabled="@IsBusy"
                               OnClick="() => OnRegionSelectedAsync(context.RegionCode)">
                        @(IsSelected(context.RegionCode) ? "Selected" : "Select")
                    </MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>

        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Spacing="4">
            <MudText Typo="Typo.caption">
                Final destination city will be drawn using the selected region's existing weighted city probabilities. Rows start sorted by Access %.
            </MudText>
            <MudButton Variant="Variant.Filled"
                       Color="MudBlazor.Color.Primary"
                       Disabled="@(!CanConfirm || IsBusy)"
                       OnClick="ConfirmRequested">
                Confirm Region
            </MudButton>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public RegionChoicePhaseModel Phase { get; set; } = new();

    [Parameter]
    public string? SelectedRegionCode { get; set; }

    [Parameter]
    public EventCallback<string?> SelectedRegionCodeChanged { get; set; }

    [Parameter]
    public EventCallback ConfirmRequested { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    private bool CanConfirm => Phase.CanConfirm && !string.IsNullOrWhiteSpace(SelectedRegionCode);

    private bool IsSelected(string regionCode)
    {
        return string.Equals(regionCode, SelectedRegionCode, StringComparison.OrdinalIgnoreCase);
    }

    private Task OnRegionSelectedAsync(string regionCode)
    {
        return SelectedRegionCodeChanged.InvokeAsync(regionCode);
    }

    private static string FormatPercent(decimal value)
    {
        return string.Concat(value.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture), "%");
    }

    private static string FormatAverageDistance(decimal? value)
    {
        return value.HasValue
            ? value.Value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)
            : "-";
    }

    private static string FormatCurrency(decimal? value)
    {
        return value.HasValue
            ? string.Concat("$", decimal.Round(value.Value, 0, MidpointRounding.AwayFromZero).ToString("N0", System.Globalization.CultureInfo.InvariantCulture))
            : "-";
    }
}