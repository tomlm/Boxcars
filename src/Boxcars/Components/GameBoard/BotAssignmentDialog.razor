@using Boxcars.Data
@using Boxcars.Services
@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.h6">Ghost activation for @PlayerName</MudText>

            @if (!string.IsNullOrWhiteSpace(CurrentStatusLabel))
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    @CurrentStatusLabel
                </MudAlert>
            }

            <MudPaper Outlined="true" Class="pa-3">
                <MudText Typo="Typo.subtitle2">Strategy</MudText>
                <MudText Typo="Typo.body2">@StrategyText</MudText>
            </MudPaper>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Text"
                   Color="MudBlazor.Color.Warning"
                   Disabled="@(!CanClear)"
                   OnClick="ClearAssignment">
            Clear
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="MudBlazor.Color.Primary"
                   Disabled="false"
                   OnClick="AssignBot">
            Activate GHOST
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string PlayerName { get; set; } = string.Empty;

    [Parameter]
    public string PlayerUserId { get; set; } = string.Empty;

    [Parameter]
    public string CurrentStatusLabel { get; set; } = string.Empty;

    [Parameter]
    public string StrategyText { get; set; } = PlayerProfileService.DefaultStrategyText;

    private bool CanClear => !string.IsNullOrWhiteSpace(CurrentStatusLabel);

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void ClearAssignment()
    {
        MudDialog.Close(DialogResult.Ok(new BotAssignmentDialogResult
        {
            ClearRequested = true
        }));
    }

    private void AssignBot()
    {
        MudDialog.Close(DialogResult.Ok(new BotAssignmentDialogResult
        {
            BotDefinitionId = PlayerUserId
        }));
    }
}