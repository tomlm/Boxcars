@using Boxcars.Data
@using MudBlazor
@using System.Globalization

<MudStack Spacing="2">
    <MudStack Row="true" Wrap="Wrap.Wrap" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h6">Network</MudText>
        <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small">@BuildOwnerLabel()</MudChip>
    </MudStack>

    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
        <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small">% Access: @FormatPercent(NetworkTab.CurrentAccessPercent)</MudChip>
        <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small">% Monopoly: @FormatPercent(NetworkTab.CurrentMonopolyPercent)</MudChip>
    </MudStack>

    @if (NetworkTab.RailroadSummaries.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Dense="true">
            No owned railroads are available for network analysis yet.
        </MudAlert>
    }
    else
    {
        <MudTable T="NetworkRailroadSummaryModel" Items="NetworkTab.RailroadSummaries" Dense="true" Hover="true" Style="width: fit-content; max-width: 100%">
            <HeaderContent>
                <MudTh><MudTableSortLabel T="NetworkRailroadSummaryModel" SortBy="@(row => row.RailroadName)"><strong>Railroad</strong></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="NetworkRailroadSummaryModel" SortBy="@(row => row.OriginalPurchasePrice)"><strong>Original Value</strong></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="NetworkRailroadSummaryModel" SortBy="@(row => row.BankSalePrice)"><strong>Bank Value</strong></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="NetworkRailroadSummaryModel" SortBy="@(row => row.AccessPercentAfterSale)"><strong>% Access After</strong></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="NetworkRailroadSummaryModel" SortBy="@(row => row.MonopolyPercentAfterSale)"><strong>% Monopoly After</strong></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="NetworkRailroadSummaryModel" SortBy="@(row => row.AccessDeltaPercentAfterSale)"><strong>% Access Delta After</strong></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="NetworkRailroadSummaryModel" SortBy="@(row => row.MonopolyDeltaPercentAfterSale)"><strong>% Monopoly Delta After</strong></MudTableSortLabel></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.body2">@context.RailroadName</MudText>
                        @if (IsSelected(context))
                        {
                            <MudChip T="string" Variant="Variant.Filled" Color="MudBlazor.Color.Info" Size="Size.Small">Selected</MudChip>
                        }
                    </MudStack>
                </MudTd>
                <MudTd>@FormatCurrency(context.OriginalPurchasePrice)</MudTd>
                <MudTd>@FormatCurrency(context.BankSalePrice)</MudTd>
                <MudTd>@FormatPercent(context.AccessPercentAfterSale)</MudTd>
                <MudTd>@FormatPercent(context.MonopolyPercentAfterSale)</MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Color="@GetDeltaColor(context.AccessDeltaPercentAfterSale)">
                        @FormatSignedPercent(context.AccessDeltaPercentAfterSale)
                    </MudText>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Color="@GetDeltaColor(context.MonopolyDeltaPercentAfterSale)">
                        @FormatSignedPercent(context.MonopolyDeltaPercentAfterSale)
                    </MudText>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }

    @if (NetworkTab.SelectedRailroadImpact is not null)
    {
        <MudAlert Severity="Severity.Info" Dense="true">
            Showing projected network impact for @NetworkTab.SelectedRailroadImpact.RailroadName.
        </MudAlert>
    }
</MudStack>

@code {
    [Parameter]
    public required NetworkTabModel NetworkTab { get; set; }

    private bool IsSelected(NetworkRailroadSummaryModel summary)
    {
        return NetworkTab.SelectedRailroadImpact?.RailroadIndex == summary.RailroadIndex;
    }

    private string BuildOwnerLabel()
    {
        return string.IsNullOrWhiteSpace(NetworkTab.PlayerName)
            ? "Current player"
            : NetworkTab.PlayerName;
    }

    private static string FormatPercent(decimal value)
    {
        return value.ToString("0.#", CultureInfo.InvariantCulture) + "%";
    }

    private static string FormatCurrency(int value)
    {
        return $"${Math.Max(0, value):N0}";
    }

    private static string FormatSignedPercent(decimal value)
    {
        var formattedValue = value.ToString("0.#", CultureInfo.InvariantCulture);
        return value >= 0m ? $"+{formattedValue}%" : $"{formattedValue}%";
    }

    private static Color GetDeltaColor(decimal value)
    {
        if (value > 0m)
        {
            return Color.Success;
        }

        if (value < 0m)
        {
            return Color.Error;
        }

        return Color.Secondary;
    }
}
