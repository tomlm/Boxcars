@using Boxcars.Data
@using MudBlazor
@using System.Globalization

<MudStack Spacing="2">
    <MudStack Row="true" Wrap="Wrap.Wrap" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h6">Network</MudText>
        <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small">@BuildOwnerLabel()</MudChip>
    </MudStack>

    @if (NetworkTab.RailroadSummaries.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Dense="true">
            No owned railroads are available for network analysis yet.
        </MudAlert>
    }
    else
    {
        <MudTable T="NetworkRailroadSummaryModel" Items="NetworkTab.RailroadSummaries" Dense="true" Hover="true" Style="width: fit-content; max-width: 100%">
            <HeaderContent>
                <MudTh><MudTableSortLabel T="NetworkRailroadSummaryModel" SortBy="@(row => row.RailroadName)"><strong>Railroad</strong></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="NetworkRailroadSummaryModel" SortBy="@(row => row.OriginalPurchasePrice)"><strong>Price</strong></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="NetworkRailroadSummaryModel" SortBy="@(row => row.AccessPercentWithCurrentOwnership)"><strong>Access %</strong></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="NetworkRailroadSummaryModel" SortBy="@(row => row.MonopolyPercentWithCurrentOwnership)"><strong>Monopoly %</strong></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="NetworkRailroadSummaryModel" SortBy="@(row => GetAccessDelta(row))"><strong>Player Access</strong></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel T="NetworkRailroadSummaryModel" SortBy="@(row => GetMonopolyDelta(row))"><strong>Player Monopoly</strong></MudTableSortLabel></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.body2">@context.RailroadName</MudText>
                        @if (IsSelected(context))
                        {
                            <MudChip T="string" Variant="Variant.Filled" Color="MudBlazor.Color.Info" Size="Size.Small">Selected</MudChip>
                        }
                    </MudStack>
                </MudTd>
                <MudTd>@FormatCurrency(context.OriginalPurchasePrice)</MudTd>
                <MudTd>@FormatPercent(context.AccessPercentWithCurrentOwnership)</MudTd>
                <MudTd>@FormatPercent(context.MonopolyPercentWithCurrentOwnership)</MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Color="@GetDeltaColor(GetAccessDelta(context))">
                        @FormatSignedOptionalPercent(GetAccessDelta(context))
                    </MudText>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Color="@GetDeltaColor(GetMonopolyDelta(context))">
                        @FormatSignedOptionalPercent(GetMonopolyDelta(context))
                    </MudText>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }

    @if (NetworkTab.SelectedRailroadImpact is not null)
    {
        <MudAlert Severity="Severity.Info" Dense="true">
            Showing projected network impact for @NetworkTab.SelectedRailroadImpact.RailroadName.
        </MudAlert>
    }
</MudStack>

@code {
    [Parameter]
    public required NetworkTabModel NetworkTab { get; set; }

    private bool IsSelected(NetworkRailroadSummaryModel summary)
    {
        return NetworkTab.SelectedRailroadImpact?.RailroadIndex == summary.RailroadIndex;
    }

    private string BuildOwnerLabel()
    {
        return string.IsNullOrWhiteSpace(NetworkTab.PlayerName)
            ? "Current player"
            : NetworkTab.PlayerName;
    }

    private static string FormatPercent(decimal value)
    {
        return value.ToString("0.#", CultureInfo.InvariantCulture) + "%";
    }

    private static string FormatCurrency(int value)
    {
        return $"${Math.Max(0, value):N0}";
    }

    private static decimal? GetAccessDelta(NetworkRailroadSummaryModel summary)
    {
        return summary.AccessPercentIfSold.HasValue
            ? Math.Round(summary.AccessPercentIfSold.Value - summary.AccessPercentWithCurrentOwnership, 1, MidpointRounding.AwayFromZero)
            : null;
    }

    private static decimal? GetMonopolyDelta(NetworkRailroadSummaryModel summary)
    {
        return summary.MonopolyPercentIfSold.HasValue
            ? Math.Round(summary.MonopolyPercentIfSold.Value - summary.MonopolyPercentWithCurrentOwnership, 1, MidpointRounding.AwayFromZero)
            : null;
    }

    private static string FormatSignedOptionalPercent(decimal? value)
    {
        if (!value.HasValue)
        {
            return "-";
        }

        var formattedValue = value.Value.ToString("0.#", CultureInfo.InvariantCulture);
        return value.Value >= 0m ? $"+{formattedValue}%" : $"{formattedValue}%";
    }

    private static Color GetDeltaColor(decimal? value)
    {
        if (!value.HasValue)
        {
            return Color.Default;
        }

        if (value.Value > 0m)
        {
            return Color.Success;
        }

        if (value.Value < 0m)
        {
            return Color.Error;
        }

        return Color.Secondary;
    }
}