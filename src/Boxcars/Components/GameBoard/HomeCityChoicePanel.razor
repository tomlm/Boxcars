@using Boxcars.Data
@using MudBlazor

<MudPaper Outlined="true" Class="pa-4" Style="width: min(100%, 42rem); margin: 0 auto">
    <MudStack Spacing="2">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h6">Choose Home City</MudText>
            <MudText Typo="Typo.body2">
                @Phase.PlayerName may choose any available city in @Phase.RegionName for this match.
            </MudText>
        </MudStack>

        <MudTable T="HomeCityOption" Items="Phase.Options" Dense="true" Hover="true" Bordered="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh><strong>City</strong></MudTh>
                <MudTh><strong>Current</strong></MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="City">@context.CityName</MudTd>
                <MudTd DataLabel="Current">@(context.IsCurrentSelection ? "Current" : string.Empty)</MudTd>
                <MudTd DataLabel="Select">
                    <MudButton Variant="@(IsSelected(context.CityName) ? Variant.Filled : Variant.Outlined)"
                               Color="MudBlazor.Color.Primary"
                               Disabled="@IsBusy"
                               OnClick="() => OnCitySelectedAsync(context.CityName)">
                        @(IsSelected(context.CityName) ? "Selected" : "Select")
                    </MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>

        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Spacing="4">
            <MudText Typo="Typo.caption">
                Current home: @Phase.CurrentHomeCityName
            </MudText>
            <MudButton Variant="Variant.Filled"
                       Color="MudBlazor.Color.Primary"
                       Disabled="@(!CanConfirm || IsBusy)"
                       OnClick="ConfirmRequested">
                Confirm Home City
            </MudButton>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public HomeCityChoicePhaseModel Phase { get; set; } = new();

    [Parameter]
    public string? SelectedCityName { get; set; }

    [Parameter]
    public EventCallback<string?> SelectedCityNameChanged { get; set; }

    [Parameter]
    public EventCallback ConfirmRequested { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    private bool CanConfirm => Phase.CanConfirm && !string.IsNullOrWhiteSpace(SelectedCityName);

    private bool IsSelected(string cityName)
    {
        return string.Equals(cityName, SelectedCityName, StringComparison.OrdinalIgnoreCase);
    }

    private Task OnCitySelectedAsync(string cityName)
    {
        return SelectedCityNameChanged.InvokeAsync(cityName);
    }
}