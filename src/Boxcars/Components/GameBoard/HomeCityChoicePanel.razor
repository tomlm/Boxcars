@using Boxcars.Data
@using MudBlazor

<MudPaper Outlined="true" Class="pa-4" Style="width: min(100%, 54rem); margin: 0 auto">
    <MudStack Spacing="2">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h6">Choose Home City</MudText>
            <MudText Typo="Typo.body2">
                @Phase.PlayerName may choose any available city in @Phase.RegionName for this match.
            </MudText>
        </MudStack>

        <MudChipSet T="string"
                    SelectedValue="@SelectedCityName"
                    SelectedValueChanged="SelectedCityNameChanged"
                    SelectionMode="SelectionMode.SingleSelection"
                    CheckMark
                    Color="Color.Primary"
                    Variant="Variant.Filled"
                    Class="d-flex flex-wrap"
                    Style="gap: 0.75rem">
            @foreach (var option in Phase.Options)
            {
                <MudChip T="string"
                         Value="@option.CityName"
                         Disabled="@IsBusy"
                         Color="MudBlazor.Color.Primary"
                         SelectedColor="MudBlazor.Color.Primary"
                         Style="min-width: 10rem; justify-content: center">
                    @option.CityName
                </MudChip>
            }
        </MudChipSet>

        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Spacing="4">
            <MudText Typo="Typo.caption">
                Current home: @Phase.CurrentHomeCityName
            </MudText>
            <MudButton Variant="Variant.Filled"
                       Color="MudBlazor.Color.Primary"
                       Disabled="@(!CanConfirm || IsBusy)"
                       OnClick="ConfirmRequested">
                Confirm Home City
            </MudButton>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public HomeCityChoicePhaseModel Phase { get; set; } = new();

    [Parameter]
    public string? SelectedCityName { get; set; }

    [Parameter]
    public EventCallback<string?> SelectedCityNameChanged { get; set; }

    [Parameter]
    public EventCallback ConfirmRequested { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    private bool CanConfirm => Phase.CanConfirm && !string.IsNullOrWhiteSpace(SelectedCityName);

}
