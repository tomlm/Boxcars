@using Boxcars.Data
@using Boxcars.Services
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@inject NavigationManager Navigation
@inject PlayerProfileService ProfileService

<AuthorizeView>
    <Authorized>
        <MudMenu Dense="true"
                 AnchorOrigin="Origin.BottomRight"
                 TransformOrigin="Origin.TopRight">
            <ActivatorContent>
                <MudButton Variant="Variant.Text" Color="MudBlazor.Color.Inherit" Class="user-menu-trigger">
                    <MudAvatar Size="Size.Medium" Class="user-menu-avatar">
                        @if (HasThumbnail)
                        {
                            <MudImage Src="@_thumbnailUrl" Alt="@_fullName" Class="user-menu-avatar-image" />
                        }
                        else
                        {
                            @_initials
                        }
                    </MudAvatar>
                </MudButton>
            </ActivatorContent>
            <ChildContent>
                <MudMenuItem Disabled="true">
                    <MudText Typo="Typo.subtitle2">@_fullName</MudText>
                </MudMenuItem>

                @if (!string.IsNullOrWhiteSpace(_email))
                {
                    <MudMenuItem Disabled="true">
                        <MudText Typo="Typo.caption">@_email</MudText>
                    </MudMenuItem>
                }

                <MudDivider />
                <MudMenuItem OnClick="@(() => NavigateToAccountSettings())">Account settings</MudMenuItem>
                <MudMenuItem OnClick="@(() => SignOut())">Sign out</MudMenuItem>
            </ChildContent>
        </MudMenu>
    </Authorized>
</AuthorizeView>

@code {
    private string _initials = "?";
    private string _fullName = "Player";
    private string _email = string.Empty;
    private string _thumbnailUrl = string.Empty;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null)
        {
            var state = await AuthState;
            if (state.User.Identity?.IsAuthenticated == true)
            {
                var displayName = state.User.Identity.Name
                    ?? state.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
                    ?? "Player";
                _fullName = displayName;
                _email = state.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? string.Empty;
                _initials = GetInitials(displayName);

                var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (userId != null)
                {
                    var profile = await ProfileService.GetProfileAsync(userId, CancellationToken.None);
                    if (profile != null)
                    {
                        var nickname = !string.IsNullOrEmpty(profile.Nickname) ? profile.Nickname : "Player";
                        _fullName = nickname;
                        _initials = GetInitials(nickname);
                        _thumbnailUrl = profile.ThumbnailUrl;
                    }
                }
            }
        }
    }

    private bool HasThumbnail => !string.IsNullOrWhiteSpace(_thumbnailUrl);

    private void NavigateToAccountSettings()
    {
        Navigation.NavigateTo("/Account/Manage/Preferences");
    }

    private void SignOut()
    {
        Navigation.NavigateTo("/Account/Logout", forceLoad: true);
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant()
            : name[..Math.Min(2, name.Length)].ToUpperInvariant();
    }
}
