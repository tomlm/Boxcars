@page "/Account/Login"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using Boxcars.Data
@using MudBlazor
@attribute [AllowAnonymous]

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject ILogger<Login> Logger
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Log in</PageTitle>

<MudText Typo="Typo.h4" Class="mb-3">Log in</MudText>
<MudGrid Class="mt-1">
    <MudItem xs="12" md="5">
        <MudPaper Class="pa-4" Outlined="true">
            <StatusMessage Message="@errorMessage" />
            @if (showRegistrationPrompt)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Don't have an account yet?
                    <a href="@(NavigationManager.GetUriWithQueryParameters("Account/Register", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl }))">Sign up here</a>.
                </MudAlert>
            }
            <EditForm Model="Input" method="post" OnValidSubmit="LoginUser" FormName="login">
                <DataAnnotationsValidator />
                <MudText Typo="Typo.h6">Use a local account to log in.</MudText>
                <ValidationSummary style="color: var(--mud-palette-error)" role="alert" />
                <MudStack Spacing="3">
                    <InputText @bind-Value="Input.Email"
                               type="email"
                               name="Input.Email"
                               class="mud-input-slot mud-input-root mud-input-root-outlined mud-input-root-adorned-end"
                               style="width: 100%; min-height: 56px; padding: 16.5px 14px; color: var(--mud-palette-text-primary); background-color: transparent; border: 1px solid var(--mud-palette-lines-inputs); border-radius: var(--mud-default-borderradius)"
                               autocomplete="username"
                               aria-required="true"
                               placeholder="name@example.com" />
                    <ValidationMessage For="() => Input.Email" style="color: var(--mud-palette-error)" />

                    <InputText @bind-Value="Input.Password"
                               type="password"
                               name="Input.Password"
                               class="mud-input-slot mud-input-root mud-input-root-outlined mud-input-root-adorned-end"
                               style="width: 100%; min-height: 56px; padding: 16.5px 14px; color: var(--mud-palette-text-primary); background-color: transparent; border: 1px solid var(--mud-palette-lines-inputs); border-radius: var(--mud-default-borderradius)"
                               autocomplete="current-password"
                               aria-required="true"
                               placeholder="password" />
                    <ValidationMessage For="() => Input.Password" style="color: var(--mud-palette-error)" />

                    <label style="display: inline-flex; align-items: center; gap: 0.5rem">
                        <InputCheckbox @bind-Value="Input.RememberMe" name="Input.RememberMe" style="width: 1rem; height: 1rem" />
                        <span>Remember me</span>
                    </label>

                    <MudButton ButtonType="MudBlazor.ButtonType.Submit" Variant="Variant.Filled" Color="MudBlazor.Color.Primary" FullWidth="true">Log in</MudButton>

                    <MudLink Href="Account/ForgotPassword">Forgot your password?</MudLink>
                    <MudLink Href="@(NavigationManager.GetUriWithQueryParameters("Account/Register", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl }))">Register as a new user</MudLink>
                    <MudLink Href="Account/ResendEmailConfirmation">Resend email confirmation</MudLink>
                </MudStack>
            </EditForm>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="7">
        <MudPaper Class="pa-4" Outlined="true">
            <MudText Typo="Typo.h6">Use another service to log in.</MudText>
            <ExternalLoginPicker />
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private string? errorMessage;
    private bool showRegistrationPrompt;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    private InputModel? _input;

    [SupplyParameterFromForm]
    private InputModel Input
    {
        get => _input ??= new();
        set => _input = value;
    }

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; } = "/dashboard";

    protected override void OnParametersSet()
    {
        Input ??= new();
    }

    protected override async Task OnInitializedAsync()
    {
        if (HttpMethods.IsGet(HttpContext.Request.Method))
        {
            // Clear the existing external cookie to ensure a clean login process
            await HttpContext.SignOutAsync(IdentityConstants.ExternalScheme);
        }
    }

    public async Task LoginUser()
    {
        showRegistrationPrompt = false;

        var user = await UserManager.FindByEmailAsync(Input.Email);
        if (user is null)
        {
            errorMessage = "Error: You're not registered yet.";
            showRegistrationPrompt = true;
            return;
        }

        // This doesn't count login failures towards account lockout
        // To enable password failures to trigger account lockout, set lockoutOnFailure: true
        var result = await SignInManager.PasswordSignInAsync(Input.Email, Input.Password, Input.RememberMe, lockoutOnFailure: false);
        if (result.Succeeded)
        {
            Logger.LogInformation("User logged in.");
            RedirectManager.RedirectTo(ReturnUrl);
        }
        else if (result.RequiresTwoFactor)
        {
            RedirectManager.RedirectTo(
                "Account/LoginWith2fa",
                new() { ["returnUrl"] = ReturnUrl, ["rememberMe"] = Input.RememberMe });
        }
        else if (result.IsLockedOut)
        {
            Logger.LogWarning("User account locked out.");
            RedirectManager.RedirectTo("Account/Lockout");
        }
        else
        {
            errorMessage = "Error: Invalid login attempt.";
        }
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [Display(Name = "Remember me?")]
        public bool RememberMe { get; set; }
    }
}
