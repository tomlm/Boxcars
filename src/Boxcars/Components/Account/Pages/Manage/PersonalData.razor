@page "/Account/Manage/PersonalData"

@inject IdentityUserAccessor UserAccessor
@using MudBlazor

<PageTitle>Personal Data</PageTitle>

<MudStack Style="max-width: 37.5rem; margin: 0 auto" Spacing="6">
    <MudText Typo="Typo.h3">Personal Data</MudText>
    <StatusMessage />

    <MudPaper Class="pa-6">
        <MudStack Spacing="4">
            <MudText Typo="Typo.body1">
                Your account contains personal data that you have given us. This page allows you to permanently delete that data by closing your account.
            </MudText>

            <MudAlert Dense="true" Variant="Variant.Outlined" Severity="Severity.Warning">
                Deleting this data will permanently remove your account, and this cannot be recovered.
            </MudAlert>

            <MudStack Row="true" Spacing="4" Style="margin-top: 0.5rem">
                <MudButton Href="Account/Manage/DeletePersonalData"
                           Variant="Variant.Filled"
                           Color="MudBlazor.Color.Error">
                    Delete Account
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>
</MudStack>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        _ = await UserAccessor.GetRequiredUserAsync(HttpContext);
    }
}
