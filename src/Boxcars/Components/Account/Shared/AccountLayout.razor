@inherits LayoutComponentBase
@layout Boxcars.Components.Layout.MainLayout
@inject NavigationManager NavigationManager
@using MudBlazor

@if (HttpContext is null)
{
    <MudStack Justify="Justify.Center" AlignItems="AlignItems.Center" Spacing="3" Style="min-height: 10rem">
        <MudProgressCircular Indeterminate="true" Size="Size.Medium" Color="MudBlazor.Color.Primary" />
        <MudText Typo="Typo.body2">Loading...</MudText>
    </MudStack>
}
else
{
    @Body
}

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    protected override void OnParametersSet()
    {
        if (HttpContext is null)
        {
            // If this code runs, we're currently rendering in interactive mode, so there is no HttpContext.
            // The identity pages need to set cookies, so they require an HttpContext. To achieve this we
            // must transition back from interactive mode to a server-rendered page.
            NavigationManager.Refresh(forceReload: true);
        }
    }
}
