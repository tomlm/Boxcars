@inherits LayoutComponentBase
@layout AccountLayout
@using MudBlazor

<MudStack Class="manage-layout-root">
    <MudText Typo="Typo.h4">Manage your account</MudText>
    <MudText Typo="Typo.h6">Change your account settings</MudText>

    <MudGrid>
        <MudItem xs="12" md="3">
            <ManageNavMenu />
        </MudItem>
        <MudItem xs="12" md="9">
            @Body
        </MudItem>
    </MudGrid>
</MudStack>
