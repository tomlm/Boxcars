@page "/"
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>BoxCars</PageTitle>

<MudStack Class="home-loading" Justify="Justify.Center" AlignItems="AlignItems.Center">
    <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="MudBlazor.Color.Primary" />
</MudStack>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            Navigation.NavigateTo("/dashboard", replace: true);
        }
    }
}
