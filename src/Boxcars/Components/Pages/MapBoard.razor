@using Boxcars.Data.Maps
@using Boxcars.Services.Maps
@using System.Globalization
@using Microsoft.AspNetCore.Components
@using Microsoft.FluentUI.AspNetCore.Components
@using Microsoft.JSInterop
@inject IMapParserService MapParserService
@inject BoardProjectionService BoardProjectionService
@inject BoardViewportService BoardViewportService
@inject MapRouteService MapRouteService
@inject IWebHostEnvironment HostEnvironment
@inject IJSRuntime JavaScriptRuntime
@implements IAsyncDisposable

<div class="map-board-shell">
    <FluentCard class="map-board-controls">
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.75rem;">
            <FluentLabel Typo="Typography.H5">Map Board</FluentLabel>
            <FluentLabel Typo="Typography.Body">Map selection is provided by game setup.</FluentLabel>

            <div class="map-board-mode-row">
                <FluentLabel Typo="Typography.Body">Mode</FluentLabel>
                <FluentButton Appearance="@GetModeButtonAppearance(MapInteractionMode.Rail)"
                              OnClick="() => SetInteractionMode(MapInteractionMode.Rail)">
                    Rail mode
                </FluentButton>
                <FluentButton Appearance="@GetModeButtonAppearance(MapInteractionMode.Route)"
                              OnClick="() => SetInteractionMode(MapInteractionMode.Route)">
                    Movement mode
                </FluentButton>
                @if (!string.IsNullOrWhiteSpace(_routeStartNodeName))
                {
                    <FluentLabel Typo="Typography.Body">Start: @_routeStartNodeName</FluentLabel>
                }
            </div>

            <div class="map-board-zoom-row">
                <FluentLabel Typo="Typography.Body">Zoom (@_viewport.ZoomPercent.ToString("F0")%)</FluentLabel>
                <input type="range"
                       min="100"
                       max="500"
                       step="50"
                       value="@_viewport.ZoomPercent"
                       @oninput="OnZoomSliderInput"
                       class="map-board-zoom-slider" />
                <FluentButton Appearance="Appearance.Neutral" OnClick="ResetZoom">Fit to board</FluentButton>

                @if (ShowEndGameButton)
                {
                    <FluentButton Appearance="Appearance.Lightweight" OnClick="OnEndGameClickedAsync" Disabled="@(!EndGameRequested.HasDelegate)">
                        End Game
                    </FluentButton>
                }
            </div>
        </FluentStack>
    </FluentCard>

    @if (_errors.Count > 0)
    {
        <FluentCard class="map-board-message map-board-error">
            <FluentLabel Typo="Typography.H6">Unable to render map</FluentLabel>
            @foreach (var error in _errors)
            {
                <FluentLabel Typo="Typography.Body">@error</FluentLabel>
            }
        </FluentCard>
    }

    <div class="map-board-viewport"
         @ref="_boardViewportElement"
         tabindex="0">
        @if (_mapDefinition is null || _renderModel is null)
        {
            <FluentCard class="map-board-placeholder">
                <FluentLabel Typo="Typography.Body">No map loaded yet.</FluentLabel>
            </FluentCard>
        }
        else
        {
            <svg class="map-board-svg"
                 viewBox="@GetMapViewBoxValue()"
                 preserveAspectRatio="none"
                 aria-label="Rail Baron game board">
                <g class="map-board-camera" transform="@GetCameraTransform()">
                    <g class="map-board-regions">
                        @foreach (var regionFill in _renderModel.RegionFills)
                        {
                            <path d="@regionFill.PathData" fill="@regionFill.FillColor" />
                        }
                    </g>

                    <g class="map-board-lines">
                        @foreach (var line in _renderModel.MapLines)
                        {
                            <line x1="@line.X1" y1="@line.Y1" x2="@line.X2" y2="@line.Y2" />
                        }
                    </g>

                    <g class="map-board-separators">
                        @foreach (var separator in _renderModel.Separators)
                        {
                            <line x1="@separator.X1" y1="@separator.Y1" x2="@separator.X2" y2="@separator.Y2" />
                        }
                    </g>

                    <g class="map-board-railroads">
                        @foreach (var railroadSegment in _renderModel.RailroadSegments)
                        {
                            <line x1="@railroadSegment.X1"
                                  y1="@railroadSegment.Y1"
                                  x2="@railroadSegment.X2"
                                  y2="@railroadSegment.Y2"
                                  stroke="@railroadSegment.StrokeColor"
                                  class="@GetRailroadSegmentClass(railroadSegment)" />
                            <line x1="@railroadSegment.X1"
                                  y1="@railroadSegment.Y1"
                                  x2="@railroadSegment.X2"
                                  y2="@railroadSegment.Y2"
                                  class="map-board-railroad-hitbox"
                                  data-mapboard-pan-ignore="true"
                                  @onmousedown:stopPropagation="true"
                                  @onclick="@(() => OnRailroadSegmentClicked(railroadSegment.RailroadIndex))"
                                    @onclick:stopPropagation="@(_interactionMode == MapInteractionMode.Rail)" />
                        }
                    </g>

                    @if (_interactionMode == MapInteractionMode.Route && _selectedRouteSegments.Count > 0)
                    {
                        <g class="map-board-route-overlay">
                            @foreach (var routeSegment in _selectedRouteSegments)
                            {
                                <line x1="@routeSegment.X1"
                                      y1="@routeSegment.Y1"
                                      x2="@routeSegment.X2"
                                      y2="@routeSegment.Y2"
                                      stroke="@GetRouteSegmentStrokeColor(routeSegment)" />
                            }
                        </g>
                    }

                    <g class="map-board-train-dots">
                        @foreach (var dot in _renderModel.TrainDots)
                        {
                            <circle cx="@dot.X" cy="@dot.Y" r="0.9" />
                        }
                    </g>

                    <g class="map-board-cities">
                        @foreach (var city in _renderModel.Cities)
                        {
                            <rect x="@(city.X - 1.4)" y="@(city.Y - 1.4)" width="2.8" height="2.8" rx="0.2" ry="0.2" />
                        }
                    </g>

                    @if (_interactionMode == MapInteractionMode.Route)
                    {
                        var routeNodeHitboxWidth = GetRouteNodeHitboxWidth();
                        var routeNodeHitboxHeight = GetRouteNodeHitboxHeight();

                        <g class="map-board-route-node-hitboxes">
                            @foreach (var routeNode in _routeNodes)
                            {
                                <rect x="@(routeNode.X - (routeNodeHitboxWidth / 2))"
                                      y="@(routeNode.Y - (routeNodeHitboxHeight / 2))"
                                      width="@routeNodeHitboxWidth"
                                      height="@routeNodeHitboxHeight"
                                      class="map-board-route-node-hitbox"
                                      data-mapboard-pan-ignore="true"
                                      @onmousedown:stopPropagation="true"
                                      @onclick="@(() => OnRouteNodeClicked(routeNode))"
                                      @onclick:stopPropagation="true" />
                            }
                        </g>
                    }

                    <g class="map-board-region-labels">
                        @foreach (var label in _renderModel.RegionLabels)
                        {
                            <svg:text x="@label.X"
                                      y="@label.Y"
                                      transform="@GetTextUnstretchTransform(label.X, label.Y)">@label.Text</svg:text>
                        }
                    </g>

                    <g class="map-board-city-labels">
                        @foreach (var city in _renderModel.Cities)
                        {
                            <svg:text x="@(city.X + 2.2)"
                                      y="@(city.Y - 2.2)"
                                      transform="@GetTextUnstretchTransform(city.X + 2.2, city.Y - 2.2)">@city.Name</svg:text>
                        }
                    </g>
                </g>
            </svg>
        }
    </div>

    @if (_warnings.Count > 0)
    {
        <FluentCard class="map-board-message map-board-warning map-board-warning-panel">
            <details open>
                <summary>Map Warnings (@_warnings.Count)</summary>
                <div class="map-board-warning-list">
                    @foreach (var warning in _warnings)
                    {
                        <FluentLabel Typo="Typography.Body">@warning</FluentLabel>
                    }
                </div>
            </details>
        </FluentCard>
    }
</div>

@code {
    [Parameter]
    public bool ShowEndGameButton { get; set; }

    [Parameter]
    public EventCallback EndGameRequested { get; set; }

    [Parameter]
    public string MapFileName { get; set; } = "U21MAP.RB3";

    private readonly List<string> _errors = new();
    private readonly List<string> _warnings = new();

    private ElementReference _boardViewportElement;
    private DotNetObjectReference<MapBoard>? _mapBoardReference;
    private MapDefinition? _mapDefinition = null;
    private BoardRenderModel? _renderModel = null;
    private BoardViewport _viewport = new()
    {
        ZoomPercent = 100,
        CenterX = 0,
        CenterY = 0,
        ZoomAnchor = ZoomAnchor.ViewportCenter
    };

    private string? _loadedMapFileName;
    private int? _selectedRailroadIndex;
    private MapInteractionMode _interactionMode = MapInteractionMode.Rail;
    private readonly List<RouteNodeRenderItem> _routeNodes = new();
    private readonly List<RouteGraphEdge> _selectedRouteSegments = new();
    private readonly List<string> _selectedRouteNodeIds = new();
    private readonly Dictionary<int, string> _railroadStrokeColors = new();
    private MapRouteContext? _routeContext;
    private string? _routeStartNodeId;
    private string? _routeStartNodeName;
    private bool _cameraUnavailable;
    private bool _cameraInitialized;
    private bool _suspendCameraPush;
    private const double RouteClickRegionSizePixels = 18;
    private long _lastClientViewportSequence;
    private double _viewportRenderWidth = 1;
    private double _viewportRenderHeight = 1;

    protected override async Task OnParametersSetAsync()
    {
        var configuredMapFile = string.IsNullOrWhiteSpace(MapFileName)
            ? "U21MAP.RB3"
            : MapFileName.Trim();

        if (string.Equals(_loadedMapFileName, configuredMapFile, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        await LoadConfiguredMapAsync(configuredMapFile);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_mapDefinition is null || _renderModel is null)
        {
            if (_cameraInitialized)
            {
                await JavaScriptRuntime.InvokeVoidAsync("mapBoard.disposeCamera", _boardViewportElement);
                _cameraInitialized = false;
            }

            return;
        }

        var relativePoint = await JavaScriptRuntime.InvokeAsync<RelativePoint>(
            "mapBoard.getRelativePoint",
            _boardViewportElement,
            0,
            0);

        var renderSizeChanged = UpdateViewportRenderSize(relativePoint);

        if (!_cameraUnavailable)
        {
            try
            {
                await InitializeCameraInteropAsync();
            }
            catch (JSException)
            {
                _cameraUnavailable = true;
                _cameraInitialized = false;
            }
        }

        if (renderSizeChanged)
        {
            StateHasChanged();
        }
    }

    private async Task LoadConfiguredMapAsync(string configuredMapFile)
    {
        _errors.Clear();
        _warnings.Clear();
        _selectedRailroadIndex = null;
        _routeNodes.Clear();
        _selectedRouteSegments.Clear();
        _selectedRouteNodeIds.Clear();
        _railroadStrokeColors.Clear();
        _routeContext = null;
        _routeStartNodeId = null;
        _routeStartNodeName = null;
        _cameraUnavailable = false;
        _cameraInitialized = false;
        _lastClientViewportSequence = 0;
        _loadedMapFileName = null;

        var resolvedPath = ResolveMapPath(configuredMapFile);
        if (resolvedPath is null)
        {
            _mapDefinition = null;
            _renderModel = null;
            _errors.Add($"Configured map file '{configuredMapFile}' was not found.");
            return;
        }

        await using var stream = File.OpenRead(resolvedPath);
        var parseResult = await MapParserService.ParseAsync(Path.GetFileName(resolvedPath), stream, CancellationToken.None);

        if (!parseResult.Succeeded || parseResult.Definition is null)
        {
            _mapDefinition = null;
            _renderModel = null;
            _errors.AddRange(parseResult.Errors);
            _warnings.AddRange(parseResult.Warnings);
            return;
        }

        _mapDefinition = parseResult.Definition;
        _warnings.AddRange(parseResult.Warnings);

        var projectionResult = BoardProjectionService.Project(_mapDefinition);
        _renderModel = projectionResult.Model;
        _warnings.AddRange(projectionResult.Warnings);
        PopulateRailroadStrokeColors();

        _routeNodes.AddRange(_renderModel.RouteNodes);
        _routeContext = MapRouteService.BuildContext(_mapDefinition);
        InitializeChicagoStartNode();

        _viewport = BoardViewportService.InitializeFitToBoard(_mapDefinition);
        _loadedMapFileName = configuredMapFile;
    }

    private string? ResolveMapPath(string configuredMapFile)
    {
        if (Path.IsPathRooted(configuredMapFile) && File.Exists(configuredMapFile))
        {
            return configuredMapFile;
        }

        var candidates = new[]
        {
            Path.Combine(HostEnvironment.ContentRootPath, configuredMapFile),
            Path.Combine(HostEnvironment.ContentRootPath, "maps", configuredMapFile),
            Path.Combine(AppContext.BaseDirectory, configuredMapFile),
            Path.Combine(AppContext.BaseDirectory, "maps", configuredMapFile)
        };

        return candidates.FirstOrDefault(File.Exists);
    }

    private void OnZoomSliderInput(ChangeEventArgs args)
    {
        if (_mapDefinition is null)
        {
            return;
        }

        if (!double.TryParse(args.Value?.ToString(), out var requestedZoom))
        {
            return;
        }

        if (BoardViewportService.ClampZoom(requestedZoom) <= BoardViewportService.MinZoom)
        {
            _viewport = BoardViewportService.InitializeFitToBoard(_mapDefinition);
            return;
        }

        _viewport = BoardViewportService.UpdateViewportCentered(_viewport, requestedZoom);
    }

    private void ResetZoom()
    {
        if (_mapDefinition is null)
        {
            return;
        }

        _viewport = BoardViewportService.InitializeFitToBoard(_mapDefinition);
    }


    private async Task InitializeCameraInteropAsync()
    {
        if (_mapDefinition is null || _renderModel is null)
        {
            return;
        }

        if (_suspendCameraPush)
        {
            _suspendCameraPush = false;
            return;
        }

        _mapBoardReference ??= DotNetObjectReference.Create(this);

        await JavaScriptRuntime.InvokeVoidAsync(
            "mapBoard.initializeCamera",
            _boardViewportElement,
            new
            {
                mapLeft = _mapDefinition.ScaleLeft,
                mapTop = _mapDefinition.ScaleTop,
                mapWidth = _mapDefinition.ScaleWidth,
                mapHeight = _mapDefinition.ScaleHeight,
                zoomPercent = _viewport.ZoomPercent,
                centerX = _viewport.CenterX,
                centerY = _viewport.CenterY,
                minZoom = BoardViewportService.MinZoom,
                maxZoom = BoardViewportService.MaxZoom
            },
            _mapBoardReference);

        _cameraInitialized = true;
    }

    private string GetMapViewBoxValue()
    {
        if (_mapDefinition is null)
        {
            return "0 0 1 1";
        }

        return FormattableString.Invariant(
            $"{_mapDefinition.ScaleLeft:F4} {_mapDefinition.ScaleTop:F4} {_mapDefinition.ScaleWidth:F4} {_mapDefinition.ScaleHeight:F4}");
    }

    private string? GetCameraTransform()
    {
        if (_mapDefinition is null)
        {
            return null;
        }

        var zoomScale = _viewport.ZoomPercent / 100.0;
        var mapCenterX = _mapDefinition.ScaleLeft + (_mapDefinition.ScaleWidth / 2.0);
        var mapCenterY = _mapDefinition.ScaleTop + (_mapDefinition.ScaleHeight / 2.0);

        return FormattableString.Invariant(
            $"translate({mapCenterX:F4} {mapCenterY:F4}) scale({zoomScale:F6}) translate({-_viewport.CenterX:F4} {-_viewport.CenterY:F4})");
    }

    private bool UpdateViewportRenderSize(RelativePoint relativePoint)
    {
        var width = Math.Max(1, relativePoint.Width);
        var height = Math.Max(1, relativePoint.Height);

        if (Math.Abs(width - _viewportRenderWidth) < 0.5
            && Math.Abs(height - _viewportRenderHeight) < 0.5)
        {
            return false;
        }

        _viewportRenderWidth = width;
        _viewportRenderHeight = height;
        return true;
    }

    private string? GetTextUnstretchTransform(double x, double y)
    {
        if (_mapDefinition is null)
        {
            return null;
        }

        var scaleX = _viewportRenderWidth / Math.Max(0.0001, _mapDefinition.ScaleWidth);
        var scaleY = _viewportRenderHeight / Math.Max(0.0001, _mapDefinition.ScaleHeight);

        if (scaleX <= 0 || scaleY <= 0)
        {
            return null;
        }

        var compensationScaleX = scaleY / scaleX;
        if (Math.Abs(compensationScaleX - 1) < 0.0001)
        {
            return null;
        }

        return FormattableString.Invariant(
            $"translate({x:F4} {y:F4}) scale({compensationScaleX:F6} 1) translate({-x:F4} {-y:F4})");
    }

    private async Task OnEndGameClickedAsync()
    {
        if (!EndGameRequested.HasDelegate)
        {
            return;
        }

        await EndGameRequested.InvokeAsync();
    }

    private void OnRailroadSegmentClicked(int railroadIndex)
    {
        if (_interactionMode != MapInteractionMode.Rail)
        {
            return;
        }

        if (railroadIndex <= 0)
        {
            return;
        }

        _selectedRailroadIndex = railroadIndex;
    }

    private void OnRouteNodeClicked(RouteNodeRenderItem routeNode)
    {
        if (_interactionMode != MapInteractionMode.Route
            || _routeContext is null
            || string.IsNullOrWhiteSpace(_routeStartNodeId))
        {
            return;
        }

        if (_selectedRouteNodeIds.Count == 0)
        {
            _selectedRouteNodeIds.Add(_routeStartNodeId);
        }

        var currentEndpoint = _selectedRouteNodeIds[^1];

        if (string.Equals(routeNode.NodeId, currentEndpoint, StringComparison.OrdinalIgnoreCase))
        {
            CycleEndpointRailroadSelection();
            return;
        }

        var existingIndex = _selectedRouteNodeIds.FindIndex(nodeId =>
            string.Equals(nodeId, routeNode.NodeId, StringComparison.OrdinalIgnoreCase));

        if (existingIndex >= 0)
        {
            var currentSelection = new RouteSelection
            {
                NodeIds = _selectedRouteNodeIds.ToList(),
                Segments = _selectedRouteSegments.ToList()
            };

            var truncated = MapRouteService.TruncateToNode(currentSelection, routeNode.NodeId);
            _selectedRouteNodeIds.Clear();
            _selectedRouteNodeIds.AddRange(truncated.NodeIds);
            _selectedRouteSegments.Clear();
            _selectedRouteSegments.AddRange(truncated.Segments);
            return;
        }

        var extension = MapRouteService.FindShortestSelection(_routeContext, currentEndpoint, routeNode.NodeId);
        if (extension is null)
        {
            return;
        }

        foreach (var segment in extension.Segments)
        {
            _selectedRouteSegments.Add(segment);
        }

        foreach (var extensionNodeId in extension.NodeIds.Skip(1))
        {
            _selectedRouteNodeIds.Add(extensionNodeId);
        }
    }

    private double GetRouteNodeHitboxWidth()
    {
        if (_mapDefinition is null)
        {
            return 0;
        }

        var viewBox = BoardViewportService.GetViewBox(_viewport, _mapDefinition);
        var mapUnitsPerPixelX = viewBox.Width / Math.Max(1, _viewportRenderWidth);
        return RouteClickRegionSizePixels * mapUnitsPerPixelX;
    }

    private double GetRouteNodeHitboxHeight()
    {
        if (_mapDefinition is null)
        {
            return 0;
        }

        var viewBox = BoardViewportService.GetViewBox(_viewport, _mapDefinition);
        var mapUnitsPerPixelY = viewBox.Height / Math.Max(1, _viewportRenderHeight);
        return RouteClickRegionSizePixels * mapUnitsPerPixelY;
    }

    private void InitializeChicagoStartNode()
    {
        var chicagoNode = _routeNodes.FirstOrDefault(node =>
            string.Equals(node.Name, "Chicago", StringComparison.OrdinalIgnoreCase));

        if (chicagoNode is null)
        {
            _warnings.Add("Route mode is unavailable: Chicago was not found on the loaded map.");
            return;
        }

        _routeStartNodeId = chicagoNode.NodeId;
        _routeStartNodeName = chicagoNode.Name;
        _selectedRouteNodeIds.Clear();
        _selectedRouteNodeIds.Add(chicagoNode.NodeId);
        _selectedRouteSegments.Clear();
    }

    private void CycleEndpointRailroadSelection()
    {
        if (_routeContext is null
            || _selectedRouteNodeIds.Count < 2
            || _selectedRouteSegments.Count == 0)
        {
            return;
        }

        var previousNodeId = _selectedRouteNodeIds[^2];
        var currentNodeId = _selectedRouteNodeIds[^1];

        if (!_routeContext.Adjacency.TryGetValue(previousNodeId, out var adjacentEdges))
        {
            return;
        }

        var candidates = adjacentEdges
            .Where(edge => string.Equals(edge.ToNodeId, currentNodeId, StringComparison.OrdinalIgnoreCase))
            .OrderBy(edge => edge.RailroadIndex)
            .ToList();

        if (candidates.Count <= 1)
        {
            return;
        }

        var currentSegment = _selectedRouteSegments[^1];
        var currentIndex = candidates.FindIndex(candidate =>
            candidate.RailroadIndex == currentSegment.RailroadIndex
            && string.Equals(candidate.FromNodeId, currentSegment.FromNodeId, StringComparison.OrdinalIgnoreCase)
            && string.Equals(candidate.ToNodeId, currentSegment.ToNodeId, StringComparison.OrdinalIgnoreCase));

        var nextIndex = currentIndex < 0
            ? 0
            : (currentIndex + 1) % candidates.Count;

        _selectedRouteSegments[^1] = candidates[nextIndex];
    }

    private void PopulateRailroadStrokeColors()
    {
        _railroadStrokeColors.Clear();

        if (_renderModel is null)
        {
            return;
        }

        foreach (var segment in _renderModel.RailroadSegments)
        {
            _railroadStrokeColors.TryAdd(segment.RailroadIndex, segment.StrokeColor);
        }
    }

    private string GetRouteSegmentStrokeColor(RouteGraphEdge routeSegment)
    {
        return _railroadStrokeColors.TryGetValue(routeSegment.RailroadIndex, out var strokeColor)
            ? strokeColor
            : "#000000";
    }

    private void SetInteractionMode(MapInteractionMode mode)
    {
        _interactionMode = mode;
        if (mode == MapInteractionMode.Route)
        {
            _selectedRailroadIndex = null;
        }
    }

    [JSInvokable]
    public Task OnClientViewportChanged(long sequence, double zoomPercent, double centerX, double centerY, double width, double height)
    {
        if (sequence <= _lastClientViewportSequence)
        {
            return Task.CompletedTask;
        }

        _lastClientViewportSequence = sequence;

        var nextZoom = BoardViewportService.ClampZoom(zoomPercent);
        var changed = Math.Abs(_viewport.ZoomPercent - nextZoom) > 0.01
            || Math.Abs(_viewport.CenterX - centerX) > 0.01
            || Math.Abs(_viewport.CenterY - centerY) > 0.01;

        _viewport = new BoardViewport
        {
            ZoomPercent = nextZoom,
            CenterX = centerX,
            CenterY = centerY,
            ZoomAnchor = ZoomAnchor.ViewportCenter
        };

        _suspendCameraPush = true;

        var sizeChanged = UpdateViewportRenderSize(new RelativePoint(0, 0, width, height));

        if (!changed && !sizeChanged)
        {
            return Task.CompletedTask;
        }

        return InvokeAsync(StateHasChanged);
    }

    private Appearance GetModeButtonAppearance(MapInteractionMode mode)
    {
        return _interactionMode == mode ? Appearance.Accent : Appearance.Neutral;
    }

    private string GetRailroadSegmentClass(RailroadRenderSegment segment)
    {
        var ownershipClass = segment.IsOwned ? "owned" : "unowned";
        return _selectedRailroadIndex == segment.RailroadIndex
            ? $"{ownershipClass} selected"
            : ownershipClass;
    }

    public async ValueTask DisposeAsync()
    {
        if (_cameraInitialized)
        {
            try
            {
                await JavaScriptRuntime.InvokeVoidAsync("mapBoard.disposeCamera", _boardViewportElement);
            }
            catch (JSDisconnectedException)
            {
                // ignored during teardown
            }
        }

        _mapBoardReference?.Dispose();
    }

    private enum MapInteractionMode
    {
        Rail,
        Route
    }

}
