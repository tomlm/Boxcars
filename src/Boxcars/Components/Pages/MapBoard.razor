@using Boxcars.Data.Maps
@using Boxcars.Services.Maps
@using Microsoft.AspNetCore.Components
@using Microsoft.FluentUI.AspNetCore.Components
@using Microsoft.JSInterop
@inject IMapParserService MapParserService
@inject MapBackgroundResolver BackgroundResolver
@inject BoardProjectionService BoardProjectionService
@inject BoardViewportService BoardViewportService
@inject IWebHostEnvironment HostEnvironment
@inject IJSRuntime JavaScriptRuntime

<div class="map-board-shell">
    <FluentCard class="map-board-controls">
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.75rem;">
            <FluentLabel Typo="Typography.H5">Map Board</FluentLabel>
            <FluentLabel Typo="Typography.Body">Map selection is provided by game setup.</FluentLabel>

            <div class="map-board-zoom-row">
                <FluentLabel Typo="Typography.Body">Zoom (@_viewport.ZoomPercent.ToString("F0")%)</FluentLabel>
                <input type="range"
                       min="25"
                       max="500"
                       step="1"
                       value="@_viewport.ZoomPercent"
                       @oninput="OnZoomSliderInput"
                       class="map-board-zoom-slider" />
                <FluentButton Appearance="Appearance.Neutral" OnClick="ResetZoom">Fit to board</FluentButton>

                @if (ShowEndGameButton)
                {
                    <FluentButton Appearance="Appearance.Lightweight" OnClick="OnEndGameClickedAsync" Disabled="@(!EndGameRequested.HasDelegate)">
                        End Game
                    </FluentButton>
                }
            </div>
        </FluentStack>
    </FluentCard>

    @if (_errors.Count > 0)
    {
        <FluentCard class="map-board-message map-board-error">
            <FluentLabel Typo="Typography.H6">Unable to render map</FluentLabel>
            @foreach (var error in _errors)
            {
                <FluentLabel Typo="Typography.Body">@error</FluentLabel>
            }
        </FluentCard>
    }

    <div class="map-board-viewport @(_isPanning ? "panning" : string.Empty)"
         @ref="_boardViewportElement"
         tabindex="0"
         @onmousedown="StartPanAsync"
         @onmousedown:preventDefault="true"
         @onmousemove="ContinuePan"
         @onmouseup="EndPan"
         @onmouseleave="EndPan"
         @onwheel:preventDefault="true"
         @onwheel:stopPropagation="true"
         @onwheel="HandleWheelZoomAsync">
        @if (_mapDefinition is null || _renderModel is null)
        {
            <FluentCard class="map-board-placeholder">
                <FluentLabel Typo="Typography.Body">No map loaded yet.</FluentLabel>
            </FluentCard>
        }
        else
        {
            <svg class="map-board-svg"
                 viewBox="@GetViewBoxValue()"
                 preserveAspectRatio="xMidYMid meet"
                 aria-label="Rail Baron game board">
                @if (!string.IsNullOrWhiteSpace(_backgroundDataUrl))
                {
                    <image href="@_backgroundDataUrl"
                           x="@_mapDefinition.ScaleLeft"
                           y="@_mapDefinition.ScaleTop"
                           width="@_mapDefinition.ScaleWidth"
                           height="@_mapDefinition.ScaleHeight"
                           preserveAspectRatio="none" />
                }

                <g class="map-board-lines">
                    @foreach (var line in _renderModel.MapLines)
                    {
                        <line x1="@line.X1" y1="@line.Y1" x2="@line.X2" y2="@line.Y2" />
                    }
                </g>

                <g class="map-board-separators">
                    @foreach (var separator in _renderModel.Separators)
                    {
                        <line x1="@separator.X1" y1="@separator.Y1" x2="@separator.X2" y2="@separator.Y2" />
                    }
                </g>

                <g class="map-board-railroads">
                    @foreach (var railroadSegment in _renderModel.RailroadSegments)
                    {
                        <line x1="@railroadSegment.X1"
                              y1="@railroadSegment.Y1"
                              x2="@railroadSegment.X2"
                              y2="@railroadSegment.Y2"
                              stroke="@railroadSegment.StrokeColor"
                              class="@(railroadSegment.IsOwned ? "owned" : "unowned")" />
                    }
                </g>

                <g class="map-board-train-dots">
                    @foreach (var dot in _renderModel.TrainDots)
                    {
                        <circle cx="@dot.X" cy="@dot.Y" r="0.9" />
                    }
                </g>

                <g class="map-board-cities">
                    @foreach (var city in _renderModel.Cities)
                    {
                        <rect x="@(city.X - 1.4)" y="@(city.Y - 1.4)" width="2.8" height="2.8" rx="0.2" ry="0.2" />
                    }
                </g>

                <g class="map-board-city-labels">
                    @foreach (var city in _renderModel.Cities)
                    {
                        <svg:text x="@(city.X + 2.2)" y="@(city.Y - 2.2)">@city.Name</svg:text>
                    }
                </g>
            </svg>
        }
    </div>

    @if (_warnings.Count > 0)
    {
        <FluentCard class="map-board-message map-board-warning map-board-warning-panel">
            <details open>
                <summary>Map Warnings (@_warnings.Count)</summary>
                <div class="map-board-warning-list">
                    @foreach (var warning in _warnings)
                    {
                        <FluentLabel Typo="Typography.Body">@warning</FluentLabel>
                    }
                </div>
            </details>
        </FluentCard>
    }
</div>

@code {
    [Parameter]
    public bool ShowEndGameButton { get; set; }

    [Parameter]
    public EventCallback EndGameRequested { get; set; }

    [Parameter]
    public string MapFileName { get; set; } = "U21MAP.RB3";

    private readonly List<string> _errors = new();
    private readonly List<string> _warnings = new();

    private ElementReference _boardViewportElement;
    private MapDefinition? _mapDefinition = null;
    private BoardRenderModel? _renderModel = null;
    private BoardViewport _viewport = new()
    {
        ZoomPercent = 100,
        CenterX = 0,
        CenterY = 0,
        ZoomAnchor = ZoomAnchor.ViewportCenter
    };

    private string? _backgroundDataUrl = null;
    private string? _loadedMapFileName;
    private bool _isPanning;
    private double _panStartClientX;
    private double _panStartClientY;
    private double _panStartCenterX;
    private double _panStartCenterY;
    private double _panStartViewBoxWidth;
    private double _panStartViewBoxHeight;
    private double _panViewportWidth;
    private double _panViewportHeight;

    protected override async Task OnParametersSetAsync()
    {
        var configuredMapFile = string.IsNullOrWhiteSpace(MapFileName)
            ? "U21MAP.RB3"
            : MapFileName.Trim();

        if (string.Equals(_loadedMapFileName, configuredMapFile, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        await LoadConfiguredMapAsync(configuredMapFile);
    }

    private async Task LoadConfiguredMapAsync(string configuredMapFile)
    {
        _errors.Clear();
        _warnings.Clear();
        _loadedMapFileName = null;

        var resolvedPath = ResolveMapPath(configuredMapFile);
        if (resolvedPath is null)
        {
            _mapDefinition = null;
            _renderModel = null;
            _backgroundDataUrl = null;
            _errors.Add($"Configured map file '{configuredMapFile}' was not found.");
            return;
        }

        await using var stream = File.OpenRead(resolvedPath);
        var parseResult = await MapParserService.ParseAsync(Path.GetFileName(resolvedPath), stream, CancellationToken.None);

        if (!parseResult.Succeeded || parseResult.Definition is null)
        {
            _mapDefinition = null;
            _renderModel = null;
            _backgroundDataUrl = null;
            _errors.AddRange(parseResult.Errors);
            _warnings.AddRange(parseResult.Warnings);
            return;
        }

        _mapDefinition = parseResult.Definition;
        _warnings.AddRange(parseResult.Warnings);

        var projectionResult = BoardProjectionService.Project(_mapDefinition);
        _renderModel = projectionResult.Model;
        _warnings.AddRange(projectionResult.Warnings);

        var backgroundResult = await BackgroundResolver.ResolveAsync(_mapDefinition, uploadedBackgroundDataUrl: null, CancellationToken.None);
        if (backgroundResult.Succeeded)
        {
            _backgroundDataUrl = backgroundResult.DataUrl;
        }
        else if (backgroundResult.Error is not null)
        {
            _errors.Add(backgroundResult.Error);
        }

        _viewport = BoardViewportService.InitializeFitToBoard(_mapDefinition);
        _loadedMapFileName = configuredMapFile;
    }

    private string? ResolveMapPath(string configuredMapFile)
    {
        if (Path.IsPathRooted(configuredMapFile) && File.Exists(configuredMapFile))
        {
            return configuredMapFile;
        }

        var candidates = new[]
        {
            Path.Combine(HostEnvironment.ContentRootPath, configuredMapFile),
            Path.Combine(HostEnvironment.ContentRootPath, "maps", configuredMapFile),
            Path.Combine(AppContext.BaseDirectory, configuredMapFile),
            Path.Combine(AppContext.BaseDirectory, "maps", configuredMapFile)
        };

        return candidates.FirstOrDefault(File.Exists);
    }

    private void OnZoomSliderInput(ChangeEventArgs args)
    {
        if (_mapDefinition is null)
        {
            return;
        }

        if (!double.TryParse(args.Value?.ToString(), out var requestedZoom))
        {
            return;
        }

        _viewport = BoardViewportService.UpdateViewportCentered(_viewport, requestedZoom);
    }

    private void ResetZoom()
    {
        if (_mapDefinition is null)
        {
            return;
        }

        _viewport = BoardViewportService.InitializeFitToBoard(_mapDefinition);
    }

    private async Task HandleWheelZoomAsync(WheelEventArgs args)
    {
        if (_mapDefinition is null)
        {
            return;
        }

        var delta = args.DeltaY < 0 ? 10 : -10;
        var requestedZoom = _viewport.ZoomPercent + delta;

        var relativePoint = await JavaScriptRuntime.InvokeAsync<RelativePoint>(
            "mapBoard.getRelativePoint",
            _boardViewportElement,
            args.ClientX,
            args.ClientY);

        _viewport = BoardViewportService.UpdateCursorAnchored(_viewport, requestedZoom, relativePoint, _mapDefinition);
    }

    private async Task StartPanAsync(MouseEventArgs args)
    {
        if (_mapDefinition is null || args.Button != 0)
        {
            return;
        }

        var relativePoint = await JavaScriptRuntime.InvokeAsync<RelativePoint>(
            "mapBoard.getRelativePoint",
            _boardViewportElement,
            args.ClientX,
            args.ClientY);

        var viewBox = BoardViewportService.GetViewBox(_viewport, _mapDefinition);

        _isPanning = true;
        _panStartClientX = args.ClientX;
        _panStartClientY = args.ClientY;
        _panStartCenterX = _viewport.CenterX;
        _panStartCenterY = _viewport.CenterY;
        _panStartViewBoxWidth = viewBox.Width;
        _panStartViewBoxHeight = viewBox.Height;
        _panViewportWidth = Math.Max(1, relativePoint.Width);
        _panViewportHeight = Math.Max(1, relativePoint.Height);
    }

    private void ContinuePan(MouseEventArgs args)
    {
        if (!_isPanning || _mapDefinition is null)
        {
            return;
        }

        var deltaX = args.ClientX - _panStartClientX;
        var deltaY = args.ClientY - _panStartClientY;

        var boardDeltaX = deltaX * (_panStartViewBoxWidth / _panViewportWidth);
        var boardDeltaY = deltaY * (_panStartViewBoxHeight / _panViewportHeight);

        _viewport = new BoardViewport
        {
            ZoomPercent = _viewport.ZoomPercent,
            CenterX = _panStartCenterX - boardDeltaX,
            CenterY = _panStartCenterY - boardDeltaY,
            ZoomAnchor = ZoomAnchor.ViewportCenter
        };
    }

    private void EndPan(MouseEventArgs _)
    {
        _isPanning = false;
    }

    private string GetViewBoxValue()
    {
        if (_mapDefinition is null)
        {
            return "0 0 1 1";
        }

        var viewBox = BoardViewportService.GetViewBox(_viewport, _mapDefinition);
        return viewBox.ToSvgValue();
    }

    private async Task OnEndGameClickedAsync()
    {
        if (!EndGameRequested.HasDelegate)
        {
            return;
        }

        await EndGameRequested.InvokeAsync();
    }

}
