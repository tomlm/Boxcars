@using Azure
@using Boxcars.Data
@using Boxcars.Services
@using MudBlazor
@inject UserDirectoryService UserDirectoryService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudStack Spacing="3" Class="dashboard-bot-library">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5" Class="dashboard-section-title">Bots</MudText>
            <MudText Typo="Typo.body2" Class="dashboard-muted">Bots are reusable global library definitions with their own strategy text.</MudText>
        </MudStack>
        <MudButton Variant="Variant.Outlined" Color="MudBlazor.Color.Primary" OnClick="RefreshAsync" Disabled="_loading" Class="dashboard-bot-library-refresh">
            Refresh
        </MudButton>
    </MudStack>

    <MudPaper Outlined="true" Class="pa-4 dashboard-bot-editor">
        <MudStack Spacing="2">
            <MudText Typo="Typo.subtitle1">@(_editor.IsEditingExisting ? "Edit Bot" : "Create Bot")</MudText>
            <MudTextField @bind-Value="_editorName" Label="Bot Name" Variant="Variant.Outlined" Required="true" />
            <MudTextField @bind-Value="_editorStrategyText"
                          Label="Strategy"
                          Variant="Variant.Outlined"
                          Lines="5"
                          AutoGrow="true"
                          Placeholder="Describe how this bot should make decisions." />
            @if (!string.IsNullOrWhiteSpace(_editorError))
            {
                <MudAlert Severity="Severity.Error" Dense="true">@_editorError</MudAlert>
            }
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled"
                           Color="MudBlazor.Color.Primary"
                           OnClick="SaveAsync"
                           Disabled="_saveInProgress || string.IsNullOrWhiteSpace(CurrentUserId)">
                    @(_editor.IsEditingExisting ? "Save Changes" : "Create Bot")
                </MudButton>
                @if (_editor.IsEditingExisting)
                {
                    <MudButton Variant="Variant.Text" OnClick="ResetEditor">Cancel</MudButton>
                }
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="MudBlazor.Color.Primary" />
    }
    else if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <MudAlert Severity="Severity.Error">@_loadError</MudAlert>
    }
    else if (_bots.Count == 0)
    {
        <MudAlert Severity="Severity.Info">No bots have been created yet.</MudAlert>
    }
    else
    {
        <MudTable T="BotLibraryRowModel" Items="_bots" Dense="true" Hover="true" Class="dashboard-bot-table">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Strategy</MudTh>
                <MudTh>Updated</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="Strategy">@BuildStrategyPreview(context)</MudTd>
                <MudTd DataLabel="Updated">@context.ModifiedUtc.ToLocalTime().ToString("g")</MudTd>
                <MudTd>
                    <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="1" Class="dashboard-bot-actions">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="Size.Small"
                                       Color="MudBlazor.Color.Primary"
                                       OnClick="() => BeginEdit(context)"
                                       aria-label="Edit bot" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Small"
                                       Color="MudBlazor.Color.Error"
                                       OnClick="() => DeleteAsync(context)"
                                       aria-label="Delete bot" />
                    </MudStack>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudStack>

@code {
    private List<BotLibraryRowModel> _bots = [];
    private BotLibraryEditorModel _editor = new();
    private string _editorName = string.Empty;
    private string _editorStrategyText = string.Empty;
    private string? _editorError;
    private string? _loadError;
    private bool _loading;
    private bool _saveInProgress;

    [Parameter]
    public string CurrentUserId { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        _loadError = null;

        try
        {
            _bots = (await UserDirectoryService.ListBotDefinitionsAsync(CancellationToken.None))
                .Select(bot => new BotLibraryRowModel
                {
                    BotDefinitionId = bot.BotDefinitionId,
                    Name = bot.Name,
                    StrategyText = bot.StrategyText,
                    ModifiedUtc = bot.ModifiedUtc,
                    ETag = bot.ETag
                })
                .ToList();
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void BeginEdit(BotLibraryRowModel row)
    {
        _editor = new BotLibraryEditorModel
        {
            BotDefinitionId = row.BotDefinitionId,
            Name = row.Name,
            StrategyText = row.StrategyText,
            ETag = row.ETag,
            IsEditingExisting = true
        };
        _editorName = row.Name;
        _editorStrategyText = row.StrategyText;
        _editorError = null;
    }

    private void ResetEditor()
    {
        _editor = new BotLibraryEditorModel();
        _editorName = string.Empty;
        _editorStrategyText = string.Empty;
        _editorError = null;
    }

    private async Task SaveAsync()
    {
        _editorError = null;

        if (string.IsNullOrWhiteSpace(CurrentUserId))
        {
            _editorError = "You must be signed in to manage bots.";
            return;
        }

        _saveInProgress = true;

        try
        {
            BotDefinitionWriteResult result;
            if (_editor.IsEditingExisting)
            {
                result = await UserDirectoryService.UpdateBotDefinitionAsync(
                    CurrentUserId,
                    _editor.BotDefinitionId,
                    _editor.ETag,
                    _editorName,
                    _editorStrategyText,
                    CancellationToken.None);
            }
            else
            {
                result = await UserDirectoryService.CreateBotDefinitionAsync(CurrentUserId, _editorName, _editorStrategyText, CancellationToken.None);
            }

            if (!result.Succeeded)
            {
                _editorError = result.ErrorMessage ?? "Unable to save bot definition.";
                if (result.IsConflict || result.IsNotFound)
                {
                    Snackbar.Add(_editorError, result.IsConflict ? Severity.Warning : Severity.Info);
                    await RefreshAsync();
                }

                return;
            }

            Snackbar.Add(_editor.IsEditingExisting ? "Bot updated." : "Bot created.", Severity.Success);
            ResetEditor();
            await RefreshAsync();
        }
        finally
        {
            _saveInProgress = false;
        }
    }

    private async Task DeleteAsync(BotLibraryRowModel row)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Delete bot?",
            $"Are you sure you want to delete \"{row.Name}\"? This cannot be undone.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed != true)
        {
            return;
        }

        var result = await UserDirectoryService.DeleteBotDefinitionAsync(row.BotDefinitionId, row.ETag, CancellationToken.None);
        switch (result)
        {
            case BotDefinitionDeleteResult.Success:
                Snackbar.Add("Bot deleted.", Severity.Success);
                if (string.Equals(_editor.BotDefinitionId, row.BotDefinitionId, StringComparison.Ordinal))
                {
                    ResetEditor();
                }

                await RefreshAsync();
                break;

            case BotDefinitionDeleteResult.Conflict:
                Snackbar.Add("That bot changed before it could be deleted. The list has been refreshed.", Severity.Warning);
                await RefreshAsync();
                break;

            case BotDefinitionDeleteResult.NotFound:
                Snackbar.Add("That bot no longer exists. The list has been refreshed.", Severity.Info);
                await RefreshAsync();
                break;

            default:
                Snackbar.Add("Unable to delete that bot.", Severity.Error);
                break;
        }
    }

    private static string BuildStrategyPreview(BotLibraryRowModel row)
    {
        if (string.IsNullOrWhiteSpace(row.StrategyText))
        {
            return "No strategy text.";
        }

        return row.StrategyText.Length <= 100
            ? row.StrategyText
            : string.Concat(row.StrategyText[..97], "...");
    }
}