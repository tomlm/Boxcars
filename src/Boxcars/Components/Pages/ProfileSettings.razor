@page "/profile-settings"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Boxcars.Data
@using Boxcars.Services
@attribute [Authorize]
@inject PlayerProfileService ProfileService
@inject NavigationManager Navigation
@inject IMessageService MessageService

<PageTitle>Profile Settings - BoxCars</PageTitle>

@if (_loading)
{
    <FluentProgressRing />
}
else if (_profile == null)
{
    <FluentCard Style="max-width: 600px; margin: 2rem auto; text-align: center; padding: 2rem;">
        <FluentLabel Typo="Typography.H4">Unable to load profile</FluentLabel>
        <FluentButton Appearance="Appearance.Accent" OnClick="@LoadProfileAsync" Style="margin-top: 1rem;">Retry</FluentButton>
    </FluentCard>
}
else
{
    <FluentStack Orientation="Orientation.Vertical" Style="max-width: 600px; margin: 0 auto; gap: 1.5rem;">
        <FluentLabel Typo="Typography.H3">Profile Settings</FluentLabel>

        <FluentCard Style="padding: 1.5rem;">
            <FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem;">
                <FluentTextField @bind-Value="_nickname"
                                 Label="Nickname"
                                 Placeholder="Enter your display name"
                                 Style="width: 100%;" />

                <FluentTextField @bind-Value="_thumbnailUrl"
                                 Label="Thumbnail URL"
                                 Placeholder="https://example.com/avatar.png"
                                 Style="width: 100%;" />

                <FluentStack Orientation="Orientation.Horizontal" Style="gap: 1rem; margin-top: 0.5rem;">
                    <FluentButton Appearance="Appearance.Accent"
                                  OnClick="@SaveAsync"
                                  Disabled="@_saving">
                        @(_saving ? "Saving..." : "Save Changes")
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Outline"
                                  OnClick="@(() => Navigation.NavigateTo("/dashboard"))">
                        Back to Dashboard
                    </FluentButton>
                </FluentStack>
            </FluentStack>
        </FluentCard>
    </FluentStack>
}

@code {
    private bool _loading = true;
    private bool _saving;
    private ApplicationUser? _profile;
    private string _nickname = string.Empty;
    private string _thumbnailUrl = string.Empty;
    private string? _currentUserId;
    private string _originalNickname = string.Empty;
    private string _originalThumbnailUrl = string.Empty;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null)
        {
            var state = await AuthState;
            _currentUserId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        }

        await LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        _loading = true;
        StateHasChanged();

        if (_currentUserId != null)
        {
            _profile = await ProfileService.GetProfileAsync(_currentUserId, CancellationToken.None);
            if (_profile != null)
            {
                _nickname = _profile.Nickname;
                _thumbnailUrl = _profile.ThumbnailUrl;
                _originalNickname = _profile.Nickname;
                _originalThumbnailUrl = _profile.ThumbnailUrl;
            }
        }

        _loading = false;
        StateHasChanged();
    }

    private async Task SaveAsync()
    {
        if (_currentUserId == null || _profile == null) return;

        _saving = true;
        StateHasChanged();

        var nicknameChanged = _nickname.Trim() != _originalNickname;
        var thumbnailChanged = _thumbnailUrl.Trim() != _originalThumbnailUrl;

        try
        {
            if (nicknameChanged && !string.IsNullOrWhiteSpace(_nickname))
            {
                var result = await ProfileService.UpdateNicknameAsync(_currentUserId, _nickname.Trim(), CancellationToken.None);

                switch (result)
                {
                    case NicknameResult.Conflict:
                        await MessageService.ShowMessageBarAsync("Nickname already taken. Please choose another.", MessageIntent.Error, "SETTINGS");
                        _saving = false;
                        StateHasChanged();
                        return;
                    case NicknameResult.UpdateFailed:
                    case NicknameResult.UserNotFound:
                        await MessageService.ShowMessageBarAsync("Save failed, please try again.", MessageIntent.Error, "SETTINGS");
                        _saving = false;
                        StateHasChanged();
                        return;
                    case NicknameResult.Success:
                        _originalNickname = _nickname.Trim();
                        break;
                }
            }

            if (thumbnailChanged)
            {
                var updated = await ProfileService.UpdateThumbnailUrlAsync(_currentUserId, _thumbnailUrl.Trim(), CancellationToken.None);
                if (!updated)
                {
                    await MessageService.ShowMessageBarAsync("Save failed, please try again.", MessageIntent.Error, "SETTINGS");
                    _saving = false;
                    StateHasChanged();
                    return;
                }
                _originalThumbnailUrl = _thumbnailUrl.Trim();
            }

            if (nicknameChanged || thumbnailChanged)
            {
                await MessageService.ShowMessageBarAsync("Profile updated successfully!", MessageIntent.Success, "SETTINGS");
                // Force page refresh to update the header profile menu
                Navigation.NavigateTo("/profile-settings", forceLoad: true);
            }
            else
            {
                await MessageService.ShowMessageBarAsync("No changes to save.", MessageIntent.Info, "SETTINGS");
            }
        }
        catch
        {
            await MessageService.ShowMessageBarAsync("Save failed, please try again.", MessageIntent.Error, "SETTINGS");
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }
}
