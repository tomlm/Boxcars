@page "/profile-settings"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@using Boxcars.Data
@using Boxcars.Services
@attribute [Authorize]
@inject PlayerProfileService ProfileService
@inject NavigationManager Navigation
@inject IMessageService MessageService

<PageTitle>Profile Settings - BoxCars</PageTitle>

@if (_loading)
{
    <MudStack Class="profile-loading" Justify="Justify.Center" AlignItems="AlignItems.Center">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="MudBlazor.Color.Primary" />
    </MudStack>
}
else if (_profile == null)
{
    <MudPaper Class="profile-error">
        <MudText Typo="Typo.h4">Unable to load profile</MudText>
        <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" OnClick="@LoadProfileAsync" Class="profile-retry">Retry</MudButton>
    </MudPaper>
}
else
{
    <MudStack Class="profile-container">
        <MudText Typo="Typo.h3">Profile Settings</MudText>

        <MudPaper Class="profile-card">
            <MudStack Class="profile-fields">
                <MudTextField @bind-Value="_nickname"
                              Label="Nickname"
                              Placeholder="Enter your display name"
                              Variant="Variant.Outlined"
                              Class="profile-field" />

                <MudTextField @bind-Value="_thumbnailUrl"
                              Label="Thumbnail URL"
                              Placeholder="https://example.com/avatar.png"
                              Variant="Variant.Outlined"
                              Class="profile-field" />

                <MudSelect T="string"
                           Label="Preferred Color"
                           Value="@_preferredColor"
                           ValueChanged="OnPreferredColorChanged"
                           Variant="Variant.Outlined"
                           Class="profile-field">
                    @foreach (var color in PlayerColorOptions.Colors)
                    {
                        <MudSelectItem Value="@color">@PlayerColorOptions.ToLabel(color)</MudSelectItem>
                    }
                </MudSelect>

                <MudStack Row="true" Class="profile-actions">
                    <MudButton Variant="Variant.Filled"
                               Color="MudBlazor.Color.Primary"
                               OnClick="@SaveAsync"
                               Disabled="@_saving">
                        @(_saving ? "Saving..." : "Save Changes")
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="MudBlazor.Color.Primary"
                               OnClick="@(() => Navigation.NavigateTo("/dashboard"))">
                        Back to Dashboard
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudStack>
}

@code {
    private bool _loading = true;
    private bool _saving;
    private ApplicationUser? _profile;
    private string _nickname = string.Empty;
    private string _thumbnailUrl = string.Empty;
    private string _preferredColor = PlayerColorOptions.Colors[0];
    private string? _currentUserId;
    private string _originalNickname = string.Empty;
    private string _originalThumbnailUrl = string.Empty;
    private string _originalPreferredColor = PlayerColorOptions.Colors[0];

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null)
        {
            var state = await AuthState;
            _currentUserId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        }

        await LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        _loading = true;
        StateHasChanged();

        if (_currentUserId != null)
        {
            _profile = await ProfileService.GetProfileAsync(_currentUserId, CancellationToken.None);
            if (_profile != null)
            {
                _nickname = _profile.Nickname;
                _thumbnailUrl = _profile.ThumbnailUrl;
                _preferredColor = PlayerColorOptions.NormalizeOrDefault(_profile.PreferredColor);
                _originalNickname = _profile.Nickname;
                _originalThumbnailUrl = _profile.ThumbnailUrl;
                _originalPreferredColor = _preferredColor;
            }
        }

        _loading = false;
        StateHasChanged();
    }

    private async Task SaveAsync()
    {
        if (_currentUserId == null || _profile == null) return;

        _saving = true;
        StateHasChanged();

        var nicknameChanged = _nickname.Trim() != _originalNickname;
        var thumbnailChanged = _thumbnailUrl.Trim() != _originalThumbnailUrl;
        var preferredColorChanged = _preferredColor != _originalPreferredColor;

        try
        {
            if (nicknameChanged && !string.IsNullOrWhiteSpace(_nickname))
            {
                var result = await ProfileService.UpdateNicknameAsync(_currentUserId, _nickname.Trim(), CancellationToken.None);

                switch (result)
                {
                    case NicknameResult.Conflict:
                        await MessageService.ShowMessageBarAsync("Nickname already taken. Please choose another.", MessageIntent.Error, "SETTINGS");
                        _saving = false;
                        StateHasChanged();
                        return;
                    case NicknameResult.UpdateFailed:
                    case NicknameResult.UserNotFound:
                        await MessageService.ShowMessageBarAsync("Save failed, please try again.", MessageIntent.Error, "SETTINGS");
                        _saving = false;
                        StateHasChanged();
                        return;
                    case NicknameResult.Success:
                        _originalNickname = _nickname.Trim();
                        break;
                }
            }

            if (thumbnailChanged)
            {
                var updated = await ProfileService.UpdateThumbnailUrlAsync(_currentUserId, _thumbnailUrl.Trim(), CancellationToken.None);
                if (!updated)
                {
                    await MessageService.ShowMessageBarAsync("Save failed, please try again.", MessageIntent.Error, "SETTINGS");
                    _saving = false;
                    StateHasChanged();
                    return;
                }
                _originalThumbnailUrl = _thumbnailUrl.Trim();
            }

            if (preferredColorChanged)
            {
                var updated = await ProfileService.UpdatePreferredColorAsync(_currentUserId, _preferredColor, CancellationToken.None);
                if (!updated)
                {
                    await MessageService.ShowMessageBarAsync("Save failed, please try again.", MessageIntent.Error, "SETTINGS");
                    _saving = false;
                    StateHasChanged();
                    return;
                }

                _originalPreferredColor = _preferredColor;
            }

            if (nicknameChanged || thumbnailChanged || preferredColorChanged)
            {
                await MessageService.ShowMessageBarAsync("Profile updated successfully!", MessageIntent.Success, "SETTINGS");
                // Force page refresh to update the header profile menu
                Navigation.NavigateTo("/profile-settings", forceLoad: true);
            }
            else
            {
                await MessageService.ShowMessageBarAsync("No changes to save.", MessageIntent.Info, "SETTINGS");
            }
        }
        catch
        {
            await MessageService.ShowMessageBarAsync("Save failed, please try again.", MessageIntent.Error, "SETTINGS");
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private Task OnPreferredColorChanged(string value)
    {
        _preferredColor = PlayerColorOptions.NormalizeOrDefault(value);
        return Task.CompletedTask;
    }
}
