@page "/Account/Manage"
@page "/Account/Manage/Preferences"
@using Boxcars.Components.Account.Shared
@using System.ComponentModel.DataAnnotations
@layout ManageLayout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@using Boxcars.Data
@using Boxcars.Services
@attribute [Authorize]
@rendermode InteractiveServer
@inject PlayerProfileService ProfileService
@inject NavigationManager Navigation

<PageTitle>Preferences - BoxCars</PageTitle>

@if (_loading)
{
    <MudStack Class="profile-loading" Justify="Justify.Center" AlignItems="AlignItems.Center">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="MudBlazor.Color.Primary" />
    </MudStack>
}
else if (_profile == null)
{
    <MudPaper Class="profile-error">
        <MudText Typo="Typo.h4">Unable to load profile</MudText>
        @if (!string.IsNullOrWhiteSpace(message))
        {
            <MudAlert Class="manage-status-message" Dense="true" Variant="Variant.Outlined" Severity="@messageSeverity">
                @message
            </MudAlert>
        }
        <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" OnClick="@LoadProfileAsync"
                   Class="profile-retry">Retry</MudButton>
    </MudPaper>
}
else
{
    <MudStack Class="profile-container">
        <MudText Typo="Typo.h3">Preferences</MudText>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <MudAlert Class="manage-status-message" Dense="true" Variant="Variant.Outlined" Severity="@messageSeverity">
                @message
            </MudAlert>
        }

        <MudPaper Class="profile-card">
            <EditForm Model="CurrentInput" OnValidSubmit="OnValidSubmitAsync">
                <DataAnnotationsValidator />
                <MudStack Class="profile-fields">
                    <ValidationSummary class="auth-validation" role="alert" />

                    <MudTextField @bind-Value="CurrentInput.Nickname" Label="Nickname" Placeholder="Enter your display name"
                                  Variant="Variant.Outlined" Class="profile-field" />

                    <MudTextField @bind-Value="CurrentInput.ThumbnailUrl" Label="Thumbnail URL"
                                  Placeholder="https://example.com/avatar.png" Variant="Variant.Outlined" Class="profile-field" />

                    <MudText Typo="Typo.body2" Class="manage-page-helper">
                        Choose your preferred color:
                    </MudText>

                    <div class="profile-color-options">
                        <MudRadioGroup T="string" @bind-Value="CurrentInput.PreferredColor">
                            @foreach (var color in PlayerColorOptions.Colors)
                            {
                                <span class="@GetColorOptionClass(color)">
                                    <MudRadio T="string" Value="@color" Class="profile-color-radio">
                                        @PlayerColorOptions.ToLabel(color)
                                    </MudRadio>
                                </span>
                            }
                        </MudRadioGroup>
                    </div>

                    <MudStack Row="true" Class="profile-actions">
                        <MudButton ButtonType="MudBlazor.ButtonType.Submit" Variant="Variant.Filled"
                                   Color="MudBlazor.Color.Primary" Disabled="@_saving">
                            Save Changes
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="MudBlazor.Color.Primary"
                                   OnClick="@(() => Navigation.NavigateTo("/dashboard"))">
                            Back to Dashboard
                        </MudButton>
                    </MudStack>
                </MudStack>
            </EditForm>
        </MudPaper>
    </MudStack>
}

@code {
    private bool _loading = true;
    private bool _saving;
    private string? message;
    private Severity messageSeverity = Severity.Info;
    private ApplicationUser? _profile;
    private string? currentUserId;
    private string originalNickname = string.Empty;
    private string originalThumbnailUrl = string.Empty;
    private string originalPreferredColor = PlayerColorOptions.Colors[0];

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private InputModel CurrentInput { get; } = new();

    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationStateTask is not null)
        {
            var authenticationState = await AuthenticationStateTask;
            currentUserId = authenticationState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        }

        await LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        _loading = true;
        message = null;

        if (string.IsNullOrWhiteSpace(currentUserId))
        {
            _profile = null;
            message = "Error: Unable to determine the current user.";
            messageSeverity = Severity.Error;
            _loading = false;
            return;
        }

        _profile = await ProfileService.GetProfileAsync(currentUserId, CancellationToken.None);

        if (_profile == null)
        {
            message = "Error: Unable to load your preferences.";
            messageSeverity = Severity.Error;
            _loading = false;
            return;
        }

        CurrentInput.Nickname = _profile.Nickname;
        CurrentInput.ThumbnailUrl = _profile.ThumbnailUrl;
        CurrentInput.PreferredColor = PlayerColorOptions.NormalizeOrDefault(_profile.PreferredColor);
        originalNickname = CurrentInput.Nickname ?? string.Empty;
        originalThumbnailUrl = CurrentInput.ThumbnailUrl ?? string.Empty;
        originalPreferredColor = CurrentInput.PreferredColor ?? PlayerColorOptions.Colors[0];
        _loading = false;
    }

    private async Task OnValidSubmitAsync()
    {
        if (_profile == null || string.IsNullOrWhiteSpace(currentUserId))
        {
            message = "Error: Unable to load your preferences.";
            messageSeverity = Severity.Error;
            return;
        }

        _saving = true;

        var nickname = CurrentInput.Nickname?.Trim() ?? string.Empty;
        var thumbnailUrl = CurrentInput.ThumbnailUrl?.Trim() ?? string.Empty;
        var preferredColor = PlayerColorOptions.NormalizeOrDefault(CurrentInput.PreferredColor);
        var nicknameChanged = !string.Equals(nickname, originalNickname, StringComparison.Ordinal);
        var thumbnailChanged = !string.Equals(thumbnailUrl, originalThumbnailUrl, StringComparison.Ordinal);
        var preferredColorChanged = !string.Equals(preferredColor, originalPreferredColor, StringComparison.Ordinal);

        try
        {
            if (!nicknameChanged && !thumbnailChanged && !preferredColorChanged)
            {
                message = "No changes to save.";
                messageSeverity = Severity.Info;
                return;
            }

            if (nicknameChanged)
            {
                if (string.IsNullOrWhiteSpace(nickname))
                {
                    message = "Error: Nickname cannot be empty.";
                    messageSeverity = Severity.Error;
                    return;
                }

                var nicknameResult = await ProfileService.UpdateNicknameAsync(currentUserId, nickname, CancellationToken.None);
                switch (nicknameResult)
                {
                    case NicknameResult.Conflict:
                        message = "Error: Nickname already taken. Please choose another.";
                        messageSeverity = Severity.Error;
                        return;
                    case NicknameResult.UpdateFailed:
                    case NicknameResult.UserNotFound:
                        message = "Error: Save failed, please try again.";
                        messageSeverity = Severity.Error;
                        return;
                }

                _profile.Nickname = nickname;
            }

            if (thumbnailChanged)
            {
                var thumbnailUpdated = await ProfileService.UpdateThumbnailUrlAsync(currentUserId, thumbnailUrl,
CancellationToken.None);
                if (!thumbnailUpdated)
                {
                    message = "Error: Save failed, please try again.";
                    messageSeverity = Severity.Error;
                    return;
                }

                _profile.ThumbnailUrl = thumbnailUrl;
            }

            if (preferredColorChanged)
            {
                var preferredColorUpdated = await ProfileService.UpdatePreferredColorAsync(currentUserId, preferredColor,
CancellationToken.None);
                if (!preferredColorUpdated)
                {
                    message = "Error: Save failed, please try again.";
                    messageSeverity = Severity.Error;
                    return;
                }

                _profile.PreferredColor = preferredColor;
            }

            originalNickname = nickname;
            originalThumbnailUrl = thumbnailUrl;
            originalPreferredColor = preferredColor;
            message = "Your preferences have been updated.";
            messageSeverity = Severity.Success;
        }
        catch
        {
            message = "Error: Save failed, please try again.";
            messageSeverity = Severity.Error;
        }
        finally
        {
            _saving = false;
        }
    }

    private sealed class InputModel
    {
        [Display(Name = "Nickname")]
        public string? Nickname { get; set; }

        [Display(Name = "Thumbnail URL")]
        public string? ThumbnailUrl { get; set; }

        [Required]
        [Display(Name = "Preferred rail color")]
        public string? PreferredColor { get; set; }
    }

    private static string GetColorOptionClass(string color) =>
        $"profile-color-pill profile-color-pill--{PlayerColorOptions.NormalizeOrDefault(color)}";
}