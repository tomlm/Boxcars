@page "/preferences"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@using Boxcars.Data
@using Boxcars.Services
@attribute [Authorize]
@rendermode InteractiveServer
@inject PlayerProfileService ProfileService
@inject NavigationManager Navigation

<PageTitle>Preferences - BoxCars</PageTitle>

@if (_loading)
{
    <MudStack Style="min-height: 12rem" Justify="Justify.Center" AlignItems="AlignItems.Center">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="MudBlazor.Color.Primary" />
    </MudStack>
}
else if (_profile == null)
{
    <MudPaper Style="max-width: 37.5rem; margin: 2rem auto; text-align: center; padding: 2rem">
        <MudText Typo="Typo.h4">Unable to load profile</MudText>
        @if (!string.IsNullOrWhiteSpace(message))
        {
            <MudAlert Style="margin-bottom: 1rem" Dense="true" Variant="Variant.Outlined" Severity="@messageSeverity">
                @message
            </MudAlert>
        }
        <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" OnClick="@LoadProfileAsync"
                   Style="margin-top: 1rem">Retry</MudButton>
    </MudPaper>
}
else
{
    <MudStack Style="max-width: 37.5rem; margin: 0 auto" Spacing="6">
        <MudText Typo="Typo.h3">Preferences</MudText>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <MudAlert Style="margin-bottom: 1rem" Dense="true" Variant="Variant.Outlined" Severity="@messageSeverity">
                @message
            </MudAlert>
        }

        <MudPaper Class="pa-6">
            <EditForm Model="CurrentInput" OnValidSubmit="OnValidSubmitAsync">
                <DataAnnotationsValidator />
                <MudStack Spacing="4">
                    <ValidationSummary style="color: var(--mud-palette-error)" role="alert" />

                    <MudTextField @bind-Value="CurrentInput.Nickname" Label="Nickname" Placeholder="Enter your display name"
                                  Variant="Variant.Outlined" FullWidth="true" />

                    <MudTextField @bind-Value="CurrentInput.ThumbnailUrl" Label="Thumbnail URL"
                                  Placeholder="https://example.com/avatar.png" Variant="Variant.Outlined" FullWidth="true" />

                    <MudTextField @bind-Value="CurrentInput.StrategyText"
                                  Label="Strategy"
                                  Variant="Variant.Outlined"
                                  Lines="4"
                                  AutoGrow="true"
                                  Required="true"
                                  RequiredError="Strategy is required."
                                  Placeholder="@PlayerProfileService.DefaultStrategyText"
                                  FullWidth="true" />

                    <MudText Typo="Typo.body2" Style="opacity: 0.75">
                        Choose your preferred color:
                    </MudText>

                    <MudChipSet T="string" @bind-SelectedValue="CurrentInput.PreferredColor" 
                        SelectionMode="SelectionMode.SingleSelection"
                        CheckMark>
                        @foreach (var color in PlayerColorOptions.Colors)
                        {
                            <MudChip T="string" Value="@color" Style="@GetColorChipStyle(color)">
                                @PlayerColorOptions.ToLabel(color)
                            </MudChip>
                        }
                    </MudChipSet>

                    <MudStack Row="true" Spacing="4" Style="margin-top: 0.5rem">
                        <MudButton ButtonType="MudBlazor.ButtonType.Submit" Variant="Variant.Filled"
                                   Color="MudBlazor.Color.Primary" Disabled="@_saving">
                            Save Changes
                        </MudButton>
                        @if (!RequiredStrategy)
                        {
                            <MudButton Variant="Variant.Outlined" Color="MudBlazor.Color.Primary"
                                       OnClick="NavigateBack">
                                Back to Dashboard
                            </MudButton>
                        }
                    </MudStack>
                </MudStack>
            </EditForm>
        </MudPaper>
    </MudStack>
}

@code {
    private bool _loading = true;
    private bool _saving;
    private string? message;
    private Severity messageSeverity = Severity.Info;
    private ApplicationUser? _profile;
    private string? currentUserId;
    private string originalNickname = string.Empty;
    private string originalThumbnailUrl = string.Empty;
    private string originalPreferredColor = PlayerColorOptions.Colors[0];
    private string originalStrategyText = string.Empty;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    [SupplyParameterFromQuery(Name = "requiredStrategy")]
    private bool RequiredStrategy { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    private string? ReturnUrl { get; set; }

    private InputModel CurrentInput { get; } = new();

    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationStateTask is not null)
        {
            var authenticationState = await AuthenticationStateTask;
            currentUserId = authenticationState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        }

        await LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        _loading = true;
        message = null;

        if (string.IsNullOrWhiteSpace(currentUserId))
        {
            _profile = null;
            message = "Error: Unable to determine the current user.";
            messageSeverity = Severity.Error;
            _loading = false;
            return;
        }

        _profile = await ProfileService.GetProfileAsync(currentUserId, CancellationToken.None);

        if (_profile == null)
        {
            message = "Error: Unable to load your preferences.";
            messageSeverity = Severity.Error;
            _loading = false;
            return;
        }

        CurrentInput.Nickname = _profile.Nickname;
        CurrentInput.ThumbnailUrl = _profile.ThumbnailUrl;
        CurrentInput.PreferredColor = PlayerColorOptions.NormalizeOrDefault(_profile.PreferredColor);
        CurrentInput.StrategyText = PlayerProfileService.ResolveStrategyTextOrDefault(_profile.StrategyText);
        originalNickname = CurrentInput.Nickname ?? string.Empty;
        originalThumbnailUrl = CurrentInput.ThumbnailUrl ?? string.Empty;
        originalPreferredColor = CurrentInput.PreferredColor ?? PlayerColorOptions.Colors[0];
        originalStrategyText = CurrentInput.StrategyText ?? string.Empty;

        if (RequiredStrategy && !PlayerProfileService.HasRequiredStrategyText(_profile.StrategyText))
        {
            message = "Set your strategy before continuing into the app.";
            messageSeverity = Severity.Warning;
        }

        _loading = false;
    }

    private async Task OnValidSubmitAsync()
    {
        if (_profile == null || string.IsNullOrWhiteSpace(currentUserId))
        {
            message = "Error: Unable to load your preferences.";
            messageSeverity = Severity.Error;
            return;
        }

        _saving = true;

        var nickname = CurrentInput.Nickname?.Trim() ?? string.Empty;
        var thumbnailUrl = CurrentInput.ThumbnailUrl?.Trim() ?? string.Empty;
        var preferredColor = PlayerColorOptions.NormalizeOrDefault(CurrentInput.PreferredColor);
        var strategyText = PlayerProfileService.NormalizeStrategyText(CurrentInput.StrategyText);
        var nicknameChanged = !string.Equals(nickname, originalNickname, StringComparison.Ordinal);
        var thumbnailChanged = !string.Equals(thumbnailUrl, originalThumbnailUrl, StringComparison.Ordinal);
        var preferredColorChanged = !string.Equals(preferredColor, originalPreferredColor, StringComparison.Ordinal);
        var strategyChanged = !string.Equals(strategyText, originalStrategyText, StringComparison.Ordinal);

        try
        {
            if (!PlayerProfileService.HasRequiredStrategyText(strategyText))
            {
                message = "Error: Strategy is required.";
                messageSeverity = Severity.Error;
                return;
            }

            if (!nicknameChanged && !thumbnailChanged && !preferredColorChanged && !strategyChanged)
            {
                message = "No changes to save.";
                messageSeverity = Severity.Info;
                return;
            }

            if (nicknameChanged)
            {
                if (string.IsNullOrWhiteSpace(nickname))
                {
                    message = "Error: Nickname cannot be empty.";
                    messageSeverity = Severity.Error;
                    return;
                }

                var nicknameResult = await ProfileService.UpdateNicknameAsync(currentUserId, nickname, CancellationToken.None);
                switch (nicknameResult)
                {
                    case NicknameResult.Conflict:
                        message = "Error: Nickname already taken. Please choose another.";
                        messageSeverity = Severity.Error;
                        return;
                    case NicknameResult.UpdateFailed:
                    case NicknameResult.UserNotFound:
                        message = "Error: Save failed, please try again.";
                        messageSeverity = Severity.Error;
                        return;
                }

                _profile.Nickname = nickname;
            }

            if (thumbnailChanged)
            {
                var thumbnailUpdated = await ProfileService.UpdateThumbnailUrlAsync(currentUserId, thumbnailUrl,
CancellationToken.None);
                if (!thumbnailUpdated)
                {
                    message = "Error: Save failed, please try again.";
                    messageSeverity = Severity.Error;
                    return;
                }

                _profile.ThumbnailUrl = thumbnailUrl;
            }

            if (preferredColorChanged)
            {
                var preferredColorUpdated = await ProfileService.UpdatePreferredColorAsync(currentUserId, preferredColor,
CancellationToken.None);
                if (!preferredColorUpdated)
                {
                    message = "Error: Save failed, please try again.";
                    messageSeverity = Severity.Error;
                    return;
                }

                _profile.PreferredColor = preferredColor;
            }

            if (strategyChanged)
            {
                var strategyUpdated = await ProfileService.UpdateStrategyTextAsync(currentUserId, strategyText, CancellationToken.None);
                if (!strategyUpdated)
                {
                    message = "Error: Save failed, please try again.";
                    messageSeverity = Severity.Error;
                    return;
                }

                _profile.StrategyText = strategyText;
            }

            originalNickname = nickname;
            originalThumbnailUrl = thumbnailUrl;
            originalPreferredColor = preferredColor;
            originalStrategyText = strategyText;

            if (RequiredStrategy)
            {
                Navigation.NavigateTo(ResolvePostSaveTarget(), replace: true);
                return;
            }

            message = "Your preferences have been updated.";
            messageSeverity = Severity.Success;
        }
        catch
        {
            message = "Error: Save failed, please try again.";
            messageSeverity = Severity.Error;
        }
        finally
        {
            _saving = false;
        }
    }

    private sealed class InputModel
    {
        [Display(Name = "Nickname")]
        public string? Nickname { get; set; }

        [Display(Name = "Thumbnail URL")]
        public string? ThumbnailUrl { get; set; }

        [Required]
        [Display(Name = "Preferred rail color")]
        public string? PreferredColor { get; set; }

        [Required(ErrorMessage = "Strategy is required.")]
        [Display(Name = "Strategy")]
        public string? StrategyText { get; set; }
    }

    private void NavigateBack()
    {
        Navigation.NavigateTo(ResolvePostSaveTarget());
    }

    private string ResolvePostSaveTarget()
    {
        if (!string.IsNullOrWhiteSpace(ReturnUrl) && Uri.IsWellFormedUriString(ReturnUrl, UriKind.Relative))
        {
            return ReturnUrl;
        }

        return "/dashboard";
    }

    private static string GetColorChipStyle(string color)
    {
        var (bg, fg) = PlayerColorOptions.NormalizeOrDefault(color) switch
        {
            "darkblue" => ("#0b3d91", "#f8fbff"),
            "blue" => ("#2563eb", "#f8fbff"),
            "cyan" => ("#06b6d4", "#f8fbff"),
            "red" => ("#dc2626", "#fff7f7"),
            "darkred" => ("#7f1d1d", "#fff7f7"),
            "orange" => ("#ea580c", "#fff7ed"),
            "yellow" => ("#facc15", "#1f2937"),
            "purple" => ("#9333ea", "#faf5ff"),
            "green" => ("#16a34a", "#f7fff9"),
            "darkgreen" => ("#166534", "#f7fff9"),
            _ => ("#4b5563", "#fff")
        };
        return $"background: {bg}; color: {fg}; font-weight: 700; text-shadow: 0 1px 2px rgb(0 0 0 / 0.75), 0 0 10px rgb(0 0 0 / 0.35)";
    }
}