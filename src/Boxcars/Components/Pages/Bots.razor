@page "/bots"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Bot Library - BoxCars</PageTitle>

<MudStack Class="bots-page-shell" Spacing="4">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="bots-page-header">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h3">Bot Library</MudText>
            <MudText Typo="Typo.body1" Class="bots-page-helper">
                Shared bot definitions live here and are immediately available when assigning bots in a game.
            </MudText>
        </MudStack>
        <MudButton Variant="Variant.Outlined"
                   Color="MudBlazor.Color.Primary"
                   OnClick='@(() => Navigation.NavigateTo("/dashboard"))'>
            Back to Dashboard
        </MudButton>
    </MudStack>

    <MudPaper Class="pa-6 bots-page-panel-shell">
        <DashboardBotLibraryPanel CurrentUserId="@(_currentUserId ?? string.Empty)" />
    </MudPaper>
</MudStack>

@code {
    private string? _currentUserId;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is null)
        {
            return;
        }

        var state = await AuthState;
        _currentUserId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    }
}