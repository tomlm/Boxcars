@page "/login"
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@inject NavigationManager Navigation
@inject IAuthenticationSchemeProvider SchemeProvider

<PageTitle>Sign in - BoxCars</PageTitle>

<MudStack Style="max-width: 28rem; margin: 4rem auto" Spacing="6" AlignItems="AlignItems.Stretch">
    <MudText Typo="Typo.h3" Align="Align.Center">Sign in to BoxCars</MudText>
    <MudText Typo="Typo.body2" Align="Align.Center" Style="opacity: 0.75">
        Choose a provider below. Your email is used as your BoxCars identity.
    </MudText>

    <MudPaper Class="pa-6">
        <MudStack Spacing="3">
            @if (_googleEnabled)
            {
                <MudButton Variant="Variant.Filled"
                           Color="MudBlazor.Color.Surface"
                           FullWidth="true"
                           Size="Size.Large"
                           Style="color: rgba(0,0,0,0.87); background: #ffffff; text-transform: none; font-weight: 600; justify-content: flex-start; padding-left: 1rem"
                           Href="@($"/login/Google?returnUrl={ReturnUrlEncoded}")">
                    <span style="display: inline-flex; align-items: center; gap: 0.75rem">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="20" height="20" aria-hidden="true">
                            <path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z" />
                            <path fill="#FF3D00" d="M6.306 14.691l6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z" />
                            <path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238C29.211 35.091 26.715 36 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z" />
                            <path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303c-.792 2.237-2.231 4.166-4.087 5.571l6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z" />
                        </svg>
                        Continue with Google
                    </span>
                </MudButton>
            }
            @if (_microsoftEnabled)
            {
                <MudButton Variant="Variant.Filled"
                           Color="MudBlazor.Color.Surface"
                           FullWidth="true"
                           Size="Size.Large"
                           Style="color: rgba(0,0,0,0.87); background: #ffffff; text-transform: none; font-weight: 600; justify-content: flex-start; padding-left: 1rem"
                           Href="@($"/login/Microsoft?returnUrl={ReturnUrlEncoded}")">
                    <span style="display: inline-flex; align-items: center; gap: 0.75rem">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 23 23" width="20" height="20" aria-hidden="true">
                            <path fill="#f25022" d="M1 1h10v10H1z" />
                            <path fill="#7fba00" d="M12 1h10v10H12z" />
                            <path fill="#00a4ef" d="M1 12h10v10H1z" />
                            <path fill="#ffb900" d="M12 12h10v10H12z" />
                        </svg>
                        Continue with Microsoft
                    </span>
                </MudButton>
            }
            @if (!_googleEnabled && !_microsoftEnabled)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                    No identity providers are configured. Set <code>Auth:Google:ClientId</code> /
                    <code>Auth:Microsoft:ClientId</code> (and matching secrets) in user-secrets or
                    app configuration.
                </MudAlert>
            }
        </MudStack>
    </MudPaper>
</MudStack>

@code {
    private bool _googleEnabled;
    private bool _microsoftEnabled;

    [SupplyParameterFromQuery(Name = "returnUrl")]
    private string? ReturnUrl { get; set; }

    private string ReturnUrlEncoded => Uri.EscapeDataString(
        !string.IsNullOrWhiteSpace(ReturnUrl) && Uri.IsWellFormedUriString(ReturnUrl, UriKind.Relative)
            ? ReturnUrl!
            : "/");

    protected override async Task OnInitializedAsync()
    {
        var schemes = await SchemeProvider.GetAllSchemesAsync();
        _googleEnabled = schemes.Any(s => s.Name == "Google");
        _microsoftEnabled = schemes.Any(s => s.Name == "Microsoft");
    }
}
