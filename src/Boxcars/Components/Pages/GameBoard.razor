    private async Task OnSetDisconnectedSeatControlAsync(DisconnectedSeatControlRequest request)
    {
        if (string.IsNullOrWhiteSpace(GameId) || string.IsNullOrWhiteSpace(_currentUserId))
        {
            return;
        }

        var slotUserId = _playerUserIdsByIndex.GetValueOrDefault(request.PlayerIndex);
        if (string.IsNullOrWhiteSpace(slotUserId))
        {
            return;
        }

        var game = _game;
        var delegatedControllerUserId = GamePresenceService.GetDelegatedControllerUserId(GameId, slotUserId);
        bool changed;

        if (string.Equals(request.ControlMode, DisconnectedSeatControlModes.Manual, StringComparison.OrdinalIgnoreCase))
        {
            changed = GamePresenceService.TryTakeDelegatedControl(GameId, slotUserId, _currentUserId);
            if (changed && game is not null)
            {
                ClearActiveBotControl(slotUserId, "Manual control selected.");
                await PersistPlayerStatesAndRefreshAsync(game, "Unable to update seat control.", notifyNewItems: true);
            }
        }
        else if (string.Equals(request.ControlMode, DisconnectedSeatControlModes.AI, StringComparison.OrdinalIgnoreCase))
        {
            changed = string.IsNullOrWhiteSpace(delegatedControllerUserId)
                || GamePresenceService.ReleaseDelegatedControl(GameId, slotUserId, delegatedControllerUserId);

            if (game is not null)
            {
                ActivateBotControl(slotUserId);
                changed = true;
                await PersistPlayerStatesAndRefreshAsync(game, "Unable to update seat control.", notifyNewItems: true);
            }
        }
        else
        {
            changed = string.IsNullOrWhiteSpace(delegatedControllerUserId)
                || GamePresenceService.ReleaseDelegatedControl(GameId, slotUserId, delegatedControllerUserId);

            if (changed && game is not null)
            {
                ClearActiveBotControl(slotUserId, "Wait for reconnect selected.");
                await PersistPlayerStatesAndRefreshAsync(game, "Unable to update seat control.", notifyNewItems: true);
            }
        }

        if (!changed)
        {
            ShowNotification("Unable to update seat control for that player.", Severity.Warning);
            return;
        }
    }

    private async Task<bool> PersistPlayerStatesAndRefreshAsync(GameEntity game, string saveErrorMessage, bool notifyNewItems)
    {
        var updateResult = await GameService.UpdateSeatStatesAsync(game.GameId, GetCurrentPlayerStates(), CancellationToken.None);
        if (!updateResult.Succeeded || updateResult.Game is null)
        {
            ShowNotification(updateResult.ErrorMessage ?? saveErrorMessage, updateResult.IsConflict ? Severity.Warning : Severity.Error);
            ApplyGameEntity(await GameService.GetGameAsync(GameId, CancellationToken.None));
            await RefreshBotDisplayNamesAsync();
            if (_gameState is not null && _game is not null)
            {
                ApplyGameState(_gameState, queueRestoredRouteSelection: false);
            }

            return false;
        }

        ApplyGameEntity(updateResult.Game);
        await RefreshBotDisplayNamesAsync();
        _gameState = await SharedGameEngine.GetCurrentStateAsync(GameId, CancellationToken.None);
        await RefreshGameEntityAsync();
        await RefreshBotDisplayNamesAsync();
        if (_gameState is not null)
        {
            ApplyGameState(_gameState, queueRestoredRouteSelection: false);
            await RefreshTimelineAsync(notifyNewItems: notifyNewItems);
        }

        return true;
    }

    private bool ShouldShowDisconnectedControlToggle(int playerIndex, string? slotUserId)
    {
        return _gameState is not null
            && !string.IsNullOrWhiteSpace(slotUserId)
            && playerIndex >= 0
            && playerIndex < _gameState.Players.Count
            && _gameState.Players[playerIndex].IsActive
            && !IsBotUser(slotUserId)
            && !IsPlayerConnected(slotUserId)
            && !PlayerControlRules.IsDirectlyBoundToUser(slotUserId, _currentUserId)
            && IsCurrentUserInGameRoster();
    }

    private bool CanCurrentUserSelectManualControl(int playerIndex, string? slotUserId, string? delegatedControllerUserId)
    {
        if (!ShouldShowDisconnectedControlToggle(playerIndex, slotUserId)
            || string.IsNullOrWhiteSpace(_currentUserId))
        {
            return false;
        }

        return string.IsNullOrWhiteSpace(delegatedControllerUserId)
            || PlayerControlRules.IsDelegatedController(delegatedControllerUserId, _currentUserId);
    }

    private bool CanCurrentUserSelectAiControl(int playerIndex, string? slotUserId, string? delegatedControllerUserId)
    {
        if (!ShouldShowDisconnectedControlToggle(playerIndex, slotUserId))
        {
            return false;
        }

        return string.IsNullOrWhiteSpace(delegatedControllerUserId)
            || PlayerControlRules.IsDelegatedController(delegatedControllerUserId, _currentUserId);
    }

    private bool IsCurrentUserInGameRoster()
    {
        return _gameState is not null
            && _currentUserPlayerIndex >= 0
            && _currentUserPlayerIndex < _gameState.Players.Count;
    }

    private static string ResolveDisconnectedControlMode(string? controllerMode)
    {
        if (SeatControllerModes.IsAiControlled(controllerMode))
        {
            return DisconnectedSeatControlModes.AI;
        }

        if (SeatControllerModes.IsDelegated(controllerMode))
        {
            return DisconnectedSeatControlModes.Manual;
        }

        return DisconnectedSeatControlModes.Wait;
    }

    private string ResolveParticipantDisplayName(string? userId, IReadOnlyDictionary<string, string>? playerDisplayNamesByUserId)
    {
        if (string.IsNullOrWhiteSpace(userId))
        {
            return string.Empty;
        }

        if (playerDisplayNamesByUserId is not null
            && playerDisplayNamesByUserId.TryGetValue(userId, out var displayName)
            && !string.IsNullOrWhiteSpace(displayName))
        {
            return displayName;
        }

        if (_playerProfilesByUserId.TryGetValue(userId, out var profile))
        {
            if (!string.IsNullOrWhiteSpace(profile.Nickname))
            {
                return profile.Nickname;
            }

            if (!string.IsNullOrWhiteSpace(profile.Name))
            {
                return profile.Name;
            }
        }

        var matchingPlayer = _players.FirstOrDefault(player =>
            string.Equals(_playerUserIdsByIndex.GetValueOrDefault(player.Index), userId, StringComparison.OrdinalIgnoreCase));
        return matchingPlayer?.Name ?? userId;
    }

