    private async Task EnsureGameHubConnectionAsync()
    {
        if (_gameHubConnection is not null || string.IsNullOrWhiteSpace(_currentUserId) || string.IsNullOrWhiteSpace(GameId))
        {
            return;
        }

        _gameHubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/game"))
            .WithAutomaticReconnect()
            .Build();

        _gameHubConnection.On<GameStateUpdate>(GameHubEvents.StateUpdated, async update =>
        {
            await SharedGameEngine.SynchronizeStateAsync(GameId, update.State, CancellationToken.None);
            OnSharedGameStateChanged(GameId, update);
        });

        _gameHubConnection.On(GameHubEvents.PresenceUpdated, () =>
        {
            OnPresenceChanged(new GamePresenceChange(GameId));
        });

        _gameHubConnection.Reconnected += async _ =>
        {
            await JoinGameHubGroupAsync();
            await LoadGameStateAsync();
            await InvokeAsync(StateHasChanged);
        };

        try
        {
            await _gameHubConnection.StartAsync();
            await JoinGameHubGroupAsync();
        }
        catch
        {
            // Without the game hub connection, same-instance updates still work; cross-instance sync will not.
        }
    }

    private async Task JoinGameHubGroupAsync()
    {
        if (_gameHubConnection is null
            || _gameHubConnection.State is not HubConnectionState.Connected
            || string.IsNullOrWhiteSpace(GameId))
        {
            return;
        }

        await _gameHubConnection.InvokeAsync(GameHubEvents.JoinGame, GameId);
    }

    private void OnSharedGameStateChanged(string gameId, GameStateUpdate update)
    {
        if (!string.Equals(gameId, GameId, StringComparison.Ordinal))
        {
            return;
        }

        var state = update.State;

        var stateChangeVersion = Interlocked.Increment(ref _latestSharedStateChangeVersion);

        _ = InvokeAsync(async () =>
        {
            var priorTurnNumber = _gameState?.TurnNumber ?? -1;
            var priorActivePlayerIndex = _gameState?.ActivePlayerIndex ?? -1;
            var wasAuthenticatedUserActivePlayer = IsAuthenticatedUserActivePlayer;
            _awaitingAuthoritativeUpdate = false;

            if (stateChangeVersion != Volatile.Read(ref _latestSharedStateChangeVersion))
            {
                return;
            }

            ApplyGameState(state);

            if (_autoZoomEnabled
                && _gameMap is not null
                && (priorTurnNumber != state.TurnNumber || priorActivePlayerIndex != state.ActivePlayerIndex)
                && (wasAuthenticatedUserActivePlayer || IsAuthenticatedUserActivePlayer))
            {
                await _gameMap.ResetZoom();
            }

            if (!wasAuthenticatedUserActivePlayer && IsAuthenticatedUserActivePlayer)
            {
                _lastAutoSuggestKey = null;
                SyncRouteSelectionToActivePlayer();
            }

            if (update.ReplaceTimeline)
            {
                ReplaceTimelineItems(update.TimelineItems);
            }
            else
            {
                ApplyLiveTimelineItems(update.TimelineItems);
            }

            if (stateChangeVersion != Volatile.Read(ref _latestSharedStateChangeVersion))
            {
                return;
            }

            StateHasChanged();
        });
    }

    private void OnSharedGameActionFailed(string gameId, GameActionFailure failure)
    {
