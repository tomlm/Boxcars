    private string ResolveActionPlayerColor(RailBaronGameState state)
    {
        if (state.ActivePlayerIndex >= 0
            && state.ActivePlayerIndex < _players.Count)
        {
            return _players[state.ActivePlayerIndex].Color;
        }

        return _currentUserPlayerIndex >= 0 && _currentUserPlayerIndex < _players.Count
            ? _players[_currentUserPlayerIndex].Color
            : PlayerColorOptions.Colors[0];
    }

    private async Task ResolvePurchasePhaseAsync()
    {
        if (_gameState is null
            || CurrentPurchasePhase is null
            || !string.Equals(_turnViewState.TurnPhase, "Purchase", StringComparison.OrdinalIgnoreCase)
            || !IsCurrentUserActivePlayer)
        {
            _lastPurchaseResolutionKey = null;
            return;
        }

        if (CurrentPurchasePhase.HasActivePurchaseControls || _awaitingAuthoritativeUpdate)
        {
            return;
        }

        var purchaseResolutionKey = string.Join(
            ':',
            _gameState.TurnNumber.ToString(CultureInfo.InvariantCulture),
            _gameState.ActivePlayerIndex.ToString(CultureInfo.InvariantCulture),
            CurrentPurchasePhase.CashAfterPayout.ToString(CultureInfo.InvariantCulture),
            CurrentPurchasePhase.NoPurchaseNotification ?? string.Empty);

        if (string.Equals(_lastPurchaseResolutionKey, purchaseResolutionKey, StringComparison.Ordinal))
        {
            return;
        }

        _lastPurchaseResolutionKey = purchaseResolutionKey;

        if (!string.IsNullOrWhiteSpace(CurrentPurchasePhase.NoPurchaseNotification))
        {
            ShowNotification(CurrentPurchasePhase.NoPurchaseNotification, Severity.Warning);
        }

        await DeclinePurchaseCoreAsync(requireConfirmation: false);
    }

    private async Task ResolveDrawDestinationPhaseAsync()
    {
        if (_gameState is null
            || string.IsNullOrWhiteSpace(GameId)
            || _awaitingAuthoritativeUpdate
            || _resolvingDrawDestinationPhase
            || IsGameCompleted
            || !IsCurrentUserActivePlayer
            || !string.Equals(_turnViewState.TurnPhase, TurnPhase.DrawDestination.ToString(), StringComparison.OrdinalIgnoreCase))
        {
            ClearPendingDrawDestinationDecision();
            return;
        }

        if (_gameState.ActivePlayerIndex < 0 || _gameState.ActivePlayerIndex >= _gameState.Players.Count)
        {
            return;
        }

        if (_game is null)
        {
            await RefreshGameEntityAsync();
            if (_game is null)
            {
                return;
            }
        }

        var activePlayer = _gameState.Players[_gameState.ActivePlayerIndex];
        if (!string.IsNullOrWhiteSpace(activePlayer.DestinationCityName) || activePlayer.HasDeclared)
        {
            ClearPendingDrawDestinationDecision();
            return;
        }

        var decisionKey = FormattableString.Invariant(
            $"{_gameState.TurnNumber}:{_gameState.ActivePlayerIndex}:{activePlayer.Cash}:{activePlayer.CurrentCityName}:{activePlayer.HomeCityName}");
        if (!string.Equals(_pendingDrawDestinationDecisionKey, decisionKey, StringComparison.Ordinal))
        {
            _pendingDrawDestinationDecisionKey = decisionKey;
            _pendingDrawDestinationShouldDeclare = null;
        }

        var winningCash = GameSettingsResolver.Resolve(_game).Settings.WinningCash;

        _resolvingDrawDestinationPhase = true;

        try
        {
            if (activePlayer.Cash >= winningCash && !_pendingDrawDestinationShouldDeclare.HasValue)
            {
                var homeDistance = CalculateDistanceToHome(activePlayer);
                var distanceText = homeDistance.HasValue
                    ? homeDistance.Value.ToString(CultureInfo.InvariantCulture)
                    : "an unknown distance";
                var result = await DialogService.ShowMessageBox(
                    "Declare Attempt",
                    $"You are {distanceText} away from {activePlayer.HomeCityName} and you have ${activePlayer.Cash:N0}. Do you want to declare you are going home?",
                    yesText: "Yes",
                    noText: "No");

                _pendingDrawDestinationShouldDeclare = result == true;
            }

            if (_gameState is null
                || _awaitingAuthoritativeUpdate
                || _gameState.ActivePlayerIndex < 0
                || _gameState.ActivePlayerIndex >= _gameState.Players.Count
                || !string.Equals(_turnViewState.TurnPhase, TurnPhase.DrawDestination.ToString(), StringComparison.OrdinalIgnoreCase))
            {
                ClearPendingDrawDestinationDecision();
                return;
            }

            if (IsGameBusy)
            {
                await Task.Delay(75);
                await InvokeAsync(StateHasChanged);
                return;
            }

            var shouldDeclare = _pendingDrawDestinationShouldDeclare == true;
            ClearPendingDrawDestinationDecision();

            MarkAuthoritativeUpdatePending();
            await EnqueueBoardActionAsync(
                shouldDeclare
                    ? new DeclareAction
                    {
                        PlayerId = CurrentTurnPlayerName,
                        ActorUserId = _currentUserId ?? string.Empty,
                        PlayerIndex = _gameState.ActivePlayerIndex
                    }
                    : new PickDestinationAction
                    {
                        PlayerId = CurrentTurnPlayerName,
                        ActorUserId = _currentUserId ?? string.Empty,
                        PlayerIndex = _gameState.ActivePlayerIndex
                    },
                actionAlreadyMarkedPending: true);
        }
        finally
        {
            _resolvingDrawDestinationPhase = false;
        }
    }

    private void ClearPendingDrawDestinationDecision()
    {
        _pendingDrawDestinationDecisionKey = null;
        _pendingDrawDestinationShouldDeclare = null;
    }

    private int? CalculateDistanceToHome(Boxcars.Engine.Persistence.PlayerState activePlayer)
    {
        if (_playerBoardMapDefinition is null || string.IsNullOrWhiteSpace(activePlayer.CurrentNodeId))
        {
            return null;
        }

        var homeCity = _playerBoardMapDefinition.Cities.FirstOrDefault(city =>
            string.Equals(city.Name, activePlayer.HomeCityName, StringComparison.OrdinalIgnoreCase));
        if (homeCity?.MapDotIndex is not int homeDotIndex)
        {
            return null;
        }

        var regionIndex = _playerBoardMapDefinition.Regions
            .FirstOrDefault(region => string.Equals(region.Code, homeCity.RegionCode, StringComparison.OrdinalIgnoreCase))
            ?.Index;
        if (!regionIndex.HasValue)
        {
            return null;
        }

        var homeNodeId = MapRouteService.NodeKey(regionIndex.Value, homeDotIndex);
        if (string.Equals(activePlayer.CurrentNodeId, homeNodeId, StringComparison.OrdinalIgnoreCase))
        {
            return 0;
        }

        var routeContext = RouteService.BuildContext(_playerBoardMapDefinition);
        return routeContext.Adjacency.ContainsKey(homeNodeId)
            ? RouteService.FindShortestSelection(routeContext, activePlayer.CurrentNodeId, homeNodeId)?.Segments.Count
            : null;
    }

    private void NotifyGameCompleted(RailBaronGameState? previousState, RailBaronGameState currentState)
    {
        var wasCompleted = previousState is not null
            && string.Equals(previousState.GameStatus, Boxcars.Engine.Domain.GameStatus.Completed.ToString(), StringComparison.OrdinalIgnoreCase);
        var isCompleted = string.Equals(currentState.GameStatus, Boxcars.Engine.Domain.GameStatus.Completed.ToString(), StringComparison.OrdinalIgnoreCase);
        if (wasCompleted || !isCompleted)
        {
            return;
        }

        var winnerName = currentState.WinnerIndex.HasValue
            && currentState.WinnerIndex.Value >= 0
            && currentState.WinnerIndex.Value < _players.Count
                ? _players[currentState.WinnerIndex.Value].Name
                : "A player";

        ShowNotification(
            $"{winnerName} Won",
            Severity.Success,
            historyKey: $"game-won:{currentState.TurnNumber}:{currentState.WinnerIndex?.ToString(CultureInfo.InvariantCulture) ?? "unknown"}",
            icon: Icons.Material.Filled.EmojiEvents,
            visibleStateDuration: 5000);
    }

    private string BuildCompletedGameStatusMessage()
    {
        if (_gameState is null)
        {
            return "Game over.";
        }

        var winnerName = _gameState.WinnerIndex.HasValue
            && _gameState.WinnerIndex.Value >= 0
            && _gameState.WinnerIndex.Value < _players.Count
                ? _players[_gameState.WinnerIndex.Value].Name
                : "A player";
        return $"{winnerName} won. Gameplay has ended.";
    }

