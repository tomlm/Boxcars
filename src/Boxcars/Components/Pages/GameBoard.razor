@page "/game/{GameId}"
@rendermode InteractiveServer
@using Boxcars.Components.GameBoard
@using Boxcars.Components.Map
@using Boxcars.Data
@using Boxcars.Data.Maps
@using Boxcars.Engine
@using Boxcars.Engine.Data.Maps
@using Boxcars.Engine.Domain
@using Boxcars.GameEngine
@using Boxcars.Services
@using Boxcars.Services.Maps
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Hosting
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@using MudBlazor
@using System.Globalization
@using RailBaronGameEngine = Boxcars.Engine.Domain.GameEngine
@using RailBaronGameState = Boxcars.Engine.Persistence.GameState
@attribute [Authorize]
@implements IAsyncDisposable
@inject NavigationManager Navigation
@inject GameService GameService
@inject GamePresenceService GamePresenceService
@inject GameBoardStateMapper GameBoardStateMapper
@inject NetworkCoverageService NetworkCoverageService
@inject PlayerProfileService ProfileService
@inject IGameEngine SharedGameEngine
@inject ISnackbar Snackbar
@inject IJSRuntime JavaScriptRuntime
@inject IWebHostEnvironment WebHostEnvironment

<PageTitle>Game - BoxCars</PageTitle>

<div class="map-board-shell">
    <div class="map-board-sidebar">
        <PlayerBoard Players="_players"
                 OnToggleTestPlayer="OnToggleTestPlayerAsync"
                 OnToggleConnection="OnTogglePlayerConnectionAsync" />
    </div>

    <div class="map-board-main">
        @if (_gameMap?.Errors.Count > 0)
        {
            <MudStack Class="map-board-message map-board-error">
                <MudText Typo="Typo.h6">Unable to render map</MudText>
                @foreach (var error in _gameMap.Errors)
                {
                    <MudText Typo="Typo.body2">@error</MudText>
                }
            </MudStack>
        }

        @if (ShouldShowPurchaseExperienceTabs)
        {
            <div class="map-board-purchase-tab-strip">
                <MudButton Variant="@(IsMapPurchaseTabActive ? Variant.Filled : Variant.Text)"
                           Color="@(IsMapPurchaseTabActive ? MudBlazor.Color.Primary : MudBlazor.Color.Default)"
                           OnClick="() => OnPurchaseTabSelected(PurchaseExperienceTab.Map)">
                    Map
                </MudButton>
                <MudButton Variant="@(!IsMapPurchaseTabActive ? Variant.Filled : Variant.Text)"
                           Color="@(!IsMapPurchaseTabActive ? MudBlazor.Color.Primary : MudBlazor.Color.Default)"
                           OnClick="() => OnPurchaseTabSelected(PurchaseExperienceTab.Information)">
                    Information
                </MudButton>
            </div>
        }

        <div class="@MapAreaClass" @ref="_mapAreaElement">
            <GameMapComponent @ref="_gameMap" MapFileName="@(_game?.MapFileName ?? GameService.DefaultMapFileName)"
                              SelectionMode="@_selectionMode" PlayerId="@CurrentMapPlayerId" PlayerColor="@CurrentMapPlayerColor"
                              PlayerStates="@_mapPlayerStates" CurrentTurnMovementRemaining="@CurrentTurnMovementRemaining"
                              MovementType="@CurrentMovementType"
                              IsCurrentUserActivePlayer="@IsCurrentUserActivePlayer"
                              PlayerOwnedRailroadIndices="@ActivePlayerOwnedRailroadIndices"
                              OtherOwnedRailroadIndices="@OtherOwnedRailroadIndices"
                              RailroadOwnerColors="@RailroadOwnerColors"
                              SelectableRailroadIndices="@SelectableRailroadIndices"
                              SelectedRailroadIndex="@SelectedRailroadIndex"
                              RailroadSelected="OnRailroadSelectedAsync"
                              AutoZoomEnabled="@_autoZoomEnabled"
                              AutoZoomEnabledChanged="OnAutoZoomEnabledChangedAsync"
                              RouteSuggestionChanged="OnRouteSuggestionChangedAsync"
                              RoutePreviewChanged="OnRoutePreviewChangedAsync" />

            @if (SelectedRailroadOverlay is not null && ShouldShowPurchaseTaskbar && IsMapPurchaseTabActive)
            {
                <div class="map-board-purchase-overlay" style="@SelectedRailroadOverlayStyle">
                    <RailroadPurchaseOverlay Overlay="SelectedRailroadOverlay"
                                             DismissRequested="DismissSelectedRailroadOverlayAsync" />
                </div>
            }
        </div>

        @if (ShouldShowPurchaseExperienceTabs)
        {
            <div class="@AnalysisAreaClass">
                <PurchaseAnalysisReport Report="@CurrentPurchasePhase?.MapAnalysisReport"
                                        RecommendationInputs="@DisplayRecommendationInputs" />
            </div>
        }

        @* ── Status strip: turn state center, zoom right ── *@
        <MudStack Row="true" Wrap="Wrap.NoWrap" AlignItems="AlignItems.Center" Justify="Justify.Center"
                  Class="map-board-status-bar px-3 py-2" Spacing="2">
            <MudStack Row="true" Wrap="Wrap.NoWrap" AlignItems="AlignItems.Center" Justify="Justify.Center" Class="map-board-status-main" Spacing="2">
                <TurnStatusPanel State="@_turnViewState" />

                @if (ShouldShowPurchaseTaskbar)
                {
                    <PurchaseTaskbar TaskbarState="CurrentPurchaseTaskbarState"
                                     SelectedOptionKey="@_selectedPurchaseOptionKey"
                                     SelectedOptionKeyChanged="OnSelectedPurchaseOptionChangedAsync"
                                     BuyRequested="OnBuyPurchaseAsync"
                                     DeclineRequested="DeclinePurchaseAsync"
                                     CurrentCoverage="CurrentPurchasePhase?.CurrentCoverage"
                                     ProjectedCoverage="SelectedProjectedCoverage"
                                     SelectedEngineOption="SelectedEngineOption" />
                }
                else if (!ShouldHidePrimaryAction)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="MudBlazor.Color.Primary"
                               Disabled="@(!CanPrimaryGameAction)"
                               OnClick="OnPrimaryGameActionAsync"
                               Class="map-board-primary-action">
                        @PrimaryGameActionLabel
                    </MudButton>
                }
            </MudStack>
        </MudStack>
    </div>
</div>

@code {
    private string? _currentUserId;
    private ApplicationUser? _currentUserProfile;
    private GameEntity? _game;
    private GameMapComponent? _gameMap;
    private bool _gameStateSubscriptionInitialized;
    private RailBaronGameState? _gameState;
    private MapDefinition? _playerBoardMapDefinition;
    private BoardTurnViewState _turnViewState = new();
    private MapSelectionMode _selectionMode = MapSelectionMode.Route;
    private string _currentPlayerColor = PlayerColorOptions.Colors[0];
    private List<PlayerBoardModel> _players = new();
    private Dictionary<int, string?> _playerUserIdsByIndex = new();
    private List<EventTimelineItem> _gameEngineEvents = new();
    private List<PlayerMapState> _mapPlayerStates = new();
    private int _currentUserPlayerIndex = -1;
    private bool _timelineInitialized;
    private bool _pendingRestoredRouteSelection;
    private string? _lastAutoSuggestKey;
    private string? _selectedPurchaseOptionKey;
    private string? _dismissedRailroadOverlayOptionKey;
    private string? _lastPurchaseResolutionKey;
    private double? _selectedRailroadOverlayClientX;
    private double? _selectedRailroadOverlayClientY;
    private ElementReference _mapAreaElement;
    private PurchaseExperienceTab _selectedPurchaseTab = PurchaseExperienceTab.Map;
    private bool _wasPurchasePhaseActive;
    private int _testControlledPlayerIndex = -1;
    private bool _awaitingAuthoritativeUpdate;
    private bool _autoZoomEnabled;
    private readonly string _pagePresenceRegistrationId = Guid.NewGuid().ToString("N");
    private bool _pagePresenceRegistered;
    private bool _presenceNotificationsEnabled;

    [Parameter]
    public string GameId { get; set; } = string.Empty;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        GamePresenceService.PresenceChanged += OnPresenceChanged;

        if (AuthState is null)
        {
            return;
        }

        var state = await AuthState;
        _currentUserId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (!string.IsNullOrWhiteSpace(_currentUserId))
        {
            _currentUserProfile = await ProfileService.GetProfileAsync(_currentUserId, CancellationToken.None);
        }

        if (string.IsNullOrWhiteSpace(GameId))
        {
            return;
        }

        if (!_gameStateSubscriptionInitialized)
        {
            _gameStateSubscriptionInitialized = true;
            SharedGameEngine.OnStateChanged += OnSharedGameStateChanged;
        }

        _game = await GameService.GetGameAsync(GameId, CancellationToken.None);
        await EnsurePlayerBoardMapDefinitionAsync(CancellationToken.None);
        await LoadGameStateAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (string.IsNullOrWhiteSpace(GameId))
        {
            return;
        }

        if (firstRender)
        {
            RegisterPagePresence();
        }

        TryRestoreRouteSelection();
        await AutoSuggestRouteIfNeededAsync();
        await ResolvePurchasePhaseAsync();
    }

    private async Task EndGameAsync()
    {
        if (string.IsNullOrWhiteSpace(_currentUserId) || string.IsNullOrWhiteSpace(GameId))
        {
            Snackbar.Add("Unable to end game: missing user or game context.", Severity.Error);
            return;
        }

        var result = await GameService.EndGameAsync(_currentUserId, GameId, CancellationToken.None);
        if (!result.Success)
        {
            Snackbar.Add(result.Reason ?? "Unable to end game.", Severity.Error);
            return;
        }

        Navigation.NavigateTo("/dashboard");
    }

    private string PrimaryGameActionLabel => _turnViewState.TurnPhase switch
    {
        "DrawDestination" => "AUTOMATIC",
        "Roll" => "AUTOMATIC",
        "Move" => "MOVE",
        "EndTurn" => "AUTOMATIC",
        _ => "TURN ACTION"
    };

    private bool CanPrimaryGameAction => !string.IsNullOrWhiteSpace(GameId)
        && _gameState is not null
        && !_awaitingAuthoritativeUpdate
        && IsCurrentUserActivePlayer
        && _turnViewState.TurnPhase switch
        {
            "DrawDestination" => false,
            "Roll" => false,
            "Move" => CurrentRouteMoveCount > 0 && CanCommitMoveSelection(),
            "Purchase" => false,
            "EndTurn" => false,
            _ => false
        };

    private string ObserverTurnMessage => string.IsNullOrWhiteSpace(_turnViewState.ActivePlayerName)
        ? "Waiting for the active player to complete their turn."
        : $"Waiting for {_turnViewState.ActivePlayerName} to complete their turn.";

    private async Task OnPrimaryGameActionAsync()
    {
        if (string.IsNullOrWhiteSpace(GameId) || _gameState is null || _gameState.Players.Count == 0)
        {
            return;
        }

        if (!IsCurrentUserActivePlayer)
        {
            return;
        }

        switch (_turnViewState.TurnPhase)
        {
            case "DrawDestination":
            case "Roll":
            case "EndTurn":
                return;

            case "Move":
                await CommitMovePhaseAsync();
                break;

            case "Purchase":
                return;
        }
    }

    private async Task OnSelectedPurchaseOptionChangedAsync(string? optionKey)
    {
        _selectedPurchaseOptionKey = optionKey;

        var selectedRailroad = CurrentPurchasePhase?.RailroadOptions.FirstOrDefault(option =>
            string.Equals(BuildRailroadOptionKey(option.RailroadIndex), optionKey, StringComparison.Ordinal));

        if (selectedRailroad is not null && _gameMap is not null)
        {
            if (!string.Equals(optionKey, _dismissedRailroadOverlayOptionKey, StringComparison.Ordinal))
            {
                _dismissedRailroadOverlayOptionKey = null;
            }

            var selectionEvent = await _gameMap.GetRailroadClientAnchorAsync(selectedRailroad.RailroadIndex);
            if (selectionEvent is not null)
            {
                await PositionPurchaseOverlayAsync(selectionEvent);
            }
            else
            {
                _selectedRailroadOverlayClientX = null;
                _selectedRailroadOverlayClientY = null;
            }
        }
        else
        {
            _selectedRailroadOverlayClientX = null;
            _selectedRailroadOverlayClientY = null;
        }

        await InvokeAsync(StateHasChanged);
    }

    private Task OnPurchaseTabSelected(PurchaseExperienceTab tab)
    {
        _selectedPurchaseTab = tab;
        return InvokeAsync(StateHasChanged);
    }

    private async Task OnRailroadSelectedAsync(RailroadSelectionEvent selectionEvent)
    {
        if (CurrentPurchasePhase is null)
        {
            return;
        }

        var matchingRailroad = CurrentPurchasePhase.RailroadOptions.FirstOrDefault(option => option.RailroadIndex == selectionEvent.RailroadIndex);
        if (matchingRailroad is null)
        {
            return;
        }

        var optionKey = BuildRailroadOptionKey(selectionEvent.RailroadIndex);
        if (!string.Equals(optionKey, _dismissedRailroadOverlayOptionKey, StringComparison.Ordinal))
        {
            _dismissedRailroadOverlayOptionKey = null;
        }

        _selectedPurchaseOptionKey = optionKey;
        await PositionPurchaseOverlayAsync(selectionEvent);
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnBuyPurchaseAsync()
    {
        if (_gameState is null || CurrentPurchasePhase is null || string.IsNullOrWhiteSpace(_selectedPurchaseOptionKey))
        {
            return;
        }

        var selectedRailroad = CurrentPurchasePhase.RailroadOptions.FirstOrDefault(option =>
            string.Equals(BuildRailroadOptionKey(option.RailroadIndex), _selectedPurchaseOptionKey, StringComparison.Ordinal));
        if (selectedRailroad is not null)
        {
            if (!selectedRailroad.IsAffordable)
            {
                return;
            }

            await EnqueuePurchaseActionAsync(new PurchaseRailroadAction
            {
                PlayerId = CurrentTurnPlayerName,
                ActorUserId = _currentUserId ?? string.Empty,
                PlayerIndex = _gameState.ActivePlayerIndex,
                RailroadIndex = selectedRailroad.RailroadIndex,
                AmountPaid = selectedRailroad.PurchasePrice
            });
            return;
        }

        var selectedEngine = CurrentPurchasePhase.EngineOptions.FirstOrDefault(option =>
            string.Equals(BuildEngineOptionKey(option.EngineType), _selectedPurchaseOptionKey, StringComparison.Ordinal));
        if (selectedEngine is not null)
        {
            if (!selectedEngine.IsEligible)
            {
                return;
            }

            await EnqueuePurchaseActionAsync(new BuyEngineAction
            {
                PlayerId = CurrentTurnPlayerName,
                ActorUserId = _currentUserId ?? string.Empty,
                PlayerIndex = _gameState.ActivePlayerIndex,
                EngineType = selectedEngine.EngineType,
                AmountPaid = selectedEngine.PurchasePrice
            });
        }
    }

    private async Task EnqueuePurchaseActionAsync(PlayerAction action)
    {
        MarkAuthoritativeUpdatePending();

        try
        {
            await SharedGameEngine.EnqueueActionAsync(GameId, action, CancellationToken.None);
        }
        catch
        {
            _awaitingAuthoritativeUpdate = false;
            throw;
        }
    }

    private async Task CommitMovePhaseAsync()
    {
        if (_gameState is null || _gameMap is null || !CanCommitMoveSelection())
        {
            return;
        }

        var selectedNodeIds = _gameMap.GetSelectedRouteNodeIds();
        var selectedSegmentKeys = _gameMap.GetSelectedRouteSegmentKeys();
        if (selectedNodeIds.Count < 2 || selectedSegmentKeys.Count == 0)
        {
            return;
        }

        MarkAuthoritativeUpdatePending();

        try
        {
            await SharedGameEngine.EnqueueActionAsync(
                GameId,
                new MoveAction
                {
                    PlayerId = CurrentTurnPlayerName,
                    ActorUserId = _currentUserId ?? string.Empty,
                    PlayerIndex = _gameState.ActivePlayerIndex,
                    PointsTaken = selectedNodeIds,
                    SelectedSegmentKeys = selectedSegmentKeys
                },
                CancellationToken.None);
        }
        catch
        {
            _awaitingAuthoritativeUpdate = false;
            throw;
        }
    }

    private bool CanCommitMoveSelection()
    {
        return _turnViewState.CanEndTurn || SelectionReachesDestination();
    }

    private bool SelectionReachesDestination()
    {
        if (_gameMap is null)
        {
            return false;
        }

        var destinationNodeId = _gameMap.DestinationNodeId;
        var selectedNodeIds = _gameMap.GetSelectedRouteNodeIds();

        return !string.IsNullOrWhiteSpace(destinationNodeId)
            && selectedNodeIds.Count > 0
            && string.Equals(selectedNodeIds[^1], destinationNodeId, StringComparison.OrdinalIgnoreCase);
    }

    private async Task DeclinePurchaseAsync()
    {
        if (_gameState is null)
        {
            return;
        }

        MarkAuthoritativeUpdatePending();

        try
        {
            await SharedGameEngine.EnqueueActionAsync(
                GameId,
                new DeclinePurchaseAction
                {
                    PlayerId = CurrentTurnPlayerName,
                    ActorUserId = _currentUserId ?? string.Empty,
                    PlayerIndex = _gameState.ActivePlayerIndex
                },
                CancellationToken.None);
        }
        catch
        {
            _awaitingAuthoritativeUpdate = false;
            throw;
        }
    }

    private async Task AdvanceToNextPlayerAsync()
    {
        if (_gameState is null)
        {
            return;
        }

        MarkAuthoritativeUpdatePending();

        try
        {
            await SharedGameEngine.EnqueueActionAsync(
                GameId,
                new EndTurnAction
                {
                    PlayerId = CurrentTurnPlayerName,
                    ActorUserId = _currentUserId ?? string.Empty,
                    PlayerIndex = _gameState.ActivePlayerIndex
                },
                CancellationToken.None);
        }
        catch
        {
            _awaitingAuthoritativeUpdate = false;
            throw;
        }
    }

    private Task OnRoutePreviewChangedAsync(TurnMovementPreview preview)
    {
        if (_gameState is null)
        {
            return Task.CompletedTask;
        }

        _turnViewState = GameBoardStateMapper.BuildTurnViewState(
            _game,
            _gameState,
            _currentUserId,
            _playerBoardMapDefinition,
            preview,
            _turnViewState.ArrivalResolution);

        return InvokeAsync(StateHasChanged);
    }

    private async Task OnRouteSuggestionChangedAsync(RouteSuggestionResult suggestion)
    {
        if (ShouldApplyAutoZoom() && _gameMap is not null && suggestion.Status == RouteSuggestionStatus.Success)
        {
            var focusNodeIds = suggestion.NodeIds.Count > 0
                ? suggestion.NodeIds
                : BuildFallbackRouteNodeIds();

            await _gameMap.FocusRouteAsync(focusNodeIds);
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadGameStateAsync()
    {
        _gameState = await SharedGameEngine.GetCurrentStateAsync(GameId, CancellationToken.None);
        ApplyGameState(_gameState);
        SyncRouteSelectionToActivePlayer();
        await RefreshTimelineAsync();
    }

    private void OnSharedGameStateChanged(string gameId, RailBaronGameState state)
    {
        if (!string.Equals(gameId, GameId, StringComparison.Ordinal))
        {
            return;
        }

        _ = InvokeAsync(async () =>
        {
            var priorTurnNumber = _gameState?.TurnNumber ?? -1;
            var priorActivePlayerIndex = _gameState?.ActivePlayerIndex ?? -1;
            var wasAuthenticatedUserActivePlayer = IsAuthenticatedUserActivePlayer;
            _awaitingAuthoritativeUpdate = false;
            ApplyGameState(state);

            if (_autoZoomEnabled
                && _gameMap is not null
                && (priorTurnNumber != state.TurnNumber || priorActivePlayerIndex != state.ActivePlayerIndex)
                && (wasAuthenticatedUserActivePlayer || IsAuthenticatedUserActivePlayer))
            {
                await _gameMap.ResetZoom();
            }

            await RefreshTimelineAsync(notifyNewItems: true);
            TryRestoreRouteSelection();
            await AutoSuggestRouteIfNeededAsync();
            StateHasChanged();
        });
    }

    private void MarkAuthoritativeUpdatePending()
    {
        _awaitingAuthoritativeUpdate = true;
        StateHasChanged();
    }

    private void ApplyGameState(RailBaronGameState state)
    {
        _gameState = state;
        _turnViewState = GameBoardStateMapper.BuildTurnViewState(_game, state, _currentUserId, _playerBoardMapDefinition);
        _selectionMode = ResolveSelectionMode(_turnViewState);
        _currentUserPlayerIndex = _turnViewState.CurrentUserPlayerIndex;
        _mapPlayerStates = GameBoardStateMapper.BuildPlayerMapStates(_game, state, _currentUserId).ToList();

        var playerSelections = GameBoardStateMapper.GetPlayerSelections(_game);
        var suggestedRouteDistances = BuildSuggestedRouteDistances(state);

        var playerUserIdsByDisplayName = playerSelections
            .Where(selection => !string.IsNullOrWhiteSpace(selection.DisplayName) && !string.IsNullOrWhiteSpace(selection.UserId))
            .GroupBy(selection => selection.DisplayName, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(group => group.Key, group => group.First().UserId, StringComparer.OrdinalIgnoreCase);

        _players = state.Players
            .Select((player, index) =>
            {
                var selection = index < playerSelections.Count ? playerSelections[index] : null;
                var resolvedUserId = ResolvePlayerUserId(player, selection, playerUserIdsByDisplayName);
                var canUseTestControl = PlayerControlRules.IsBeatlesSlot(resolvedUserId);

                if (canUseTestControl && !string.IsNullOrWhiteSpace(resolvedUserId))
                {
                    GamePresenceService.EnsureMockConnectionState(GameId, resolvedUserId, defaultConnected: true);
                }

                var isCurrentUser = !string.IsNullOrWhiteSpace(_currentUserId)
                    && !string.IsNullOrWhiteSpace(resolvedUserId)
                    && string.Equals(_currentUserId, resolvedUserId, StringComparison.OrdinalIgnoreCase);

                if (isCurrentUser)
                {
                    _currentUserPlayerIndex = index;
                }

                return new PlayerBoardModel
                {
                    Index = index,
                    Name = selection?.DisplayName ?? player.Name,
                    ThumbnailUrl = ResolveThumbnailUrl(selection?.DisplayName ?? player.Name),
                    Color = ResolvePlayerColor(selection, index),
                    IsAtDestination = string.IsNullOrWhiteSpace(player.DestinationCityName)
                        || string.Equals(player.CurrentCityName, player.DestinationCityName, StringComparison.OrdinalIgnoreCase),
                    TripStartLabel = string.IsNullOrWhiteSpace(player.TripStartCityName)
                        ? player.CurrentCityName
                        : player.TripStartCityName,
                    TripDestinationLabel = string.IsNullOrWhiteSpace(player.DestinationCityName)
                        ? player.CurrentCityName
                        : player.DestinationCityName,
                    DistanceToDestination = suggestedRouteDistances.TryGetValue(index, out var suggestedDistance)
                        ? suggestedDistance
                        : CalculateDistanceToDestination(player),
                    Payoff = CalculateTripPayoff(player),
                    Cash = player.Cash,
                    IsCurrentUser = isCurrentUser,
                    IsTestControlled = index == _testControlledPlayerIndex,
                    CanUseTestControl = canUseTestControl,
                    CanToggleConnection = canUseTestControl,
                    HomeCity = player.HomeCityName,
                    IsActiveTurn = index == state.ActivePlayerIndex,
                    IsConnected = IsPlayerConnected(resolvedUserId),
                    LocomotiveLabel = player.LocomotiveType,
                    FeesOwed = index == state.ActivePlayerIndex ? CalculateFeesOwed(state, index) : 0,
                    CoverageMetrics = BuildPlayerCoverageMetricRows(player)
                };
            })
            .ToList();

        _playerUserIdsByIndex = state.Players
            .Select((player, index) =>
            {
                var selection = index < playerSelections.Count ? playerSelections[index] : null;
                var resolvedUserId = ResolvePlayerUserId(player, selection, playerUserIdsByDisplayName);
                return new KeyValuePair<int, string?>(index, resolvedUserId);
            })
            .ToDictionary(pair => pair.Key, pair => pair.Value);

        _currentPlayerColor = ResolveActionPlayerColor(state);
        SyncPurchaseSelection();
        TrackPurchasePhaseTransition();
        _pendingRestoredRouteSelection = true;
    }

    private void TrackPurchasePhaseTransition()
    {
        var isPurchaseNow = CurrentPurchasePhase is { HasActivePurchaseControls: true };

        if (isPurchaseNow && !_wasPurchasePhaseActive)
        {
            // Entering purchase phase: reset zoom so full board is visible
            _ = ResetZoomForPurchaseAsync();
        }
        else if (!isPurchaseNow && _wasPurchasePhaseActive)
        {
            // Exiting purchase phase: reset zoom and clear selection artifacts
            _selectedPurchaseOptionKey = null;
            _dismissedRailroadOverlayOptionKey = null;
            _selectedRailroadOverlayClientX = null;
            _selectedRailroadOverlayClientY = null;
            _selectedPurchaseTab = PurchaseExperienceTab.Map;
            _ = ResetZoomForPurchaseAsync();
        }

        _wasPurchasePhaseActive = isPurchaseNow;
    }

    private async Task ResetZoomForPurchaseAsync()
    {
        if (_gameMap is not null)
        {
            await _gameMap.ResetZoom();
        }
    }

    private IReadOnlyDictionary<int, int> BuildSuggestedRouteDistances(RailBaronGameState state)
    {
        if (_playerBoardMapDefinition is null)
        {
            return new Dictionary<int, int>();
        }

        try
        {
            var engine = RailBaronGameEngine.FromSnapshot(state, _playerBoardMapDefinition, new DefaultRandomProvider(0));
            var distances = new Dictionary<int, int>(state.Players.Count);

            for (var index = 0; index < state.Players.Count; index++)
            {
                var player = state.Players[index];
                if (string.IsNullOrWhiteSpace(player.DestinationCityName))
                {
                    distances[index] = 0;
                    continue;
                }

                distances[index] = engine.SuggestRouteForPlayer(index).Segments.Count;
            }

            return distances;
        }
        catch
        {
            return new Dictionary<int, int>();
        }
    }

    private async Task EnsurePlayerBoardMapDefinitionAsync(CancellationToken cancellationToken)
    {
        if (_playerBoardMapDefinition is not null)
        {
            return;
        }

        var configuredMapFile = string.IsNullOrWhiteSpace(_game?.MapFileName)
            ? GameService.DefaultMapFileName
            : _game.MapFileName.Trim();
        var mapPath = Path.Combine(WebHostEnvironment.ContentRootPath, configuredMapFile);

        if (!File.Exists(mapPath))
        {
            return;
        }

        await using var stream = File.OpenRead(mapPath);
        var loadResult = await MapDefinition.LoadAsync(Path.GetFileName(mapPath), stream, cancellationToken);
        if (loadResult.Succeeded)
        {
            _playerBoardMapDefinition = loadResult.Definition;
        }
    }

    private static int CalculateDistanceToDestination(Boxcars.Engine.Persistence.PlayerState player)
    {
        if (string.IsNullOrWhiteSpace(player.DestinationCityName))
        {
            return 0;
        }

        if (player.SelectedRouteSegmentKeys.Count > 0)
        {
            return player.SelectedRouteSegmentKeys.Count;
        }

        if (player.ActiveRoute is null)
        {
            return 0;
        }

        var completedSegments = Math.Clamp(player.RouteProgressIndex, 0, player.ActiveRoute.Segments.Count);
        return Math.Max(0, player.ActiveRoute.Segments.Count - completedSegments);
    }

    private static int CalculateFeesOwed(RailBaronGameState state, int playerIndex)
    {
        if (playerIndex < 0 || playerIndex >= state.Players.Count)
        {
            return 0;
        }

        var player = state.Players[playerIndex];
        var grandfatheredRailroads = player.GrandfatheredRailroadIndices.ToHashSet();
        var ownerBuckets = new Dictionary<int, bool>();
        var usesBaseRateRailroad = false;

        foreach (var railroadIndex in state.Turn.RailroadsRiddenThisTurn)
        {
            if (!state.RailroadOwnership.TryGetValue(railroadIndex, out var ownerIndex) || ownerIndex is null)
            {
                usesBaseRateRailroad = true;
                continue;
            }

            if (ownerIndex.Value == playerIndex)
            {
                usesBaseRateRailroad = true;
                continue;
            }

            var requiresFullOwnerRate = !grandfatheredRailroads.Contains(railroadIndex);
            if (!ownerBuckets.TryGetValue(ownerIndex.Value, out var existingRequiresFullOwnerRate))
            {
                ownerBuckets[ownerIndex.Value] = requiresFullOwnerRate;
            }
            else
            {
                ownerBuckets[ownerIndex.Value] = existingRequiresFullOwnerRate || requiresFullOwnerRate;
            }
        }

        var opponentRate = state.AllRailroadsSold ? 10000 : 5000;
        return (usesBaseRateRailroad ? 1000 : 0)
            + ownerBuckets.Values.Sum(requiresFullOwnerRate => requiresFullOwnerRate ? opponentRate : 1000);
    }

    private int CalculateTripPayoff(Boxcars.Engine.Persistence.PlayerState player)
    {
        if (_playerBoardMapDefinition is null || string.IsNullOrWhiteSpace(player.DestinationCityName))
        {
            return 0;
        }

        var tripStartCityName = string.IsNullOrWhiteSpace(player.TripStartCityName)
            ? player.CurrentCityName
            : player.TripStartCityName;
        var originCity = _playerBoardMapDefinition.Cities.FirstOrDefault(city =>
            string.Equals(city.Name, tripStartCityName, StringComparison.OrdinalIgnoreCase));
        var destinationCity = _playerBoardMapDefinition.Cities.FirstOrDefault(city =>
            string.Equals(city.Name, player.DestinationCityName, StringComparison.OrdinalIgnoreCase));

        if (originCity?.PayoutIndex is not int originPayoutIndex || destinationCity?.PayoutIndex is not int
destinationPayoutIndex)
        {
            return 0;
        }

        return _playerBoardMapDefinition.TryGetPayout(originPayoutIndex, destinationPayoutIndex, out var payout)
            ? payout
            : 0;
    }

    private static MapSelectionMode ResolveSelectionMode(BoardTurnViewState turnViewState)
    {
        return string.Equals(turnViewState.TurnPhase, "Purchase", StringComparison.OrdinalIgnoreCase)
            && turnViewState.PurchasePhase is { HasActivePurchaseControls: true, RailroadOptions.Count: > 0 }
            ? MapSelectionMode.Rail
            : MapSelectionMode.Route;
    }

    private async Task RefreshTimelineAsync(bool notifyNewItems = false)
    {
        if (string.IsNullOrWhiteSpace(GameId))
        {
            _gameEngineEvents = [];
            _timelineInitialized = true;
            return;
        }

        var existingEventIds = _gameEngineEvents
            .Select(item => item.EventId)
            .ToHashSet(StringComparer.Ordinal);

        var events = await LoadTimelineEventsAsync(existingEventIds, notifyNewItems && _timelineInitialized);
        _gameEngineEvents = events.ToList();

        if (notifyNewItems && _timelineInitialized)
        {
            NotifyNewTimelineItems(existingEventIds);
        }

        _timelineInitialized = true;
    }

    private async Task<IReadOnlyList<EventTimelineItem>> LoadTimelineEventsAsync(HashSet<string> existingEventIds, bool waitForNewItems)
    {
        IReadOnlyList<EventTimelineItem> latestEvents = [];

        for (var attempt = 0; attempt < 5; attempt++)
        {
            latestEvents = await GameService.GetGameEventsAsync(GameId, CancellationToken.None);

            if (!waitForNewItems || latestEvents.Any(item => !existingEventIds.Contains(item.EventId)))
            {
                return latestEvents;
            }

            await Task.Delay(100);
        }

        return latestEvents;
    }

