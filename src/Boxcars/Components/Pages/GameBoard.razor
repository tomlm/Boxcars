        if (CurrentPurchasePhase?.TaskbarOptions.Count > 0)
        {
            if (!string.IsNullOrWhiteSpace(_selectedPurchaseOptionKey)
                && !CurrentPurchasePhase.TaskbarOptions.Any(option => string.Equals(option.OptionKey, _selectedPurchaseOptionKey, StringComparison.Ordinal)))
            {
                _selectedPurchaseOptionKey = null;
                _dismissedRailroadOverlayOptionKey = null;
                _selectedRailroadOverlayClientX = null;
                _selectedRailroadOverlayClientY = null;
