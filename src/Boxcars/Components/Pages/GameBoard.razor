    private async Task PositionPurchaseOverlayAsync(RailroadSelectionEvent selectionEvent)
    {
        const double overlayGapPixels = 12;
        const double overlayMarginPixels = 16;
        const double overlayMaxWidthPixels = 704;
        const double overlayEstimatedHeightPixels = 480;

        var relativePoint = await JavaScriptRuntime.InvokeAsync<RelativePoint>(
            "mapBoard.getRelativePoint",
            _mapAreaElement,
            selectionEvent.ClientX,
            selectionEvent.ClientY);

        var areaLeft = selectionEvent.ClientX - relativePoint.X;
        var areaTop = selectionEvent.ClientY - relativePoint.Y;
        var areaRight = areaLeft + relativePoint.Width;
        var areaBottom = areaTop + relativePoint.Height;
        var overlayWidth = Math.Min(overlayMaxWidthPixels, Math.Max(320, relativePoint.Width - (overlayMarginPixels * 2)));
        var desiredLeft = selectionEvent.ClientX + overlayGapPixels;
        var desiredTop = selectionEvent.ClientY + overlayGapPixels;
        var rightOverflow = desiredLeft + overlayWidth + overlayMarginPixels - areaRight;

        if (rightOverflow > 0 && _gameMap is not null)
        {
            await _gameMap.ShiftViewportByPixels(rightOverflow, 0);
            desiredLeft -= rightOverflow;
        }

        var maxLeft = Math.Max(areaLeft + overlayMarginPixels, areaRight - overlayWidth - overlayMarginPixels);
        desiredLeft = Math.Clamp(desiredLeft, areaLeft + overlayMarginPixels, maxLeft);

        if (desiredTop + overlayEstimatedHeightPixels + overlayMarginPixels > areaBottom)
        {
            desiredTop = Math.Max(areaTop + overlayMarginPixels, areaBottom - overlayEstimatedHeightPixels - overlayMarginPixels);
        }

        _selectedRailroadOverlayClientX = desiredLeft;
        _selectedRailroadOverlayClientY = Math.Max(areaTop + overlayMarginPixels, desiredTop);
    }

