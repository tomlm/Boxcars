        _selectedPurchaseOptionKey = null;
        _dismissedRailroadOverlayOptionKey = null;
        _selectedRailroadOverlayClientX = null;
        _selectedRailroadOverlayClientY = null;
    }

    private async Task AutoSuggestRouteIfNeededAsync()
    {
        if (_gameMap is null || _gameState is null)
        {
            return;
        }

        if (!string.Equals(_turnViewState.TurnPhase, "Move", StringComparison.OrdinalIgnoreCase))
        {
            _lastAutoSuggestKey = null;
            return;
        }

        var activePlayer = _gameState.Players[_gameState.ActivePlayerIndex];
        if (string.IsNullOrWhiteSpace(activePlayer.DestinationCityName)
            || _gameMap.CanSuggestRoute != true)
        {
            return;
        }

        var autoSuggestKey = string.Join(
            ':',
            _gameState.TurnNumber.ToString(CultureInfo.InvariantCulture),
            _gameState.ActivePlayerIndex.ToString(CultureInfo.InvariantCulture),
            activePlayer.CurrentNodeId ?? string.Empty,
            _gameState.Turn.MovementRemaining.ToString(CultureInfo.InvariantCulture),
            _gameState.Turn.MovementAllowance.ToString(CultureInfo.InvariantCulture),
            activePlayer.DestinationCityName);

        if (string.Equals(_lastAutoSuggestKey, autoSuggestKey, StringComparison.Ordinal))
        {
            return;
        }

        _lastAutoSuggestKey = autoSuggestKey;
        await _gameMap.SuggestRouteAsync();
    }

    private async Task OnAutoZoomEnabledChangedAsync(bool enabled)
    {
        _autoZoomEnabled = enabled;

        if (_gameMap is null)
        {
            return;
        }

        if (!enabled)
        {
            await _gameMap.ResetZoom();
            return;
        }

        if (!ShouldApplyAutoZoom())
        {
            return;
        }

        var routeSuggestion = _gameMap.RouteSuggestion;
        if (routeSuggestion?.Status == RouteSuggestionStatus.Success)
        {
            var focusNodeIds = routeSuggestion.NodeIds.Count > 0
                ? routeSuggestion.NodeIds
                : BuildFallbackRouteNodeIds();

            await _gameMap.FocusRouteAsync(focusNodeIds);
        }
    }

    private bool ShouldApplyAutoZoom()
    {
        return _autoZoomEnabled
            && IsAuthenticatedUserActivePlayer
            && string.Equals(_turnViewState.TurnPhase, "Move", StringComparison.OrdinalIgnoreCase);
    }

    private IReadOnlyList<string> BuildFallbackRouteNodeIds()
    {
        if (_gameMap is null)
        {
            return Array.Empty<string>();
        }

        if (_turnViewState.SelectedRoutePreview.NodeIds.Count > 0)
        {
            return _turnViewState.SelectedRoutePreview.NodeIds;
        }

        var fallbackNodeIds = new List<string>();
        if (!string.IsNullOrWhiteSpace(_gameMap.RouteStartNodeId))
        {
            fallbackNodeIds.Add(_gameMap.RouteStartNodeId);
        }

        if (!string.IsNullOrWhiteSpace(_gameMap.DestinationNodeId)
            && !fallbackNodeIds.Contains(_gameMap.DestinationNodeId, StringComparer.OrdinalIgnoreCase))
        {
            fallbackNodeIds.Add(_gameMap.DestinationNodeId);
        }

        return fallbackNodeIds;
    }

    private bool IsPlayerConnected(string? userId)
    {
        return GamePresenceService.IsUserConnected(GameId, userId);
    }

    private void RefreshPlayerConnectionStates()
    {
        if (_players.Count == 0)
        {
            return;
        }

        var previousConnectionStates = _players
            .ToDictionary(player => player.Index, player => player.IsConnected);

        _players = _players
            .Select(player => new PlayerBoardModel
            {
                Index = player.Index,
                Name = player.Name,
                ThumbnailUrl = player.ThumbnailUrl,
                Color = player.Color,
                IsAtDestination = player.IsAtDestination,
                TripStartLabel = player.TripStartLabel,
                TripDestinationLabel = player.TripDestinationLabel,
                DistanceToDestination = player.DistanceToDestination,
                Payoff = player.Payoff,
                Cash = player.Cash,
                IsCurrentUser = player.IsCurrentUser,
                IsTestControlled = player.IsTestControlled,
                CanUseTestControl = player.CanUseTestControl,
                CanToggleConnection = player.CanToggleConnection,
                HomeCity = player.HomeCity,
                IsActiveTurn = player.IsActiveTurn,
                IsConnected = IsPlayerConnected(_playerUserIdsByIndex.GetValueOrDefault(player.Index)),
                LocomotiveLabel = player.LocomotiveLabel,
                CoverageMetrics = player.CoverageMetrics
            })
            .ToList();

        if (_presenceNotificationsEnabled)
        {
            NotifyPresenceChanges(previousConnectionStates);
        }
    }

    private void RegisterPagePresence()
    {
        if (_pagePresenceRegistered || string.IsNullOrWhiteSpace(GameId) || string.IsNullOrWhiteSpace(_currentUserId))
        {
            return;
        }

        _pagePresenceRegistered = true;
        GamePresenceService.AddConnection(GameId, _currentUserId, _pagePresenceRegistrationId);
        RefreshPlayerConnectionStates();
        _presenceNotificationsEnabled = true;
        StateHasChanged();
    }

    private void UnregisterPagePresence()
    {
        if (!_pagePresenceRegistered || string.IsNullOrWhiteSpace(GameId) || string.IsNullOrWhiteSpace(_currentUserId))
        {
            return;
        }

        _presenceNotificationsEnabled = false;
        _pagePresenceRegistered = false;
        GamePresenceService.RemoveConnection(GameId, _currentUserId, _pagePresenceRegistrationId);
    }

    private void OnPresenceChanged(string gameId)
    {
        if (!string.Equals(gameId, GameId, StringComparison.Ordinal))
        {
            return;
        }

        _ = InvokeAsync(() =>
        {
            RefreshPlayerConnectionStates();
            StateHasChanged();
        });
    }

    private void NotifyPresenceChanges(IReadOnlyDictionary<int, bool> previousConnectionStates)
    {
        foreach (var player in _players)
        {
            if (!previousConnectionStates.TryGetValue(player.Index, out var wasConnected)
                || wasConnected == player.IsConnected)
            {
                continue;
            }

            var message = $"{player.Name} {(player.IsConnected ? "connected" : "disconnected")}.";
            Snackbar.Add(
                message,
                player.IsConnected ? Severity.Success : Severity.Warning,
                options =>
                {
                    var playerColor = PlayerColorOptions.NormalizeOrDefault(player.Color);
                    options.SnackbarTypeClass = $"player-snackbar player-snackbar-{playerColor}";
                });
        }
    }

    private void NotifyNewTimelineItems(HashSet<string> existingEventIds)
    {
        var notifyCandidates = _gameEngineEvents
            .Where(item => !existingEventIds.Contains(item.EventId))
            .ToList();

        var purchaseOpportunitiesByBaseEventId = notifyCandidates
            .Where(item => item.EventKind == EventTimelineKind.PurchaseOpportunity)
            .GroupBy(GetTimelineEventBaseId, StringComparer.Ordinal)
            .ToDictionary(group => group.Key, group => group.First(), StringComparer.Ordinal);

        foreach (var item in notifyCandidates.Where(ShouldNotifyTimelineItem))
        {
            var message = item.Description;
            if (item.EventKind == EventTimelineKind.NewDestination
                && item.ActingPlayerIndex.HasValue
                && item.ActingPlayerIndex.Value >= 0
                && item.ActingPlayerIndex.Value < _players.Count)
            {
                var payoff = _players[item.ActingPlayerIndex.Value].Payoff;
                if (payoff > 0)
                {
                    message = $"{message}, Payoff ${payoff:N0}";
                }
            }
            else if (item.EventKind == EventTimelineKind.Arrival
                && purchaseOpportunitiesByBaseEventId.TryGetValue(GetTimelineEventBaseId(item), out var purchaseOpportunity))
            {
                message = $"{item.Description} {purchaseOpportunity.Description}";
            }

            Snackbar.Add(
                message,
                ResolveTimelineSeverity(item),
                options =>
                {
                    var snackbarClass = ResolveTimelineSnackbarClass(item);
                    if (!string.IsNullOrWhiteSpace(snackbarClass))
                    {
                        options.SnackbarTypeClass = snackbarClass;
                    }
                });
        }
    }

    private static bool ShouldNotifyTimelineItem(EventTimelineItem item)
    {
        return item.EventKind switch
        {
            EventTimelineKind.NewDestination => true,
            EventTimelineKind.Move => true,
            EventTimelineKind.Arrival => true,
            EventTimelineKind.Purchase => true,
            EventTimelineKind.DeclinedPurchase => true,
            _ => false
        };
    }

    private static string GetTimelineEventBaseId(EventTimelineItem item)
    {
        var separatorIndex = item.EventId.LastIndexOf(':');
        return separatorIndex >= 0
            ? item.EventId[..separatorIndex]
            : item.EventId;
    }

    private static Severity ResolveTimelineSeverity(EventTimelineItem item)
    {
        return item.EventKind switch
        {
            EventTimelineKind.Arrival => Severity.Success,
            EventTimelineKind.PurchaseOpportunity => Severity.Warning,
            EventTimelineKind.Purchase => Severity.Warning,
            _ => Severity.Info
        };
    }

    private string? ResolveTimelineSnackbarClass(EventTimelineItem item)
    {
        if (!item.ActingPlayerIndex.HasValue
            || item.ActingPlayerIndex.Value < 0
            || item.ActingPlayerIndex.Value >= _players.Count)
        {
            return null;
        }

        var playerColor = PlayerColorOptions.NormalizeOrDefault(_players[item.ActingPlayerIndex.Value].Color);
        return $"player-snackbar player-snackbar-{playerColor}";
    }

    private Task OnToggleTestPlayerAsync(int playerIndex)
    {
        var selectedPlayer = _players.FirstOrDefault(player => player.Index == playerIndex);
        if (selectedPlayer is null || !selectedPlayer.CanUseTestControl)
        {
            return Task.CompletedTask;
        }

        if (_testControlledPlayerIndex == playerIndex)
        {
            _testControlledPlayerIndex = -1;
            Snackbar.Add($"Stopped local test control for {selectedPlayer.Name}.", Severity.Info);
        }
        else
        {
            _testControlledPlayerIndex = playerIndex;
            Snackbar.Add($"Enabled local test control for {selectedPlayer.Name}.", Severity.Info);
        }

        if (_gameState is not null)
        {
            ApplyGameState(_gameState);
            StateHasChanged();
        }

        return Task.CompletedTask;
    }

    private Task OnTogglePlayerConnectionAsync(int playerIndex)
    {
        var selectedPlayer = _players.FirstOrDefault(player => player.Index == playerIndex);
        if (selectedPlayer is null || !selectedPlayer.CanToggleConnection)
        {
            return Task.CompletedTask;
        }

        var userId = _playerUserIdsByIndex.GetValueOrDefault(playerIndex);
        if (string.IsNullOrWhiteSpace(userId))
        {
            return Task.CompletedTask;
        }

        var nextConnectedState = !selectedPlayer.IsConnected;
        GamePresenceService.SetMockConnectionState(GameId, userId, nextConnectedState);

        return Task.CompletedTask;
    }

    private string ResolveActionPlayerColor(RailBaronGameState state)
    {
        if (state.ActivePlayerIndex >= 0
            && state.ActivePlayerIndex < _players.Count)
        {
            return _players[state.ActivePlayerIndex].Color;
        }

        return _currentUserPlayerIndex >= 0 && _currentUserPlayerIndex < _players.Count
            ? _players[_currentUserPlayerIndex].Color
            : PlayerColorOptions.Colors[0];
    }

    private async Task ResolvePurchasePhaseAsync()
    {
        if (_gameState is null
            || CurrentPurchasePhase is null
            || !string.Equals(_turnViewState.TurnPhase, "Purchase", StringComparison.OrdinalIgnoreCase)
            || !IsCurrentUserActivePlayer)
        {
            _lastPurchaseResolutionKey = null;
            return;
        }

        if (CurrentPurchasePhase.HasActivePurchaseControls || _awaitingAuthoritativeUpdate)
        {
            return;
        }

        var purchaseResolutionKey = string.Join(
            ':',
            _gameState.TurnNumber.ToString(CultureInfo.InvariantCulture),
            _gameState.ActivePlayerIndex.ToString(CultureInfo.InvariantCulture),
            CurrentPurchasePhase.CashAfterPayout.ToString(CultureInfo.InvariantCulture),
            CurrentPurchasePhase.NoPurchaseNotification ?? string.Empty);

        if (string.Equals(_lastPurchaseResolutionKey, purchaseResolutionKey, StringComparison.Ordinal))
        {
            return;
        }

        _lastPurchaseResolutionKey = purchaseResolutionKey;

        if (!string.IsNullOrWhiteSpace(CurrentPurchasePhase.NoPurchaseNotification))
        {
            Snackbar.Add(CurrentPurchasePhase.NoPurchaseNotification, Severity.Warning);
        }

        await DeclinePurchaseAsync();
    }

    private static string BuildRailroadOptionKey(int railroadIndex)
    {
        return $"railroad:{railroadIndex}";
    }

    private static string BuildEngineOptionKey(LocomotiveType locomotiveType)
    {
        return $"engine:{locomotiveType}";
    }

    private static string FormatFee(int fee)
    {
        return string.Format(CultureInfo.InvariantCulture, "${0:N0}", Math.Max(0, fee));
    }

    public async ValueTask DisposeAsync()
    {
        GamePresenceService.PresenceChanged -= OnPresenceChanged;
        UnregisterPagePresence();

        if (_gameStateSubscriptionInitialized)
        {
            SharedGameEngine.OnStateChanged -= OnSharedGameStateChanged;
            _gameStateSubscriptionInitialized = false;
        }

        await Task.CompletedTask;
    }
}