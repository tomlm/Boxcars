@page "/game/{GameId}"
@rendermode InteractiveServer
@using Boxcars.Components.GameBoard
@using Boxcars.Components.Map
@using Boxcars.Data
@using Boxcars.Data.Maps
@using Boxcars.Engine
@using Boxcars.Engine.Data.Maps
@using Boxcars.GameEngine
@using Boxcars.Services
@using Boxcars.Services.Maps
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Hosting
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@using System.Globalization
@using RailBaronGameEngine = Boxcars.Engine.Domain.GameEngine
@using RailBaronGameState = Boxcars.Engine.Persistence.GameState
@attribute [Authorize]
@implements IAsyncDisposable
@inject NavigationManager Navigation
@inject GameService GameService
@inject GamePresenceService GamePresenceService
@inject GameBoardStateMapper GameBoardStateMapper
@inject PlayerProfileService ProfileService
@inject IGameEngine SharedGameEngine
@inject ISnackbar Snackbar
@inject IWebHostEnvironment WebHostEnvironment

<PageTitle>Game - BoxCars</PageTitle>

<div class="map-board-shell">
    <div class="map-board-sidebar">
        <PlayerBoard Players="_players"
                 OnToggleTestPlayer="OnToggleTestPlayerAsync"
                 OnToggleConnection="OnTogglePlayerConnectionAsync" />
    </div>

    <div class="map-board-main">
        @if (_gameMap?.Errors.Count > 0)
        {
            <MudStack Class="map-board-message map-board-error">
                <MudText Typo="Typo.h6">Unable to render map</MudText>
                @foreach (var error in _gameMap.Errors)
                {
                    <MudText Typo="Typo.body2">@error</MudText>
                }
            </MudStack>
        }

        <div class="map-board-map-area">
            <GameMapComponent @ref="_gameMap" MapFileName="@(_game?.MapFileName ?? GameService.DefaultMapFileName)"
                              SelectionMode="@_selectionMode" PlayerId="@CurrentMapPlayerId" PlayerColor="@CurrentMapPlayerColor"
                              PlayerStates="@_mapPlayerStates" CurrentTurnMovementRemaining="@CurrentTurnMovementRemaining"
                              IsCurrentUserActivePlayer="@IsCurrentUserActivePlayer"
                              AutoZoomEnabled="@_autoZoomEnabled"
                              AutoZoomEnabledChanged="OnAutoZoomEnabledChangedAsync"
                              RouteSuggestionChanged="OnRouteSuggestionChangedAsync"
                              RoutePreviewChanged="OnRoutePreviewChangedAsync" />
        </div>

        @* ── Status strip: turn state center, zoom right ── *@
        <MudStack Row="true" Wrap="Wrap.NoWrap" AlignItems="AlignItems.Center" Justify="Justify.Center"
                  Class="map-board-status-bar px-3 py-2" Spacing="2">
            <MudStack Row="true" Wrap="Wrap.NoWrap" AlignItems="AlignItems.Center" Justify="Justify.Center" Class="map-board-status-main" Spacing="2">
                <TurnStatusPanel State="@_turnViewState" />

                <MudButton Variant="Variant.Filled"
                           Color="MudBlazor.Color.Primary"
                           Disabled="@(!CanPrimaryGameAction)"
                           OnClick="OnPrimaryGameActionAsync"
                           Class="map-board-primary-action">
                    @PrimaryGameActionLabel
                </MudButton>
            </MudStack>
        </MudStack>

        <PurchaseOpportunityDialog IsOpen="@_isPurchaseOpportunityDialogOpen"
                                   Arrival="@_turnViewState.ArrivalResolution" OnConfirm="ClosePurchaseOpportunityDialog"
                                   OnCancel="ClosePurchaseOpportunityDialog" />
    </div>
</div>

@code {
    private string? _currentUserId;
    private ApplicationUser? _currentUserProfile;
    private GameEntity? _game;
    private GameMapComponent? _gameMap;
    private bool _gameStateSubscriptionInitialized;
    private RailBaronGameState? _gameState;
    private MapDefinition? _playerBoardMapDefinition;
    private BoardTurnViewState _turnViewState = new();
    private MapSelectionMode _selectionMode = MapSelectionMode.Route;
    private string _currentPlayerColor = PlayerColorOptions.Colors[0];
    private List<PlayerBoardModel> _players = new();
    private Dictionary<int, string?> _playerUserIdsByIndex = new();
    private List<EventTimelineItem> _gameEngineEvents = new();
    private List<PlayerMapState> _mapPlayerStates = new();
    private int _currentUserPlayerIndex = -1;
    private bool _timelineInitialized;
    private bool _pendingRestoredRouteSelection;
    private bool _isPurchaseOpportunityDialogOpen;
    private string? _lastPurchaseOpportunityKey;
    private string? _lastAutoSuggestKey;
    private int _testControlledPlayerIndex = -1;
    private bool _awaitingAuthoritativeUpdate;
    private bool _autoZoomEnabled;
    private readonly string _pagePresenceRegistrationId = Guid.NewGuid().ToString("N");
    private bool _pagePresenceRegistered;
    private bool _presenceNotificationsEnabled;

    [Parameter]
    public string GameId { get; set; } = string.Empty;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        GamePresenceService.PresenceChanged += OnPresenceChanged;

        if (AuthState is null)
        {
            return;
        }

        var state = await AuthState;
        _currentUserId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (!string.IsNullOrWhiteSpace(_currentUserId))
        {
            _currentUserProfile = await ProfileService.GetProfileAsync(_currentUserId, CancellationToken.None);
        }

        if (string.IsNullOrWhiteSpace(GameId))
        {
            return;
        }

        if (!_gameStateSubscriptionInitialized)
        {
            _gameStateSubscriptionInitialized = true;
            SharedGameEngine.OnStateChanged += OnSharedGameStateChanged;
        }

        _game = await GameService.GetGameAsync(GameId, CancellationToken.None);
        await EnsurePlayerBoardMapDefinitionAsync(CancellationToken.None);
        await LoadGameStateAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (string.IsNullOrWhiteSpace(GameId))
        {
            return;
        }

        if (firstRender)
        {
            RegisterPagePresence();
        }

        TryRestoreRouteSelection();
        await AutoSuggestRouteIfNeededAsync();
    }

    private async Task EndGameAsync()
    {
        if (string.IsNullOrWhiteSpace(_currentUserId) || string.IsNullOrWhiteSpace(GameId))
        {
            Snackbar.Add("Unable to end game: missing user or game context.", Severity.Error);
            return;
        }

        var result = await GameService.EndGameAsync(_currentUserId, GameId, CancellationToken.None);
        if (!result.Success)
        {
            Snackbar.Add(result.Reason ?? "Unable to end game.", Severity.Error);
            return;
        }

        Navigation.NavigateTo("/dashboard");
    }

    private string PrimaryGameActionLabel => _turnViewState.TurnPhase switch
    {
        "DrawDestination" => "AUTOMATIC",
        "Roll" => "AUTOMATIC",
        "Move" => "MOVE",
        "Purchase" => "END TURN",
        "EndTurn" => "AUTOMATIC",
        _ => "TURN ACTION"
    };

    private bool CanPrimaryGameAction => !string.IsNullOrWhiteSpace(GameId)
        && _gameState is not null
        && !_awaitingAuthoritativeUpdate
        && IsCurrentUserActivePlayer
        && _turnViewState.TurnPhase switch
        {
            "DrawDestination" => false,
            "Roll" => false,
            "Move" => CurrentRouteMoveCount > 0 && CanCommitMoveSelection(),
            "Purchase" => true,
            "EndTurn" => false,
            _ => false
        };

    private string ObserverTurnMessage => string.IsNullOrWhiteSpace(_turnViewState.ActivePlayerName)
        ? "Waiting for the active player to complete their turn."
        : $"Waiting for {_turnViewState.ActivePlayerName} to complete their turn.";

    private async Task OnPrimaryGameActionAsync()
    {
        if (string.IsNullOrWhiteSpace(GameId) || _gameState is null || _gameState.Players.Count == 0)
        {
            return;
        }

        if (!IsCurrentUserActivePlayer)
        {
            return;
        }

        switch (_turnViewState.TurnPhase)
        {
            case "DrawDestination":
            case "Roll":
            case "EndTurn":
                return;

            case "Move":
                await CommitMovePhaseAsync();
                break;

            case "Purchase":
                await DeclinePurchaseAsync();
                break;
        }
    }

    private async Task CommitMovePhaseAsync()
    {
        if (_gameState is null || _gameMap is null || !CanCommitMoveSelection())
        {
            return;
        }

        var selectedNodeIds = _gameMap.GetSelectedRouteNodeIds();
        var selectedSegmentKeys = _gameMap.GetSelectedRouteSegmentKeys();
        if (selectedNodeIds.Count < 2 || selectedSegmentKeys.Count == 0)
        {
            return;
        }

        MarkAuthoritativeUpdatePending();

        try
        {
            await SharedGameEngine.EnqueueActionAsync(
                GameId,
                new MoveAction
                {
                    PlayerId = CurrentTurnPlayerName,
                    ActorUserId = _currentUserId ?? string.Empty,
                    PlayerIndex = _gameState.ActivePlayerIndex,
                    PointsTaken = selectedNodeIds,
                    SelectedSegmentKeys = selectedSegmentKeys
                },
                CancellationToken.None);
        }
        catch
        {
            _awaitingAuthoritativeUpdate = false;
            throw;
        }
    }

    private bool CanCommitMoveSelection()
    {
        return _turnViewState.CanEndTurn || SelectionReachesDestination();
    }

    private bool SelectionReachesDestination()
    {
        if (_gameMap is null)
        {
            return false;
        }

        var destinationNodeId = _gameMap.DestinationNodeId;
        var selectedNodeIds = _gameMap.GetSelectedRouteNodeIds();

        return !string.IsNullOrWhiteSpace(destinationNodeId)
            && selectedNodeIds.Count > 0
            && string.Equals(selectedNodeIds[^1], destinationNodeId, StringComparison.OrdinalIgnoreCase);
    }

    private async Task DeclinePurchaseAsync()
    {
        if (_gameState is null)
        {
            return;
        }

        MarkAuthoritativeUpdatePending();

        try
        {
            await SharedGameEngine.EnqueueActionAsync(
                GameId,
                new DeclinePurchaseAction
                {
                    PlayerId = CurrentTurnPlayerName,
                    ActorUserId = _currentUserId ?? string.Empty,
                    PlayerIndex = _gameState.ActivePlayerIndex
                },
                CancellationToken.None);
        }
        catch
        {
            _awaitingAuthoritativeUpdate = false;
            throw;
        }
    }

    private async Task AdvanceToNextPlayerAsync()
    {
        if (_gameState is null)
        {
            return;
        }

        MarkAuthoritativeUpdatePending();

        try
        {
            await SharedGameEngine.EnqueueActionAsync(
                GameId,
                new EndTurnAction
                {
                    PlayerId = CurrentTurnPlayerName,
                    ActorUserId = _currentUserId ?? string.Empty,
                    PlayerIndex = _gameState.ActivePlayerIndex
                },
                CancellationToken.None);
        }
        catch
        {
            _awaitingAuthoritativeUpdate = false;
            throw;
        }
    }

    private Task OnRoutePreviewChangedAsync(TurnMovementPreview preview)
    {
        if (_gameState is null)
        {
            return Task.CompletedTask;
        }

        _turnViewState = GameBoardStateMapper.BuildTurnViewState(
            _game,
            _gameState,
            _currentUserId,
            preview,
            _turnViewState.ArrivalResolution);

        return InvokeAsync(StateHasChanged);
    }

    private async Task OnRouteSuggestionChangedAsync(RouteSuggestionResult suggestion)
    {
        if (ShouldApplyAutoZoom() && _gameMap is not null && suggestion.Status == RouteSuggestionStatus.Success)
        {
            var focusNodeIds = suggestion.NodeIds.Count > 0
                ? suggestion.NodeIds
                : BuildFallbackRouteNodeIds();

            await _gameMap.FocusRouteAsync(focusNodeIds);
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadGameStateAsync()
    {
        _gameState = await SharedGameEngine.GetCurrentStateAsync(GameId, CancellationToken.None);
        ApplyGameState(_gameState);
        SyncRouteSelectionToActivePlayer();
        await RefreshTimelineAsync();
    }

    private void OnSharedGameStateChanged(string gameId, RailBaronGameState state)
    {
        if (!string.Equals(gameId, GameId, StringComparison.Ordinal))
        {
            return;
        }

        _ = InvokeAsync(async () =>
        {
            var priorTurnNumber = _gameState?.TurnNumber ?? -1;
            var priorActivePlayerIndex = _gameState?.ActivePlayerIndex ?? -1;
            _awaitingAuthoritativeUpdate = false;
            ApplyGameState(state);

            if (_autoZoomEnabled
                && _gameMap is not null
                && (priorTurnNumber != state.TurnNumber || priorActivePlayerIndex != state.ActivePlayerIndex))
            {
                await _gameMap.ResetZoom();
            }

            await RefreshTimelineAsync(notifyNewItems: true);
            TryRestoreRouteSelection();
            await AutoSuggestRouteIfNeededAsync();
            StateHasChanged();
        });
    }

    private void MarkAuthoritativeUpdatePending()
    {
        _awaitingAuthoritativeUpdate = true;
        StateHasChanged();
    }

    private void ApplyGameState(RailBaronGameState state)
    {
        _gameState = state;
        _turnViewState = GameBoardStateMapper.BuildTurnViewState(_game, state, _currentUserId);
        _selectionMode = ResolveSelectionMode(_turnViewState.TurnPhase);
        _currentUserPlayerIndex = _turnViewState.CurrentUserPlayerIndex;
        _mapPlayerStates = GameBoardStateMapper.BuildPlayerMapStates(_game, state, _currentUserId).ToList();

        var playerSelections = GameBoardStateMapper.GetPlayerSelections(_game);
        var suggestedRouteDistances = BuildSuggestedRouteDistances(state);

        var playerUserIdsByDisplayName = playerSelections
            .Where(selection => !string.IsNullOrWhiteSpace(selection.DisplayName) && !string.IsNullOrWhiteSpace(selection.UserId))
            .GroupBy(selection => selection.DisplayName, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(group => group.Key, group => group.First().UserId, StringComparer.OrdinalIgnoreCase);

        _players = state.Players
            .Select((player, index) =>
            {
                var selection = index < playerSelections.Count ? playerSelections[index] : null;
                var resolvedUserId = ResolvePlayerUserId(player, selection, playerUserIdsByDisplayName);
                var canUseTestControl = PlayerControlRules.IsBeatlesSlot(resolvedUserId);

                if (canUseTestControl && !string.IsNullOrWhiteSpace(resolvedUserId))
                {
                    GamePresenceService.EnsureMockConnectionState(GameId, resolvedUserId, defaultConnected: true);
                }

                var isCurrentUser = !string.IsNullOrWhiteSpace(_currentUserId)
                    && !string.IsNullOrWhiteSpace(resolvedUserId)
                    && string.Equals(_currentUserId, resolvedUserId, StringComparison.OrdinalIgnoreCase);

                if (isCurrentUser)
                {
                    _currentUserPlayerIndex = index;
                }

                return new PlayerBoardModel
                {
                    Index = index,
                    Name = selection?.DisplayName ?? player.Name,
                    ThumbnailUrl = ResolveThumbnailUrl(selection?.DisplayName ?? player.Name),
                    Color = ResolvePlayerColor(selection, index),
                    IsAtDestination = string.IsNullOrWhiteSpace(player.DestinationCityName)
                        || string.Equals(player.CurrentCityName, player.DestinationCityName, StringComparison.OrdinalIgnoreCase),
                    TripStartLabel = string.IsNullOrWhiteSpace(player.TripStartCityName)
                        ? player.CurrentCityName
                        : player.TripStartCityName,
                    TripDestinationLabel = string.IsNullOrWhiteSpace(player.DestinationCityName)
                        ? player.CurrentCityName
                        : player.DestinationCityName,
                    DistanceToDestination = suggestedRouteDistances.TryGetValue(index, out var suggestedDistance)
                        ? suggestedDistance
                        : CalculateDistanceToDestination(player),
                    Payoff = CalculateTripPayoff(player),
                    Cash = player.Cash,
                    IsCurrentUser = isCurrentUser,
                    IsTestControlled = index == _testControlledPlayerIndex,
                    CanUseTestControl = canUseTestControl,
                    CanToggleConnection = canUseTestControl,
                    HomeCity = player.HomeCityName,
                    IsActiveTurn = index == state.ActivePlayerIndex,
                    IsConnected = IsPlayerConnected(resolvedUserId),
                    LocomotiveLabel = player.LocomotiveType
                };
            })
            .ToList();

        _playerUserIdsByIndex = state.Players
            .Select((player, index) =>
            {
                var selection = index < playerSelections.Count ? playerSelections[index] : null;
                var resolvedUserId = ResolvePlayerUserId(player, selection, playerUserIdsByDisplayName);
                return new KeyValuePair<int, string?>(index, resolvedUserId);
            })
            .ToDictionary(pair => pair.Key, pair => pair.Value);

        _currentPlayerColor = ResolveActionPlayerColor(state);
        UpdatePurchaseOpportunityDialogState();
        _pendingRestoredRouteSelection = true;
    }

    private IReadOnlyDictionary<int, int> BuildSuggestedRouteDistances(RailBaronGameState state)
    {
        if (_playerBoardMapDefinition is null)
        {
            return new Dictionary<int, int>();
        }

        try
        {
            var engine = RailBaronGameEngine.FromSnapshot(state, _playerBoardMapDefinition, new DefaultRandomProvider(0));
            var distances = new Dictionary<int, int>(state.Players.Count);

            for (var index = 0; index < state.Players.Count; index++)
            {
                var player = state.Players[index];
                if (string.IsNullOrWhiteSpace(player.DestinationCityName))
                {
                    distances[index] = 0;
                    continue;
                }

                distances[index] = engine.SuggestRouteForPlayer(index).Segments.Count;
            }

            return distances;
        }
        catch
        {
            return new Dictionary<int, int>();
        }
    }

    private async Task EnsurePlayerBoardMapDefinitionAsync(CancellationToken cancellationToken)
    {
        if (_playerBoardMapDefinition is not null)
        {
            return;
        }

        var configuredMapFile = string.IsNullOrWhiteSpace(_game?.MapFileName)
            ? GameService.DefaultMapFileName
            : _game.MapFileName.Trim();
        var mapPath = Path.Combine(WebHostEnvironment.ContentRootPath, configuredMapFile);

        if (!File.Exists(mapPath))
        {
            return;
        }

        await using var stream = File.OpenRead(mapPath);
        var loadResult = await MapDefinition.LoadAsync(Path.GetFileName(mapPath), stream, cancellationToken);
        if (loadResult.Succeeded)
        {
            _playerBoardMapDefinition = loadResult.Definition;
        }
    }

    private static int CalculateDistanceToDestination(Boxcars.Engine.Persistence.PlayerState player)
    {
        if (string.IsNullOrWhiteSpace(player.DestinationCityName))
        {
            return 0;
        }

        if (player.SelectedRouteSegmentKeys.Count > 0)
        {
            return player.SelectedRouteSegmentKeys.Count;
        }

        if (player.ActiveRoute is null)
        {
            return 0;
        }

        var completedSegments = Math.Clamp(player.RouteProgressIndex, 0, player.ActiveRoute.Segments.Count);
        return Math.Max(0, player.ActiveRoute.Segments.Count - completedSegments);
    }

    private int CalculateTripPayoff(Boxcars.Engine.Persistence.PlayerState player)
    {
        if (_playerBoardMapDefinition is null || string.IsNullOrWhiteSpace(player.DestinationCityName))
        {
            return 0;
        }

        var tripStartCityName = string.IsNullOrWhiteSpace(player.TripStartCityName)
            ? player.CurrentCityName
            : player.TripStartCityName;
        var originCity = _playerBoardMapDefinition.Cities.FirstOrDefault(city =>
            string.Equals(city.Name, tripStartCityName, StringComparison.OrdinalIgnoreCase));
        var destinationCity = _playerBoardMapDefinition.Cities.FirstOrDefault(city =>
            string.Equals(city.Name, player.DestinationCityName, StringComparison.OrdinalIgnoreCase));

        if (originCity?.PayoutIndex is not int originPayoutIndex || destinationCity?.PayoutIndex is not int
destinationPayoutIndex)
        {
            return 0;
        }

        return _playerBoardMapDefinition.TryGetPayout(originPayoutIndex, destinationPayoutIndex, out var payout)
            ? payout
            : 0;
    }

    private static MapSelectionMode ResolveSelectionMode(string? turnPhase)
    {
        return string.Equals(turnPhase, "Purchase", StringComparison.OrdinalIgnoreCase)
            ? MapSelectionMode.Rail
            : MapSelectionMode.Route;
    }

    private async Task RefreshTimelineAsync(bool notifyNewItems = false)
    {
        if (string.IsNullOrWhiteSpace(GameId))
        {
            _gameEngineEvents = [];
            _timelineInitialized = true;
            return;
        }

        var existingEventIds = _gameEngineEvents
            .Select(item => item.EventId)
            .ToHashSet(StringComparer.Ordinal);

        var events = await LoadTimelineEventsAsync(existingEventIds, notifyNewItems && _timelineInitialized);
        _gameEngineEvents = events.ToList();

        if (notifyNewItems && _timelineInitialized)
        {
            NotifyNewTimelineItems(existingEventIds);
        }

        _timelineInitialized = true;
    }

    private async Task<IReadOnlyList<EventTimelineItem>> LoadTimelineEventsAsync(HashSet<string> existingEventIds, bool waitForNewItems)
    {
        IReadOnlyList<EventTimelineItem> latestEvents = [];

        for (var attempt = 0; attempt < 5; attempt++)
        {
            latestEvents = await GameService.GetGameEventsAsync(GameId, CancellationToken.None);

            if (!waitForNewItems || latestEvents.Any(item => !existingEventIds.Contains(item.EventId)))
            {
                return latestEvents;
            }

            await Task.Delay(100);
        }

        return latestEvents;
    }

    private string ResolvePlayerColor(GamePlayerSelection? selection, int index)
    {
        return selection is null
            ? PlayerColorOptions.Colors[index % PlayerColorOptions.Colors.Length]
            : PlayerColorOptions.NormalizeOrDefault(selection.Color, PlayerColorOptions.Colors[index %
PlayerColorOptions.Colors.Length]);
    }

    private string ResolvePlayerUserId(
        Boxcars.Engine.Persistence.PlayerState player,
        GamePlayerSelection? selection,
        IReadOnlyDictionary<string, string> playerUserIdsByDisplayName)
    {
        if (!string.IsNullOrWhiteSpace(selection?.UserId))
        {
            return selection.UserId;
        }

        if (playerUserIdsByDisplayName.TryGetValue(player.Name, out var selectedUserId))
        {
            return selectedUserId;
        }

        var matchesCurrentUser = !string.IsNullOrWhiteSpace(_currentUserId)
            && (
                string.Equals(player.Name, _currentUserId, StringComparison.OrdinalIgnoreCase)
                || (!string.IsNullOrWhiteSpace(_currentUserProfile?.Nickname)
                    && string.Equals(player.Name, _currentUserProfile.Nickname, StringComparison.OrdinalIgnoreCase))
                || (!string.IsNullOrWhiteSpace(_currentUserProfile?.Email)
                    && string.Equals(player.Name, _currentUserProfile.Email, StringComparison.OrdinalIgnoreCase))
            );

        return matchesCurrentUser
            ? _currentUserId ?? player.Name
            : player.Name;
    }

    private string ResolveCurrentPlayerColor()
    {
        if (string.IsNullOrWhiteSpace(_currentUserId))
        {
            return PlayerColorOptions.Colors[0];
        }

        var playerSelections = string.IsNullOrWhiteSpace(_game?.PlayersJson)
            ? []
            : GamePlayerSelectionSerialization.Deserialize(_game.PlayersJson);

        var currentSelection = playerSelections.FirstOrDefault(player => string.Equals(player.UserId, _currentUserId,
StringComparison.OrdinalIgnoreCase));
        return currentSelection is null
            ? PlayerColorOptions.Colors[0]
            : PlayerColorOptions.NormalizeOrDefault(currentSelection.Color);
    }

    private string ResolveThumbnailUrl(string playerName)
    {
        if (_currentUserProfile is null || string.IsNullOrWhiteSpace(_currentUserProfile.ThumbnailUrl))
        {
            return string.Empty;
        }

        var matchesCurrentUserId = !string.IsNullOrWhiteSpace(_currentUserId)
            && string.Equals(playerName, _currentUserId, StringComparison.OrdinalIgnoreCase);

        var matchesNickname = !string.IsNullOrWhiteSpace(_currentUserProfile.Nickname)
            && string.Equals(playerName, _currentUserProfile.Nickname, StringComparison.OrdinalIgnoreCase);

        return matchesCurrentUserId || matchesNickname
            ? _currentUserProfile.ThumbnailUrl
            : string.Empty;
    }

    private void SyncRouteSelectionToActivePlayer()
    {
        if (_gameMap is null || _gameState is null || _gameState.Players.Count == 0)
        {
            return;
        }

        var activePlayer = _gameState.Players[_gameState.ActivePlayerIndex];
        var restoredPreviewNodeIds = _turnViewState.SelectedRoutePreview.NodeIds;
        var restoredPreviewSegmentKeys = _turnViewState.SelectedRoutePreview.SegmentKeys;
        var startNodeId = restoredPreviewNodeIds.FirstOrDefault() ?? activePlayer.CurrentNodeId;

        if (!string.IsNullOrWhiteSpace(startNodeId))
        {
            _gameMap.SetStartCity(startNodeId);
        }
        else
        {
            var routeCityOptions = _gameMap.RouteCityOptions;
            var startCity = routeCityOptions.FirstOrDefault(option =>
                string.Equals(option.CityName, activePlayer.CurrentCityName, StringComparison.OrdinalIgnoreCase));

            if (!string.IsNullOrWhiteSpace(startCity.NodeId))
            {
                _gameMap.SetStartCity(startCity.NodeId);
            }
        }

        if (string.IsNullOrWhiteSpace(activePlayer.DestinationCityName))
        {
            _gameMap.RestoreSelectedRoute(restoredPreviewNodeIds, restoredPreviewSegmentKeys);
            _pendingRestoredRouteSelection = false;
            return;
        }

        var destinationRouteCityOptions = _gameMap.RouteCityOptions;

        var destinationCity = destinationRouteCityOptions.FirstOrDefault(option =>
            string.Equals(option.CityName, activePlayer.DestinationCityName, StringComparison.OrdinalIgnoreCase));

        if (!string.IsNullOrWhiteSpace(destinationCity.NodeId))
        {
            _gameMap.SetDestinationCity(destinationCity.NodeId);
        }

        _gameMap.RestoreSelectedRoute(restoredPreviewNodeIds, restoredPreviewSegmentKeys);
        _pendingRestoredRouteSelection = false;
    }

    private void TryRestoreRouteSelection()
    {
        if (!_pendingRestoredRouteSelection)
        {
            return;
        }

        SyncRouteSelectionToActivePlayer();
    }

    private string CurrentTurnPlayerName
    {
        get
        {
            if (_gameState is null || _gameState.Players.Count == 0)
            {
                return "No active player";
            }

            return _gameState.Players[_gameState.ActivePlayerIndex].Name;
        }
    }

    private string CurrentRollTotalLabel
    {
        get
        {
            if (_gameState?.Turn.DiceResult is not { } diceResult)
            {
                return "-";
            }

            var whiteDiceTotal = diceResult.WhiteDice?.Sum() ?? 0;
            var total = whiteDiceTotal + (diceResult.RedDie ?? 0);
            return total.ToString(CultureInfo.InvariantCulture);
        }
    }

    private int CurrentRouteMoveCount => _gameMap?.GetSelectedRouteMoveCount() ??
_turnViewState.SelectedRoutePreview.MoveCount;

    private int CurrentRouteFees => _turnViewState.PreviewFee;

    private int CurrentTurnMovementRemaining => Math.Max(0, _gameState?.Turn.MovementRemaining ?? 0);

    private bool IsCurrentUserActivePlayer => _turnViewState.IsCurrentUserActivePlayer || IsActivePlayerUnderTestControl;

    private bool IsActivePlayerUnderTestControl => _gameState is not null
        && _testControlledPlayerIndex >= 0
        && _testControlledPlayerIndex == _gameState.ActivePlayerIndex;

    private bool HasArrivalPurchaseOpportunity => _turnViewState.ArrivalResolution is
    {
        IsVisible: true,
        PurchaseOpportunityAvailable: true
    };

    private string CurrentUserPlayerColor => _currentUserPlayerIndex >= 0
        ? _players[_currentUserPlayerIndex].Color
        : "var(--accent-fill-rest)";

    private string CurrentMapPlayerId => _mapPlayerStates.FirstOrDefault(playerState => playerState.IsActiveTurn)?.PlayerId
        ?? _currentUserId
        ?? string.Empty;

    private string CurrentMapPlayerColor => _mapPlayerStates.FirstOrDefault(playerState => playerState.IsActiveTurn)?.Color
        ?? _currentPlayerColor;

    private Task ClosePurchaseOpportunityDialog()
    {
        _isPurchaseOpportunityDialogOpen = false;

        return InvokeAsync(StateHasChanged);
    }

    private async Task AutoSuggestRouteIfNeededAsync()
    {
        if (_gameMap is null || _gameState is null)
        {
            return;
        }

        if (!string.Equals(_turnViewState.TurnPhase, "Move", StringComparison.OrdinalIgnoreCase))
        {
            _lastAutoSuggestKey = null;
            return;
        }

        var activePlayer = _gameState.Players[_gameState.ActivePlayerIndex];
        if (string.IsNullOrWhiteSpace(activePlayer.DestinationCityName)
            || _gameMap.CanSuggestRoute != true)
        {
            return;
        }

        var autoSuggestKey = string.Join(
            ':',
            _gameState.TurnNumber.ToString(CultureInfo.InvariantCulture),
            _gameState.ActivePlayerIndex.ToString(CultureInfo.InvariantCulture),
            activePlayer.CurrentNodeId ?? string.Empty,
            activePlayer.DestinationCityName);

        if (string.Equals(_lastAutoSuggestKey, autoSuggestKey, StringComparison.Ordinal))
        {
            return;
        }

        _lastAutoSuggestKey = autoSuggestKey;
        await _gameMap.SuggestRouteAsync();
    }

    private async Task OnAutoZoomEnabledChangedAsync(bool enabled)
    {
        _autoZoomEnabled = enabled;

        if (_gameMap is null)
        {
            return;
        }

        if (!enabled)
        {
            await _gameMap.ResetZoom();
            return;
        }

        if (!ShouldApplyAutoZoom())
        {
            return;
        }

        var routeSuggestion = _gameMap.RouteSuggestion;
        if (routeSuggestion?.Status == RouteSuggestionStatus.Success)
        {
            var focusNodeIds = routeSuggestion.NodeIds.Count > 0
                ? routeSuggestion.NodeIds
                : BuildFallbackRouteNodeIds();

            await _gameMap.FocusRouteAsync(focusNodeIds);
        }
    }

    private bool ShouldApplyAutoZoom()
    {
        return _autoZoomEnabled
            && IsCurrentUserActivePlayer
            && string.Equals(_turnViewState.TurnPhase, "Move", StringComparison.OrdinalIgnoreCase);
    }

    private IReadOnlyList<string> BuildFallbackRouteNodeIds()
    {
        if (_gameMap is null)
        {
            return Array.Empty<string>();
        }

        if (_turnViewState.SelectedRoutePreview.NodeIds.Count > 0)
        {
            return _turnViewState.SelectedRoutePreview.NodeIds;
        }

        var fallbackNodeIds = new List<string>();
        if (!string.IsNullOrWhiteSpace(_gameMap.RouteStartNodeId))
        {
            fallbackNodeIds.Add(_gameMap.RouteStartNodeId);
        }

        if (!string.IsNullOrWhiteSpace(_gameMap.DestinationNodeId)
            && !fallbackNodeIds.Contains(_gameMap.DestinationNodeId, StringComparer.OrdinalIgnoreCase))
        {
            fallbackNodeIds.Add(_gameMap.DestinationNodeId);
        }

        return fallbackNodeIds;
    }

    private bool IsPlayerConnected(string? userId)
    {
        return GamePresenceService.IsUserConnected(GameId, userId);
    }

    private void RefreshPlayerConnectionStates()
    {
        if (_players.Count == 0)
        {
            return;
        }

        var previousConnectionStates = _players
            .ToDictionary(player => player.Index, player => player.IsConnected);

        _players = _players
            .Select(player => new PlayerBoardModel
            {
                Index = player.Index,
                Name = player.Name,
                ThumbnailUrl = player.ThumbnailUrl,
                Color = player.Color,
                IsAtDestination = player.IsAtDestination,
                TripStartLabel = player.TripStartLabel,
                TripDestinationLabel = player.TripDestinationLabel,
                DistanceToDestination = player.DistanceToDestination,
                Payoff = player.Payoff,
                Cash = player.Cash,
                IsCurrentUser = player.IsCurrentUser,
                IsTestControlled = player.IsTestControlled,
                CanUseTestControl = player.CanUseTestControl,
                CanToggleConnection = player.CanToggleConnection,
                HomeCity = player.HomeCity,
                IsActiveTurn = player.IsActiveTurn,
                IsConnected = IsPlayerConnected(_playerUserIdsByIndex.GetValueOrDefault(player.Index)),
                LocomotiveLabel = player.LocomotiveLabel
            })
            .ToList();

        if (_presenceNotificationsEnabled)
        {
            NotifyPresenceChanges(previousConnectionStates);
        }
    }

    private void RegisterPagePresence()
    {
        if (_pagePresenceRegistered || string.IsNullOrWhiteSpace(GameId) || string.IsNullOrWhiteSpace(_currentUserId))
        {
            return;
        }

        _pagePresenceRegistered = true;
        GamePresenceService.AddConnection(GameId, _currentUserId, _pagePresenceRegistrationId);
        RefreshPlayerConnectionStates();
        _presenceNotificationsEnabled = true;
        StateHasChanged();
    }

    private void UnregisterPagePresence()
    {
        if (!_pagePresenceRegistered || string.IsNullOrWhiteSpace(GameId) || string.IsNullOrWhiteSpace(_currentUserId))
        {
            return;
        }

        _presenceNotificationsEnabled = false;
        _pagePresenceRegistered = false;
        GamePresenceService.RemoveConnection(GameId, _currentUserId, _pagePresenceRegistrationId);
    }

    private void OnPresenceChanged(string gameId)
    {
        if (!string.Equals(gameId, GameId, StringComparison.Ordinal))
        {
            return;
        }

        _ = InvokeAsync(() =>
        {
            RefreshPlayerConnectionStates();
            StateHasChanged();
        });
    }

    private void NotifyPresenceChanges(IReadOnlyDictionary<int, bool> previousConnectionStates)
    {
        foreach (var player in _players)
        {
            if (!previousConnectionStates.TryGetValue(player.Index, out var wasConnected)
                || wasConnected == player.IsConnected)
            {
                continue;
            }

            var message = $"{player.Name} {(player.IsConnected ? "connected" : "disconnected")}.";
            Snackbar.Add(
                message,
                player.IsConnected ? Severity.Success : Severity.Warning,
                options =>
                {
                    var playerColor = PlayerColorOptions.NormalizeOrDefault(player.Color);
                    options.SnackbarTypeClass = $"player-snackbar player-snackbar-{playerColor}";
                });
        }
    }

    private void NotifyNewTimelineItems(HashSet<string> existingEventIds)
    {
        var notifyCandidates = _gameEngineEvents
            .Where(item => !existingEventIds.Contains(item.EventId))
            .ToList();

        var purchaseOpportunitiesByBaseEventId = notifyCandidates
            .Where(item => item.EventKind == EventTimelineKind.PurchaseOpportunity)
            .GroupBy(GetTimelineEventBaseId, StringComparer.Ordinal)
            .ToDictionary(group => group.Key, group => group.First(), StringComparer.Ordinal);

        foreach (var item in notifyCandidates.Where(ShouldNotifyTimelineItem))
        {
            var message = item.Description;
            if (item.EventKind == EventTimelineKind.NewDestination
                && item.ActingPlayerIndex.HasValue
                && item.ActingPlayerIndex.Value >= 0
                && item.ActingPlayerIndex.Value < _players.Count)
            {
                var payoff = _players[item.ActingPlayerIndex.Value].Payoff;
                if (payoff > 0)
                {
                    message = $"{message}, Payoff ${payoff:N0}";
                }
            }
            else if (item.EventKind == EventTimelineKind.Arrival
                && purchaseOpportunitiesByBaseEventId.TryGetValue(GetTimelineEventBaseId(item), out var purchaseOpportunity))
            {
                message = $"{item.Description} {purchaseOpportunity.Description}";
            }

            Snackbar.Add(
                message,
                ResolveTimelineSeverity(item),
                options =>
                {
                    var snackbarClass = ResolveTimelineSnackbarClass(item);
                    if (!string.IsNullOrWhiteSpace(snackbarClass))
                    {
                        options.SnackbarTypeClass = snackbarClass;
                    }
                });
        }
    }

    private static bool ShouldNotifyTimelineItem(EventTimelineItem item)
    {
        return item.EventKind switch
        {
            EventTimelineKind.NewDestination => true,
            EventTimelineKind.Move => true,
            EventTimelineKind.Arrival => true,
            EventTimelineKind.Purchase => true,
            EventTimelineKind.DeclinedPurchase => true,
            _ => false
        };
    }

    private static string GetTimelineEventBaseId(EventTimelineItem item)
    {
        var separatorIndex = item.EventId.LastIndexOf(':');
        return separatorIndex >= 0
            ? item.EventId[..separatorIndex]
            : item.EventId;
    }

    private static Severity ResolveTimelineSeverity(EventTimelineItem item)
    {
        return item.EventKind switch
        {
            EventTimelineKind.Arrival => Severity.Success,
            EventTimelineKind.PurchaseOpportunity => Severity.Warning,
            EventTimelineKind.Purchase => Severity.Warning,
            _ => Severity.Info
        };
    }

    private string? ResolveTimelineSnackbarClass(EventTimelineItem item)
    {
        if (!item.ActingPlayerIndex.HasValue
            || item.ActingPlayerIndex.Value < 0
            || item.ActingPlayerIndex.Value >= _players.Count)
        {
            return null;
        }

        var playerColor = PlayerColorOptions.NormalizeOrDefault(_players[item.ActingPlayerIndex.Value].Color);
        return $"player-snackbar player-snackbar-{playerColor}";
    }

    private Task OnToggleTestPlayerAsync(int playerIndex)
    {
        var selectedPlayer = _players.FirstOrDefault(player => player.Index == playerIndex);
        if (selectedPlayer is null || !selectedPlayer.CanUseTestControl)
        {
            return Task.CompletedTask;
        }

        if (_testControlledPlayerIndex == playerIndex)
        {
            _testControlledPlayerIndex = -1;
            Snackbar.Add($"Stopped local test control for {selectedPlayer.Name}.", Severity.Info);
        }
        else
        {
            _testControlledPlayerIndex = playerIndex;
            Snackbar.Add($"Enabled local test control for {selectedPlayer.Name}.", Severity.Info);
        }

        if (_gameState is not null)
        {
            ApplyGameState(_gameState);
            StateHasChanged();
        }

        return Task.CompletedTask;
    }

    private Task OnTogglePlayerConnectionAsync(int playerIndex)
    {
        var selectedPlayer = _players.FirstOrDefault(player => player.Index == playerIndex);
        if (selectedPlayer is null || !selectedPlayer.CanToggleConnection)
        {
            return Task.CompletedTask;
        }

        var userId = _playerUserIdsByIndex.GetValueOrDefault(playerIndex);
        if (string.IsNullOrWhiteSpace(userId))
        {
            return Task.CompletedTask;
        }

        var nextConnectedState = !selectedPlayer.IsConnected;
        GamePresenceService.SetMockConnectionState(GameId, userId, nextConnectedState);

        return Task.CompletedTask;
    }

    private string ResolveActionPlayerColor(RailBaronGameState state)
    {
        if (state.ActivePlayerIndex >= 0
            && state.ActivePlayerIndex < _players.Count)
        {
            return _players[state.ActivePlayerIndex].Color;
        }

        return _currentUserPlayerIndex >= 0 && _currentUserPlayerIndex < _players.Count
            ? _players[_currentUserPlayerIndex].Color
            : PlayerColorOptions.Colors[0];
    }

    private void UpdatePurchaseOpportunityDialogState()
    {
        if (!HasArrivalPurchaseOpportunity || !IsCurrentUserActivePlayer || _gameState is null)
        {
            _isPurchaseOpportunityDialogOpen = false;
            return;
        }

        var arrival = _turnViewState.ArrivalResolution!;
        var purchaseOpportunityKey = string.Join(
            ':',
            _gameState.TurnNumber.ToString(CultureInfo.InvariantCulture),
            _gameState.ActivePlayerIndex.ToString(CultureInfo.InvariantCulture),
            arrival.DestinationCityName,
            arrival.PayoutAmount.ToString(CultureInfo.InvariantCulture),
            arrival.CashAfterPayout.ToString(CultureInfo.InvariantCulture));

        if (!string.Equals(_lastPurchaseOpportunityKey, purchaseOpportunityKey, StringComparison.Ordinal))
        {
            _lastPurchaseOpportunityKey = purchaseOpportunityKey;
            _isPurchaseOpportunityDialogOpen = true;
        }
    }

    private static string FormatFee(int fee)
    {
        return string.Format(CultureInfo.InvariantCulture, "${0:N0}", Math.Max(0, fee));
    }

    public async ValueTask DisposeAsync()
    {
        GamePresenceService.PresenceChanged -= OnPresenceChanged;
        UnregisterPagePresence();

        if (_gameStateSubscriptionInitialized)
        {
            SharedGameEngine.OnStateChanged -= OnSharedGameStateChanged;
            _gameStateSubscriptionInitialized = false;
        }

        await Task.CompletedTask;
    }
}