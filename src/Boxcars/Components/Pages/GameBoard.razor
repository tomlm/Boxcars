@page "/game/{GameId}"
@rendermode InteractiveServer
@using Boxcars.Components.GameBoard
@using Boxcars.Components.Map
@using Boxcars.Data
@using Boxcars.Data.Maps
@using Boxcars.Engine
@using Boxcars.Engine.Data.Maps
@using Boxcars.Engine.Domain
@using Boxcars.GameEngine
@using Boxcars.Hubs
@using Boxcars.Services
@using Boxcars.Services.Maps
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Hosting
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.JSInterop
@using MudBlazor
@using System.Globalization
@using RailBaronGameEngine = Boxcars.Engine.Domain.GameEngine
@using RailBaronGameState = Boxcars.Engine.Persistence.GameState
@attribute [Authorize]
@implements IAsyncDisposable
@inject NavigationManager Navigation
@inject GameService GameService
@inject GamePresenceService GamePresenceService
@inject GameCircuitPresenceTracker GameCircuitPresenceTracker
@inject GameBoardStateMapper GameBoardStateMapper
@inject UserDirectoryService UserDirectoryService
@inject BotTurnService BotTurnService
@inject NetworkCoverageService NetworkCoverageService
@inject MapAnalysisService MapAnalysisService
@inject PlayerProfileService ProfileService
@inject IGameEngine SharedGameEngine
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JavaScriptRuntime
@inject IWebHostEnvironment WebHostEnvironment
@inject GameBoardAdviceService GameBoardAdviceService
@inject GameSettingsResolver GameSettingsResolver
@inject MapRouteService RouteService

<PageTitle>Game - BoxCars</PageTitle>

<MudStack Row="true" Class="overflow-hidden" Style="height: calc(100dvh - 64px); width: 100%">
    <MudPaper Class="flex-shrink-0 overflow-y-auto" Style="width: 270px; background: #000; border-right: 1px solid #ccc; padding: 0.5rem 0.4rem 0.75rem; box-sizing: border-box">
        <MudStack Spacing="2">
            <PlayerBoard Players="_players"
                     OnSetDisconnectedSeatControl="OnSetDisconnectedSeatControlAsync"
                     OnFocusPlayer="OnFocusPlayerAsync"
                     />
        </MudStack>
    </MudPaper>

    <MudStack Class="flex-grow-1 overflow-hidden" Style="min-height: 0; min-width: 0">
        @if (_gameMap?.Errors.Count > 0)
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true" Style="border-radius: 0">
                <MudText Typo="Typo.subtitle2" Style="font-weight: 700">Unable to render map</MudText>
                @foreach (var error in _gameMap.Errors)
                {
                    <MudText Typo="Typo.body2">@error</MudText>
                }
            </MudAlert>
        }

        @if (ShouldShowPurchaseExperienceTabs)
        {
            <MudToggleGroup T="PurchaseExperienceTab" Value="_selectedPurchaseTab" ValueChanged="OnPurchaseTabSelected"
                           Color="MudBlazor.Color.Primary" Size="Size.Small"
                           Class="flex-shrink-0 pa-3 pb-0">
                <MudToggleItem T="PurchaseExperienceTab" Value="PurchaseExperienceTab.Map" Text="Map" />
                <MudToggleItem T="PurchaseExperienceTab" Value="PurchaseExperienceTab.Regions" Text="Regions" />
                <MudToggleItem T="PurchaseExperienceTab" Value="PurchaseExperienceTab.Cities" Text="Cities" />
                <MudToggleItem T="PurchaseExperienceTab" Value="PurchaseExperienceTab.Railroads" Text="Railroads" />
                <MudToggleItem T="PurchaseExperienceTab" Value="PurchaseExperienceTab.Network" Text="Network" />
                <MudToggleItem T="PurchaseExperienceTab" Value="PurchaseExperienceTab.Stats" Text="Stats" />
                <MudToggleItem T="PurchaseExperienceTab" Value="PurchaseExperienceTab.History" Text="History" />
                <MudToggleItem T="PurchaseExperienceTab" Value="PurchaseExperienceTab.Advice" Text="Advice" />
                <MudToggleItem T="PurchaseExperienceTab" Value="PurchaseExperienceTab.Settings" Text="Settings" />
            </MudToggleGroup>
        }

        <div style="@MapAreaStyle" @ref="_mapAreaElement">
            <GameMapComponent @ref="_gameMap" MapFileName="@(_game?.MapFileName ?? GameService.DefaultMapFileName)"
                              SelectionMode="@_selectionMode" PlayerId="@CurrentMapPlayerId" PlayerColor="@CurrentMapPlayerColor"
                              PlayerStates="@_mapPlayerStates" CurrentTurnMovementRemaining="@CurrentTurnMovementRemaining"
                              CurrentTurnMovementAllowance="@CurrentTurnMovementAllowance"
                              MovementType="@CurrentMovementType"
                              IsCurrentUserActivePlayer="@IsCurrentUserActivePlayer"
                              PlayerOwnedRailroadIndices="@ActivePlayerOwnedRailroadIndices"
                              OtherOwnedRailroadIndices="@OtherOwnedRailroadIndices"
                              RailroadOwnerColors="@RailroadOwnerColors"
                              SelectableRailroadIndices="@SelectableRailroadIndices"
                              SelectedRailroadIndex="@SelectedRailroadIndex"
                              RailroadSelected="OnRailroadSelectedAsync"
                              AutoZoomEnabled="@_autoZoomEnabled"
                              AutoZoomEnabledChanged="OnAutoZoomEnabledChangedAsync"
                              MapReady="OnGameMapReadyAsync"
                              RouteSuggestionChanged="OnRouteSuggestionChangedAsync"
                              RoutePreviewChanged="OnRoutePreviewChangedAsync" />

            @if (SelectedRailroadOverlay is not null && IsMapPurchaseTabActive && _selectionMode == MapSelectionMode.Rail)
            {
                <div style="position: fixed; z-index: 30; max-width: min(36rem, calc(100vw - 2rem)); pointer-events: auto; @SelectedRailroadOverlayStyle">
                    <RailroadPurchaseOverlay Overlay="SelectedRailroadOverlay"
                                             DismissRequested="DismissSelectedRailroadOverlayAsync" />
                </div>
            }
        </div>

        @if (ShouldShowPurchaseExperienceTabs)
        {
            <MudStack Class="@AnalysisAreaClass" Style="@AnalysisAreaStyle">
                @if (IsNetworkPurchaseTabActive)
                {
                    <MudStack Spacing="2">
                        <NetworkTabPanel NetworkTab="CurrentDisplayNetworkTab" />
                        @if (CurrentForcedSaleImpact is not null)
                        {
                            <SaleImpactPanel Overlay="CurrentForcedSaleImpact"
                                             BankSalePrice="@(SelectedForcedSaleCandidate?.BankSalePrice ?? 0)"
                                             FeeShortfall="@(CurrentForcedSalePhase?.FeeShortfall ?? 0)" />
                        }
                    </MudStack>
                }
                else if (IsStatsPurchaseTabActive)
                {
                    <PlayerStatsTable Players="_players" PlayerStates="@(_gameState?.Players ?? [])" />
                }
                else if (IsHistoryPurchaseTabActive)
                {
                    <MudPaper Outlined="true" Class="d-flex flex-column pa-3" Style="min-height: 100%; background: color-mix(in srgb, var(--mud-palette-surface) 90%, black 10%)">
                        <MudStack Spacing="0" Class="mb-3">
                            <MudText Typo="Typo.h6">History</MudText>
                            <MudText Typo="Typo.caption">@NotificationHistorySummary</MudText>
                        </MudStack>

                        @if (_notificationHistory.Count == 0)
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">No notifications yet.</MudAlert>
                        }
                        else
                        {
                            <MudList T="NotificationHistoryEntry" Dense="true" Class="pa-0">
                                @foreach (var item in NotificationHistoryItems)
                                {
                                    <MudListItem T="NotificationHistoryEntry" Class="mb-2" Style="@ResolveNotificationHistoryItemStyle(item)">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mud-width-full">
                                            <MudIcon Icon="@item.Icon"
                                                     Color="@ResolveNotificationHistoryIconColor(item)"
                                                     Size="Size.Medium"
                                                     Class="mt-0 flex-shrink-0" />
                                            <MudStack Spacing="0" Class="overflow-hidden flex-grow-1" Style="min-width: 0">
                                                <MudText Typo="Typo.body2">@item.Message</MudText>
                                            </MudStack>
                                            @if (item.CanUndo)
                                            {
                                                <MudButton Size="Size.Small"
                                                           Variant="Variant.Outlined"
                                                           Color="MudBlazor.Color.Warning"
                                                           Disabled="_awaitingAuthoritativeUpdate"
                                                           OnClick="@(() => OnUndoToHistoryItemAsync(item))">
                                                    Undo to here
                                                </MudButton>
                                            }
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudPaper>
                }
                else if (IsAdvicePurchaseTabActive)
                {
                    <AdvisorSidebar EntryPoint="_advisorEntryPoint"
                                    Conversation="_advisorConversation"
                                    DraftMessage="@_advisorDraftMessage"
                                    ComposerResetVersion="_advisorComposerResetVersion"
                                    DraftMessageChanged="OnAdvisorDraftMessageChanged"
                                    SendRequested="OnAdvisorSendRequestedAsync"
                                    RetryRequested="OnAdvisorRetryRequestedAsync" />
                }
                else if (IsSettingsPurchaseTabActive)
                {
                    <GameSettingsPanel Summary="_gameSettingsSummary" />
                }
                else if (ShouldShowPurchaseAnalysisPanel)
                {
                    <PurchaseAnalysisReport Report="@CurrentMapAnalysisReport"
                                            RecommendationInputs="@DisplayRecommendationInputs"
                                            View="@_selectedPurchaseTab" />
                }
               
            </MudStack>
        }

        @* ── Status strip: turn state center, zoom right ── *@
        <MudStack Row="true" Class="flex-shrink-0 align-center" Style="@StatusBarAnchorStyle">
            <MudStack Row="true" Class="flex-grow-1 align-center justify-center" Style="font-size: 0.85rem; min-height: 3.75rem; padding: 0.55rem 1rem">
                <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center" Style="gap: 1rem; max-width: 100%; margin: 0 auto">
                        @if (ShouldShowStatusControls)
                        {
                            @if (!ShouldShowHomeCityChoicePanel && !ShouldShowHomeSwapPanel && !ShouldShowRegionChoicePanel && !ShouldShowPurchaseTaskbar && !ShouldShowAuctionPanel && !ShouldShowForcedSalePanel && !ShouldShowCommitMoveAction)
                            { 
                                <MovementStatusPanel State="@_turnViewState" />
                            }

                            @if (ShouldShowHomeCityChoicePanel)
                            {
                                <HomeCityChoicePanel Phase="CurrentHomeCityChoicePhase!"
                                                     SelectedCityName="@_selectedHomeCityName"
                                                     SelectedCityNameChanged="OnSelectedHomeCityChangedAsync"
                                                     IsBusy="@_awaitingAuthoritativeUpdate"
                                                     ConfirmRequested="OnConfirmHomeCityChoiceAsync" />
                            }
                            else if (ShouldShowHomeSwapPanel)
                            {
                                <HomeSwapPanel Phase="CurrentHomeSwapPhase!"
                                               IsBusy="@_awaitingAuthoritativeUpdate"
                                               KeepRequested="OnKeepHomeSwapAsync"
                                               SwapRequested="OnConfirmHomeSwapAsync" />
                            }
                            else if (ShouldShowRegionChoicePanel)
                            {
                                <RegionChoicePanel Phase="CurrentRegionChoicePhase!"
                                                   SelectedRegionCode="@_selectedRegionChoiceCode"
                                                   SelectedRegionCodeChanged="OnSelectedRegionChoiceChangedAsync"
                                                   IsBusy="@_awaitingAuthoritativeUpdate"
                                                   ConfirmRequested="OnConfirmRegionChoiceAsync" />
                            }
                            else if (ShouldShowPurchaseTaskbar)
                            {
                                <PurchaseTaskbar TaskbarState="CurrentPurchaseTaskbarState"
                                                 SelectedOptionKey="@_selectedPurchaseOptionKey"
                                                 SelectedOptionKeyChanged="OnSelectedPurchaseOptionChangedAsync"
                                                                                                 IsBusy="@_awaitingAuthoritativeUpdate"
                                                 BuyRequested="OnBuyPurchaseAsync"
                                                 DeclineRequested="DeclinePurchaseAsync"
                                                 DelegatedControlLabel="@CurrentDelegatedControlLabel"
                                                 CurrentCoverage="CurrentPurchasePhase?.CurrentCoverage"
                                                 ProjectedCoverage="SelectedProjectedCoverage"
                                                 SelectedEngineOption="SelectedEngineOption" />
                            }
                            else if (ShouldShowAuctionPanel)
                            {
                                <RailroadAuctionPanel AuctionState="CurrentAuctionPanelState"
                                                     CanCurrentUserAct="CanCurrentUserActInAuction"
                                                     IsBusy="@_awaitingAuthoritativeUpdate"
                                                     BidAmount="@AuctionBidAmount"
                                                     BidAmountChanged="OnAuctionBidAmountChangedAsync"
                                                     BidRequested="OnSubmitAuctionBidAsync"
                                                     PassRequested="OnAuctionPassAsync"
                                                     DropOutRequested="OnAuctionDropOutAsync" />
                            }
                            else if (ShouldShowForcedSalePanel)
                            {
                                <ForcedSalePanel Phase="CurrentForcedSalePhase!"
                                                 SelectedRailroadIndex="@SelectedForcedSaleCandidate?.RailroadIndex"
                                                 SelectedRailroadIndexChanged="OnForcedSaleRailroadChangedAsync"
                                                 IsBusy="@_awaitingAuthoritativeUpdate"
                                                 SellToBankRequested="OnSellRailroadToBankAsync"
                                                 StartAuctionRequested="OnStartAuctionAsync" />
                            }
                            else if (ShouldShowCommitMoveAction)
                            {
                                <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center" Style="margin: 0 auto">
                                    <MudPaper Outlined="true" Class="d-flex align-center gap-4" Style="padding: 0.45rem 0.6rem; border-radius: 0.9rem; background: var(--mud-palette-surface); border: 1px solid color-mix(in srgb, var(--mud-palette-divider) 82%, transparent); box-shadow: 0 8px 20px rgb(0 0 0 / 0.16)">
                                        <MovementStatusPanel State="@_turnViewState" UsePaper="false" />
                                        <MudButton Variant="Variant.Filled"
                                                   Color="MudBlazor.Color.Primary"
                                                   Disabled="@(!CanCommitMoveAction)"
                                                   OnClick="OnCommitMoveActionAsync"
                                                   Class="flex-shrink-0 flex-grow-0" Style="min-width: 9rem; white-space: nowrap">
                                            @CommitMoveActionLabel
                                        </MudButton>
                                    </MudPaper>
                                </MudStack>
                            }
                        }
                        else
                        {
                            <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center" Style="margin: 0 auto">
                                <MudPaper Outlined="true" Class="d-flex justify-center align-center" Style="padding: 0.45rem; border-radius: 0.9rem; background: var(--mud-palette-surface); border: 1px solid color-mix(in srgb, var(--mud-palette-divider) 82%, transparent); box-shadow: 0 8px 20px rgb(0 0 0 / 0.16)">
                                    @if (IsGameCompleted)
                                    {
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <MudText Typo="Typo.body2" Style="text-align: center; white-space: nowrap">@SpectatorStatusMessage</MudText>
                                            <MudButton Variant="Variant.Filled"
                                                       Color="MudBlazor.Color.Primary"
                                                       Disabled="@_startingReplayGame"
                                                       OnClick="PlayAgainAsync"
                                                       Style="white-space: nowrap">
                                                @(_startingReplayGame ? "Preparing..." : "Play Again")
                                            </MudButton>
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Style="text-align: center; white-space: nowrap">@SpectatorStatusMessage</MudText>
                                    }
                                </MudPaper>
                            </MudStack>
                        }
                </MudStack>
            </MudStack>
        </MudStack>
    </MudStack>
</MudStack>

@code {
    private const int PresenceHeartbeatIntervalMilliseconds = 5000;
    private string? _currentUserId;
    private ApplicationUser? _currentUserProfile;
    private Dictionary<string, ApplicationUser> _playerProfilesByUserId = new(StringComparer.OrdinalIgnoreCase);
    private GameEntity? _game;
    private GameMapComponent? _gameMap;
    private bool _gameStateSubscriptionInitialized;
    private RailBaronGameState? _gameState;
    private MapDefinition? _playerBoardMapDefinition;
    private MapAnalysisReport? _mapAnalysisReport;
    private BoardTurnViewState _turnViewState = new();
    private MapSelectionMode _selectionMode = MapSelectionMode.Route;
    private string _currentPlayerColor = PlayerColorOptions.Colors[0];
    private List<PlayerBoardModel> _players = new();
    private bool _startingReplayGame;
    private GameSettingsSummaryModel _gameSettingsSummary = GameSettingsSummaryModel.Empty;
    private Dictionary<int, string?> _playerUserIdsByIndex = new();
    private Dictionary<string, string> _botDisplayNamesByDefinitionId = new(StringComparer.OrdinalIgnoreCase);
    private List<EventTimelineItem> _gameEngineEvents = new();
    private List<NotificationHistoryEntry> _notificationHistory = new();
    private List<PlayerMapState> _mapPlayerStates = new();
    private int _currentUserPlayerIndex = -1;
    private bool _timelineInitialized;
    private bool _pendingRestoredRouteSelection;
    private string? _lastAutoSuggestKey;
    private string? _selectedPurchaseOptionKey;
    private int? _activeAuctionRailroadIndex;
    private string? _dismissedRailroadOverlayOptionKey;
    private string? _lastPurchaseResolutionKey;
    private double? _selectedRailroadOverlayClientX;
    private double? _selectedRailroadOverlayClientY;
    private ElementReference _mapAreaElement;
    private PurchaseExperienceTab _selectedPurchaseTab = PurchaseExperienceTab.Map;
    private bool _wasPurchasePhaseActive;
    private AdvisorEntryPointState _advisorEntryPoint = new();
    private AdvisorConversationSession? _advisorConversation;
    private string _advisorDraftMessage = string.Empty;
    private int _advisorComposerResetVersion;
    private string? _lastAdvisorUserQuestion;
    private bool _awaitingAuthoritativeUpdate;
    private bool _resolvingDrawDestinationPhase;
    private string? _pendingDrawDestinationDecisionKey;
    private bool? _pendingDrawDestinationShouldDeclare;
    private bool _autoZoomEnabled;
    private int _auctionBidAmount;
    private string? _selectedRegionChoiceCode;
    private string? _selectedHomeCityName;
        private Task OnSelectedHomeCityChangedAsync(string? cityName)
        {
            _selectedHomeCityName = cityName;
            return InvokeAsync(StateHasChanged);
        }
        private async Task OnConfirmHomeCityChoiceAsync()
        {
            if (_gameState is null
                || string.IsNullOrWhiteSpace(GameId)
                || string.IsNullOrWhiteSpace(_selectedHomeCityName)
                || !ShouldShowHomeCityChoicePanel)
            {
                return;
            }

            MarkAuthoritativeUpdatePending();
            await EnqueueBoardActionAsync(
                new ChooseHomeCityAction
                {
                    PlayerId = CurrentTurnPlayerName,
                    ActorUserId = _currentUserId ?? string.Empty,
                    PlayerIndex = _gameState.ActivePlayerIndex,
                    SelectedCityName = _selectedHomeCityName
                });
        }

        private async Task OnKeepHomeSwapAsync()
        {
            if (_gameState is null || string.IsNullOrWhiteSpace(GameId) || !ShouldShowHomeSwapPanel)
            {
                return;
            }

            MarkAuthoritativeUpdatePending();
            await EnqueueBoardActionAsync(
                new ResolveHomeSwapAction
                {
                    PlayerId = CurrentTurnPlayerName,
                    ActorUserId = _currentUserId ?? string.Empty,
                    PlayerIndex = _gameState.ActivePlayerIndex,
                    SwapHomeAndDestination = false
                });
        }

        private async Task OnConfirmHomeSwapAsync()
        {
            if (_gameState is null || string.IsNullOrWhiteSpace(GameId) || !ShouldShowHomeSwapPanel)
            {
                return;
            }

            MarkAuthoritativeUpdatePending();
            await EnqueueBoardActionAsync(
                new ResolveHomeSwapAction
                {
                    PlayerId = CurrentTurnPlayerName,
                    ActorUserId = _currentUserId ?? string.Empty,
                    PlayerIndex = _gameState.ActivePlayerIndex,
                    SwapHomeAndDestination = true
                });
        }
    private readonly string _pagePresenceRegistrationId = Guid.NewGuid().ToString("N");
    private readonly HashSet<string> _notificationHistoryKeys = new(StringComparer.Ordinal);
    private bool _pagePresenceRegistered;
    private bool _presenceNotificationsEnabled;
    private DotNetObjectReference<GameBoard>? _presenceHeartbeatReference;
    private HubConnection? _gameHubConnection;
    private long _latestSharedStateChangeVersion;

    [Parameter]
    public string GameId { get; set; } = string.Empty;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        GamePresenceService.PresenceChanged += OnPresenceChanged;

        if (AuthState is null)
        {
            return;
        }

        var state = await AuthState;
        _currentUserId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (!string.IsNullOrWhiteSpace(_currentUserId))
        {
            _currentUserProfile = await ProfileService.GetProfileAsync(_currentUserId, CancellationToken.None);
        }

        if (string.IsNullOrWhiteSpace(GameId))
        {
            return;
        }

        if (!_gameStateSubscriptionInitialized)
        {
            _gameStateSubscriptionInitialized = true;
            SharedGameEngine.OnStateChanged += OnSharedGameStateChanged;
            SharedGameEngine.OnActionFailed += OnSharedGameActionFailed;
        }

        await RefreshGameEntityAsync();
        await LoadPlayerProfilesAsync(CancellationToken.None);
        await EnsurePlayerBoardMapDefinitionAsync(CancellationToken.None);
        await LoadGameStateAsync(refreshGameEntity: false);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (string.IsNullOrWhiteSpace(GameId))
        {
            return;
        }

        if (firstRender)
        {
            await EnsureGameHubConnectionAsync();
            RegisterPagePresence();
            await StartPresenceHeartbeatAsync();
            await RefreshAuthoritativeStateAfterInitialPresenceAsync();
        }

        TryRestoreRouteSelection();
        await ResolveDrawDestinationPhaseAsync();
        await AutoSuggestRouteIfNeededAsync();
        await ResolvePurchasePhaseAsync();
    }

    private async Task EndGameAsync()
    {
        if (string.IsNullOrWhiteSpace(_currentUserId) || string.IsNullOrWhiteSpace(GameId))
        {
            ShowNotification("Unable to end game: missing user or game context.", Severity.Error);
            return;
        }

        var result = await GameService.EndGameAsync(_currentUserId, GameId, CancellationToken.None);
        if (!result.Success)
        {
            ShowNotification(result.Reason ?? "Unable to end game.", Severity.Error);
            return;
        }

        Navigation.NavigateTo("/dashboard");
    }

    private async Task RefreshAuthoritativeStateAfterInitialPresenceAsync()
    {
        if (string.IsNullOrWhiteSpace(GameId))
        {
            return;
        }

        const int maxAttempts = 20;
        const int delayMilliseconds = 75;

        var sawBusyState = false;
        for (var attempt = 0; attempt < maxAttempts; attempt++)
        {
            if (!SharedGameEngine.IsGameBusy(GameId))
            {
                if (sawBusyState)
                {
                    break;
                }
            }
            else
            {
                sawBusyState = true;
            }

            await Task.Delay(delayMilliseconds);
        }

        await LoadGameStateAsync(refreshGameEntity: false);
    }

    private async Task PlayAgainAsync()
    {
        if (_startingReplayGame || string.IsNullOrWhiteSpace(_currentUserId) || string.IsNullOrWhiteSpace(GameId))
        {
            return;
        }

        var gameEntity = _game ?? await GameService.GetGameAsync(GameId, CancellationToken.None);
        if (gameEntity is null)
        {
            ShowNotification("Unable to prepare replay: game settings were not found.", Severity.Error);
            return;
        }

        var playerStates = GetCurrentPlayerStates();
        if (playerStates.Count < 2)
        {
            ShowNotification("Unable to prepare replay: game players were not found.", Severity.Error);
            return;
        }

        _startingReplayGame = true;

        try
        {
            var presetPayload = ReplayGamePresetSerialization.Serialize(new ReplayGamePreset
            {
                MapFileName = gameEntity.MapFileName,
                Settings = GameSettingsResolver.Resolve(gameEntity).Settings,
                CityProbabilityOverrides = gameEntity.CityProbabilityOverrides,
                RailroadPriceOverrides = gameEntity.RailroadPriceOverrides,
                Players = GameSeatStateProjection.BuildSeatSelections(playerStates)
            });

            var result = await GameService.EndGameAsync(_currentUserId, GameId, CancellationToken.None);
            if (!result.Success)
            {
                ShowNotification(result.Reason ?? "Unable to prepare replay.", Severity.Error);
                return;
            }

            Navigation.NavigateTo($"/games/new?preset={presetPayload}");
        }
        finally
        {
            _startingReplayGame = false;
        }
    }

    private string CommitMoveActionLabel => IsPendingBonusMove ? "MOVE BONUS" : "MOVE";

    private bool CanCommitMoveAction => !string.IsNullOrWhiteSpace(GameId)
        && _gameState is not null
        && !_awaitingAuthoritativeUpdate
        && !IsGameBusy
        && IsCurrentUserActivePlayer
        && string.Equals(_turnViewState.TurnPhase, "Move", StringComparison.OrdinalIgnoreCase)
        && CurrentRouteMoveCount > 0
        && CanCommitMoveSelection();

    private string ObserverTurnMessage => string.IsNullOrWhiteSpace(_turnViewState.ActivePlayerName)
            ? "Loading..."
        : IsGameCompleted
            ? "Game over."
        : string.Equals(_turnViewState.TurnPhase, TurnPhase.RegionChoice.ToString(), StringComparison.OrdinalIgnoreCase)
            ? $"Waiting for {_turnViewState.ActivePlayerName} to choose a replacement destination region."
                : $"Waiting for {_turnViewState.ActivePlayerName} to take their turn.";

    private async Task OnCommitMoveActionAsync()
    {
        if (string.IsNullOrWhiteSpace(GameId) || _gameState is null || _gameState.Players.Count == 0)
        {
            return;
        }

        if (!IsCurrentUserActivePlayer)
        {
            return;
        }

        if (!string.Equals(_turnViewState.TurnPhase, "Move", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        await CommitMovePhaseAsync();
    }

    private async Task OnSelectedPurchaseOptionChangedAsync(string? optionKey)
    {
        _selectedPurchaseOptionKey = optionKey;

        var selectedRailroad = CurrentPurchasePhase?.RailroadOptions.FirstOrDefault(option =>
            string.Equals(BuildRailroadOptionKey(option.RailroadIndex), optionKey, StringComparison.Ordinal));

        if (selectedRailroad is not null && _gameMap is not null)
        {
            if (!string.Equals(optionKey, _dismissedRailroadOverlayOptionKey, StringComparison.Ordinal))
            {
                _dismissedRailroadOverlayOptionKey = null;
            }

            if (!await TryPositionRailroadOverlayAsync(selectedRailroad.RailroadIndex))
            {
                _selectedRailroadOverlayClientX = null;
                _selectedRailroadOverlayClientY = null;
            }
        }
        else
        {
            _selectedRailroadOverlayClientX = null;
            _selectedRailroadOverlayClientY = null;
        }

        await InvokeAsync(StateHasChanged);
    }

    private Task OnSelectedRegionChoiceChangedAsync(string? regionCode)
    {
        _selectedRegionChoiceCode = regionCode;
        return InvokeAsync(StateHasChanged);
    }

    private async Task OnPurchaseTabSelected(PurchaseExperienceTab tab)
    {
        _selectedPurchaseTab = tab;

        if (tab == PurchaseExperienceTab.Stats)
        {
            await RefreshPlayerStatesAsync();
        }

        if (tab == PurchaseExperienceTab.Advice)
        {
            EnsureAdvisorSession();
        }

        await InvokeAsync(StateHasChanged);
    }

    private void EnsureAdvisorSession()
    {
        if (_advisorConversation is not null
            && string.Equals(_advisorConversation.GameId, GameId, StringComparison.Ordinal)
            && string.Equals(_advisorConversation.CurrentUserId, _currentUserId, StringComparison.Ordinal))
        {
            return;
        }

        _advisorConversation = new AdvisorConversationSession
        {
            GameId = GameId,
            CurrentUserId = _currentUserId ?? string.Empty
        };
        _advisorConversation.EnsureGreeting();
        _advisorEntryPoint = new AdvisorEntryPointState { GameId = GameId };
        _advisorDraftMessage = string.Empty;
        _advisorComposerResetVersion++;
        _lastAdvisorUserQuestion = null;
    }

    private Task OnAdvisorDraftMessageChanged(string value)
    {
        _advisorDraftMessage = value;
        return Task.CompletedTask;
    }

    private async Task OnAdvisorSendRequestedAsync()
    {
        var question = _advisorDraftMessage?.Trim();
        if (string.IsNullOrWhiteSpace(question) || _advisorEntryPoint.IsLoading)
        {
            return;
        }

        EnsureAdvisorSession();

        _lastAdvisorUserQuestion = question;
        _advisorConversation!.AddUserMessage(question);
        _advisorDraftMessage = string.Empty;
        _advisorComposerResetVersion++;
        _advisorEntryPoint.IsLoading = true;
        _advisorEntryPoint.HasAvailabilityError = false;
        _advisorEntryPoint.AvailabilityMessage = string.Empty;
        await InvokeAsync(StateHasChanged);

        var response = await GameBoardAdviceService.GenerateAdviceAsync(
            GameId,
            _currentUserId,
            _currentUserPlayerIndex >= 0 ? _currentUserPlayerIndex : null,
            _advisorConversation,
            question,
            CancellationToken.None);

        _advisorEntryPoint.IsLoading = false;

        if (response.Succeeded)
        {
            _advisorConversation.AddAssistantMessage(response.AssistantText ?? string.Empty, response.ContextTurnNumber);
        }
        else
        {
            _advisorEntryPoint.HasAvailabilityError = true;
            _advisorEntryPoint.AvailabilityMessage = response.FailureReason ?? "The advisor is unavailable right now.";
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task OnAdvisorRetryRequestedAsync()
    {
        if (string.IsNullOrWhiteSpace(_lastAdvisorUserQuestion) || _advisorEntryPoint.IsLoading)
        {
            return;
        }

        _advisorDraftMessage = _lastAdvisorUserQuestion;
        _advisorComposerResetVersion++;
        await OnAdvisorSendRequestedAsync();
    }

