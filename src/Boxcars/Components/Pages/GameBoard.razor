    private int EffectiveRecommendationPlayerIndex
    {
        get
        {
            if (_gameState is null)
            {
                return -1;
            }

            if (CurrentAuctionActorPlayerIndex is int auctionActorPlayerIndex)
            {
                return auctionActorPlayerIndex;
            }

            if (CanCurrentUserControlPlayer(_gameState.ActivePlayerIndex))
            {
                return _gameState.ActivePlayerIndex;
            }

            if (_currentUserPlayerIndex >= 0 && _currentUserPlayerIndex < _gameState.Players.Count)
            {
                return _currentUserPlayerIndex;
            }

            return _gameState.ActivePlayerIndex;
        }
    }

    private RecommendationInputSet? DisplayRecommendationInputs
    {
        get
        {
            var baseInputs = CurrentPurchasePhase?.RecommendationInputs;
            if (_gameState is null || _playerBoardMapDefinition is null || CurrentMapAnalysisReport is null)
            {
                return baseInputs;
            }

            var effectivePlayerIndex = EffectiveRecommendationPlayerIndex;
            if (effectivePlayerIndex < 0 || effectivePlayerIndex >= _gameState.Players.Count)
            {
                return baseInputs;
            }

            if (baseInputs is not null && effectivePlayerIndex == _gameState.ActivePlayerIndex)
            {
                return baseInputs;
            }

            var ownedRailroadIndices = _gameState.Players[effectivePlayerIndex].OwnedRailroadIndices;
            var currentCoverage = NetworkCoverageService.BuildSnapshot(_playerBoardMapDefinition, ownedRailroadIndices);
            var unownedRailroadIndices = _playerBoardMapDefinition.Railroads
                .Where(railroad => !_gameState.RailroadOwnership.TryGetValue(railroad.Index, out var ownerIndex) || ownerIndex is null)
                .Select(railroad => railroad.Index)
                .ToList();
            var projectedCoverageByRailroad = unownedRailroadIndices.ToDictionary(
                railroadIndex => railroadIndex,
                railroadIndex => NetworkCoverageService.BuildProjectedSnapshot(_playerBoardMapDefinition, ownedRailroadIndices, railroadIndex));
            var effectivePurchaseCash = GetEffectivePurchaseCash(effectivePlayerIndex);
            var affordableRailroadIndices = _playerBoardMapDefinition.Railroads
                .Where(railroad => unownedRailroadIndices.Contains(railroad.Index))
                .Where(railroad => (railroad.PurchasePrice ?? RailBaronGameEngine.GetRailroadPurchasePrice(railroad.Index)) <= effectivePurchaseCash)
                .Select(railroad => railroad.Index)
                .ToList();

            return new RecommendationInputSet
            {
                MapAnalysisReport = CurrentMapAnalysisReport,
                AffordableRailroadIndices = baseInputs?.AffordableRailroadIndices ?? affordableRailroadIndices,
                UnownedRailroadIndices = baseInputs?.UnownedRailroadIndices ?? unownedRailroadIndices,
                EligibleEngineTypes = baseInputs?.EligibleEngineTypes ?? [],
                CurrentCoverage = currentCoverage,
                ProjectedCoverageByRailroad = projectedCoverageByRailroad
            };
        }
    }

