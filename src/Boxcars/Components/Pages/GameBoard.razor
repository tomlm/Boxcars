    private async Task OnUndoToHistoryItemAsync(NotificationHistoryEntry item)
    {
        if (string.IsNullOrWhiteSpace(GameId)
            || string.IsNullOrWhiteSpace(_currentUserId)
            || string.IsNullOrWhiteSpace(item.EventBaseId))
        {
            return;
        }

        var confirmed = await DialogService.ShowMessageBox(
            "Cheat",
            "Are you sure you want to cheat?",
            yesText: "YES",
            noText: "NO");

        if (confirmed != true)
        {
            return;
        }

        try
        {
            MarkAuthoritativeUpdatePending();
            var succeeded = await SharedGameEngine.UndoToEventAsync(
                GameId,
                item.EventBaseId,
                item.Message,
                _currentUserId,
                CancellationToken.None);

            if (!succeeded)
            {
                _awaitingAuthoritativeUpdate = false;
                ShowNotification("That history event could not be found anymore.", Severity.Warning);
                StateHasChanged();
            }
        }
        catch (Exception exception)
        {
            HandleActionDispatchFailure(exception);
        }
    }

