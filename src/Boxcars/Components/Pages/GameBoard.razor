@page "/game/{GameId}"
@rendermode InteractiveServer
@using Boxcars.Components.GameBoard
@using Boxcars.Components.Map
@using Boxcars.Data
@using Boxcars.Data.Maps
@using Boxcars.Engine.Data.Maps
@using Boxcars.GameEngine
@using Boxcars.Hubs
@using Boxcars.Services
@using Boxcars.Services.Maps
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@using MudBlazor
@using System.Globalization
@using RailBaronGameState = Boxcars.Engine.Persistence.GameState
@attribute [Authorize]
@implements IAsyncDisposable
@inject NavigationManager Navigation
@inject GameService GameService
@inject GameBoardStateMapper GameBoardStateMapper
@inject PlayerProfileService ProfileService
@inject IGameEngine SharedGameEngine
@inject IMessageService MessageService

<PageTitle>Game - BoxCars</PageTitle>

<MudStack Row="true" Class="map-board-shell">
    <div class="map-board-sidebar">
        <PlayerBoard Players="_players" />
    </div>

    <div class="map-board-main">
        @if (_gameMap?.Errors.Count > 0)
        {
            <MudStack Class="map-board-message map-board-error">
                <MudText Typo="Typo.h6">Unable to render map</MudText>
                @foreach (var error in _gameMap.Errors)
                {
                    <MudText Typo="Typo.body2">@error</MudText>
                }
            </MudStack>
        }

        <div class="map-board-map-area">
            <GameMapComponent @ref="_gameMap"
                              MapFileName="@(_game?.MapFileName ?? GameService.DefaultMapFileName)"
                              SelectionMode="@_selectionMode"
                              PlayerId="@(_currentUserId ?? string.Empty)"
                              PlayerColor="@_currentPlayerColor"
                              PlayerStates="@_mapPlayerStates"
                              CurrentTurnMovementRemaining="@CurrentTurnMovementRemaining"
                              IsCurrentUserActivePlayer="@IsCurrentUserActivePlayer"
                              ZoomPercentChanged="OnZoomPercentChanged"
                              RouteSuggestionChanged="OnRouteSuggestionChangedAsync"
                              RoutePreviewChanged="OnRoutePreviewChangedAsync" />
        </div>

        @* ── Status line below map ── *@
        <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Class="map-board-status-bar">
            @if (_players.Count > 0)
            {
                var active = _players.FirstOrDefault(p => p.IsActiveTurn);
                if (active is not null)
                {
                    <MudText Typo="Typo.body2" Class="status-bar-text">@active.Name: @active.LocomotiveLabel engine</MudText>
                }
            }

            @if (_selectionMode == MapSelectionMode.Route)
            {
                <MudStack Row="true" Class="map-board-route-picker-row">
                    <MudButton Variant="Variant.Filled"
                               Color="MudBlazor.Color.Primary"
                               OnClick="OnSuggestRouteClickedAsync"
                               Disabled="@(_gameMap?.CanSuggestRoute != true)">
                        Suggest
                    </MudButton>
                </MudStack>
            }
        </MudStack>

        @* ── Bottom bar: action log + zoom/OK controls ── *@
        <div class="map-board-bottom-bar">
            <div class="map-board-history-panel">
                <TurnStatusPanel State="@_turnViewState" />
                <EventTimelinePanel Items="@_gameEngineEvents" StatusText="@TurnStatusText" />
            </div>

            <MudStack Class="map-board-controls">
                <ArrivalResolutionPanel Arrival="@_turnViewState.ArrivalResolution" />

                <TurnActionPanel PrimaryActionLabel="@PrimaryGameActionLabel"
                                 CanPrimaryAction="@CanPrimaryGameAction"
                                 OnPrimaryAction="OnPrimaryGameActionAsync"
                                 IsCurrentUserActivePlayer="@IsCurrentUserActivePlayer"
                                 ObserverMessage="@ObserverTurnMessage" />

                <MudStack Row="true" Class="map-board-zoom-row">
                    <MudText Typo="Typo.body2">Zoom:</MudText>
                    <MudSlider T="int"
                               Min="100"
                               Max="500"
                               Step="50"
                               @bind-Value="@_zoomPercent"
                               @bind-Value:after="OnZoomSliderChangedAsync"
                               Class="map-board-zoom-slider" />
                </MudStack>

                <MudButton Variant="Variant.Text" Color="MudBlazor.Color.Default" OnClick="EndGameAsync">
                    End Game
                </MudButton>
            </MudStack>
        </div>
    </div>
</MudStack>

@code {
    private string? _currentUserId;
    private ApplicationUser? _currentUserProfile;
    private GameEntity? _game;
    private GameMapComponent? _gameMap;
    private HubConnection? _hubConnection;
    private bool _hubConnectionInitialized;
    private RailBaronGameState? _gameState;
    private BoardTurnViewState _turnViewState = new();
    private MapSelectionMode _selectionMode = MapSelectionMode.Route;
    private int _zoomPercent = 100;
    private string _currentPlayerColor = PlayerColorOptions.Colors[0];
    private List<PlayerBoardModel> _players = new();
    private List<EventTimelineItem> _gameEngineEvents = new();
    private List<PlayerMapState> _mapPlayerStates = new();
    private int _currentUserPlayerIndex = -1;
    private bool _pendingRestoredRouteSelection;

    [Parameter]
    public string GameId { get; set; } = string.Empty;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is null)
        {
            return;
        }

        var state = await AuthState;
        _currentUserId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (!string.IsNullOrWhiteSpace(_currentUserId))
        {
            _currentUserProfile = await ProfileService.GetProfileAsync(_currentUserId, CancellationToken.None);
        }

        if (string.IsNullOrWhiteSpace(GameId))
        {
            return;
        }

        _game = await GameService.GetGameAsync(GameId, CancellationToken.None);
        await LoadGameStateAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _hubConnectionInitialized || string.IsNullOrWhiteSpace(GameId))
        {
            return;
        }

        _hubConnectionInitialized = true;

        try
        {
            await ConnectToGameHubAsync();
        }
        catch
        {
            // Game board can still render from loaded state without live hub updates.
        }

        TryRestoreRouteSelection();
    }

    private async Task EndGameAsync()
    {
        if (string.IsNullOrWhiteSpace(_currentUserId) || string.IsNullOrWhiteSpace(GameId))
        {
            await MessageService.ShowMessageBarAsync("Unable to end game: missing user or game context.", MessageIntent.Error, "GAME");
            return;
        }

        var result = await GameService.EndGameAsync(_currentUserId, GameId, CancellationToken.None);
        if (!result.Success)
        {
            await MessageService.ShowMessageBarAsync(result.Reason ?? "Unable to end game.", MessageIntent.Error, "GAME");
            return;
        }

        Navigation.NavigateTo("/dashboard");
    }

    private void OnZoomPercentChanged(double zoomPercent)
    {
        _zoomPercent = (int)zoomPercent;
        StateHasChanged();
    }

    private async Task OnZoomSliderChangedAsync()
    {
        if (_gameMap is null)
        {
            return;
        }

        await _gameMap.SetZoom(_zoomPercent);
    }

    private string PrimaryGameActionLabel => _turnViewState.TurnPhase switch
    {
        "DrawDestination" => "DRAW DESTINATION",
        "Roll" => "ROLL DICE",
        "Move" => "COMMIT MOVE",
        "Purchase" => "DECLINE PURCHASE",
        "EndTurn" => "END TURN",
        _ => "TURN ACTION"
    };

    private bool CanPrimaryGameAction => !string.IsNullOrWhiteSpace(GameId)
        && _gameState is not null
        && IsCurrentUserActivePlayer
        && _turnViewState.TurnPhase switch
        {
            "DrawDestination" => true,
            "Roll" => true,
            "Move" => _turnViewState.SelectedRoutePreview.MoveCount > 0 && CanCommitMoveSelection(),
            "Purchase" => true,
            "EndTurn" => true,
            _ => false
        };

    private string ObserverTurnMessage => string.IsNullOrWhiteSpace(_turnViewState.ActivePlayerName)
        ? "Waiting for the active player to complete their turn."
        : $"Waiting for {_turnViewState.ActivePlayerName} to complete their turn.";

    private async Task OnPrimaryGameActionAsync()
    {
        if (string.IsNullOrWhiteSpace(GameId) || _gameState is null || _gameState.Players.Count == 0)
        {
            return;
        }

        if (!IsCurrentUserActivePlayer)
        {
            return;
        }

        switch (_turnViewState.TurnPhase)
        {
            case "DrawDestination":
                await SharedGameEngine.EnqueueActionAsync(
                    GameId,
                    new PickDestinationAction
                    {
                        PlayerId = CurrentTurnPlayerName,
                        ActorUserId = _currentUserId ?? string.Empty,
                        PlayerIndex = _gameState.ActivePlayerIndex
                    },
                    CancellationToken.None);
                await RefreshStateAfterTurnAsync(state => !string.Equals(state.Turn.Phase, "DrawDestination", StringComparison.OrdinalIgnoreCase));
                break;

            case "Roll":
                await SharedGameEngine.EnqueueActionAsync(
                    GameId,
                    new RollDiceAction
                    {
                        PlayerId = CurrentTurnPlayerName,
                        ActorUserId = _currentUserId ?? string.Empty,
                        PlayerIndex = _gameState.ActivePlayerIndex,
                        WhiteDieOne = 0,
                        WhiteDieTwo = 0
                    },
                    CancellationToken.None);
                await RefreshStateAfterTurnAsync(state => !string.Equals(state.Turn.Phase, "Roll", StringComparison.OrdinalIgnoreCase));
                break;

            case "Move":
                await CommitMovePhaseAsync();
                break;

            case "Purchase":
                await DeclinePurchaseAndAdvanceTurnAsync();
                break;

            case "EndTurn":
                await AdvanceToNextPlayerAsync();
                break;
        }
    }

    private async Task CommitMovePhaseAsync()
    {
        if (_gameState is null || _gameMap is null || !CanCommitMoveSelection())
        {
            return;
        }

        var selectedNodeIds = _gameMap.GetSelectedRouteNodeIds();
        var selectedSegmentKeys = _gameMap.GetSelectedRouteSegmentKeys();
        if (selectedNodeIds.Count < 2 || selectedSegmentKeys.Count == 0)
        {
            return;
        }

        var movementRemainingBeforeCommit = _gameState.Turn.MovementRemaining;

        await SharedGameEngine.EnqueueActionAsync(
            GameId,
            new ChooseRouteAction
            {
                PlayerId = CurrentTurnPlayerName,
                ActorUserId = _currentUserId ?? string.Empty,
                PlayerIndex = _gameState.ActivePlayerIndex,
                RouteNodeIds = selectedNodeIds,
                RouteSegmentKeys = selectedSegmentKeys
            },
            CancellationToken.None);

        await SharedGameEngine.EnqueueActionAsync(
            GameId,
            new MoveAction
            {
                PlayerId = CurrentTurnPlayerName,
                ActorUserId = _currentUserId ?? string.Empty,
                PlayerIndex = _gameState.ActivePlayerIndex,
                PointsTaken = selectedNodeIds,
                SelectedSegmentKeys = selectedSegmentKeys
            },
            CancellationToken.None);

        await RefreshStateAfterTurnAsync(state =>
            state.Turn.MovementRemaining != movementRemainingBeforeCommit
            || !string.Equals(state.Turn.Phase, "Move", StringComparison.OrdinalIgnoreCase));

        if (_gameState is not null
            && string.Equals(_gameState.Turn.Phase, "Purchase", StringComparison.OrdinalIgnoreCase)
            && !string.IsNullOrWhiteSpace(_gameState.Players[_gameState.ActivePlayerIndex].DestinationCityName))
        {
            await DeclinePurchaseAndAdvanceTurnAsync();
        }
    }

    private bool CanCommitMoveSelection()
    {
        return _turnViewState.CanEndTurn || SelectionReachesDestination();
    }

    private bool SelectionReachesDestination()
    {
        if (_gameMap is null)
        {
            return false;
        }

        var destinationNodeId = _gameMap.DestinationNodeId;
        var selectedNodeIds = _gameMap.GetSelectedRouteNodeIds();

        return !string.IsNullOrWhiteSpace(destinationNodeId)
            && selectedNodeIds.Count > 0
            && string.Equals(selectedNodeIds[^1], destinationNodeId, StringComparison.OrdinalIgnoreCase);
    }

    private async Task DeclinePurchaseAndAdvanceTurnAsync()
    {
        if (_gameState is null)
        {
            return;
        }

        var activePlayerIndexBeforeAdvance = _gameState.ActivePlayerIndex;
        var turnNumberBeforeAdvance = _gameState.TurnNumber;

        await SharedGameEngine.EnqueueActionAsync(
            GameId,
            new DeclinePurchaseAction
            {
                PlayerId = CurrentTurnPlayerName,
                ActorUserId = _currentUserId ?? string.Empty,
                PlayerIndex = _gameState.ActivePlayerIndex
            },
            CancellationToken.None);

        await SharedGameEngine.EnqueueActionAsync(
            GameId,
            new EndTurnAction
            {
                PlayerId = CurrentTurnPlayerName,
                ActorUserId = _currentUserId ?? string.Empty,
                PlayerIndex = _gameState.ActivePlayerIndex
            },
            CancellationToken.None);

        await RefreshStateAfterTurnAsync(state =>
            state.TurnNumber > turnNumberBeforeAdvance
            || state.ActivePlayerIndex != activePlayerIndexBeforeAdvance);
    }

    private async Task AdvanceToNextPlayerAsync()
    {
        if (_gameState is null)
        {
            return;
        }

        var activePlayerIndexBeforeEnd = _gameState.ActivePlayerIndex;
        var turnNumberBeforeEnd = _gameState.TurnNumber;

        await SharedGameEngine.EnqueueActionAsync(
            GameId,
            new EndTurnAction
            {
                PlayerId = CurrentTurnPlayerName,
                ActorUserId = _currentUserId ?? string.Empty,
                PlayerIndex = _gameState.ActivePlayerIndex
            },
            CancellationToken.None);

        await RefreshStateAfterTurnAsync(state =>
            state.TurnNumber > turnNumberBeforeEnd
            || state.ActivePlayerIndex != activePlayerIndexBeforeEnd);
    }

    private Task OnRoutePreviewChangedAsync(TurnMovementPreview preview)
    {
        if (_gameState is null)
        {
            return Task.CompletedTask;
        }

        _turnViewState = GameBoardStateMapper.BuildTurnViewState(
            _game,
            _gameState,
            _currentUserId,
            preview,
            _turnViewState.ArrivalResolution);

        return InvokeAsync(StateHasChanged);
    }

    private async Task RefreshStateAfterTurnAsync(Func<RailBaronGameState, bool> completion)
    {
        for (var attempt = 0; attempt < 15; attempt++)
        {
            await Task.Delay(100);

            var updatedState = await SharedGameEngine.GetCurrentStateAsync(GameId, CancellationToken.None);
            ApplyGameState(updatedState);
            SyncRouteSelectionToActivePlayer();

            if (completion(updatedState))
            {
                return;
            }
        }
    }

    private Task OnRouteSuggestionChangedAsync(RouteSuggestionResult _)
    {
        return InvokeAsync(StateHasChanged);
    }

    private async Task OnSuggestRouteClickedAsync()
    {
        if (_gameMap is null)
        {
            return;
        }

        await _gameMap.SuggestRouteAsync();
    }

    private async Task LoadGameStateAsync()
    {
        _gameState = await SharedGameEngine.GetCurrentStateAsync(GameId, CancellationToken.None);
        ApplyGameState(_gameState);
        SyncRouteSelectionToActivePlayer();
        await RefreshTimelineAsync();
    }

    private async Task ConnectToGameHubAsync()
    {
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/game"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<RailBaronGameState>(GameHubEvents.StateUpdated, state =>
        {
            ApplyGameState(state);
            return InvokeAsync(async () =>
            {
                await RefreshTimelineAsync();
                TryRestoreRouteSelection();
                StateHasChanged();
            });
        });

        await _hubConnection.StartAsync();
        await _hubConnection.InvokeAsync(GameHubEvents.JoinGame, GameId);
    }

    private void ApplyGameState(RailBaronGameState state)
    {
        _gameState = state;
        _turnViewState = GameBoardStateMapper.BuildTurnViewState(_game, state, _currentUserId);
        _selectionMode = ResolveSelectionMode(_turnViewState.TurnPhase);
        _currentUserPlayerIndex = _turnViewState.CurrentUserPlayerIndex;
        _mapPlayerStates = GameBoardStateMapper.BuildPlayerMapStates(_game, state, _currentUserId).ToList();

        var playerSelections = GameBoardStateMapper.GetPlayerSelections(_game);

        var playerUserIdsByDisplayName = playerSelections
            .Where(selection => !string.IsNullOrWhiteSpace(selection.DisplayName) && !string.IsNullOrWhiteSpace(selection.UserId))
            .GroupBy(selection => selection.DisplayName, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(group => group.Key, group => group.First().UserId, StringComparer.OrdinalIgnoreCase);

        _players = state.Players
            .Select((player, index) =>
            {
                var selection = index < playerSelections.Count ? playerSelections[index] : null;
                var resolvedUserId = ResolvePlayerUserId(player, selection, playerUserIdsByDisplayName);
                var isCurrentUser = !string.IsNullOrWhiteSpace(_currentUserId)
                    && !string.IsNullOrWhiteSpace(resolvedUserId)
                    && string.Equals(_currentUserId, resolvedUserId, StringComparison.OrdinalIgnoreCase);

                if (isCurrentUser)
                {
                    _currentUserPlayerIndex = index;
                }

                return new PlayerBoardModel
                {
                    Index = index,
                    Name = selection?.DisplayName ?? player.Name,
                    ThumbnailUrl = ResolveThumbnailUrl(selection?.DisplayName ?? player.Name),
                    Color = ResolvePlayerColor(selection, index),
                    IsAtDestination = string.IsNullOrWhiteSpace(player.DestinationCityName),
                    TripStartLabel = player.CurrentCityName,
                    TripDestinationLabel = string.IsNullOrWhiteSpace(player.DestinationCityName)
                        ? player.CurrentCityName
                        : player.DestinationCityName,
                    DistanceToDestination = 0,
                    Payoff = 0,
                    Cash = player.Cash,
                    IsCurrentUser = isCurrentUser,
                    HomeCity = player.HomeCityName,
                    IsActiveTurn = index == state.ActivePlayerIndex,
                    IsConnected = player.IsActive,
                    LocomotiveLabel = player.LocomotiveType
                };
            })
            .ToList();

        _currentPlayerColor = _currentUserPlayerIndex >= 0
            ? _players[_currentUserPlayerIndex].Color
            : PlayerColorOptions.Colors[0];
        _pendingRestoredRouteSelection = true;
    }

    private static MapSelectionMode ResolveSelectionMode(string? turnPhase)
    {
        return string.Equals(turnPhase, "Purchase", StringComparison.OrdinalIgnoreCase)
            ? MapSelectionMode.Rail
            : MapSelectionMode.Route;
    }

    private async Task RefreshTimelineAsync()
    {
        if (string.IsNullOrWhiteSpace(GameId))
        {
            _gameEngineEvents = [];
            return;
        }

        var events = await GameService.GetGameEventsAsync(GameId, CancellationToken.None);
        _gameEngineEvents = events.ToList();
    }

    private string ResolvePlayerColor(GamePlayerSelection? selection, int index)
    {
        return selection is null
            ? PlayerColorOptions.Colors[index % PlayerColorOptions.Colors.Length]
            : PlayerColorOptions.NormalizeOrDefault(selection.Color, PlayerColorOptions.Colors[index % PlayerColorOptions.Colors.Length]);
    }

    private string ResolvePlayerUserId(
        Boxcars.Engine.Persistence.PlayerState player,
        GamePlayerSelection? selection,
        IReadOnlyDictionary<string, string> playerUserIdsByDisplayName)
    {
        if (!string.IsNullOrWhiteSpace(selection?.UserId))
        {
            return selection.UserId;
        }

        if (playerUserIdsByDisplayName.TryGetValue(player.Name, out var selectedUserId))
        {
            return selectedUserId;
        }

        var matchesCurrentUser = !string.IsNullOrWhiteSpace(_currentUserId)
            && (
                string.Equals(player.Name, _currentUserId, StringComparison.OrdinalIgnoreCase)
                || (!string.IsNullOrWhiteSpace(_currentUserProfile?.Nickname)
                    && string.Equals(player.Name, _currentUserProfile.Nickname, StringComparison.OrdinalIgnoreCase))
                || (!string.IsNullOrWhiteSpace(_currentUserProfile?.Email)
                    && string.Equals(player.Name, _currentUserProfile.Email, StringComparison.OrdinalIgnoreCase))
            );

        return matchesCurrentUser
            ? _currentUserId ?? player.Name
            : player.Name;
    }

    private string ResolveCurrentPlayerColor()
    {
        if (string.IsNullOrWhiteSpace(_currentUserId))
        {
            return PlayerColorOptions.Colors[0];
        }

        var playerSelections = string.IsNullOrWhiteSpace(_game?.PlayersJson)
            ? []
            : GamePlayerSelectionSerialization.Deserialize(_game.PlayersJson);

        var currentSelection = playerSelections.FirstOrDefault(player => string.Equals(player.UserId, _currentUserId, StringComparison.OrdinalIgnoreCase));
        return currentSelection is null
            ? PlayerColorOptions.Colors[0]
            : PlayerColorOptions.NormalizeOrDefault(currentSelection.Color);
    }

    private string ResolveThumbnailUrl(string playerName)
    {
        if (_currentUserProfile is null || string.IsNullOrWhiteSpace(_currentUserProfile.ThumbnailUrl))
        {
            return string.Empty;
        }

        var matchesCurrentUserId = !string.IsNullOrWhiteSpace(_currentUserId)
            && string.Equals(playerName, _currentUserId, StringComparison.OrdinalIgnoreCase);

        var matchesNickname = !string.IsNullOrWhiteSpace(_currentUserProfile.Nickname)
            && string.Equals(playerName, _currentUserProfile.Nickname, StringComparison.OrdinalIgnoreCase);

        return matchesCurrentUserId || matchesNickname
            ? _currentUserProfile.ThumbnailUrl
            : string.Empty;
    }

    private void SyncRouteSelectionToActivePlayer()
    {
        if (_gameMap is null || _gameState is null || _gameState.Players.Count == 0)
        {
            return;
        }

        var activePlayer = _gameState.Players[_gameState.ActivePlayerIndex];
        var restoredPreviewNodeIds = _turnViewState.SelectedRoutePreview.NodeIds;
        var restoredPreviewSegmentKeys = _turnViewState.SelectedRoutePreview.SegmentKeys;
        var startNodeId = restoredPreviewNodeIds.FirstOrDefault() ?? activePlayer.CurrentNodeId;

        if (!string.IsNullOrWhiteSpace(startNodeId))
        {
            _gameMap.SetStartCity(startNodeId);
        }
        else
        {
            var routeCityOptions = _gameMap.RouteCityOptions;
            var startCity = routeCityOptions.FirstOrDefault(option =>
                string.Equals(option.CityName, activePlayer.CurrentCityName, StringComparison.OrdinalIgnoreCase));

            if (!string.IsNullOrWhiteSpace(startCity.NodeId))
            {
                _gameMap.SetStartCity(startCity.NodeId);
            }
        }

        if (string.IsNullOrWhiteSpace(activePlayer.DestinationCityName))
        {
            _gameMap.RestoreSelectedRoute(restoredPreviewNodeIds, restoredPreviewSegmentKeys);
            _pendingRestoredRouteSelection = false;
            return;
        }

        var destinationRouteCityOptions = _gameMap.RouteCityOptions;

        var destinationCity = destinationRouteCityOptions.FirstOrDefault(option =>
            string.Equals(option.CityName, activePlayer.DestinationCityName, StringComparison.OrdinalIgnoreCase));

        if (!string.IsNullOrWhiteSpace(destinationCity.NodeId))
        {
            _gameMap.SetDestinationCity(destinationCity.NodeId);
        }

        _gameMap.RestoreSelectedRoute(restoredPreviewNodeIds, restoredPreviewSegmentKeys);
        _pendingRestoredRouteSelection = false;
    }

    private void TryRestoreRouteSelection()
    {
        if (!_pendingRestoredRouteSelection)
        {
            return;
        }

        SyncRouteSelectionToActivePlayer();
    }

    private string TurnStatusText => $"{CurrentTurnPlayerName} Roll={CurrentRollTotalLabel} Moves={CurrentRouteMoveCount} Fees={FormatFee(CurrentRouteFees)} Sugg={FormatFee(SuggestedRouteFees)}";

    private string CurrentTurnPlayerName
    {
        get
        {
            if (_gameState is null || _gameState.Players.Count == 0)
            {
                return "No active player";
            }

            return _gameState.Players[_gameState.ActivePlayerIndex].Name;
        }
    }

    private string CurrentRollTotalLabel
    {
        get
        {
            if (_gameState?.Turn.DiceResult is not { } diceResult)
            {
                return "-";
            }

            var whiteDiceTotal = diceResult.WhiteDice?.Sum() ?? 0;
            var total = whiteDiceTotal + (diceResult.RedDie ?? 0);
            return total.ToString(CultureInfo.InvariantCulture);
        }
    }

    private int CurrentRouteMoveCount => _turnViewState.SelectedRoutePreview.MoveCount;

    private int CurrentRouteFees => _turnViewState.PreviewFee;

    private int SuggestedRouteFees => _gameMap?.RouteSuggestion?.TotalCost ?? 0;

    private int CurrentTurnMovementRemaining => Math.Max(0, _gameState?.Turn.MovementRemaining ?? 0);

    private bool IsCurrentUserActivePlayer => _gameState is not null
        && _currentUserPlayerIndex >= 0
        && _currentUserPlayerIndex == _gameState.ActivePlayerIndex;

    private string CurrentUserPlayerColor => _currentUserPlayerIndex >= 0
        ? _players[_currentUserPlayerIndex].Color
        : "var(--accent-fill-rest)";

    private static string FormatFee(int fee)
    {
        return string.Format(CultureInfo.InvariantCulture, "${0:N0}", Math.Max(0, fee));
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            if (_hubConnection.State == HubConnectionState.Connected)
            {
                await _hubConnection.InvokeAsync(GameHubEvents.LeaveGame, GameId);
            }

            await _hubConnection.DisposeAsync();
        }
    }
}
