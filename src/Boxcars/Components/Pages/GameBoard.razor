        _ = InvokeAsync(() =>
        {
            _awaitingAuthoritativeUpdate = false;
            ShowNotification(failure.Message, Severity.Error);
            StateHasChanged();
            return Task.CompletedTask;
        });
    }

    private void MarkAuthoritativeUpdatePending()
    {
        _awaitingAuthoritativeUpdate = true;
        StateHasChanged();
    }

    private void HandleActionDispatchFailure(Exception exception)
    {
        _awaitingAuthoritativeUpdate = false;

        var message = string.IsNullOrWhiteSpace(exception.Message)
            ? "Unable to submit that action right now."
            : exception.Message;

        ShowNotification(message, Severity.Error);
        StateHasChanged();
    }

    private async Task EnqueueBoardActionAsync(PlayerAction action, bool actionAlreadyMarkedPending = false)
    {
        const int maxAttempts = 20;
        const int retryDelayMilliseconds = 75;

        if (!actionAlreadyMarkedPending)
        {
            MarkAuthoritativeUpdatePending();
        }

        for (var attempt = 0; attempt < maxAttempts; attempt++)
        {
            try
            {
                await SharedGameEngine.EnqueueActionAsync(GameId, action, CancellationToken.None);
                return;
            }
            catch (InvalidOperationException exception) when (IsGameBusyDispatchFailure(exception) && attempt < maxAttempts - 1)
            {
                await Task.Delay(retryDelayMilliseconds);
            }
            catch (Exception exception)
            {
                HandleActionDispatchFailure(exception);
                return;
            }
        }

        HandleActionDispatchFailure(new InvalidOperationException("Another action is still being processed for this game. Wait for the board to finish updating and try again."));
    }

    private static bool IsGameBusyDispatchFailure(InvalidOperationException exception)
    {
        return exception.Message.Contains("Another action is still being processed", StringComparison.OrdinalIgnoreCase);
    }

    private void ApplyGameState(RailBaronGameState state, bool queueRestoredRouteSelection = true)
    {
        var previousState = _gameState;
        _gameState = state;
        var currentPlayerStates = GetCurrentPlayerStates();
        _turnViewState = GameBoardStateMapper.BuildTurnViewState(GameId, currentPlayerStates, state, _currentUserId, _playerBoardMapDefinition, gameEntity: _game);
        _currentUserPlayerIndex = _turnViewState.CurrentUserPlayerIndex;

        var playerSelections = GameBoardStateMapper.GetSeatSelections(currentPlayerStates);
        var botAssignmentsByUserId = GameBoardStateMapper.BuildLatestBotControlStates(currentPlayerStates);
        var suggestedRouteDistances = BuildSuggestedRouteDistances(state);

        var playerUserIdsByDisplayName = playerSelections
            .Where(selection => !string.IsNullOrWhiteSpace(selection.DisplayName) && !string.IsNullOrWhiteSpace(selection.UserId))
            .GroupBy(selection => selection.DisplayName, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(group => group.Key, group => group.First().UserId, StringComparer.OrdinalIgnoreCase);

        var playerDisplayNamesByUserId = playerSelections
            .Where(selection => !string.IsNullOrWhiteSpace(selection.UserId))
            .ToDictionary(
                selection => selection.UserId,
                selection => string.IsNullOrWhiteSpace(selection.DisplayName) ? selection.UserId : selection.DisplayName,
                StringComparer.OrdinalIgnoreCase);

        var resolvedUserIdsByIndex = state.Players
            .Select((player, index) =>
            {
                var selection = index < playerSelections.Count ? playerSelections[index] : null;
                return ResolvePlayerUserId(player, selection, playerUserIdsByDisplayName);
            })
            .ToList();

        var resolvedSettings = _game is null ? Boxcars.Engine.Persistence.GameSettings.Default : GameSettingsResolver.Resolve(_game).Settings;

        _players = state.Players
            .Select((player, index) =>
            {
                var selection = index < playerSelections.Count ? playerSelections[index] : null;
                var resolvedUserId = resolvedUserIdsByIndex[index];

                var isConnected = IsPlayerConnected(resolvedUserId);
                var delegatedControllerUserId = GamePresenceService.GetDelegatedControllerUserId(GameId, resolvedUserId) ?? string.Empty;
                var isDelegatedToCurrentUser = PlayerControlRules.IsDelegatedController(delegatedControllerUserId, _currentUserId);
                var isBotUser = IsBotUser(resolvedUserId);
                var latestBotAssignment = !string.IsNullOrWhiteSpace(resolvedUserId)
                    && botAssignmentsByUserId.TryGetValue(resolvedUserId, out var assignment)
                        ? assignment
                        : null;
                var activeBotAssignment = latestBotAssignment is not null
                    && string.Equals(latestBotAssignment.BotControlStatus, BotControlStatuses.Active, StringComparison.OrdinalIgnoreCase)
                    && latestBotAssignment.BotControlClearedUtc is null
                        ? latestBotAssignment
                        : null;
                var latestBotName = latestBotAssignment is not null
                    && !string.IsNullOrWhiteSpace(latestBotAssignment.PlayerUserId)
                    && _botDisplayNamesByDefinitionId.TryGetValue(latestBotAssignment.PlayerUserId, out var botDisplayName)
                        ? botDisplayName
                        : null;
                var controllerState = GamePresenceService.ResolveSeatControllerState(GameId, resolvedUserId, activeBotAssignment);

                var isCurrentUser = !string.IsNullOrWhiteSpace(_currentUserId)
                    && !string.IsNullOrWhiteSpace(resolvedUserId)
                    && string.Equals(_currentUserId, resolvedUserId, StringComparison.OrdinalIgnoreCase);

                if (isCurrentUser)
                {
                    _currentUserPlayerIndex = index;
                }

                return new PlayerBoardModel
                {
                    Index = index,
                    Name = selection?.DisplayName ?? player.Name,
                    ThumbnailUrl = (isBotUser || activeBotAssignment is not null)
                        ? ResolveBotThumbnailUrl(selection?.DisplayName ?? player.Name)
                        : ResolveThumbnailUrl(resolvedUserId),
                    Color = ResolvePlayerColor(selection, index),
                    IsAtDestination = string.IsNullOrWhiteSpace(player.DestinationCityName)
                        || string.Equals(player.CurrentCityName, player.DestinationCityName, StringComparison.OrdinalIgnoreCase),
                    TripStartLabel = string.IsNullOrWhiteSpace(player.TripStartCityName)
                        ? player.CurrentCityName
                        : player.TripStartCityName,
                    TripDestinationLabel = string.IsNullOrWhiteSpace(player.DestinationCityName)
                        ? player.CurrentCityName
                        : player.DestinationCityName,
                    DistanceToDestination = suggestedRouteDistances.TryGetValue(index, out var suggestedDistance)
                        ? suggestedDistance
                        : CalculateDistanceToDestination(player),
                    Payoff = CalculateTripPayoff(player),
                    Cash = player.Cash,
                    IsCurrentUser = isCurrentUser,
                    IsDelegatedToCurrentUser = isDelegatedToCurrentUser,
                    KeepCashSecret = resolvedSettings.KeepCashSecret,
                    AnnouncingCashThreshold = resolvedSettings.AnnouncingCash,
                    HomeCity = player.HomeCityName,
                    HasDeclared = player.HasDeclared,
                    AlternateCity = player.AlternateDestinationCityName ?? string.Empty,
                    IsActiveTurn = index == state.ActivePlayerIndex,
                    IsWinner = state.WinnerIndex.HasValue && state.WinnerIndex.Value == index,
                    IsEliminated = !player.IsActive,
                    IsConnected = isConnected,
                    ShowDisconnectedControlToggle = ShouldShowDisconnectedControlToggle(index, resolvedUserId),
                    CanSelectAiControl = CanCurrentUserSelectAiControl(index, resolvedUserId, delegatedControllerUserId),
                    CanSelectManualControl = CanCurrentUserSelectManualControl(index, resolvedUserId, delegatedControllerUserId),
                    IsAiControlSelected = SeatControllerModes.IsAiControlled(controllerState.ControllerMode),
                    IsManualControlSelected = SeatControllerModes.IsDelegated(controllerState.ControllerMode),
                    DisconnectedControlMode = ResolveDisconnectedControlMode(controllerState.ControllerMode),
                    DelegatedControllerUserId = delegatedControllerUserId,
                    DelegatedControllerDisplayName = ResolveParticipantDisplayName(delegatedControllerUserId, playerDisplayNamesByUserId),
                    HasActiveBotControl = activeBotAssignment is not null,
                    IsAiControlled = isBotUser || SeatControllerModes.IsAiControlled(controllerState.ControllerMode) || activeBotAssignment is not null,
                    ControllerMode = controllerState.ControllerMode,
                    IsBotPlayer = isBotUser,
                    AssignedBotDefinitionId = activeBotAssignment?.PlayerUserId ?? string.Empty,
                    BotControlStatusLabel = SeatControllerModes.IsAiControlled(controllerState.ControllerMode)
                        ? "AUTO"
                        : GameBoardStateMapper.GetBotControlStatusLabel(latestBotAssignment, latestBotName),
                    HasMissingBotDefinition = string.Equals(latestBotAssignment?.BotControlStatus, BotControlStatuses.MissingDefinition, StringComparison.OrdinalIgnoreCase),
                    LocomotiveLabel = player.LocomotiveType,
                    BonusPendingLabel = index == state.ActivePlayerIndex ? BuildBonusPendingLabel(state, player) : string.Empty,
                    FeesOwed = index == state.ActivePlayerIndex ? CalculateFeesOwed(state, index, resolvedSettings) : 0,
                    CoverageMetrics = BuildPlayerCoverageMetricRows(player)
                };
            })
            .ToList();

        _playerUserIdsByIndex = resolvedUserIdsByIndex
            .Select((resolvedUserId, index) => new KeyValuePair<int, string?>(index, resolvedUserId))
            .ToDictionary(pair => pair.Key, pair => pair.Value);

        _selectionMode = ResolveSelectionMode(_turnViewState, CanInspectRailroadsWhileWaiting);
        _auctionBidAmount = CurrentAuctionState?.MinimumBid ?? 0;
        _mapPlayerStates = GameBoardStateMapper.BuildPlayerMapStates(currentPlayerStates, state, _currentUserId).ToList();
        _currentPlayerColor = ResolveActionPlayerColor(state);
        SyncHomeCitySelection();
        SyncRegionChoiceSelection();
        SyncPurchaseSelection();
        TrackPurchasePhaseTransition();
        if (queueRestoredRouteSelection)
        {
            _pendingRestoredRouteSelection = true;
        }

        NotifyGameCompleted(previousState, state);
    }

    private void ReevaluatePlayerPresenceState()
    {
        if (_gameState is null)
        {
            return;
        }

        RefreshPlayerConnectionStates();
        _selectionMode = ResolveSelectionMode(_turnViewState, CanInspectRailroadsWhileWaiting);
    }

    private void TrackPurchasePhaseTransition()
    {
        var isPurchaseNow = CurrentPurchasePhase is { HasActivePurchaseControls: true }
            && IsCurrentUserActivePlayer
            && string.Equals(_turnViewState.TurnPhase, "Purchase", StringComparison.OrdinalIgnoreCase);

        if (isPurchaseNow && !_wasPurchasePhaseActive)
        {
            // Entering purchase phase: reset zoom so full board is visible
            _ = ResetZoomForPurchaseAsync();
        }
        else if (!isPurchaseNow && _wasPurchasePhaseActive)
        {
            // Exiting purchase phase: reset zoom and clear selection artifacts
            _selectedPurchaseOptionKey = null;
            _dismissedRailroadOverlayOptionKey = null;
            _selectedRailroadOverlayClientX = null;
            _selectedRailroadOverlayClientY = null;
            _selectedPurchaseTab = PurchaseExperienceTab.Map;
            _ = ResetZoomForPurchaseAsync();
        }

        _wasPurchasePhaseActive = isPurchaseNow;
    }

    private async Task ResetZoomForPurchaseAsync()
    {
        if (_gameMap is not null)
        {
            await _gameMap.ResetZoom();
        }
    }

    private IReadOnlyDictionary<int, int> BuildSuggestedRouteDistances(RailBaronGameState state)
    {
        if (_playerBoardMapDefinition is null)
        {
            return new Dictionary<int, int>();
        }

        try
        {
            var engine = RailBaronGameEngine.FromSnapshot(state, _playerBoardMapDefinition, new DefaultRandomProvider(0));
            var distances = new Dictionary<int, int>(state.Players.Count);

            for (var index = 0; index < state.Players.Count; index++)
            {
                var player = state.Players[index];
                if (string.IsNullOrWhiteSpace(player.DestinationCityName))
                {
                    distances[index] = 0;
                    continue;
                }

                distances[index] = engine.SuggestRouteForPlayer(index).Segments.Count;
            }

            return distances;
        }
        catch
        {
            return new Dictionary<int, int>();
        }
    }

    private async Task EnsurePlayerBoardMapDefinitionAsync(CancellationToken cancellationToken)
    {
        if (_playerBoardMapDefinition is not null)
        {
            return;
        }

        var configuredMapFile = string.IsNullOrWhiteSpace(_game?.MapFileName)
            ? GameService.DefaultMapFileName
            : _game.MapFileName.Trim();
        var mapPath = Path.Combine(WebHostEnvironment.ContentRootPath, configuredMapFile);

        if (!File.Exists(mapPath))
        {
            return;
        }

        await using var stream = File.OpenRead(mapPath);
        var loadResult = await MapDefinition.LoadAsync(Path.GetFileName(mapPath), stream, cancellationToken);
        if (loadResult.Succeeded)
        {
            var mapDefinition = MapProbabilityService.ApplyCityProbabilities(loadResult.Definition!, _game?.CityProbabilityOverrides, _game?.RailroadPriceOverrides);
            _playerBoardMapDefinition = mapDefinition;
            _mapAnalysisReport = MapAnalysisService.BuildReport(mapDefinition);
        }
    }

    private static int CalculateDistanceToDestination(Boxcars.Engine.Persistence.PlayerState player)
    {
        if (string.IsNullOrWhiteSpace(player.DestinationCityName))
        {
            return 0;
        }

        if (player.SelectedRouteSegmentKeys.Count > 0)
        {
            return player.SelectedRouteSegmentKeys.Count;
        }

        if (player.ActiveRoute is null)
        {
            return 0;
        }

        var completedSegments = Math.Clamp(player.RouteProgressIndex, 0, player.ActiveRoute.Segments.Count);
        return Math.Max(0, player.ActiveRoute.Segments.Count - completedSegments);
    }

    private static int CalculateFeesOwed(RailBaronGameState state, int playerIndex, Boxcars.Engine.Persistence.GameSettings settings)
    {
        if (playerIndex < 0 || playerIndex >= state.Players.Count)
        {
            return 0;
        }

        var player = state.Players[playerIndex];
        var fullRateRailroads = state.Turn.RailroadsRequiringFullOwnerRateThisTurn.ToHashSet();
        var ownerBuckets = new Dictionary<int, bool>();
        var usesPublicFee = false;
        var usesPrivateFee = false;

        foreach (var railroadIndex in state.Turn.RailroadsRiddenThisTurn)
        {
            if (!state.RailroadOwnership.TryGetValue(railroadIndex, out var ownerIndex) || ownerIndex is null)
            {
                usesPublicFee = true;
                continue;
            }

            if (ownerIndex.Value == playerIndex)
            {
                usesPrivateFee = true;
                continue;
            }

            var requiresFullOwnerRate = fullRateRailroads.Contains(railroadIndex);
            if (!ownerBuckets.TryGetValue(ownerIndex.Value, out var existingRequiresFullOwnerRate))
            {
                ownerBuckets[ownerIndex.Value] = requiresFullOwnerRate;
            }
            else
            {
                ownerBuckets[ownerIndex.Value] = existingRequiresFullOwnerRate || requiresFullOwnerRate;
            }
        }

        var opponentRate = RailBaronGameEngine.GetUnfriendlyFee(settings, state.AllRailroadsSold);
        return (usesPublicFee ? RailBaronGameEngine.GetPublicFee(settings) : 0)
            + (usesPrivateFee ? RailBaronGameEngine.GetPrivateFee(settings) : 0)
            + ownerBuckets.Values.Sum(requiresFullOwnerRate => requiresFullOwnerRate ? opponentRate : RailBaronGameEngine.GetPrivateFee(settings));
    }

    private int CalculateTripPayoff(Boxcars.Engine.Persistence.PlayerState player)
    {
        if (_playerBoardMapDefinition is null || string.IsNullOrWhiteSpace(player.DestinationCityName))
        {
            return 0;
        }

        var tripStartCityName = string.IsNullOrWhiteSpace(player.TripStartCityName)
            ? player.CurrentCityName
            : player.TripStartCityName;
        var originCity = _playerBoardMapDefinition.Cities.FirstOrDefault(city =>
            string.Equals(city.Name, tripStartCityName, StringComparison.OrdinalIgnoreCase));
        var destinationCity = _playerBoardMapDefinition.Cities.FirstOrDefault(city =>
            string.Equals(city.Name, player.DestinationCityName, StringComparison.OrdinalIgnoreCase));

        if (originCity?.PayoutIndex is not int originPayoutIndex || destinationCity?.PayoutIndex is not int
destinationPayoutIndex)
        {
            return 0;
        }

        return _playerBoardMapDefinition.TryGetPayout(originPayoutIndex, destinationPayoutIndex, out var payout)
            ? payout
            : 0;
    }

    private static MapSelectionMode ResolveSelectionMode(BoardTurnViewState turnViewState, bool canInspectRailroadsWhileWaiting)
    {
        return canInspectRailroadsWhileWaiting
            || (string.Equals(turnViewState.TurnPhase, "Purchase", StringComparison.OrdinalIgnoreCase)
                && turnViewState.PurchasePhase is { HasActivePurchaseControls: true, RailroadOptions.Count: > 0 })
            || (string.Equals(turnViewState.TurnPhase, "UseFees", StringComparison.OrdinalIgnoreCase)
                && turnViewState.ForcedSalePhase is { SaleCandidates.Count: > 0 })
            || turnViewState.ForcedSalePhase?.AuctionState is not null
            ? MapSelectionMode.Rail
            : MapSelectionMode.Route;
    }

    private async Task RefreshTimelineAsync(bool notifyNewItems = false)
    {
        if (string.IsNullOrWhiteSpace(GameId))
        {
            _gameEngineEvents = [];
            _timelineInitialized = true;
            return;
        }

        var existingEventIds = _gameEngineEvents
            .Select(item => item.EventId)
            .ToHashSet(StringComparer.Ordinal);
        var shouldFetchIncrementally = notifyNewItems && _timelineInitialized;

        var events = await LoadTimelineEventsAsync(shouldFetchIncrementally);

        if (shouldFetchIncrementally)
        {
            var newEvents = events
                .Where(item => !existingEventIds.Contains(item.EventId))
                .ToList();

            if (newEvents.Count > 0)
            {
                _gameEngineEvents.AddRange(newEvents);
            }
        }
        else
        {
            _gameEngineEvents = events.ToList();
        }

        if (notifyNewItems && _timelineInitialized && existingEventIds.Count > 0)
        {
            NotifyNewTimelineItems(existingEventIds);
        }

        _timelineInitialized = true;
    }

    private async Task OnFocusPlayerAsync(int playerIndex)
    {
        if (_gameMap is null || playerIndex < 0 || playerIndex >= _mapPlayerStates.Count)
        {
            return;
        }

        var playerState = _mapPlayerStates[playerIndex];
        var focusNodeId = playerState.CurrentNodeId;

        if (string.IsNullOrWhiteSpace(focusNodeId) && !string.IsNullOrWhiteSpace(playerState.CurrentCityName))
        {
            focusNodeId = _gameMap.RouteCityOptions
                .FirstOrDefault(option => string.Equals(option.CityName, playerState.CurrentCityName, StringComparison.OrdinalIgnoreCase))
                .NodeId;
        }

        if (string.IsNullOrWhiteSpace(focusNodeId))
        {
            return;
        }

        await _gameMap.FocusRouteAsync([focusNodeId]);
    }

    private async Task<IReadOnlyList<EventTimelineItem>> LoadTimelineEventsAsync(bool waitForNewItems)
    {
        var lastKnownEventRowKey = _gameEngineEvents.Count > 0
            ? GetTimelineEventBaseId(_gameEngineEvents[^1])
            : null;

        return waitForNewItems && !string.IsNullOrWhiteSpace(lastKnownEventRowKey)
            ? await GameService.GetGameEventsAsync(GameId, lastKnownEventRowKey, CancellationToken.None)
            : await GameService.GetGameEventsAsync(GameId, CancellationToken.None);
    }

    private void ApplyLiveTimelineItems(IReadOnlyList<EventTimelineItem> timelineItems)
    {
        if (timelineItems.Count == 0)
        {
            return;
        }

        var previousEventIds = _gameEngineEvents
            .Select(item => item.EventId)
            .ToHashSet(StringComparer.Ordinal);
        var existingEventIds = new HashSet<string>(previousEventIds, StringComparer.Ordinal);
        var newItems = timelineItems
            .Where(item => existingEventIds.Add(item.EventId))
            .ToList();

        if (newItems.Count == 0)
        {
            return;
        }

        _gameEngineEvents.AddRange(newItems);
        _timelineInitialized = true;
        NotifyNewTimelineItems(previousEventIds);
    }

    private void ReplaceTimelineItems(IReadOnlyList<EventTimelineItem> timelineItems)
    {
        _gameEngineEvents = timelineItems.ToList();
        RemoveTimelineHistoryEntries();
        MergeTimelineNotifications();
        _timelineInitialized = true;
    }

