    private static int? ParseSelectedRailroadIndex(string? optionKey)
    {
        if (string.IsNullOrWhiteSpace(optionKey) || !optionKey.StartsWith("railroad:", StringComparison.Ordinal))
        {
            return null;
        }

        return int.TryParse(optionKey["railroad:".Length..], NumberStyles.Integer, CultureInfo.InvariantCulture, out var railroadIndex)
            ? railroadIndex
            : null;
    }

