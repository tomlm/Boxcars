    private void SyncRouteSelectionToActivePlayer()
    {
        if (_gameMap is null || _gameState is null || _gameState.Players.Count == 0)
        {
            return;
        }

        var activePlayer = _gameState.Players[_gameState.ActivePlayerIndex];
        var isBonusMove = _turnViewState.RedDie.HasValue && _turnViewState.WhiteDieOne <= 0 && _turnViewState.WhiteDieTwo <= 0;
        var restoredPreviewNodeIds = isBonusMove
            ? Array.Empty<string>()
            : _turnViewState.SelectedRoutePreview.NodeIds;
        var restoredPreviewSegmentKeys = isBonusMove
            ? Array.Empty<string>()
            : _turnViewState.SelectedRoutePreview.SegmentKeys;
        var startNodeId = activePlayer.CurrentNodeId ?? restoredPreviewNodeIds.FirstOrDefault();

        if (!string.IsNullOrWhiteSpace(startNodeId))
        {
            if (!string.Equals(_gameMap.RouteStartNodeId, startNodeId, StringComparison.OrdinalIgnoreCase))
            {
                _gameMap.SetStartCity(startNodeId);
            }
        }
        else
        {
            var routeCityOptions = _gameMap.RouteCityOptions;
            var startCity = routeCityOptions.FirstOrDefault(option =>
                string.Equals(option.CityName, activePlayer.CurrentCityName, StringComparison.OrdinalIgnoreCase));

            if (!string.IsNullOrWhiteSpace(startCity.NodeId))
            {
                startNodeId = startCity.NodeId;
                if (!string.Equals(_gameMap.RouteStartNodeId, startCity.NodeId, StringComparison.OrdinalIgnoreCase))
                {
                    _gameMap.SetStartCity(startCity.NodeId);
                }
            }
        }

        var restoredNodeIds = !string.IsNullOrWhiteSpace(startNodeId) && isBonusMove
            ? [startNodeId]
            : !string.IsNullOrWhiteSpace(startNodeId) && string.IsNullOrWhiteSpace(activePlayer.DestinationCityName)
                ? [startNodeId]
                : restoredPreviewNodeIds;

        if (string.IsNullOrWhiteSpace(activePlayer.DestinationCityName))
        {
            if (!RouteSelectionMatchesCurrentMap(restoredNodeIds, restoredPreviewSegmentKeys))
            {
                _gameMap.RestoreSelectedRoute(restoredNodeIds, restoredPreviewSegmentKeys);
            }

            _pendingRestoredRouteSelection = false;
            return;
        }

        var destinationRouteCityOptions = _gameMap.RouteCityOptions;

        if (destinationRouteCityOptions.Count == 0)
        {
            return;
        }

        var destinationCity = destinationRouteCityOptions.FirstOrDefault(option =>
            string.Equals(option.CityName, activePlayer.DestinationCityName, StringComparison.OrdinalIgnoreCase));

        if (string.IsNullOrWhiteSpace(destinationCity.NodeId))
        {
            _pendingRestoredRouteSelection = false;
            return;
        }

        if (!string.IsNullOrWhiteSpace(destinationCity.NodeId))
        {
            if (!string.Equals(_gameMap.DestinationNodeId, destinationCity.NodeId, StringComparison.OrdinalIgnoreCase))
            {
                _gameMap.SetDestinationCity(destinationCity.NodeId);
            }
        }

        if (!RouteSelectionMatchesCurrentMap(restoredNodeIds, restoredPreviewSegmentKeys))
        {
            _gameMap.RestoreSelectedRoute(restoredNodeIds, restoredPreviewSegmentKeys);
        }

        _pendingRestoredRouteSelection = false;
    }

    private void TryRestoreRouteSelection()
    {
        if (!_pendingRestoredRouteSelection)
        {
            return;
        }

        SyncRouteSelectionToActivePlayer();
    }

