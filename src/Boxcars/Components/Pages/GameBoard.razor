    private static string BuildBonusPendingLabel(RailBaronGameState state, Boxcars.Engine.Persistence.PlayerState player)
    {
        if (!state.Turn.BonusRollAvailable)
        {
            return string.Empty;
        }

        if (string.Equals(player.LocomotiveType, LocomotiveType.Superchief.ToString(), StringComparison.OrdinalIgnoreCase)
            && state.Turn.DiceResult?.RedDie is int redDie
            && redDie > 0)
        {
            return $"Bonus {redDie} pending";
        }

        return "Bonus Pending";
    }

    public async ValueTask DisposeAsync()
    {
        GamePresenceService.PresenceChanged -= OnPresenceChanged;

        try
        {
            await JavaScriptRuntime.InvokeVoidAsync("mapBoardPresence.stopHeartbeat", _pagePresenceRegistrationId);
        }
        catch (JSDisconnectedException)
        {
        }

        _presenceHeartbeatReference?.Dispose();
        _presenceHeartbeatReference = null;
        UnregisterPagePresence();

        if (_gameStateSubscriptionInitialized)
        {
            SharedGameEngine.OnStateChanged -= OnSharedGameStateChanged;
            SharedGameEngine.OnActionFailed -= OnSharedGameActionFailed;
            _gameStateSubscriptionInitialized = false;
        }

        if (_gameHubConnection is not null)
        {
            try
            {
                if (_gameHubConnection.State is HubConnectionState.Connected && !string.IsNullOrWhiteSpace(GameId))
                {
                    await _gameHubConnection.InvokeAsync(GameHubEvents.LeaveGame, GameId);
                }
            }
            catch
            {
            }

            await _gameHubConnection.DisposeAsync();
            _gameHubConnection = null;
        }

        await Task.CompletedTask;
    }

