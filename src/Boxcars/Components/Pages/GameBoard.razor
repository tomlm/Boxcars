    private NetworkTabModel CurrentDisplayNetworkTab
    {
        get
        {
            if (CurrentForcedSalePhase is not null)
            {
                return CurrentForcedSalePhase.NetworkTab;
            }

            if (_gameState is null || _playerBoardMapDefinition is null)
            {
                return new NetworkTabModel();
            }

            var playerIndex = EffectiveRecommendationPlayerIndex;
            if (playerIndex < 0 || playerIndex >= _gameState.Players.Count)
            {
                return new NetworkTabModel();
            }

            var player = _gameState.Players[playerIndex];
            var ownedRailroadIndices = player.OwnedRailroadIndices;
            if (ownedRailroadIndices.Count == 0)
            {
                return new NetworkTabModel { PlayerName = player.Name };
            }

            var currentCoverage = NetworkCoverageService.BuildSnapshot(_playerBoardMapDefinition, ownedRailroadIndices);
            var summaries = _playerBoardMapDefinition.Railroads
                .Where(railroad => ownedRailroadIndices.Contains(railroad.Index))
                .OrderBy(railroad => railroad.Name, StringComparer.OrdinalIgnoreCase)
                .Select(railroad =>
                {
                    var purchasePrice = railroad.PurchasePrice ?? RailBaronGameEngine.GetRailroadPurchasePrice(railroad.Index);
                    var projectedCoverage = NetworkCoverageService.BuildProjectedSnapshotAfterSale(_playerBoardMapDefinition, ownedRailroadIndices, railroad.Index);
                    return new NetworkRailroadSummaryModel
                    {
                        RailroadIndex = railroad.Index,
                        RailroadName = railroad.Name,
                        OriginalPurchasePrice = purchasePrice,
                        AccessPercentWithCurrentOwnership = currentCoverage.AccessibleCityPercent,
                        MonopolyPercentWithCurrentOwnership = currentCoverage.MonopolyCityPercent,
                        AccessPercentIfSold = projectedCoverage.AccessibleCityPercent,
                        MonopolyPercentIfSold = projectedCoverage.MonopolyCityPercent
                    };
                })
                .ToList();

            return new NetworkTabModel
            {
                PlayerName = player.Name,
                RailroadSummaries = summaries
            };
        }
    }

    private bool CanCurrentUserControlPlayer(int playerIndex)
    {
        if (_gameState is null
            || playerIndex < 0
            || playerIndex >= _gameState.Players.Count
            || !_gameState.Players[playerIndex].IsActive)
        {
            return false;
        }

        var slotUserId = _playerUserIdsByIndex.GetValueOrDefault(playerIndex);
        var delegatedControllerUserId = GamePresenceService.GetDelegatedControllerUserId(GameId, slotUserId);
        var isDirectlyBound = PlayerControlRules.IsDirectlyBoundToUser(slotUserId, _currentUserId);
        var isDelegatedController = PlayerControlRules.IsDelegatedController(delegatedControllerUserId, _currentUserId);

        return isDirectlyBound || isDelegatedController;
    }

    private bool CanCurrentUserAuthenticatedlyControlPlayer(int playerIndex)
    {
        if (_gameState is null
            || playerIndex < 0
            || playerIndex >= _gameState.Players.Count
            || !_gameState.Players[playerIndex].IsActive)
        {
            return false;
        }

        var slotUserId = _playerUserIdsByIndex.GetValueOrDefault(playerIndex);
        var delegatedControllerUserId = GamePresenceService.GetDelegatedControllerUserId(GameId, slotUserId);
        return PlayerControlRules.IsDirectlyBoundToUser(slotUserId, _currentUserId)
            || PlayerControlRules.IsDelegatedController(delegatedControllerUserId, _currentUserId);
    }

    private Boxcars.Engine.Persistence.PlayerState? CurrentControlledPlayerState
    {
        get
        {
            if (_gameState is null)
            {
                return null;
