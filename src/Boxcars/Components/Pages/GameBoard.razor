@page "/game/{GameId}"
@rendermode InteractiveServer
@using Boxcars.Components.Map
@using Boxcars.Data
@using Boxcars.Data.Maps
@using Boxcars.Engine.Data.Maps
@using Boxcars.Services
@using Boxcars.Services.Maps
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.FluentUI.AspNetCore.Components
@using System.Globalization
@attribute [Authorize]
@inject NavigationManager Navigation
@inject GameService GameService
@inject IMessageService MessageService

<PageTitle>Game - BoxCars</PageTitle>

<div class="map-board-shell">
    @* ── Left sidebar: player board ── *@
    <div class="map-board-sidebar">
        <PlayerBoard Players="_players" />
    </div>

    @* ── Main area: map + status bar + bottom bar ── *@
    <div class="map-board-main">
        @if (_gameMap?.Errors.Count > 0)
        {
            <FluentStack Orientation="Orientation.Vertical" Class="map-board-message map-board-error">
                <FluentLabel Typo="Typography.H6">Unable to render map</FluentLabel>
                @foreach (var error in _gameMap.Errors)
                {
                    <FluentLabel Typo="Typography.Body">@error</FluentLabel>
                }
            </FluentStack>
        }

        <div class="map-board-map-area">
            <MapComponent @ref="_gameMap"
                          MapFileName="@(_game?.MapFileName ?? GameService.DefaultMapFileName)"
                          SelectionMode="@_selectionMode"
                          PlayerId="@(_currentUserId ?? string.Empty)"
                          ZoomPercentChanged="OnZoomPercentChanged" />
        </div>

        @* ── Status line below map ── *@
        <FluentStack Orientation="Orientation.Horizontal" Wrap="true" VerticalAlignment="VerticalAlignment.Center" Class="map-board-status-bar">
            @if (_players.Count > 0)
            {
                var active = _players.FirstOrDefault(p => p.IsActiveTurn);
                if (active is not null)
                {
                    <FluentLabel Typo="Typography.Body" Class="status-bar-text">@active.Name: @active.LocomotiveLabel engine</FluentLabel>
                }
            }

            @if (_selectionMode == MapSelectionMode.Route && _gameMap?.RouteCityOptions.Count > 0)
            {
                <FluentStack Orientation="Orientation.Horizontal" Class="map-board-route-picker-row">
                    <FluentSelect TOption="string"
                                  Value="@(_gameMap?.RouteStartNodeId ?? string.Empty)"
                                  ValueChanged="OnStartCitySelected"
                                  Class="map-board-route-picker-select">
                        @foreach (var option in _gameMap!.RouteCityOptions)
                        {
                            <FluentOption Value="@option.NodeId">@option.CityName</FluentOption>
                        }
                    </FluentSelect>
                    <FluentSelect TOption="string"
                                  Value="@(_gameMap?.DestinationNodeId ?? string.Empty)"
                                  ValueChanged="OnDestinationCitySelected"
                                  Class="map-board-route-picker-select">
                        <FluentOption Value="">Destination</FluentOption>
                        @foreach (var option in _gameMap!.RouteCityOptions)
                        {
                            <FluentOption Value="@option.NodeId">@option.CityName</FluentOption>
                        }
                    </FluentSelect>
                    <FluentButton Appearance="Appearance.Accent"
                                  OnClick="OnSuggestRouteClickedAsync"
                                  Disabled="@(_gameMap?.CanSuggestRoute != true)">
                        Suggest
                    </FluentButton>
                </FluentStack>
            }
        </FluentStack>

        @* ── Bottom bar: action log + zoom/OK controls ── *@
        <FluentStack Orientation="Orientation.Horizontal" Class="map-board-bottom-bar">
            <div class="map-board-action-log">
                @foreach (var entry in _actionLog)
                {
                    <FluentLabel Typo="Typography.Body" Class="action-log-entry">@entry</FluentLabel>
                }
            </div>

            <FluentStack Orientation="Orientation.Vertical" Class="map-board-controls">
                <FluentStack Orientation="Orientation.Horizontal" Class="map-board-mode-row">
                    <FluentButton Appearance="@GetModeButtonAppearance(MapSelectionMode.Rail)"
                                  OnClick="() => SetSelectionMode(MapSelectionMode.Rail)">
                        Rail
                    </FluentButton>
                    <FluentButton Appearance="@GetModeButtonAppearance(MapSelectionMode.Route)"
                                  OnClick="() => SetSelectionMode(MapSelectionMode.Route)">
                        Move
                    </FluentButton>
                </FluentStack>

                <FluentStack Orientation="Orientation.Horizontal" Class="map-board-zoom-row">
                    <FluentLabel Typo="Typography.Body">Zoom:</FluentLabel>
                    <FluentSlider TValue="int"
                                  Min="100"
                                  Max="500"
                                  Step="50"
                                  @bind-Value="@_zoomPercent"
                                  @bind-Value:after="OnZoomSliderChangedAsync"
                                  Class="map-board-zoom-slider" />
                </FluentStack>

                <FluentButton Appearance="Appearance.Accent" OnClick="OnResetZoomAsync">
                    OK (done)
                </FluentButton>

                <FluentButton Appearance="Appearance.Lightweight" OnClick="EndGameAsync">
                    End Game
                </FluentButton>
            </FluentStack>
        </FluentStack>
    </div>
</div>

@code {
    private string? _currentUserId;
    private GameEntity? _game;
    private MapComponent? _gameMap;
    private MapSelectionMode _selectionMode = MapSelectionMode.Rail;
    private int _zoomPercent = 100;
    private List<PlayerBoardModel> _players = new();
    private List<string> _actionLog = new();

    [Parameter]
    public string GameId { get; set; } = string.Empty;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is null)
        {
            return;
        }

        var state = await AuthState;
        _currentUserId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrWhiteSpace(GameId))
        {
            return;
        }

        _game = await GameService.GetGameAsync(GameId, CancellationToken.None);

        // TODO: Replace with real player data from GameEngine once wired up
        _players = GetPlaceholderPlayers();
        _actionLog = GetPlaceholderActionLog();
    }

    private async Task EndGameAsync()
    {
        if (string.IsNullOrWhiteSpace(_currentUserId) || string.IsNullOrWhiteSpace(GameId))
        {
            await MessageService.ShowMessageBarAsync("Unable to end game: missing user or game context.", MessageIntent.Error, "GAME");
            return;
        }

        var result = await GameService.EndGameAsync(_currentUserId, GameId, CancellationToken.None);
        if (!result.Success)
        {
            await MessageService.ShowMessageBarAsync(result.Reason ?? "Unable to end game.", MessageIntent.Error, "GAME");
            return;
        }

        Navigation.NavigateTo("/dashboard");
    }

    private void SetSelectionMode(MapSelectionMode mode)
    {
        _selectionMode = mode;
    }

    private void OnZoomPercentChanged(double zoomPercent)
    {
        _zoomPercent = (int)zoomPercent;
        StateHasChanged();
    }

    private async Task OnZoomSliderChangedAsync()
    {
        if (_gameMap is null)
        {
            return;
        }

        await _gameMap.SetZoom(_zoomPercent);
    }

    private async Task OnResetZoomAsync()
    {
        if (_gameMap is null)
        {
            return;
        }

        await _gameMap.ResetZoom();
    }

    private void OnStartCitySelected(string? selectedNodeId)
    {
        if (string.IsNullOrWhiteSpace(selectedNodeId) || _gameMap is null)
        {
            return;
        }

        _gameMap.SetStartCity(selectedNodeId);
    }

    private void OnDestinationCitySelected(string? selectedNodeId)
    {
        if (string.IsNullOrWhiteSpace(selectedNodeId) || _gameMap is null)
        {
            return;
        }

        _gameMap.SetDestinationCity(selectedNodeId);
    }

    private async Task OnSuggestRouteClickedAsync()
    {
        if (_gameMap is null)
        {
            return;
        }

        await _gameMap.SuggestRouteAsync();
    }

    private Appearance GetModeButtonAppearance(MapSelectionMode mode)
    {
        return _selectionMode == mode ? Appearance.Accent : Appearance.Neutral;
    }

    private List<PlayerBoardModel> GetPlaceholderPlayers()
    {
        // Placeholder data — replace with actual GameEngine player state
        return new List<PlayerBoardModel>
        {
            new() { Index = 0, Name = "Player 1", Color = "#00c000", IsAtDestination = true, LocationLabel = "Salt Lake City", Payoff = 25000, Cash = 85000, IsCurrentUser = true, HomeCity = "Chicago", IsActiveTurn = true, LocomotiveLabel = "Superchief" },
            new() { Index = 1, Name = "Player 2", Color = "#ff0000", IsAtDestination = false, LocationLabel = "Knoxville", DistanceToDestination = 1, Payoff = 5500, Cash = 42000, HomeCity = "Kansas City" },
            new() { Index = 2, Name = "Player 3", Color = "#00e0e0", IsAtDestination = false, LocationLabel = "Philadelphia", DistanceToDestination = 1, Payoff = 6500, Cash = 115000, HomeCity = "Chicago" },
            new() { Index = 3, Name = "Player 4", Color = "#000080", IsAtDestination = false, LocationLabel = "Kansas City", DistanceToDestination = 1, Payoff = 6500, Cash = 72000, HomeCity = "Atlanta" },
        };
    }

    private List<string> GetPlaceholderActionLog()
    {
        // Placeholder log — replace with real game engine events
        return new List<string>
        {
            "Player 4 paid Player 1 $10,000 in use fees",
            "Player 1 rolled 10; moved SW55,SW59,SW58,SW53,SW52,NW62,NW61",
            "Player 1 arrived in Salt Lake City; gets $25,000",
            "Player 1 upgrades to a Superchief",
            "Player 1 paid Player 4 $10,000 in use fees",
            "ROUND 47, elapsed mins=75.1",
            "Player 4's next destination is Knoxville",
            "Player 4 rolled 10 (6 + 4 bonus); moved NC52,NC54,NC57,SC36,SC94,SC41,SC22,SC21,SC19,SC15,SE42,SE85,SE41",
        };
    }
}
