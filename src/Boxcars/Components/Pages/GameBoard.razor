        && (
            CurrentPurchasePhase.RailroadOptions.Any(option =>
                string.Equals(BuildRailroadOptionKey(option.RailroadIndex), _selectedPurchaseOptionKey, StringComparison.Ordinal)
                && option.IsAffordable)
            || CurrentPurchasePhase.EngineOptions.Any(option =>
                string.Equals(BuildEngineOptionKey(option.EngineType), _selectedPurchaseOptionKey, StringComparison.Ordinal)
                && option.IsEligible));

