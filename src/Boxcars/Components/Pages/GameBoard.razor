@page "/game/{GameId}"
@rendermode InteractiveServer
@using Boxcars.Components.Map
@using Boxcars.Data.Maps
@using Boxcars.Engine.Data.Maps
@using Boxcars.Services
@using Boxcars.Services.Maps
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.FluentUI.AspNetCore.Components
@using System.Globalization
@attribute [Authorize]
@inject NavigationManager Navigation
@inject GameService GameService
@inject IMessageService MessageService

<PageTitle>Game - BoxCars</PageTitle>

<div class="map-board-shell">
    <FluentCard class="map-board-controls">
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.75rem;">
            <FluentLabel Typo="Typography.H5">Map Board</FluentLabel>
            <FluentLabel Typo="Typography.Body">Map selection is provided by game setup.</FluentLabel>

            <div class="map-board-mode-row">
                <FluentLabel Typo="Typography.Body">Mode</FluentLabel>
                <FluentButton Appearance="@GetModeButtonAppearance(MapSelectionMode.Rail)"
                              OnClick="() => SetSelectionMode(MapSelectionMode.Rail)">
                    Rail mode
                </FluentButton>
                <FluentButton Appearance="@GetModeButtonAppearance(MapSelectionMode.Route)"
                              OnClick="() => SetSelectionMode(MapSelectionMode.Route)">
                    Movement mode
                </FluentButton>
                @if (!string.IsNullOrWhiteSpace(_gameMap?.RouteStartNodeName))
                {
                    <FluentLabel Typo="Typography.Body">Start: @_gameMap.RouteStartNodeName</FluentLabel>
                }
                @if (!string.IsNullOrWhiteSpace(_gameMap?.DestinationCityName))
                {
                    <FluentLabel Typo="Typography.Body">Destination: @_gameMap.DestinationCityName</FluentLabel>
                }
                @if (_gameMap?.RouteSuggestion is not null)
                {
                    if (_gameMap.RouteSuggestion.Status == RouteSuggestionStatus.Success)
                    {
                        <FluentLabel Typo="Typography.Body">Suggested Cost: @_gameMap.RouteSuggestion.TotalCost.ToString("C0", CultureInfo.CurrentCulture)</FluentLabel>
                    }
                    else if (_gameMap.RouteSuggestion.Status == RouteSuggestionStatus.NoRoute)
                    {
                        <FluentLabel Typo="Typography.Body">No route available</FluentLabel>
                    }
                }
            </div>

            @if (_selectionMode == MapSelectionMode.Route && _gameMap?.RouteCityOptions.Count > 0)
            {
                <div class="map-board-route-picker-row">
                    <div class="map-board-route-picker-group">
                        <FluentLabel Typo="Typography.Body">Start city</FluentLabel>
                        <select class="map-board-route-picker-select"
                                value="@(_gameMap?.RouteStartNodeId ?? string.Empty)"
                                @onchange="OnStartCityChanged">
                            @foreach (var option in _gameMap!.RouteCityOptions)
                            {
                                <option value="@option.NodeId">@option.CityName</option>
                            }
                        </select>
                    </div>

                    <div class="map-board-route-picker-group">
                        <FluentLabel Typo="Typography.Body">Destination city</FluentLabel>
                        <select class="map-board-route-picker-select"
                                value="@(_gameMap?.DestinationNodeId ?? string.Empty)"
                                @onchange="OnDestinationCityChanged">
                            <option value="">Select destination</option>
                            @foreach (var option in _gameMap!.RouteCityOptions)
                            {
                                <option value="@option.NodeId">@option.CityName</option>
                            }
                        </select>
                    </div>

                    <FluentButton Appearance="Appearance.Accent"
                                  OnClick="OnSuggestRouteClickedAsync"
                                  Disabled="@(_gameMap?.CanSuggestRoute != true)">
                        Suggest route
                    </FluentButton>
                </div>
            }

            <div class="map-board-zoom-row">
                <FluentLabel Typo="Typography.Body">Zoom (@_zoomPercent.ToString("F0")%)</FluentLabel>
                <input type="range"
                       min="100"
                       max="500"
                       step="50"
                       value="@_zoomPercent"
                       @oninput="OnZoomSliderInput"
                       class="map-board-zoom-slider" />
                <FluentButton Appearance="Appearance.Neutral" OnClick="OnResetZoomAsync">Fit to board</FluentButton>

                <FluentButton Appearance="Appearance.Lightweight" OnClick="EndGameAsync">
                    End Game
                </FluentButton>
            </div>
        </FluentStack>
    </FluentCard>

    @if (_gameMap?.Errors.Count > 0)
    {
        <FluentCard class="map-board-message map-board-error">
            <FluentLabel Typo="Typography.H6">Unable to render map</FluentLabel>
            @foreach (var error in _gameMap.Errors)
            {
                <FluentLabel Typo="Typography.Body">@error</FluentLabel>
            }
        </FluentCard>
    }

    <MapComponent @ref="_gameMap"
                   MapFileName="@_mapFileName"
                   SelectionMode="@_selectionMode"
                   ZoomPercentChanged="OnZoomPercentChanged" />

    @if (_gameMap?.Warnings.Count > 0)
    {
        <FluentCard class="map-board-message map-board-warning map-board-warning-panel">
            <details open>
                <summary>Map Warnings (@_gameMap.Warnings.Count)</summary>
                <div class="map-board-warning-list">
                    @foreach (var warning in _gameMap.Warnings)
                    {
                        <FluentLabel Typo="Typography.Body">@warning</FluentLabel>
                    }
                </div>
            </details>
        </FluentCard>
    }
</div>

@code {
    private string? _currentUserId;
    private string _mapFileName = GameService.DefaultMapFileName;
    private MapComponent? _gameMap;
    private MapSelectionMode _selectionMode = MapSelectionMode.Rail;
    private double _zoomPercent = 100;

    [Parameter]
    public string GameId { get; set; } = string.Empty;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is null)
        {
            return;
        }

        var state = await AuthState;
        _currentUserId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrWhiteSpace(GameId))
        {
            return;
        }

        var game = await GameService.GetGameAsync(GameId, CancellationToken.None);
        if (!string.IsNullOrWhiteSpace(game?.MapFileName))
        {
            _mapFileName = game.MapFileName;
        }
    }

    private async Task EndGameAsync()
    {
        if (string.IsNullOrWhiteSpace(_currentUserId) || string.IsNullOrWhiteSpace(GameId))
        {
            await MessageService.ShowMessageBarAsync("Unable to end game: missing user or game context.", MessageIntent.Error, "GAME");
            return;
        }

        var result = await GameService.EndGameAsync(_currentUserId, GameId, CancellationToken.None);
        if (!result.Success)
        {
            await MessageService.ShowMessageBarAsync(result.Reason ?? "Unable to end game.", MessageIntent.Error, "GAME");
            return;
        }

        Navigation.NavigateTo("/dashboard");
    }

    private void SetSelectionMode(MapSelectionMode mode)
    {
        _selectionMode = mode;
    }

    private void OnZoomPercentChanged(double zoomPercent)
    {
        _zoomPercent = zoomPercent;
        StateHasChanged();
    }

    private async Task OnZoomSliderInput(ChangeEventArgs args)
    {
        if (_gameMap is null)
        {
            return;
        }

        if (!double.TryParse(args.Value?.ToString(), out var requestedZoom))
        {
            return;
        }

        await _gameMap.SetZoom(requestedZoom);
    }

    private async Task OnResetZoomAsync()
    {
        if (_gameMap is null)
        {
            return;
        }

        await _gameMap.ResetZoom();
    }

    private void OnStartCityChanged(ChangeEventArgs args)
    {
        var selectedNodeId = args.Value?.ToString();
        if (string.IsNullOrWhiteSpace(selectedNodeId) || _gameMap is null)
        {
            return;
        }

        _gameMap.SetStartCity(selectedNodeId);
    }

    private void OnDestinationCityChanged(ChangeEventArgs args)
    {
        var selectedNodeId = args.Value?.ToString();
        if (string.IsNullOrWhiteSpace(selectedNodeId) || _gameMap is null)
        {
            return;
        }

        _gameMap.SetDestinationCity(selectedNodeId);
    }

    private async Task OnSuggestRouteClickedAsync()
    {
        if (_gameMap is null)
        {
            return;
        }

        await _gameMap.SuggestRouteAsync();
    }

    private Appearance GetModeButtonAppearance(MapSelectionMode mode)
    {
        return _selectionMode == mode ? Appearance.Accent : Appearance.Neutral;
    }
}
