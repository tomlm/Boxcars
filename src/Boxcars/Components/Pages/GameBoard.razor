    private RailroadOverlayInfo? BuildSelectedRailroadOverlay(int railroadIndex)
    {
        if (_gameState is null || _playerBoardMapDefinition is null)
        {
            return null;
        }

        var effectivePlayerIndex = EffectiveRecommendationPlayerIndex;
        if (effectivePlayerIndex < 0 || effectivePlayerIndex >= _gameState.Players.Count)
        {
            return null;
        }

        var effectivePlayer = _gameState.Players[effectivePlayerIndex];
        var railroad = _playerBoardMapDefinition.Railroads.FirstOrDefault(entry => entry.Index == railroadIndex);
        if (railroad is null)
        {
            return null;
        }

        var ownedRailroadIndices = effectivePlayer.OwnedRailroadIndices;
        var currentCoverage = NetworkCoverageService.BuildSnapshot(_playerBoardMapDefinition, ownedRailroadIndices);
        var purchasePrice = railroad.PurchasePrice ?? RailBaronGameEngine.GetRailroadPurchasePrice(railroad.Index);
        var bankSalePrice = purchasePrice / 2;
        var ownerIndex = _gameState.RailroadOwnership.TryGetValue(railroad.Index, out var resolvedOwnerIndex) ? resolvedOwnerIndex : null;

        if (ownerIndex == effectivePlayerIndex)
        {
            var projectedCoverage = NetworkCoverageService.BuildProjectedSnapshotAfterSale(_playerBoardMapDefinition, ownedRailroadIndices, railroad.Index);
            return new RailroadOverlayInfo
            {
                RailroadIndex = railroad.Index,
                RailroadName = railroad.Name,
                ContextLabel = "Owned by you",
                ValueLabel = "Bank sale value",
                PurchasePrice = bankSalePrice,
                IsAffordable = true,
                ValueKind = RailroadOverlayValueKind.Sale,
                MetricRows = BuildOverlayMetricRows(currentCoverage, projectedCoverage, CurrentMapAnalysisReport)
            };
        }

        var projectedPurchaseCoverage = NetworkCoverageService.BuildProjectedSnapshot(_playerBoardMapDefinition, ownedRailroadIndices, railroad.Index);
        if (ownerIndex.HasValue)
        {
            var ownerName = ownerIndex.Value >= 0 && ownerIndex.Value < _gameState.Players.Count
                ? _gameState.Players[ownerIndex.Value].Name
                : "another player";
            var canAffordAuctionOpeningBid = effectivePlayer.Cash >= bankSalePrice;

            return new RailroadOverlayInfo
            {
                RailroadIndex = railroad.Index,
                RailroadName = railroad.Name,
                ContextLabel = $"Owned by {ownerName}",
                ValueLabel = "Auction opening bid",
                PurchasePrice = bankSalePrice,
                IsAffordable = canAffordAuctionOpeningBid,
                ValueKind = canAffordAuctionOpeningBid ? RailroadOverlayValueKind.Affordable : RailroadOverlayValueKind.TooExpensive,
                MetricRows = BuildOverlayMetricRows(currentCoverage, projectedPurchaseCoverage, CurrentMapAnalysisReport)
            };
        }

        var isAffordable = effectivePlayer.Cash >= purchasePrice;
        return new RailroadOverlayInfo
        {
            RailroadIndex = railroad.Index,
            RailroadName = railroad.Name,
            ContextLabel = "Unowned railroad",
            ValueLabel = "Purchase price",
            PurchasePrice = purchasePrice,
            IsAffordable = isAffordable,
            ValueKind = isAffordable ? RailroadOverlayValueKind.Affordable : RailroadOverlayValueKind.TooExpensive,
            MetricRows = BuildOverlayMetricRows(currentCoverage, projectedPurchaseCoverage, CurrentMapAnalysisReport)
        };
    }

    private IReadOnlyList<RailroadPurchaseOption> WaitingRailroadOptions
    {
        get
        {
            if (_gameState is null || _playerBoardMapDefinition is null)
            {
                return [];
            }

            var effectivePlayerIndex = EffectiveRecommendationPlayerIndex;
            if (effectivePlayerIndex < 0 || effectivePlayerIndex >= _gameState.Players.Count)
            {
                return [];
            }

            var cashAvailable = _gameState.Players[effectivePlayerIndex].Cash;
            return _playerBoardMapDefinition.Railroads
                .Where(railroad => !_gameState.RailroadOwnership.TryGetValue(railroad.Index, out var ownerIndex) || ownerIndex is null)
                .Select(railroad =>
                {
                    var purchasePrice = railroad.PurchasePrice ?? RailBaronGameEngine.GetRailroadPurchasePrice(railroad.Index);
                    return new RailroadPurchaseOption
                    {
                        RailroadIndex = railroad.Index,
                        RailroadName = railroad.Name,
                        ShortName = railroad.ShortName ?? string.Empty,
                        PurchasePrice = purchasePrice,
                        IsAffordable = cashAvailable >= purchasePrice,
                        IsSelected = string.Equals(BuildRailroadOptionKey(railroad.Index), _selectedPurchaseOptionKey, StringComparison.Ordinal)
                    };
                })
                .OrderByDescending(option => option.PurchasePrice)
                .ThenBy(option => option.RailroadName, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
    }

    private static List<RailroadOverlayMetricRow> BuildOverlayMetricRows(
        NetworkCoverageSnapshot currentCoverage,
        NetworkCoverageSnapshot projectedCoverage,
        MapAnalysisReport? report)
    {
        var currentAccessByCode = currentCoverage.RegionAccess.ToDictionary(region => region.RegionCode, region => region.AccessibleDestinationPercent, StringComparer.OrdinalIgnoreCase);
        var projectedAccessByCode = projectedCoverage.RegionAccess.ToDictionary(region => region.RegionCode, region => region.AccessibleDestinationPercent, StringComparer.OrdinalIgnoreCase);
        var currentMonopolyByCode = currentCoverage.RegionAccess.ToDictionary(region => region.RegionCode, region => region.MonopolyDestinationPercent, StringComparer.OrdinalIgnoreCase);
        var projectedMonopolyByCode = projectedCoverage.RegionAccess.ToDictionary(region => region.RegionCode, region => region.MonopolyDestinationPercent, StringComparer.OrdinalIgnoreCase);
        var rows = new List<RailroadOverlayMetricRow>
        {
            new()
            {
                Label = "Total",
                AccessPercent = currentCoverage.AccessibleDestinationPercent,
                ProjectedAccessPercent = projectedCoverage.AccessibleDestinationPercent,
                MonopolyPercent = currentCoverage.MonopolyDestinationPercent,
                ProjectedMonopolyPercent = projectedCoverage.MonopolyDestinationPercent,
                AccessDeltaPercent = Math.Round(projectedCoverage.AccessibleDestinationPercent - currentCoverage.AccessibleDestinationPercent, 1, MidpointRounding.AwayFromZero),
                MonopolyDeltaPercent = Math.Round(projectedCoverage.MonopolyDestinationPercent - currentCoverage.MonopolyDestinationPercent, 1, MidpointRounding.AwayFromZero)
            }
        };

        rows.AddRange((report?.RegionProbabilityRows ?? Array.Empty<RegionProbabilityRow>())
            .Select(region =>
            {
                var currentAccessPercent = currentAccessByCode.TryGetValue(region.RegionCode, out var currentAccessValue) ? currentAccessValue : 0m;
                var projectedAccessPercent = projectedAccessByCode.TryGetValue(region.RegionCode, out var projectedAccessValue) ? projectedAccessValue : 0m;
                var currentMonopolyPercent = currentMonopolyByCode.TryGetValue(region.RegionCode, out var currentMonopolyValue) ? currentMonopolyValue : 0m;
                var projectedMonopolyPercent = projectedMonopolyByCode.TryGetValue(region.RegionCode, out var projectedMonopolyValue) ? projectedMonopolyValue : 0m;
                return new RailroadOverlayMetricRow
                {
                    Label = region.RegionCode,
                    AccessPercent = currentAccessPercent,
                    ProjectedAccessPercent = projectedAccessPercent,
                    MonopolyPercent = currentMonopolyPercent,
                    ProjectedMonopolyPercent = projectedMonopolyPercent,
                    AccessDeltaPercent = Math.Round(projectedAccessPercent - currentAccessPercent, 1, MidpointRounding.AwayFromZero),
                    MonopolyDeltaPercent = Math.Round(projectedMonopolyPercent - currentMonopolyPercent, 1, MidpointRounding.AwayFromZero)
                };
            }));

        return rows;
    }

    private IReadOnlyList<RailroadOverlayMetricRow> BuildPlayerCoverageMetricRows(Boxcars.Engine.Persistence.PlayerState player)
    {
        if (_playerBoardMapDefinition is null)
        {
            return Array.Empty<RailroadOverlayMetricRow>();
        }

        var coverage = NetworkCoverageService.BuildSnapshot(_playerBoardMapDefinition, player.OwnedRailroadIndices);
        var regionAccessByCode = coverage.RegionAccess.ToDictionary(region => region.RegionCode, region => region.AccessibleDestinationPercent, StringComparer.OrdinalIgnoreCase);
        var regionMonopolyByCode = coverage.RegionAccess.ToDictionary(region => region.RegionCode, region => region.MonopolyDestinationPercent, StringComparer.OrdinalIgnoreCase);
        var rows = new List<RailroadOverlayMetricRow>
        {
            new()
            {
                Label = "Total",
                AccessPercent = coverage.AccessibleDestinationPercent,
                ProjectedAccessPercent = coverage.AccessibleDestinationPercent,
                MonopolyPercent = coverage.MonopolyDestinationPercent,
                ProjectedMonopolyPercent = coverage.MonopolyDestinationPercent,
                AccessDeltaPercent = 0m,
                MonopolyDeltaPercent = 0m
            }
        };

        rows.AddRange(_playerBoardMapDefinition.Regions.Select(region => new RailroadOverlayMetricRow
        {
            Label = region.Code,
            AccessPercent = regionAccessByCode.TryGetValue(region.Code, out var accessValue) ? accessValue : 0m,
            ProjectedAccessPercent = regionAccessByCode.TryGetValue(region.Code, out accessValue) ? accessValue : 0m,
            MonopolyPercent = regionMonopolyByCode.TryGetValue(region.Code, out var monopolyValue) ? monopolyValue : 0m,
            ProjectedMonopolyPercent = regionMonopolyByCode.TryGetValue(region.Code, out monopolyValue) ? monopolyValue : 0m,
            AccessDeltaPercent = 0m,
            MonopolyDeltaPercent = 0m
        }));

        return rows;
    }

