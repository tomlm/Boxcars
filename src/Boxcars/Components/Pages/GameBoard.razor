            if (_gameState.ActivePlayerIndex >= 0
                && _gameState.ActivePlayerIndex < _gameState.Players.Count
                && CanCurrentUserControlPlayer(_gameState.ActivePlayerIndex))
            {
                return _gameState.Players[_gameState.ActivePlayerIndex];
