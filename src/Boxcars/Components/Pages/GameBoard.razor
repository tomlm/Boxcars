    private void RefreshPlayerConnectionStates()
    {
        if (_players.Count == 0)
        {
            return;
        }

        var previousConnectionStates = _players
            .ToDictionary(player => player.Index, player => player.IsConnected);
        var previousDelegatedControllers = _players
            .ToDictionary(player => player.Index, player => player.DelegatedControllerUserId);

        _players = _players
            .Select(player =>
            {
                var slotUserId = _playerUserIdsByIndex.GetValueOrDefault(player.Index);
                var delegatedControllerUserId = GamePresenceService.GetDelegatedControllerUserId(GameId, slotUserId) ?? string.Empty;
                return new PlayerBoardModel
                {
                    Index = player.Index,
                    Name = player.Name,
                    ThumbnailUrl = player.ThumbnailUrl,
                    Color = player.Color,
                    IsAtDestination = player.IsAtDestination,
                    TripStartLabel = player.TripStartLabel,
                    TripDestinationLabel = player.TripDestinationLabel,
                    DistanceToDestination = player.DistanceToDestination,
                    Payoff = player.Payoff,
                    Cash = player.Cash,
                    IsCurrentUser = player.IsCurrentUser,
                    IsDelegatedToCurrentUser = PlayerControlRules.IsDelegatedController(delegatedControllerUserId, _currentUserId),
                    CanToggleConnection = player.CanToggleConnection,
                    HomeCity = player.HomeCity,
                    IsActiveTurn = player.IsActiveTurn,
                    IsEliminated = player.IsEliminated,
                    IsConnected = IsPlayerConnected(slotUserId),
                    CanTakeDelegatedControl = CanCurrentUserTakeDelegatedControl(player.Index, slotUserId, delegatedControllerUserId),
                    CanReleaseDelegatedControl = CanCurrentUserReleaseDelegatedControl(delegatedControllerUserId),
                    DelegatedControllerUserId = delegatedControllerUserId,
                    DelegatedControllerDisplayName = ResolveParticipantDisplayName(delegatedControllerUserId, null),
                    LocomotiveLabel = player.LocomotiveLabel,
                    FeesOwed = player.FeesOwed,
                    BonusPendingLabel = player.BonusPendingLabel,
                    CoverageMetrics = player.CoverageMetrics
                };
            })
            .ToList();

        if (_presenceNotificationsEnabled)
        {
            NotifyPresenceChanges(previousConnectionStates);
            NotifyDelegatedControlChanges(previousDelegatedControllers);
        }
    }

    private void RegisterPagePresence()
    {
        if (_pagePresenceRegistered || string.IsNullOrWhiteSpace(GameId) || string.IsNullOrWhiteSpace(_currentUserId))
        {
            return;
        }

        _pagePresenceRegistered = true;
        GamePresenceService.AddConnection(GameId, _currentUserId, _pagePresenceRegistrationId);
        ReevaluatePlayerPresenceState();
        _presenceNotificationsEnabled = true;
        StateHasChanged();
    }

    private void UnregisterPagePresence()
    {
        if (!_pagePresenceRegistered || string.IsNullOrWhiteSpace(GameId) || string.IsNullOrWhiteSpace(_currentUserId))
        {
            return;
        }

        _presenceNotificationsEnabled = false;
        _pagePresenceRegistered = false;
        GamePresenceService.RemoveConnection(GameId, _currentUserId, _pagePresenceRegistrationId);
    }

    private void OnPresenceChanged(string gameId)
    {
        if (!string.Equals(gameId, GameId, StringComparison.Ordinal))
        {
            return;
        }

        _ = InvokeAsync(() =>
        {
            ReevaluatePlayerPresenceState();
            StateHasChanged();
        });
    }

    private void NotifyPresenceChanges(IReadOnlyDictionary<int, bool> previousConnectionStates)
    {
        foreach (var player in _players)
        {
            if (!previousConnectionStates.TryGetValue(player.Index, out var wasConnected)
                || wasConnected == player.IsConnected)
            {
                continue;
            }

            var message = $"{player.Name} {(player.IsConnected ? "connected" : "disconnected")}.";
            Snackbar.Add(
                message,
                player.IsConnected ? Severity.Success : Severity.Warning,
                options =>
                {
                    var playerColor = PlayerColorOptions.NormalizeOrDefault(player.Color);
                    options.SnackbarTypeClass = $"player-snackbar player-snackbar-{playerColor}";
                });
        }
    }

    private void NotifyDelegatedControlChanges(IReadOnlyDictionary<int, string> previousDelegatedControllers)
    {
        foreach (var player in _players)
        {
            previousDelegatedControllers.TryGetValue(player.Index, out var previousControllerUserId);
            var currentControllerUserId = player.DelegatedControllerUserId;

            if (string.Equals(previousControllerUserId, currentControllerUserId, StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            string? message;
            Severity severity;

            if (!string.IsNullOrWhiteSpace(currentControllerUserId))
            {
                var controllerName = string.IsNullOrWhiteSpace(player.DelegatedControllerDisplayName)
                    ? "Another player"
                    : player.DelegatedControllerDisplayName;
                var previousControllerName = ResolveParticipantDisplayName(previousControllerUserId, null);
                message = string.IsNullOrWhiteSpace(previousControllerName)
                    ? $"{controllerName} took control of {player.Name}."
                    : $"{controllerName} took control of {player.Name} from {previousControllerName}.";
                severity = Severity.Info;
            }
            else if (!string.IsNullOrWhiteSpace(previousControllerUserId))
            {
                var previousControllerName = ResolveParticipantDisplayName(previousControllerUserId, null);
                message = player.IsConnected
                    ? $"{player.Name} reconnected. {previousControllerName} lost delegated control."
                    : $"{previousControllerName} stopped controlling {player.Name}.";
                severity = player.IsConnected ? Severity.Success : Severity.Warning;
            }
            else
            {
                continue;
            }

            Snackbar.Add(message, severity, options =>
            {
                var playerColor = PlayerColorOptions.NormalizeOrDefault(player.Color);
                options.SnackbarTypeClass = $"player-snackbar player-snackbar-{playerColor}";
            });
        }
    }

    private void NotifyNewTimelineItems(HashSet<string> existingEventIds)
    {
        var notifyCandidates = _gameEngineEvents
            .Where(item => !existingEventIds.Contains(item.EventId))
            .ToList();

        foreach (var item in notifyCandidates.Where(ShouldNotifyTimelineItem))
        {
            var message = item.Description;
            if (item.EventKind == EventTimelineKind.NewDestination
                && item.ActingPlayerIndex.HasValue
                && item.ActingPlayerIndex.Value >= 0
                && item.ActingPlayerIndex.Value < _players.Count)
            {
                var payoff = _players[item.ActingPlayerIndex.Value].Payoff;
                if (payoff > 0)
                {
                    message = $"{message}, Payoff ${payoff:N0}";
                }
            }

            Snackbar.Add(
                message,
                ResolveTimelineSeverity(item),
                options =>
                {
                    options.Icon = ResolveTimelineSnackbarIcon(item);

                    var snackbarClass = ResolveTimelineSnackbarClass(item);
                    if (!string.IsNullOrWhiteSpace(snackbarClass))
                    {
                        options.SnackbarTypeClass = snackbarClass;
                    }
                });
        }
    }

    private static bool ShouldNotifyTimelineItem(EventTimelineItem item)
    {
        return item.EventKind switch
        {
            EventTimelineKind.NewDestination => true,
            EventTimelineKind.Move => true,
            EventTimelineKind.Arrival => true,
            EventTimelineKind.PayFees => true,
            EventTimelineKind.Purchase => true,
            EventTimelineKind.DeclinedPurchase => true,
            _ => false
        };
    }

    private static string GetTimelineEventBaseId(EventTimelineItem item)
    {
        var separatorIndex = item.EventId.LastIndexOf(':');
        return separatorIndex >= 0
            ? item.EventId[..separatorIndex]
            : item.EventId;
    }

    private static Severity ResolveTimelineSeverity(EventTimelineItem item)
    {
        return item.EventKind switch
        {
            EventTimelineKind.Arrival => Severity.Success,
            EventTimelineKind.PayFees => Severity.Warning,
            EventTimelineKind.PurchaseOpportunity => Severity.Warning,
            EventTimelineKind.Purchase => Severity.Warning,
            _ => Severity.Info
        };
    }

    private string? ResolveTimelineSnackbarClass(EventTimelineItem item)
    {
        if (!item.ActingPlayerIndex.HasValue
            || item.ActingPlayerIndex.Value < 0
            || item.ActingPlayerIndex.Value >= _players.Count)
        {
            return null;
        }

        var playerColor = PlayerColorOptions.NormalizeOrDefault(_players[item.ActingPlayerIndex.Value].Color);
        return $"player-snackbar player-snackbar-{playerColor}";
    }

    private static string ResolveTimelineSnackbarIcon(EventTimelineItem item)
    {
        return item.EventKind switch
        {
            EventTimelineKind.Move => Icons.Material.Filled.DirectionsRailway,
            EventTimelineKind.NewDestination => Icons.Material.Filled.DirectionsRailway,
            EventTimelineKind.Arrival => Icons.Material.Filled.AttachMoney,
            EventTimelineKind.PayFees => Icons.Material.Filled.AttachMoney,
            EventTimelineKind.Purchase => Icons.Material.Filled.ShoppingCart,
            EventTimelineKind.DeclinedPurchase => Icons.Material.Filled.RemoveShoppingCart,
            EventTimelineKind.PurchaseOpportunity => Icons.Material.Filled.LocalOffer,
            _ => Icons.Material.Filled.Notifications
        };
    }

    private Task OnTogglePlayerConnectionAsync(int playerIndex)
    {
        var selectedPlayer = _players.FirstOrDefault(player => player.Index == playerIndex);
        if (selectedPlayer is null || !selectedPlayer.CanToggleConnection)
        {
            return Task.CompletedTask;
        }

        var userId = _playerUserIdsByIndex.GetValueOrDefault(playerIndex);
        if (string.IsNullOrWhiteSpace(userId))
        {
            return Task.CompletedTask;
        }

        var nextConnectedState = !selectedPlayer.IsConnected;
        GamePresenceService.SetMockConnectionState(GameId, userId, nextConnectedState);

        return Task.CompletedTask;
    }

    private Task OnToggleDelegatedControlAsync(int playerIndex)
    {
        if (string.IsNullOrWhiteSpace(GameId) || string.IsNullOrWhiteSpace(_currentUserId))
        {
            return Task.CompletedTask;
        }

        var slotUserId = _playerUserIdsByIndex.GetValueOrDefault(playerIndex);
        if (string.IsNullOrWhiteSpace(slotUserId))
        {
            return Task.CompletedTask;
        }

        var delegatedControllerUserId = GamePresenceService.GetDelegatedControllerUserId(GameId, slotUserId);
        var changed = PlayerControlRules.IsDelegatedController(delegatedControllerUserId, _currentUserId)
            ? GamePresenceService.ReleaseDelegatedControl(GameId, slotUserId, _currentUserId)
            : GamePresenceService.TryTakeDelegatedControl(GameId, slotUserId, _currentUserId);

        if (!changed)
        {
            Snackbar.Add("Unable to update delegated control for that player.", Severity.Warning);
            return Task.CompletedTask;
        }

        return Task.CompletedTask;
    }

    private bool CanCurrentUserTakeDelegatedControl(int playerIndex, string? slotUserId, string? delegatedControllerUserId)
    {
        if (_gameState is null
            || string.IsNullOrWhiteSpace(_currentUserId)
            || string.IsNullOrWhiteSpace(slotUserId)
            || playerIndex < 0
            || playerIndex >= _gameState.Players.Count
            || !_gameState.Players[playerIndex].IsActive
            || PlayerControlRules.IsDirectlyBoundToUser(slotUserId, _currentUserId)
            || IsPlayerConnected(slotUserId)
            || !IsCurrentUserInGameRoster())
        {
            return false;
        }

        return !PlayerControlRules.IsDelegatedController(delegatedControllerUserId, _currentUserId);
    }

    private bool CanCurrentUserReleaseDelegatedControl(string? delegatedControllerUserId)
    {
        return !string.IsNullOrWhiteSpace(_currentUserId)
            && PlayerControlRules.IsDelegatedController(delegatedControllerUserId, _currentUserId);
    }

    private bool IsCurrentUserInGameRoster()
    {
        return _gameState is not null
            && _currentUserPlayerIndex >= 0
            && _currentUserPlayerIndex < _gameState.Players.Count;
    }

    private string ResolveParticipantDisplayName(string? userId, IReadOnlyDictionary<string, string>? playerDisplayNamesByUserId)
    {
        if (string.IsNullOrWhiteSpace(userId))
        {
            return string.Empty;
        }

        if (playerDisplayNamesByUserId is not null
            && playerDisplayNamesByUserId.TryGetValue(userId, out var displayName)
            && !string.IsNullOrWhiteSpace(displayName))
        {
            return displayName;
        }

        if (_playerProfilesByUserId.TryGetValue(userId, out var profile))
        {
            if (!string.IsNullOrWhiteSpace(profile.Nickname))
            {
                return profile.Nickname;
            }

            if (!string.IsNullOrWhiteSpace(profile.Name))
            {
                return profile.Name;
            }
        }

        var matchingPlayer = _players.FirstOrDefault(player =>
            string.Equals(_playerUserIdsByIndex.GetValueOrDefault(player.Index), userId, StringComparison.OrdinalIgnoreCase));
        return matchingPlayer?.Name ?? userId;
    }

    private static string GetStatusBarColorClass(string color)
    {
        return PlayerColorOptions.NormalizeOrDefault(color) switch
        {
            "darkblue" => "map-board-status-bar-darkblue",
            "blue" => "map-board-status-bar-blue",
            "cyan" => "map-board-status-bar-cyan",
            "red" => "map-board-status-bar-red",
            "darkred" => "map-board-status-bar-darkred",
            "orange" => "map-board-status-bar-orange",
            "yellow" => "map-board-status-bar-yellow",
            "purple" => "map-board-status-bar-purple",
            "green" => "map-board-status-bar-green",
            "darkgreen" => "map-board-status-bar-darkgreen",
            _ => "map-board-status-bar-default"
        };
    }

    private string ResolveActionPlayerColor(RailBaronGameState state)
    {
        if (state.ActivePlayerIndex >= 0
            && state.ActivePlayerIndex < _players.Count)
        {
            return _players[state.ActivePlayerIndex].Color;
        }

        return _currentUserPlayerIndex >= 0 && _currentUserPlayerIndex < _players.Count
            ? _players[_currentUserPlayerIndex].Color
            : PlayerColorOptions.Colors[0];
    }

    private async Task ResolvePurchasePhaseAsync()
    {
        if (_gameState is null
            || CurrentPurchasePhase is null
            || !string.Equals(_turnViewState.TurnPhase, "Purchase", StringComparison.OrdinalIgnoreCase)
            || !IsCurrentUserActivePlayer)
        {
            _lastPurchaseResolutionKey = null;
            return;
        }

        if (CurrentPurchasePhase.HasActivePurchaseControls || _awaitingAuthoritativeUpdate)
        {
            return;
        }

        var purchaseResolutionKey = string.Join(
            ':',
            _gameState.TurnNumber.ToString(CultureInfo.InvariantCulture),
            _gameState.ActivePlayerIndex.ToString(CultureInfo.InvariantCulture),
            CurrentPurchasePhase.CashAfterPayout.ToString(CultureInfo.InvariantCulture),
            CurrentPurchasePhase.NoPurchaseNotification ?? string.Empty);

        if (string.Equals(_lastPurchaseResolutionKey, purchaseResolutionKey, StringComparison.Ordinal))
        {
            return;
        }

        _lastPurchaseResolutionKey = purchaseResolutionKey;

        if (!string.IsNullOrWhiteSpace(CurrentPurchasePhase.NoPurchaseNotification))
        {
            Snackbar.Add(CurrentPurchasePhase.NoPurchaseNotification, Severity.Warning);
        }

        await DeclinePurchaseAsync();
    }

    private static string BuildRailroadOptionKey(int railroadIndex)
    {
        return $"railroad:{railroadIndex}";
    }

    private static string BuildEngineOptionKey(LocomotiveType locomotiveType)
    {
        return $"engine:{locomotiveType}";
    }

    private static string FormatFee(int fee)
    {
        return string.Format(CultureInfo.InvariantCulture, "${0:N0}", Math.Max(0, fee));
    }

    private static string BuildBonusPendingLabel(RailBaronGameState state, Boxcars.Engine.Persistence.PlayerState player)
    {
        if (!state.Turn.BonusRollAvailable)
        {
            return string.Empty;
        }

        if (string.Equals(player.LocomotiveType, LocomotiveType.Superchief.ToString(), StringComparison.OrdinalIgnoreCase)
            && state.Turn.DiceResult?.RedDie is int redDie
            && redDie > 0)
        {
            return $"Bonus {redDie} pending";
        }

        return "Bonus Pending";
    }

    public async ValueTask DisposeAsync()
    {
        GamePresenceService.PresenceChanged -= OnPresenceChanged;
        UnregisterPagePresence();

        if (_gameStateSubscriptionInitialized)
        {
            SharedGameEngine.OnStateChanged -= OnSharedGameStateChanged;
            SharedGameEngine.OnActionFailed -= OnSharedGameActionFailed;
            _gameStateSubscriptionInitialized = false;
        }

        await Task.CompletedTask;
    }
}
