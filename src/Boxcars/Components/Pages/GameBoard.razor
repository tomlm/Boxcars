    private void SyncPurchaseSelection()
    {
        if (CurrentPurchasePhase is null && CurrentForcedSalePhase is null)
        {
            _dismissedRailroadOverlayOptionKey = null;
            _selectedRailroadOverlayClientX = null;
            _selectedRailroadOverlayClientY = null;
        }

        if (CurrentAuctionState is not null)
        {
            var auctionRailroadKey = BuildRailroadOptionKey(CurrentAuctionState.RailroadIndex);
            if (_activeAuctionRailroadIndex != CurrentAuctionState.RailroadIndex)
            {
                _selectedPurchaseOptionKey = auctionRailroadKey;
                _dismissedRailroadOverlayOptionKey = null;
                _selectedRailroadOverlayClientX = null;
                _selectedRailroadOverlayClientY = null;
                _selectedPurchaseTab = PurchaseExperienceTab.Map;
                _ = CenterAuctionRailroadOverlayAsync(CurrentAuctionState.RailroadIndex);
            }

            _activeAuctionRailroadIndex = CurrentAuctionState.RailroadIndex;
        }
        else
        {
            _activeAuctionRailroadIndex = null;
        }

        var availableRailroadOptionKeys = (CurrentForcedSalePhase?.SaleCandidates ?? [])
            .Select(candidate => BuildRailroadOptionKey(candidate.RailroadIndex))
            .Concat((CurrentPurchasePhase?.TaskbarOptions ?? []).Select(option => option.OptionKey))
            .Concat(CurrentAuctionState is not null
                ? [BuildRailroadOptionKey(CurrentAuctionState.RailroadIndex)]
                : [])
            .ToHashSet(StringComparer.Ordinal);

        if (availableRailroadOptionKeys.Count > 0)
        {
            if (!string.IsNullOrWhiteSpace(_selectedPurchaseOptionKey)
                && !availableRailroadOptionKeys.Contains(_selectedPurchaseOptionKey))
            {
                _selectedPurchaseOptionKey = null;
                _dismissedRailroadOverlayOptionKey = null;
                _selectedRailroadOverlayClientX = null;
                _selectedRailroadOverlayClientY = null;
            }

            return;
        }

        _selectedPurchaseOptionKey = null;
        _dismissedRailroadOverlayOptionKey = null;
        _selectedRailroadOverlayClientX = null;
        _selectedRailroadOverlayClientY = null;
    }

    private void SyncRegionChoiceSelection()
    {
        if (CurrentRegionChoicePhase is null || CurrentRegionChoicePhase.Options.Count == 0)
        {
            _selectedRegionChoiceCode = null;
            return;
        }

        var availableRegionCodes = CurrentRegionChoicePhase.Options
            .Select(option => option.RegionCode)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (string.IsNullOrWhiteSpace(_selectedRegionChoiceCode) || !availableRegionCodes.Contains(_selectedRegionChoiceCode))
        {
            _selectedRegionChoiceCode = CurrentRegionChoicePhase.Options[0].RegionCode;
        }
    }

    private async Task AutoSuggestRouteIfNeededAsync()
    {
        if (_gameMap is null || _gameState is null)
        {
            return;
        }

        if (!string.Equals(_turnViewState.TurnPhase, "Move", StringComparison.OrdinalIgnoreCase))
        {
            _lastAutoSuggestKey = null;
            return;
        }

        var activePlayer = _gameState.Players[_gameState.ActivePlayerIndex];
        if (string.IsNullOrWhiteSpace(activePlayer.DestinationCityName))
        {
            return;
        }

        if (_gameMap.CanSuggestRoute != true)
        {
            // Map city options may not be populated yet — try to prime start/dest directly
            // so the suggestion can fire as soon as the map is ready.
            var startNodeId = activePlayer.CurrentNodeId;
            if (string.IsNullOrWhiteSpace(startNodeId))
            {
                startNodeId = _gameMap.RouteCityOptions
                    .FirstOrDefault(option =>
                        string.Equals(option.CityName, activePlayer.CurrentCityName, StringComparison.OrdinalIgnoreCase))
                    .NodeId;
            }

            if (!string.IsNullOrWhiteSpace(startNodeId))
            {
                _gameMap.SetStartCity(startNodeId);
            }

            var destNodeId = _gameMap.RouteCityOptions
                .FirstOrDefault(option =>
                    string.Equals(option.CityName, activePlayer.DestinationCityName, StringComparison.OrdinalIgnoreCase))
                .NodeId;

            if (!string.IsNullOrWhiteSpace(destNodeId))
            {
                _gameMap.SetDestinationCity(destNodeId);
            }

            if (_gameMap.CanSuggestRoute != true)
            {
                return;
            }
        }

        var autoSuggestKey = string.Join(
            ':',
            _gameState.TurnNumber.ToString(CultureInfo.InvariantCulture),
            _gameState.ActivePlayerIndex.ToString(CultureInfo.InvariantCulture),
            activePlayer.CurrentNodeId ?? string.Empty,
            _gameState.Turn.MovementRemaining.ToString(CultureInfo.InvariantCulture),
            _gameState.Turn.MovementAllowance.ToString(CultureInfo.InvariantCulture),
            activePlayer.DestinationCityName);

        var hasCurrentSuggestion = _gameMap.RouteSuggestion?.Status == RouteSuggestionStatus.Success;
        if (string.Equals(_lastAutoSuggestKey, autoSuggestKey, StringComparison.Ordinal) && hasCurrentSuggestion)
        {
            return;
        }

        _lastAutoSuggestKey = autoSuggestKey;
        await _gameMap.SuggestRouteAsync();
        await InvokeAsync(StateHasChanged);
    }

    private bool RouteSelectionMatchesCurrentMap(IReadOnlyList<string> nodeIds, IReadOnlyList<string> segmentKeys)
    {
        if (_gameMap is null)
        {
            return false;
        }

        return SequenceEqualIgnoreCase(_gameMap.GetSelectedRouteNodeIds(), nodeIds)
            && SequenceEqualIgnoreCase(_gameMap.GetSelectedRouteSegmentKeys(), segmentKeys);
    }

    private static bool SequenceEqualIgnoreCase(IReadOnlyList<string> left, IReadOnlyList<string> right)
    {
        if (left.Count != right.Count)
        {
            return false;
        }

        for (var index = 0; index < left.Count; index++)
        {
            if (!string.Equals(left[index], right[index], StringComparison.OrdinalIgnoreCase))
            {
                return false;
            }
        }

        return true;
    }

    private async Task OnAutoZoomEnabledChangedAsync(bool enabled)
    {
        _autoZoomEnabled = enabled;

        if (_gameMap is null)
        {
            return;
        }

        if (!enabled)
        {
            await _gameMap.ResetZoom();
            return;
        }

        if (!ShouldApplyAutoZoom())
        {
            return;
        }

        var routeSuggestion = _gameMap.RouteSuggestion;
        if (routeSuggestion?.Status == RouteSuggestionStatus.Success)
        {
            var focusNodeIds = routeSuggestion.NodeIds.Count > 0
                ? routeSuggestion.NodeIds
                : BuildFallbackRouteNodeIds();

            await _gameMap.FocusRouteAsync(focusNodeIds);
        }
    }

    private bool ShouldApplyAutoZoom()
    {
        return _autoZoomEnabled
            && IsAuthenticatedUserActivePlayer
            && string.Equals(_turnViewState.TurnPhase, "Move", StringComparison.OrdinalIgnoreCase);
    }

    private IReadOnlyList<string> BuildFallbackRouteNodeIds()
    {
        if (_gameMap is null)
        {
            return Array.Empty<string>();
        }

        if (_turnViewState.SelectedRoutePreview.NodeIds.Count > 0)
        {
            return _turnViewState.SelectedRoutePreview.NodeIds;
        }

        var fallbackNodeIds = new List<string>();
        if (!string.IsNullOrWhiteSpace(_gameMap.RouteStartNodeId))
        {
            fallbackNodeIds.Add(_gameMap.RouteStartNodeId);
        }

        if (!string.IsNullOrWhiteSpace(_gameMap.DestinationNodeId)
            && !fallbackNodeIds.Contains(_gameMap.DestinationNodeId, StringComparer.OrdinalIgnoreCase))
        {
            fallbackNodeIds.Add(_gameMap.DestinationNodeId);
        }

        return fallbackNodeIds;
    }

    private bool IsPlayerConnected(string? userId)
    {
        return GamePresenceService.IsUserConnected(GameId, userId);
    }

    private void RefreshPlayerConnectionStates()
    {
        if (_players.Count == 0)
        {
            return;
        }

        var previousConnectionStates = _players
            .ToDictionary(player => player.Index, player => player.IsConnected);
        var previousDelegatedControllers = _players
            .ToDictionary(player => player.Index, player => player.DelegatedControllerUserId);

        _players = _players
            .Select(player =>
            {
                var slotUserId = _playerUserIdsByIndex.GetValueOrDefault(player.Index);
                var delegatedControllerUserId = GamePresenceService.GetDelegatedControllerUserId(GameId, slotUserId) ?? string.Empty;
                var activeBotAssignment = player.HasActiveBotControl
                    ? GetCurrentPlayerStates().FirstOrDefault(playerState =>
                        string.Equals(playerState.PlayerUserId, slotUserId, StringComparison.OrdinalIgnoreCase)
                        && string.Equals(playerState.BotControlStatus, BotControlStatuses.Active, StringComparison.OrdinalIgnoreCase)
                        && playerState.BotControlClearedUtc is null)
                    : null;
                var controllerState = GamePresenceService.ResolveSeatControllerState(GameId, slotUserId, activeBotAssignment);
                return new PlayerBoardModel
                {
                    Index = player.Index,
                    Name = player.Name,
                    ThumbnailUrl = player.ThumbnailUrl,
                    Color = player.Color,
                    IsAtDestination = player.IsAtDestination,
                    TripStartLabel = player.TripStartLabel,
                    TripDestinationLabel = player.TripDestinationLabel,
                    DistanceToDestination = player.DistanceToDestination,
                    Payoff = player.Payoff,
                    Cash = player.Cash,
                    IsCurrentUser = player.IsCurrentUser,
                    IsDelegatedToCurrentUser = PlayerControlRules.IsDelegatedController(delegatedControllerUserId, _currentUserId),
                    HomeCity = player.HomeCity,
                    IsActiveTurn = player.IsActiveTurn,
                    IsEliminated = player.IsEliminated,
                    IsConnected = IsPlayerConnected(slotUserId),
                    ShowDisconnectedControlToggle = ShouldShowDisconnectedControlToggle(player.Index, slotUserId),
                    CanSelectAiControl = CanCurrentUserSelectAiControl(player.Index, slotUserId, delegatedControllerUserId),
                    CanSelectManualControl = CanCurrentUserSelectManualControl(player.Index, slotUserId, delegatedControllerUserId),
                    IsAiControlSelected = SeatControllerModes.IsAiControlled(controllerState.ControllerMode),
                    IsManualControlSelected = SeatControllerModes.IsDelegated(controllerState.ControllerMode),
                    DisconnectedControlMode = ResolveDisconnectedControlMode(controllerState.ControllerMode),
                    DelegatedControllerUserId = delegatedControllerUserId,
                    DelegatedControllerDisplayName = ResolveParticipantDisplayName(delegatedControllerUserId, null),
                    HasActiveBotControl = player.HasActiveBotControl,
                    IsAiControlled = SeatControllerModes.IsAiControlled(controllerState.ControllerMode) || player.IsAiControlled,
                    ControllerMode = controllerState.ControllerMode,
                    IsBotPlayer = player.IsBotPlayer,
                    AssignedBotDefinitionId = player.AssignedBotDefinitionId,
                    BotControlStatusLabel = SeatControllerModes.IsAiControlled(controllerState.ControllerMode)
                        ? "AUTO"
                        : player.BotControlStatusLabel,
                    HasMissingBotDefinition = player.HasMissingBotDefinition,
                    LocomotiveLabel = player.LocomotiveLabel,
                    FeesOwed = player.FeesOwed,
                    BonusPendingLabel = player.BonusPendingLabel,
                    CoverageMetrics = player.CoverageMetrics
                };
            })
            .ToList();

        if (_presenceNotificationsEnabled)
        {
            NotifyPresenceChanges(previousConnectionStates);
            NotifyDelegatedControlChanges(previousDelegatedControllers);
        }
    }

    private void RegisterPagePresence()
    {
        if (_pagePresenceRegistered || string.IsNullOrWhiteSpace(GameId) || string.IsNullOrWhiteSpace(_currentUserId))
        {
            return;
        }

        _pagePresenceRegistered = true;
        GamePresenceService.AddConnection(GameId, _currentUserId, _pagePresenceRegistrationId);
        GameCircuitPresenceTracker.Register(GameId, _currentUserId, _pagePresenceRegistrationId);
        ReevaluatePlayerPresenceState();
        _presenceNotificationsEnabled = true;
        StateHasChanged();
    }

    private async Task StartPresenceHeartbeatAsync()
    {
        if (!_pagePresenceRegistered)
        {
            return;
        }

        _presenceHeartbeatReference ??= DotNetObjectReference.Create(this);

        try
        {
            await JavaScriptRuntime.InvokeVoidAsync(
                "mapBoardPresence.startHeartbeat",
                _pagePresenceRegistrationId,
                _presenceHeartbeatReference,
                PresenceHeartbeatIntervalMilliseconds);
        }
        catch (JSDisconnectedException)
        {
        }
    }

    private void UnregisterPagePresence()
    {
        if (!_pagePresenceRegistered)
        {
            return;
        }

        _presenceNotificationsEnabled = false;
        _pagePresenceRegistered = false;
        GameCircuitPresenceTracker.Unregister(GameId);
        if (!string.IsNullOrWhiteSpace(GameId) && !string.IsNullOrWhiteSpace(_currentUserId))
        {
            GamePresenceService.RemoveConnection(GameId, _currentUserId, _pagePresenceRegistrationId);
        }
    }

    [JSInvokable]
    public Task SendPresenceHeartbeat()
    {
        if (_pagePresenceRegistered
            && !string.IsNullOrWhiteSpace(GameId)
            && !string.IsNullOrWhiteSpace(_currentUserId))
        {
            GamePresenceService.RefreshConnection(GameId, _currentUserId, _pagePresenceRegistrationId);
        }

        return Task.CompletedTask;
    }

    private void OnPresenceChanged(GamePresenceChange change)
    {
        if (!string.Equals(change.GameId, GameId, StringComparison.Ordinal))
        {
            return;
        }

        _ = InvokeAsync(async () =>
        {
            if (change.MetadataChanged)
            {
                await RefreshGameEntityAsync();
                await RefreshBotDisplayNamesAsync();
            }

            if (_gameState is not null && _game is not null)
            {
                ApplyGameState(_gameState, queueRestoredRouteSelection: false);
            }
            else
            {
                ReevaluatePlayerPresenceState();
            }

            StateHasChanged();
        });
    }

    private async Task RefreshGameEntityAsync()
    {
        ApplyGameEntity(await GameService.GetGameAsync(GameId, CancellationToken.None));
        await RefreshPlayerStatesAsync();
    }

    private List<GameSeatState> GetCurrentPlayerStates()
    {
        return GameSeatStateProjection.BuildStates(_game, _gameState).ToList();
    }

    private void ClearActiveBotControl(string playerUserId, string clearReason)
    {
        if (_gameState is null)
        {
            return;
        }

        var now = DateTimeOffset.UtcNow;
        foreach (var seat in _game?.Seats ?? [])
        {
            if (!string.Equals(seat.PlayerUserId, playerUserId, StringComparison.OrdinalIgnoreCase)
                || seat.SeatIndex < 0
                || seat.SeatIndex >= _gameState.Players.Count)
            {
                continue;
            }

            var control = _gameState.Players[seat.SeatIndex].Control;
            if (!string.Equals(control.BotControlStatus, BotControlStatuses.Active, StringComparison.OrdinalIgnoreCase)
                || control.BotControlClearedUtc is not null)
            {
                continue;
            }

            control.BotControlStatus = BotControlStatuses.Cleared;
            control.BotControlClearReason = clearReason;
            control.BotControlClearedUtc = now;
        }
    }

    private void ActivateBotControl(string playerUserId)
    {
        if (_gameState is null)
        {
            return;
        }

        var now = DateTimeOffset.UtcNow;
        foreach (var seat in _game?.Seats ?? [])
        {
            if (!string.Equals(seat.PlayerUserId, playerUserId, StringComparison.OrdinalIgnoreCase)
                || seat.SeatIndex < 0
                || seat.SeatIndex >= _gameState.Players.Count)
            {
                continue;
            }

            var control = _gameState.Players[seat.SeatIndex].Control;
            control.ControllerMode = SeatControllerModes.AI;
            control.BotControlActivatedUtc = now;
            control.BotControlStatus = BotControlStatuses.Active;
            control.BotControlClearReason = string.Empty;
            control.BotControlClearedUtc = null;
        }
    }

    private void ApplyGameEntity(GameEntity? game)
    {
        _game = game;
        _gameSettingsSummary = GameBoardStateMapper.BuildGameSettingsSummary(game);
    }

    private async Task RefreshPlayerStatesAsync()
    {
        if (string.IsNullOrWhiteSpace(GameId))
        {
            return;
        }

        if (_gameState is not null)
        {
            _mapPlayerStates = GameBoardStateMapper.BuildPlayerMapStates(GetCurrentPlayerStates(), _gameState, _currentUserId).ToList();
        }

        await RefreshBotDisplayNamesAsync();
    }

    private async Task RefreshBotDisplayNamesAsync()
    {
        if (_game is null)
        {
            _botDisplayNamesByDefinitionId.Clear();
            return;
        }

        var assignedBotIds = GameBoardStateMapper.GetBotControlledSeatStates(GetCurrentPlayerStates())
            .Select(playerState => playerState.PlayerUserId)
            .Where(botDefinitionId => !string.IsNullOrWhiteSpace(botDefinitionId))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (assignedBotIds.Count == 0)
        {
            _botDisplayNamesByDefinitionId.Clear();
            return;
        }

        var resolvedNames = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        foreach (var assignedBotId in assignedBotIds)
        {
            var definition = await UserDirectoryService.GetBotDefinitionAsync(assignedBotId, CancellationToken.None);
            if (definition is not null && !string.IsNullOrWhiteSpace(definition.Name))
            {
                resolvedNames[assignedBotId] = definition.Name;
            }
        }

        _botDisplayNamesByDefinitionId = resolvedNames;
    }

    private void NotifyPresenceChanges(IReadOnlyDictionary<int, bool> previousConnectionStates)
    {
        foreach (var player in _players)
        {
            if (!previousConnectionStates.TryGetValue(player.Index, out var wasConnected)
                || wasConnected == player.IsConnected)
            {
                continue;
            }

            var message = $"{player.Name} {(player.IsConnected ? "connected" : "disconnected")}.";
            ShowNotification(
                message,
                player.IsConnected ? Severity.Success : Severity.Warning,
                snackbarClass: BuildPlayerSnackbarClass(player.Color));
        }
    }

    private void NotifyDelegatedControlChanges(IReadOnlyDictionary<int, string> previousDelegatedControllers)
    {
        foreach (var player in _players)
        {
            previousDelegatedControllers.TryGetValue(player.Index, out var previousControllerUserId);
            var currentControllerUserId = player.DelegatedControllerUserId;

            if (string.Equals(previousControllerUserId, currentControllerUserId, StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            string? message;
            Severity severity;

            if (!string.IsNullOrWhiteSpace(currentControllerUserId))
            {
                var controllerName = string.IsNullOrWhiteSpace(player.DelegatedControllerDisplayName)
                    ? "Another player"
                    : player.DelegatedControllerDisplayName;
                var previousControllerName = ResolveParticipantDisplayName(previousControllerUserId, null);
                message = string.IsNullOrWhiteSpace(previousControllerName)
                    ? $"{controllerName} took control of {player.Name}."
                    : $"{controllerName} took control of {player.Name} from {previousControllerName}.";
                severity = Severity.Info;
            }
            else if (!string.IsNullOrWhiteSpace(previousControllerUserId))
            {
                var previousControllerName = ResolveParticipantDisplayName(previousControllerUserId, null);
                message = player.IsConnected
                    ? $"{player.Name} reconnected. {previousControllerName} lost delegated control."
                    : $"{previousControllerName} stopped controlling {player.Name}.";
                severity = player.IsConnected ? Severity.Success : Severity.Warning;
            }
            else
            {
                continue;
            }

            ShowNotification(message, severity, snackbarClass: BuildPlayerSnackbarClass(player.Color));
        }
    }

    private void NotifyNewTimelineItems(HashSet<string> existingEventIds)
    {
        var notificationItems = _gameEngineEvents
            .Where(item => !existingEventIds.Contains(item.EventId))
            .Where(ShouldNotifyTimelineItem)
            .ToList();

        var visibleStateDuration = ResolveTimelineNotificationDuration(notificationItems.Count);

        foreach (var item in notificationItems)
        {
            ShowNotification(
                BuildTimelineNotificationMessage(item),
                ResolveTimelineSeverity(item),
                historyKey: BuildTimelineNotificationKey(item),
                icon: ResolveTimelineSnackbarIcon(item),
                snackbarClass: ResolveTimelineSnackbarClass(item),
                detail: BuildTimelineNotificationDetail(item),
                occurredUtc: item.OccurredUtc,
                visibleStateDuration: visibleStateDuration,
                eventBaseId: GetTimelineEventBaseId(item));
        }
    }

    private void MergeTimelineNotifications()
    {
        foreach (var item in _gameEngineEvents)
        {
            AddNotificationHistory(
                BuildTimelineNotificationKey(item),
                BuildTimelineNotificationMessage(item),
                ResolveTimelineSeverity(item),
                ResolveTimelineSnackbarIcon(item),
                ResolveTimelineSnackbarClass(item),
                BuildTimelineNotificationDetail(item),
                item.OccurredUtc,
                GetTimelineEventBaseId(item));
        }
    }

    private string BuildTimelineNotificationMessage(EventTimelineItem item)
    {
        var message = item.Description;
        if (item.EventKind == EventTimelineKind.NewDestination
            && item.ActingPlayerIndex.HasValue
            && item.ActingPlayerIndex.Value >= 0
            && item.ActingPlayerIndex.Value < _players.Count)
        {
            var payoff = _players[item.ActingPlayerIndex.Value].Payoff;
            if (payoff > 0)
            {
                message = $"{message}, Payoff ${payoff:N0}";
            }
        }

        return message;
    }

    private static string? BuildTimelineNotificationDetail(EventTimelineItem item)
    {
        if (!item.IsAiAction)
        {
            return null;
        }

        var detail = !item.IsBotPlayer && SeatControllerModes.IsAiControlled(item.BotControllerMode)
            ? "AUTO action"
            : "AI action";

        if (!string.IsNullOrWhiteSpace(item.BotDecisionSource))
        {
            detail = $"{detail} via {item.BotDecisionSource}";
        }

        if (!string.IsNullOrWhiteSpace(item.BotFallbackReason))
        {
            detail = $"{detail}. {item.BotFallbackReason}";
        }

        return detail;
    }

    private static string BuildTimelineNotificationKey(EventTimelineItem item)
    {
        return $"timeline:{item.EventId}";
    }

    private static bool ShouldNotifyTimelineItem(EventTimelineItem item)
    {
        return item.EventKind switch
        {
            EventTimelineKind.NewDestination => true,
            EventTimelineKind.CashAnnouncement => true,
            EventTimelineKind.Move => true,
            EventTimelineKind.Arrival => true,
            EventTimelineKind.PayFees => true,
            EventTimelineKind.Purchase => true,
            EventTimelineKind.DeclinedPurchase => true,
            _ => false
        };
    }

    private static string GetTimelineEventBaseId(EventTimelineItem item)
    {
        var separatorIndex = item.EventId.LastIndexOf(':');
        return separatorIndex >= 0
            ? item.EventId[..separatorIndex]
            : item.EventId;
    }

    private static Severity ResolveTimelineSeverity(EventTimelineItem item)
    {
        return item.EventKind switch
        {
            EventTimelineKind.Arrival => Severity.Success,
            EventTimelineKind.CashAnnouncement => Severity.Info,
            EventTimelineKind.PayFees => Severity.Warning,
            EventTimelineKind.PurchaseOpportunity => Severity.Warning,
            EventTimelineKind.Purchase => Severity.Warning,
            _ => Severity.Info
        };
    }

    private static int ResolveTimelineNotificationDuration(int notificationCount)
    {
        return notificationCount switch
        {
            >= 8 => 900,
            >= 5 => 1300,
            >= 3 => 1800,
            _ => 3200
        };
    }

    private string? ResolveTimelineSnackbarClass(EventTimelineItem item)
    {
        if (!item.ActingPlayerIndex.HasValue
            || item.ActingPlayerIndex.Value < 0
            || item.ActingPlayerIndex.Value >= _players.Count)
        {
            return null;
        }

        var playerColor = PlayerColorOptions.NormalizeOrDefault(_players[item.ActingPlayerIndex.Value].Color);
        return $"player-snackbar player-snackbar-{playerColor}";
    }

    private static string BuildPlayerSnackbarClass(string color)
    {
        var playerColor = PlayerColorOptions.NormalizeOrDefault(color);
        return $"player-snackbar player-snackbar-{playerColor}";
    }

    private static string ResolveTimelineSnackbarIcon(EventTimelineItem item)
    {
        return item.EventKind switch
        {
            EventTimelineKind.Move => Icons.Material.Filled.DirectionsRailway,
            EventTimelineKind.NewDestination => Icons.Material.Filled.DirectionsRailway,
            EventTimelineKind.CashAnnouncement => Icons.Material.Filled.Campaign,
            EventTimelineKind.Arrival => Icons.Material.Filled.AttachMoney,
            EventTimelineKind.PayFees => Icons.Material.Filled.AttachMoney,
            EventTimelineKind.Purchase => Icons.Material.Filled.ShoppingCart,
            EventTimelineKind.DeclinedPurchase => Icons.Material.Filled.RemoveShoppingCart,
            EventTimelineKind.PurchaseOpportunity => Icons.Material.Filled.LocalOffer,
            _ => Icons.Material.Filled.Notifications
        };
    }

    private void ShowNotification(
        string message,
        Severity severity,
        string? historyKey = null,
        string? icon = null,
        string? snackbarClass = null,
        string? detail = null,
        DateTimeOffset? occurredUtc = null,
        int? visibleStateDuration = null,
        string? eventBaseId = null)
    {
        AddNotificationHistory(
            historyKey ?? $"notification:{Guid.NewGuid():N}",
            message,
            severity,
            icon,
            snackbarClass,
            detail,
            occurredUtc ?? DateTimeOffset.UtcNow,
            eventBaseId);

        Snackbar.Add(message, severity, options =>
        {
            if (!string.IsNullOrWhiteSpace(icon))
            {
                options.Icon = icon;
            }

            if (!string.IsNullOrWhiteSpace(snackbarClass))
            {
                options.SnackbarTypeClass = snackbarClass;
            }

            if (visibleStateDuration.HasValue)
            {
                options.VisibleStateDuration = visibleStateDuration.Value;
            }
        });
    }

    private void AddNotificationHistory(
        string historyKey,
        string message,
        Severity severity,
        string? icon,
        string? snackbarClass,
        string? detail,
        DateTimeOffset occurredUtc,
        string? eventBaseId = null)
    {
        if (!_notificationHistoryKeys.Add(historyKey))
        {
            return;
        }

        _notificationHistory.Add(new NotificationHistoryEntry
        {
            HistoryKey = historyKey,
            Message = message,
            Detail = detail,
            Severity = severity,
            Icon = string.IsNullOrWhiteSpace(icon) ? ResolveSeverityIcon(severity) : icon,
            AccentClass = snackbarClass,
            OccurredUtc = occurredUtc,
            EventBaseId = eventBaseId
        });

        _notificationHistory = _notificationHistory
            .OrderByDescending(item => item.OccurredUtc)
            .ThenByDescending(item => item.HistoryKey, StringComparer.Ordinal)
            .ToList();
    }

    private void RemoveTimelineHistoryEntries()
    {
        var timelineKeys = _notificationHistory
            .Where(item => item.CanUndo)
            .Select(item => item.HistoryKey)
            .ToList();

        foreach (var timelineKey in timelineKeys)
        {
            _notificationHistoryKeys.Remove(timelineKey);
        }

        _notificationHistory = _notificationHistory
            .Where(item => !item.CanUndo)
            .ToList();
    }

    private IEnumerable<NotificationHistoryEntry> NotificationHistoryItems => _notificationHistory;

    private string NotificationHistorySummary => _notificationHistory.Count switch
    {
        0 => "Waiting for notifications.",
        1 => "1 notification recorded.",
        _ => string.Format(CultureInfo.InvariantCulture, "{0:N0} notifications recorded.", _notificationHistory.Count)
    };

    private string ResolveNotificationHistoryItemStyle(NotificationHistoryEntry item)
    {
        if (string.IsNullOrWhiteSpace(item.AccentClass))
        {
            return "border: 1px solid color-mix(in srgb, var(--mud-palette-divider) 82%, transparent); border-radius: 0.85rem; padding: 0.7rem 0.85rem; background: color-mix(in srgb, var(--mud-palette-surface) 92%, black 8%)";
        }

        var colorHex = ResolveSnackbarAccentHexColor(item.AccentClass);
        return $"border-radius: 0.85rem; padding: 0.7rem 0.85rem; border: 1px solid color-mix(in srgb, {colorHex} 78%, black 22%); background: color-mix(in srgb, {colorHex} 72%, rgb(15 18 24) 28%); color: #fff";
    }

    private static string ResolveSnackbarAccentHexColor(string accentClass)
    {
        const string prefix = "player-snackbar-";
        var idx = accentClass.LastIndexOf(prefix, StringComparison.Ordinal);
        if (idx < 0) return "#888";
        var colorName = accentClass[(idx + prefix.Length)..];
        return GetPlayerHexColor(colorName);
    }

