    private RecommendationInputSet? DisplayRecommendationInputs
    {
        get
        {
            var baseInputs = CurrentPurchasePhase?.RecommendationInputs;
            if (baseInputs is null || _gameState is null || _playerBoardMapDefinition is null)
            {
                return baseInputs;
            }

            var effectivePlayerIndex = EffectiveRecommendationPlayerIndex;
            if (effectivePlayerIndex < 0 || effectivePlayerIndex >= _gameState.Players.Count)
            {
                return baseInputs;
            }

            if (effectivePlayerIndex == _gameState.ActivePlayerIndex)
            {
                return baseInputs;
            }

            var ownedRailroadIndices = _gameState.Players[effectivePlayerIndex].OwnedRailroadIndices;
            var currentCoverage = NetworkCoverageService.BuildSnapshot(_playerBoardMapDefinition, ownedRailroadIndices);
            var projectedCoverageByRailroad = CurrentPurchasePhase?.RailroadOptions.ToDictionary(
                option => option.RailroadIndex,
                option => NetworkCoverageService.BuildProjectedSnapshot(_playerBoardMapDefinition, ownedRailroadIndices, option.RailroadIndex))
                ?? new Dictionary<int, NetworkCoverageSnapshot>();

            return new RecommendationInputSet
            {
                MapAnalysisReport = baseInputs.MapAnalysisReport,
                AffordableRailroadIndices = baseInputs.AffordableRailroadIndices,
                UnownedRailroadIndices = baseInputs.UnownedRailroadIndices,
                EligibleEngineTypes = baseInputs.EligibleEngineTypes,
                CurrentCoverage = currentCoverage,
                ProjectedCoverageByRailroad = projectedCoverageByRailroad
            };
        }
    }

