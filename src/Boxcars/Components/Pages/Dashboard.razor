@page "/dashboard"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@using MudBlazor
@using Boxcars.Data
@using Boxcars.Services
@attribute [Authorize]
@inject PlayerProfileService ProfileService
@inject GameService GameService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@implements IAsyncDisposable

<PageTitle>Dashboard - BoxCars</PageTitle>

@if (_loading)
{
    <MudStack Class="dashboard-loading" Justify="Justify.Center" AlignItems="AlignItems.Center">
        <MudProgressLinear Indeterminate="true" Color="MudBlazor.Color.Primary" />
    </MudStack>
}
else if (_loadError)
{
    <MudPaper Class="dashboard-error pa-8">
        <MudText Typo="Typo.h4">Something went wrong</MudText>
        <MudText Typo="Typo.body1" Class="dashboard-error-message">Unable to load your dashboard. Please try again.</MudText>
        <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" OnClick="@LoadDataAsync">Retry</MudButton>
    </MudPaper>
}
else if (_needsNickname)
{
    <MudPaper Class="dashboard-nickname pa-8">
        <MudText Typo="Typo.h4" Class="dashboard-section-title">Choose Your Nickname</MudText>
        <MudText Typo="Typo.body1" Class="dashboard-helper">
            Your nickname couldn't be auto-set during registration. Please choose one to continue.
        </MudText>
        <MudTextField @bind-Value="_newNickname"
                      Label="Nickname"
                      Placeholder="Enter a unique nickname"
                      Variant="Variant.Outlined"
                      FullWidth="true"
                      Class="dashboard-field" />
        @if (!string.IsNullOrEmpty(_nicknameError))
        {
            <MudText Typo="Typo.body2" Color="MudBlazor.Color.Error" Class="dashboard-helper">@_nicknameError</MudText>
        }
        <MudButton Variant="Variant.Filled"
                   Color="MudBlazor.Color.Primary"
                   OnClick="@SaveNicknameAsync"
                   Disabled="@(string.IsNullOrWhiteSpace(_newNickname))">
            Save Nickname
        </MudButton>
    </MudPaper>
}
else
{
    <MudStack Class="dashboard-stack" Spacing="6">
        <MudPaper Class="dashboard-card pa-6">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="dashboard-row" Spacing="4">
                <MudAvatar Size="Size.Large">
                    @if (HasProfileThumbnail())
                    {
                        <MudImage Src="@_profile!.ThumbnailUrl" Alt="@_profile.Nickname" Class="dashboard-avatar-image" />
                    }
                    else
                    {
                        @GetProfileInitials()
                    }
                </MudAvatar>
                <MudStack>
                    <MudText Typo="Typo.h5">@_profile!.Nickname</MudText>
                    <MudText Typo="Typo.body2" Class="dashboard-muted">@_profile!.Email</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>

        <MudPaper Class="dashboard-card pa-6">
            <MudText Typo="Typo.h5" Class="dashboard-section-title">Your Stats</MudText>
            <MudText Typo="Typo.body2" Class="dashboard-muted">
                Welcome to BoxCars! Start your first game to begin tracking your stats.
            </MudText>
        </MudPaper>

        <MudPaper Class="dashboard-card pa-6">
            <MudText Typo="Typo.h5" Class="dashboard-section-title">Games</MudText>

            @if (_dashboardState!.HasActiveGame)
            {
                <MudText Typo="Typo.body1" Class="dashboard-helper">You have an active game.</MudText>
                <MudStack Row="true" Class="dashboard-actions-row" Spacing="3">
                    <MudButton Variant="Variant.Filled"
                               Color="MudBlazor.Color.Primary"
                               OnClick="@(() => Navigation.NavigateTo($"/game/{_dashboardState.ActiveGameId}"))">
                        Resume Game
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="MudBlazor.Color.Primary"
                               OnClick="OpenDeleteGameDialog">
                        Delete Game
                    </MudButton>
                </MudStack>
            }
            else
            {
                @if (_dashboardState.JoinableGames.Any())
                {
                    <MudText Typo="Typo.body1" Class="dashboard-helper">Available games to join:</MudText>
                    <MudStack Class="dashboard-games-list" Spacing="3">
                        @foreach (var game in _dashboardState.JoinableGames)
                        {
                            <MudPaper Class="dashboard-join-game-card pa-4">
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <MudStack>
                                        <MudText Typo="Typo.body1">
                                            Game @game.RowKey[..8]...
                                        </MudText>
                                        <MudText Typo="Typo.caption" Class="dashboard-muted">
                                            @game.CurrentPlayerCount / @game.MaxPlayers players
                                        </MudText>
                                    </MudStack>
                                    <MudButton Variant="Variant.Filled"
                                               Color="MudBlazor.Color.Primary"
                                               OnClick="@(() => JoinGameAsync(game.RowKey))">
                                        Join Game
                                    </MudButton>
                                </MudStack>
                            </MudPaper>
                        }
                    </MudStack>
                }

                <MudText Typo="Typo.h6" Class="dashboard-section-title">Create a New Game</MudText>
                <MudStack Row="true" Class="dashboard-actions-row" Spacing="3">
                    <MudButton Variant="Variant.Filled"
                               Color="MudBlazor.Color.Primary"
                               OnClick="@CreateGameAsync">
                        Create Game
                    </MudButton>
                </MudStack>
            }
        </MudPaper>
    </MudStack>
}

@if (_dashboardState?.HasActiveGame == true && _showDeleteGameDialog)
{
    <MudOverlay Visible="true" DarkBackground="true" AutoClose="false" ZIndex="1300">
        <MudPaper Class="dashboard-delete-dialog pa-5">
            <MudText Typo="Typo.h5">Delete current game?</MudText>
            <MudText Typo="Typo.body1" Class="dashboard-helper">
                This action cannot be undone here. Type "i am sure" to confirm.
            </MudText>
            <MudTextField Value="@_deleteConfirmationInput"
                          T="string"
                          ValueChanged="@(value => OnDeleteConfirmationChanged(value))"
                          Label="Confirmation"
                          Placeholder="i am sure"
                          Variant="Variant.Outlined" />
            @if (!string.IsNullOrWhiteSpace(_deleteGameError))
            {
                <MudText Typo="Typo.body2" Color="MudBlazor.Color.Error">@_deleteGameError</MudText>
            }
            <MudStack Row="true" Justify="Justify.FlexEnd" Class="dashboard-actions-row" Spacing="3">
                <MudButton Variant="Variant.Text"
                           Color="MudBlazor.Color.Default"
                           OnClick="CancelDeleteGameDialog"
                           Disabled="_deleteGameInProgress">
                    Cancel
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="MudBlazor.Color.Error"
                           OnClick="ConfirmDeleteGameAsync"
                           Disabled="@(!CanConfirmDeleteGame || _deleteGameInProgress)">
                    Delete Game
                </MudButton>
            </MudStack>
        </MudPaper>
    </MudOverlay>
}

@code {
    private bool _loading = true;
    private bool _loadError;
    private bool _needsNickname;
    private string _newNickname = string.Empty;
    private string? _nicknameError;
    private string? _currentUserId;

    private ApplicationUser? _profile;
    private DashboardState? _dashboardState;
    private HubConnection? _hubConnection;
    private bool _showDeleteGameDialog;
    private bool _deleteGameInProgress;
    private string _deleteConfirmationInput = string.Empty;
    private string? _deleteGameError;

    private string GetProfileInitials()
    {
        if (string.IsNullOrWhiteSpace(_profile?.Nickname))
        {
            return "?";
        }

        return _profile.Nickname.Trim()[0].ToString();
    }

    private bool HasProfileThumbnail()
    {
        return !string.IsNullOrWhiteSpace(_profile?.ThumbnailUrl);
    }

    private bool CanConfirmDeleteGame => string.Equals(
        _deleteConfirmationInput.Trim(),
        "i am sure",
        StringComparison.OrdinalIgnoreCase);

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null)
        {
            var state = await AuthState;
            _currentUserId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        }

        await LoadDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _currentUserId != null)
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/hubs/dashboard"))
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On("DashboardStateRefreshed", async () =>
            {
                await RefreshDashboardStateAsync();
                await InvokeAsync(StateHasChanged);
            });

            _hubConnection.On<object>("JoinConflict", async (conflict) =>
            {
                Snackbar.Add("Game is no longer available. The list has been refreshed.", Severity.Error);
                await RefreshDashboardStateAsync();
                await InvokeAsync(StateHasChanged);
            });

            try
            {
                await _hubConnection.StartAsync();
            }
            catch
            {
                // SignalR connection failure — dashboard still works, just no real-time updates
            }
        }
    }

    private void OpenDeleteGameDialog()
    {
        _deleteConfirmationInput = string.Empty;
        _deleteGameError = null;
        _showDeleteGameDialog = true;
    }

    private void CancelDeleteGameDialog()
    {
        if (_deleteGameInProgress)
        {
            return;
        }

        _showDeleteGameDialog = false;
        _deleteConfirmationInput = string.Empty;
        _deleteGameError = null;
    }

    private void OnDeleteConfirmationChanged(string? value)
    {
        _deleteConfirmationInput = value ?? string.Empty;
        _deleteGameError = null;
    }

    private async Task ConfirmDeleteGameAsync()
    {
        if (!CanConfirmDeleteGame)
        {
            _deleteGameError = "Type 'i am sure' to delete this game.";
            return;
        }

        if (_currentUserId is null || string.IsNullOrWhiteSpace(_dashboardState?.ActiveGameId))
        {
            _deleteGameError = "Unable to identify the active game.";
            return;
        }

        _deleteGameInProgress = true;
        _deleteGameError = null;

        try
        {
            var result = await GameService.EndGameAsync(_currentUserId, _dashboardState.ActiveGameId, CancellationToken.None);
            if (!result.Success)
            {
                _deleteGameError = result.Reason ?? "Failed to delete game.";
                return;
            }

            _showDeleteGameDialog = false;
            _deleteConfirmationInput = string.Empty;
            await RefreshDashboardStateAsync();
            StateHasChanged();
        }
        finally
        {
            _deleteGameInProgress = false;
        }
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        _loadError = false;
        StateHasChanged();

        try
        {
            if (_currentUserId == null) return;

            _profile = await ProfileService.GetProfileAsync(_currentUserId, CancellationToken.None);
            if (_profile == null)
            {
                _loadError = true;
                return;
            }

            if (string.IsNullOrEmpty(_profile.Nickname))
            {
                _needsNickname = true;
                _loading = false;
                return;
            }

            try
            {
                _dashboardState = await GameService.GetDashboardStateAsync(_currentUserId, CancellationToken.None);
            }
            catch
            {
                _dashboardState = new DashboardState
                {
                    HasActiveGame = false,
                    JoinableGames = []
                };
            }
        }
        catch
        {
            _loadError = true;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task RefreshDashboardStateAsync()
    {
        if (_currentUserId == null) return;
        try
        {
            _dashboardState = await GameService.GetDashboardStateAsync(_currentUserId, CancellationToken.None);
        }
        catch
        {
            // Silently fail — user can manually refresh
        }
    }

    private async Task SaveNicknameAsync()
    {
        if (string.IsNullOrWhiteSpace(_newNickname) || _currentUserId == null) return;

        _nicknameError = null;
        var result = await ProfileService.UpdateNicknameAsync(_currentUserId, _newNickname.Trim(), CancellationToken.None);

        switch (result)
        {
            case NicknameResult.Success:
                _needsNickname = false;
                await LoadDataAsync();
                break;
            case NicknameResult.Conflict:
                _nicknameError = "That nickname is already taken. Please choose another.";
                break;
            default:
                _nicknameError = "Failed to save nickname. Please try again.";
                break;
        }
    }

    private void CreateGameAsync()
    {
        Navigation.NavigateTo("/games/new");
    }

    private async Task JoinGameAsync(string gameId)
    {
        if (_currentUserId == null) return;

        var result = await GameService.JoinGameAsync(_currentUserId, gameId, CancellationToken.None);

        if (result.Success)
        {
            Navigation.NavigateTo($"/game/{result.GameId}");
        }
        else
        {
            Snackbar.Add(result.Reason ?? "Failed to join game.", Severity.Error);
            await RefreshDashboardStateAsync();
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection != null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
