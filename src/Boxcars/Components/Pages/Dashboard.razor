@page "/dashboard"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@using MudBlazor
@using Boxcars.Data
@using Boxcars.Services
@using Boxcars.Components.GameBoard
@attribute [Authorize]
@inject PlayerProfileService ProfileService
@inject GameService GameService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@implements IAsyncDisposable

<PageTitle>Dashboard - BoxCars</PageTitle>

@if (_loading)
{
    <MudStack Style="min-height: 12rem" Justify="Justify.Center" AlignItems="AlignItems.Center">
        <MudProgressLinear Indeterminate="true" Color="MudBlazor.Color.Primary" />
    </MudStack>
}
else if (_loadError)
{
    <MudPaper Class="pa-8" Style="max-width: 37.5rem; margin: 2rem auto; text-align: center">
        <MudText Typo="Typo.h4">Something went wrong</MudText>
        <MudText Typo="Typo.body1" Style="margin: 1rem 0">Unable to load your dashboard. Please try again.</MudText>
        <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" OnClick="@LoadDataAsync">Retry</MudButton>
    </MudPaper>
}
else if (_needsNickname)
{
    <MudPaper Class="pa-8" Style="max-width: 31.25rem; margin: 2rem auto">
        <MudText Typo="Typo.h4" Class="mb-3">Choose Your Nickname</MudText>
        <MudText Typo="Typo.body1" Class="mb-4">
            Your nickname couldn't be auto-set during registration. Please choose one to continue.
        </MudText>
        <MudTextField @bind-Value="_newNickname"
                      Label="Nickname"
                      Placeholder="Enter a unique nickname"
                      Variant="Variant.Outlined"
                      FullWidth="true"
                      Class="mb-4" />
        @if (!string.IsNullOrEmpty(_nicknameError))
        {
            <MudText Typo="Typo.body2" Color="MudBlazor.Color.Error" Class="mb-4">@_nicknameError</MudText>
        }
        <MudButton Variant="Variant.Filled"
                   Color="MudBlazor.Color.Primary"
                   OnClick="@SaveNicknameAsync"
                   Disabled="@(string.IsNullOrWhiteSpace(_newNickname))">
            Save Nickname
        </MudButton>
    </MudPaper>
}
else
{
    <MudStack Spacing="6">
        <MudPaper Class="pa-6">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
                <MudAvatar Size="Size.Large">
                    @if (HasProfileThumbnail())
                    {
                        <MudImage Src="@_profile!.ThumbnailUrl" Alt="@_profile.Nickname" Style="width: 100%; height: 100%; object-fit: cover" />
                    }
                    else
                    {
                        @GetProfileInitials()
                    }
                </MudAvatar>
                <MudStack>
                    <MudText Typo="Typo.h5">@_profile!.Nickname</MudText>
                    <MudText Typo="Typo.body2" Style="opacity: 0.7">@_profile!.Email</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>

        <MudPaper Class="pa-6">
            <MudText Typo="Typo.h5" Class="mb-3">Your Stats</MudText>
            <MudText Typo="Typo.body2" Style="opacity: 0.7">
                Welcome to BoxCars! Start your first game to begin tracking your stats.
            </MudText>
        </MudPaper>

        <MudPaper Class="pa-6">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Spacing="3">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.h5" Class="mb-3">Bots</MudText>
                    <MudText Typo="Typo.body2" Style="opacity: 0.7">
                        Manage bot players and their strategies from the dedicated bots page.
                    </MudText>
                </MudStack>
                <MudButton Variant="Variant.Filled"
                           Color="MudBlazor.Color.Primary"
                           OnClick='@(() => Navigation.NavigateTo("/bots"))'>
                    Manage Bots
                </MudButton>
            </MudStack>
        </MudPaper>

        <MudPaper Class="pa-6">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Spacing="3" Class="mb-3">
                <MudText Typo="Typo.h5">Games</MudText>
                <MudButton Variant="Variant.Outlined"
                           Color="MudBlazor.Color.Primary"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           Disabled="@_refreshingGames"
                           OnClick="RefreshGamesAsync">
                    @(_refreshingGames ? "Refreshing..." : "Refresh")
                </MudButton>
            </MudStack>

            @if (_dashboardState!.Games.Count > 0)
            {
                <MudStack Class="mb-6" Spacing="3">
                    @foreach (var game in _dashboardState.Games)
                    {
                        <MudPaper Class="pa-4">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Spacing="3">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.body1">@game.Name</MudText>
                                    <MudText Typo="Typo.caption" Style="opacity: 0.7">
                                        @(game.GameDate?.ToLocalTime().ToString("MMM d, yyyy") ?? game.CreatedAt.ToLocalTime().ToString("MMM d, yyyy"))
                                        • @game.PlayerCount players
                                        • @game.State
                                        @if (game.IsCreator)
                                        {
                                            <span> • Created by you</span>
                                        }
                                    </MudText>
                                </MudStack>
                                <MudStack Row="true" Spacing="2">
                                    <MudButton Variant="Variant.Filled"
                                               Color="MudBlazor.Color.Primary"
                                               OnClick="@(() => JoinGameAsync(game.GameId))">
                                        Join
                                    </MudButton>
                                    @if (game.IsCreator)
                                    {
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="MudBlazor.Color.Primary"
                                                   OnClick="@(() => OpenDeleteGameDialog(game.GameId))">
                                            Delete
                                        </MudButton>
                                    }
                                </MudStack>
                            </MudStack>
                        </MudPaper>
                    }
                </MudStack>
            }

            <MudText Typo="Typo.h6" Class="mb-3">Create a New Game</MudText>
            <MudStack Row="true" Spacing="3">
                <MudButton Variant="Variant.Filled"
                           Color="MudBlazor.Color.Primary"
                           OnClick="@CreateGameAsync">
                    Create Game
                </MudButton>
            </MudStack>
        </MudPaper>
    </MudStack>
}


@code {
    private bool _loading = true;
    private bool _loadError;
    private bool _needsNickname;
    private bool _refreshingGames;
    private string _newNickname = string.Empty;
    private string? _nicknameError;
    private string? _currentUserId;

    private ApplicationUser? _profile;
    private DashboardState? _dashboardState;
    private HubConnection? _hubConnection;

    private string GetProfileInitials()
    {
        if (string.IsNullOrWhiteSpace(_profile?.Nickname))
        {
            return "?";
        }

        return _profile.Nickname.Trim()[0].ToString();
    }

    private bool HasProfileThumbnail()
    {
        return !string.IsNullOrWhiteSpace(_profile?.ThumbnailUrl);
    }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null)
        {
            var state = await AuthState;
            _currentUserId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        }

        await LoadDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _currentUserId != null)
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/hubs/dashboard"))
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On("DashboardStateRefreshed", async () =>
            {
                await RefreshDashboardStateAsync();
                await InvokeAsync(StateHasChanged);
            });

            _hubConnection.On<object>("JoinConflict", async (conflict) =>
            {
                Snackbar.Add("Game is no longer available. The list has been refreshed.", Severity.Error);
                await RefreshDashboardStateAsync();
                await InvokeAsync(StateHasChanged);
            });

            try
            {
                await _hubConnection.StartAsync();
            }
            catch
            {
                // SignalR connection failure — dashboard still works, just no real-time updates
            }
        }
    }

    private async Task OpenDeleteGameDialog(string gameId)
    {
        var parameters = new DialogParameters<DeleteGameDialog>
        {
            { x => x.OnDelete, async (ct) =>
                {
                    if (_currentUserId is null || string.IsNullOrWhiteSpace(gameId))
                    {
                        return (false, "Unable to identify the active game.");
                    }

                    var result = await GameService.EndGameAsync(_currentUserId, gameId, ct);
                    return (result.Success, result.Reason);
                }
            }
        };

        var dialog = await DialogService.ShowAsync<DeleteGameDialog>("Delete Game", parameters, new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true,
            BackdropClick = false
        });

        var dialogResult = await dialog.Result;
        if (dialogResult is not null && !dialogResult.Canceled)
        {
            await RefreshDashboardStateAsync();
            StateHasChanged();
        }
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        _loadError = false;
        StateHasChanged();

        try
        {
            if (_currentUserId == null) return;

            _profile = await ProfileService.GetProfileAsync(_currentUserId, CancellationToken.None);
            if (_profile == null)
            {
                _loadError = true;
                return;
            }

            if (string.IsNullOrEmpty(_profile.Nickname))
            {
                _needsNickname = true;
                _loading = false;
                return;
            }

            try
            {
                _dashboardState = await GameService.GetDashboardStateAsync(_currentUserId, CancellationToken.None);
            }
            catch
            {
                _dashboardState = new DashboardState
                {
                    Games = []
                };
            }
        }
        catch
        {
            _loadError = true;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task RefreshDashboardStateAsync()
    {
        if (_currentUserId == null) return;
        try
        {
            _dashboardState = await GameService.GetDashboardStateAsync(_currentUserId, CancellationToken.None);
        }
        catch
        {
            // Silently fail — user can manually refresh
        }
    }

    private async Task RefreshGamesAsync()
    {
        if (_refreshingGames)
        {
            return;
        }

        _refreshingGames = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await RefreshDashboardStateAsync();
        }
        finally
        {
            _refreshingGames = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SaveNicknameAsync()
    {
        if (string.IsNullOrWhiteSpace(_newNickname) || _currentUserId == null) return;

        _nicknameError = null;
        var result = await ProfileService.UpdateNicknameAsync(_currentUserId, _newNickname.Trim(), CancellationToken.None);

        switch (result)
        {
            case NicknameResult.Success:
                _needsNickname = false;
                await LoadDataAsync();
                break;
            case NicknameResult.Conflict:
                _nicknameError = "That nickname is already taken. Please choose another.";
                break;
            default:
                _nicknameError = "Failed to save nickname. Please try again.";
                break;
        }
    }

    private void CreateGameAsync()
    {
        Navigation.NavigateTo("/games/new");
    }

    private async Task JoinGameAsync(string gameId)
    {
        if (_currentUserId == null) return;

        var result = await GameService.JoinGameAsync(_currentUserId, gameId, CancellationToken.None);

        if (result.Success)
        {
            Navigation.NavigateTo($"/game/{result.GameId}");
        }
        else
        {
            Snackbar.Add(result.Reason ?? "Failed to join game.", Severity.Error);
            await RefreshDashboardStateAsync();
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection != null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
