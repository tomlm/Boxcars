@page "/games/new"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Hosting
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components
@using Boxcars.Data
@using Boxcars.Engine.Data.Maps
@using Boxcars.Engine.Domain
@using Boxcars.Engine.Persistence
@using MudBlazor
@using Boxcars.Services
@using Boxcars.Services.Maps
@attribute [Authorize]
@inject GameService GameService
@inject PlayerProfileService ProfileService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IWebHostEnvironment WebHostEnvironment

<PageTitle>Create Game - BoxCars</PageTitle>

@if (IsBusy)
{
    <MudPaper Class="pa-4 mb-4" Outlined="true">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Medium" />
            <MudText Typo="Typo.body1">@BusyMessage</MudText>
        </MudStack>
    </MudPaper>
}

<MudStack Spacing="6">
    <MudText Typo="Typo.h3">Create Game</MudText>

    <MudPaper Class="pa-6" >
        <MudStack Spacing="4">
            <MudText Typo="Typo.body1">
                Configure the players, their colors, and the starting turn order before entering the board.
            </MudText>

            <MudDivider />


            <MudSelect T="int"
                       Label="Player Count"
                       Value="@_playerCount"
                       ValueChanged="OnPlayerCountChanged"
                       Variant="Variant.Outlined"
                       Disabled="@IsBusy"
                       FullWidth="true">
                @foreach (var count in _playerCountOptions)
                {
                    <MudSelectItem Value="@count">@count players</MudSelectItem>
                }
            </MudSelect>

            @if (!string.IsNullOrWhiteSpace(_validationMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_validationMessage</MudAlert>
            }

            <MudStack Spacing="3">
                @for (var index = 0; index < _playerSlots.Count; index++)
                {
                    var slot = _playerSlots[index];

                    <MudPaper @key="slot.SlotId" Outlined="true" Class="pa-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                            <MudSpacer />
                            <MudIconButton Icon="@MudBlazor.Icons.Material.Filled.KeyboardArrowUp"
                                           Color="MudBlazor.Color.Primary"
                                           Size="Size.Small"
                                           Disabled="@(index == 0 || IsBusy)"
                                           OnClick="@(() => MovePlayer(slot, -1))" />
                            <MudIconButton Icon="@MudBlazor.Icons.Material.Filled.KeyboardArrowDown"
                                           Color="MudBlazor.Color.Primary"
                                           Size="Size.Small"
                                           Disabled="@(index == _playerSlots.Count - 1 || IsBusy)"
                                           OnClick="@(() => MovePlayer(slot, 1))" />
                        </MudStack>

                        <MudGrid>
                            <MudItem xs="12" md="7">
                                <MudSelect T="string"
                                           Label="Player"
                                           Value="@slot.UserId"
                                           ValueChanged="@(value => OnPlayerChangedAsync(slot, value))"
                                           Variant="Variant.Outlined"
                                           Disabled="@(slot.IsCreatorSeat || IsBusy)"
                                           FullWidth="true">
                                    @foreach (var profile in GetSelectablePlayers(slot))
                                    {
                                        <MudSelectItem Value="@profile.RowKey">@GetPlayerLabel(profile)</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="5">
                                <MudSelect T="string"
                                           Label="Color"
                                           Value="@slot.AssignedColor"
                                           ValueChanged="@(value => OnColorChanged(slot, value))"
                                           Variant="Variant.Outlined"
                                           Disabled="@IsBusy"
                                           FullWidth="true">
                                    @foreach (var color in PlayerColorOptions.Colors)
                                    {
                                        <MudSelectItem Value="@color">@PlayerColorOptions.ToLabel(color)</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                }
            </MudStack>
            <MudButton Variant="Variant.Outlined"
                        Color="MudBlazor.Color.Secondary"
                        Disabled="@IsBusy"
                        OnClick="GenerateRandomCitiesAsync">
                @(_generatingRandomCities ? "Generating..." : "Generate Random Cities")
            </MudButton>

            @if (!string.IsNullOrWhiteSpace(_cityProbabilitySummary))
            {
                <MudText Typo="Typo.body2" Style="opacity: 0.8">@_cityProbabilitySummary</MudText>
            }

            @if (_regionProbabilityPreview.Count > 0)
            {
                <MudPaper Class="pa-4" Outlined="true">
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 700">Region Distribution</MudText>
                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr)); gap: 0.75rem">
                            @foreach (var region in _regionProbabilityPreview)
                            {
                                <MudPaper Class="pa-3" Outlined="true">
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                        <MudText Typo="Typo.body2" Style="font-weight: 600">@region.RegionName</MudText>
                                        <MudText Typo="Typo.body2" Style="font-weight: 700">@($"{region.Probability:N1}%")</MudText>
                                    </MudStack>
                                    <MudText Typo="Typo.caption" Style="opacity: 0.75">@region.RegionCode</MudText>
                                </MudPaper>
                            }
                        </div>
                    </MudStack>
                </MudPaper>
            }

            <MudExpansionPanels>
                <MudExpansionPanel Expanded="false">
                    <TitleContent>
                        <MudText Typo="Typo.h5">Game Settings</MudText>
                    </TitleContent>
                    <ChildContent>
                        <MudGrid Style="width: fit-content; max-width: 100%">
                            <MudItem xs="12" md="6">
                                <MudNumericField T="int" Label="Starting Cash" Value="@_settings.StartingCash" ValueChanged="@(value => UpdateSettings(_settings with { StartingCash = value }))" Variant="Variant.Outlined" Min="1" Disabled="@IsBusy" FullWidth="true" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudNumericField T="int" Label="Announcing Cash" Value="@_settings.AnnouncingCash" ValueChanged="@(value => UpdateSettings(_settings with { AnnouncingCash = value }))" Variant="Variant.Outlined" Min="1" Disabled="@IsBusy" FullWidth="true" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudNumericField T="int" Label="Winning Cash" Value="@_settings.WinningCash" ValueChanged="@(value => UpdateSettings(_settings with { WinningCash = value }))" Variant="Variant.Outlined" Min="1" Disabled="@IsBusy" FullWidth="true" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudNumericField T="int" Label="Rover Cash" Value="@_settings.RoverCash" ValueChanged="@(value => UpdateSettings(_settings with { RoverCash = value }))" Variant="Variant.Outlined" Min="1" Disabled="@IsBusy" FullWidth="true" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudNumericField T="int" Label="Public Fee" Value="@_settings.PublicFee" ValueChanged="@(value => UpdateSettings(_settings with { PublicFee = value }))" Variant="Variant.Outlined" Min="1" Disabled="@IsBusy" FullWidth="true" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudNumericField T="int" Label="Private Fee" Value="@_settings.PrivateFee" ValueChanged="@(value => UpdateSettings(_settings with { PrivateFee = value }))" Variant="Variant.Outlined" Min="1" Disabled="@IsBusy" FullWidth="true" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudNumericField T="int" Label="Unfriendly Fee 1" Value="@_settings.UnfriendlyFee1" ValueChanged="@(value => UpdateSettings(_settings with { UnfriendlyFee1 = value }))" Variant="Variant.Outlined" Min="1" Disabled="@IsBusy" FullWidth="true" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudNumericField T="int" Label="Unfriendly Fee 2" Value="@_settings.UnfriendlyFee2" ValueChanged="@(value => UpdateSettings(_settings with { UnfriendlyFee2 = value }))" Variant="Variant.Outlined" Min="1" Disabled="@IsBusy" FullWidth="true" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="LocomotiveType" Label="Starting Engine" Value="@_settings.StartEngine" ValueChanged="@(value => UpdateSettings(_settings with { StartEngine = value }))" Variant="Variant.Outlined" Disabled="@IsBusy" FullWidth="true">
                                    <MudSelectItem Value="@LocomotiveType.Freight">Freight</MudSelectItem>
                                    <MudSelectItem Value="@LocomotiveType.Express">Express</MudSelectItem>
                                    <MudSelectItem Value="@LocomotiveType.Superchief">Superchief</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudNumericField T="int" Label="Express Price" Value="@_settings.ExpressPrice" ValueChanged="@(value => UpdateSettings(_settings with { ExpressPrice = value }))" Variant="Variant.Outlined" Min="1" Disabled="@IsBusy" FullWidth="true" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudNumericField T="int" Label="Superchief Price" Value="@_settings.SuperchiefPrice" ValueChanged="@(value => UpdateSettings(_settings with { SuperchiefPrice = value }))" Variant="Variant.Outlined" Min="1" Disabled="@IsBusy" FullWidth="true" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSwitch T="bool" Label="Keep Cash Secret" Value="@_settings.KeepCashSecret" ValueChanged="@(value => UpdateSettings(_settings with { KeepCashSecret = value }))" Disabled="@IsBusy" Color="Color.Primary" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSwitch T="bool" Label="Home Swapping" Value="@_settings.HomeSwapping" ValueChanged="@(value => UpdateSettings(_settings with { HomeSwapping = value }))" Disabled="@IsBusy" Color="Color.Primary" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSwitch T="bool" Label="Home City Choice" Value="@_settings.HomeCityChoice" ValueChanged="@(value => UpdateSettings(_settings with { HomeCityChoice = value }))" Disabled="@IsBusy" Color="Color.Primary" />
                            </MudItem>
                        </MudGrid>
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>


            <MudText Typo="Typo.body2" Style="opacity: 0.75">
                Map: @_mapFileName
            </MudText>

            <MudStack Row="true" Spacing="3">
                <MudButton Variant="Variant.Filled"
                           Color="MudBlazor.Color.Primary"
                           OnClick="CreateGameAsync"
                           Disabled="@IsBusy">
                    @(_creating ? "Creating..." : "Create Game")
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="MudBlazor.Color.Primary"
                           OnClick='@(() => Navigation.NavigateTo("/dashboard"))'
                           Disabled="@IsBusy">
                    Cancel
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>
</MudStack>

@code {
    private string? _currentUserId;
    private List<ApplicationUser> _availablePlayers = new();
    private readonly List<PlayerSlot> _playerSlots = new();
    private List<int> _playerCountOptions = [2, 3, 4, 5, 6];
    private int _playerCount = 4;
    private bool _creating;
    private bool _generatingRandomCities;
    private string? _validationMessage;
    private GameSettings _settings = GameSettings.Default;
    private string _mapFileName = GameService.DefaultMapFileName;
    private string? _appliedPresetPayload;
    private IReadOnlyList<CityProbabilityOverride> _cityProbabilityOverrides = [];
    private IReadOnlyList<RailroadPriceOverride> _railroadPriceOverrides = [];
    private string _cityProbabilitySummary = "Using default city probabilities.";
    private IReadOnlyList<RegionDistributionPreview> _regionProbabilityPreview = [];
    private bool IsBusy => _creating || _generatingRandomCities;
    private string BusyMessage => _creating ? "Creating game and saving settings..." : "Generating city probabilities and railroad prices...";

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    [SupplyParameterFromQuery(Name = "preset")]
    private string? Preset { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is null)
        {
            return;
        }

        var state = await AuthState;
        _currentUserId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        _availablePlayers = await ProfileService.GetSelectableProfilesAsync(CancellationToken.None);
        var maxSelectablePlayers = Math.Min(6, _availablePlayers.Count);
        _playerCountOptions = maxSelectablePlayers >= 2
            ? Enumerable.Range(2, maxSelectablePlayers - 1).ToList()
            : [2];

        if (_playerCountOptions.Count == 0)
        {
            _playerCountOptions = [2];
        }

        _playerCount = Math.Min(4, _playerCountOptions[^1]);
        InitializePlayerSlots();
        ApplyReplayPreset();
    }

    private void InitializePlayerSlots()
    {
        _playerSlots.Clear();

        if (string.IsNullOrWhiteSpace(_currentUserId))
        {
            return;
        }

        var currentUser = _availablePlayers.FirstOrDefault(player => string.Equals(player.RowKey, _currentUserId, StringComparison.Ordinal));
        if (currentUser is null)
        {
            _validationMessage = "Your profile must have a nickname before you can create a configured game.";
            return;
        }

        _playerSlots.Add(new PlayerSlot
        {
            UserId = currentUser.RowKey,
            AssignedColor = ResolveDefaultColor(currentUser, new HashSet<string>(StringComparer.OrdinalIgnoreCase)),
            IsCreatorSeat = true
        });

        while (_playerSlots.Count < _playerCount)
        {
            var usedColors = _playerSlots
                .Select(slot => slot.AssignedColor)
                .Where(color => !string.IsNullOrWhiteSpace(color))
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            _playerSlots.Add(new PlayerSlot
            {
                UserId = string.Empty,
                AssignedColor = ResolveFallbackColor(usedColors)
            });
        }
    }

    private Task OnPlayerCountChanged(int value)
    {
        _playerCount = value;

        while (_playerSlots.Count > _playerCount)
        {
            _playerSlots.RemoveAt(_playerSlots.Count - 1);
        }

        while (_playerSlots.Count < _playerCount)
        {
            var usedColors = _playerSlots
                .Select(slot => slot.AssignedColor)
                .Where(color => !string.IsNullOrWhiteSpace(color))
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            _playerSlots.Add(new PlayerSlot
            {
                UserId = string.Empty,
                AssignedColor = ResolveFallbackColor(usedColors)
            });
        }

        return Task.CompletedTask;
    }

    private IEnumerable<ApplicationUser> GetSelectablePlayers(PlayerSlot slot)
    {
        var selectedElsewhere = _playerSlots
            .Where(candidate => !ReferenceEquals(candidate, slot))
            .Select(candidate => candidate.UserId)
            .Where(userId => !string.IsNullOrWhiteSpace(userId))
            .ToHashSet(StringComparer.Ordinal);

        return _availablePlayers.Where(profile =>
            string.Equals(profile.RowKey, slot.UserId, StringComparison.Ordinal)
            || !selectedElsewhere.Contains(profile.RowKey));
    }

    private async Task OnPlayerChangedAsync(PlayerSlot slot, string? value)
    {
        slot.UserId = value ?? string.Empty;
        var selectedProfile = _availablePlayers.FirstOrDefault(profile => string.Equals(profile.RowKey, slot.UserId, StringComparison.Ordinal));
        var usedColors = _playerSlots
            .Where(candidate => !ReferenceEquals(candidate, slot))
            .Select(candidate => candidate.AssignedColor)
            .Where(color => !string.IsNullOrWhiteSpace(color))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        slot.AssignedColor = ResolveDefaultColor(selectedProfile, usedColors);
        _validationMessage = null;
        await InvokeAsync(StateHasChanged);
    }

    private Task OnColorChanged(PlayerSlot slot, string value)
    {
        slot.AssignedColor = PlayerColorOptions.NormalizeOrDefault(value);
        _validationMessage = null;
        return Task.CompletedTask;
    }

    private void MovePlayer(PlayerSlot slot, int delta)
    {
        var currentIndex = _playerSlots.IndexOf(slot);
        if (currentIndex < 0)
        {
            return;
        }

        var targetIndex = currentIndex + delta;
        if (targetIndex < 0 || targetIndex >= _playerSlots.Count)
        {
            return;
        }

        (_playerSlots[currentIndex], _playerSlots[targetIndex]) = (_playerSlots[targetIndex], _playerSlots[currentIndex]);
    }

    private async Task CreateGameAsync()
    {
        if (string.IsNullOrWhiteSpace(_currentUserId))
        {
            Snackbar.Add("Unable to create game: missing user context.", Severity.Error);
            return;
        }

        _validationMessage = ValidateSelections();
        if (!string.IsNullOrWhiteSpace(_validationMessage))
        {
            return;
        }

        _creating = true;

        try
        {
            var request = new CreateGameRequest
            {
                CreatorUserId = _currentUserId,
                MapFileName = _mapFileName,
                Settings = _settings,
                CityProbabilityOverrides = _cityProbabilityOverrides,
                RailroadPriceOverrides = _railroadPriceOverrides,
                Players = _playerSlots.Select(slot => new GamePlayerSelection
                {
                    UserId = slot.UserId,
                    DisplayName = GetSelectedPlayerDisplayName(slot.UserId),
                    Color = PlayerColorOptions.NormalizeOrDefault(slot.AssignedColor)
                }).ToList()
            };

            var result = await GameService.CreateGameAsync(request, CancellationToken.None);
            if (!result.Success)
            {
                Snackbar.Add(result.Reason ?? "Failed to create game.", Severity.Error);
                return;
            }

            Navigation.NavigateTo($"/game/{result.GameId}");
        }
        finally
        {
            _creating = false;
        }
    }

    private string? ValidateSelections()
    {
        if (_playerSlots.Any(slot => string.IsNullOrWhiteSpace(slot.UserId)))
        {
            return "Select a player for every turn-order row.";
        }

        var distinctUsers = _playerSlots
            .Select(slot => slot.UserId)
            .Distinct(StringComparer.Ordinal)
            .Count();

        if (distinctUsers != _playerSlots.Count)
        {
            return "Each player can only appear once in the game.";
        }

        if (_playerSlots.All(slot => !string.Equals(slot.UserId, _currentUserId, StringComparison.Ordinal)))
        {
            return "You must include yourself in the game.";
        }

        var distinctColors = _playerSlots
            .Select(slot => slot.AssignedColor)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Count();

        if (distinctColors != _playerSlots.Count)
        {
            return "Each player must have a unique color.";
        }

        if (_settings.WinningCash < _settings.AnnouncingCash)
        {
            return "Winning cash must be greater than or equal to announcing cash.";
        }

        if (_settings.StartingCash <= 0
            || _settings.AnnouncingCash <= 0
            || _settings.WinningCash <= 0
            || _settings.RoverCash <= 0
            || _settings.PublicFee <= 0
            || _settings.PrivateFee <= 0
            || _settings.UnfriendlyFee1 <= 0
            || _settings.UnfriendlyFee2 <= 0
            || _settings.ExpressPrice <= 0
            || _settings.SuperchiefPrice <= 0)
        {
            return "All numeric settings must be greater than zero.";
        }

        return null;
    }

    private void UpdateSettings(GameSettings settings)
    {
        _settings = settings;
        _validationMessage = null;
    }

    private async Task GenerateRandomCitiesAsync()
    {
        _generatingRandomCities = true;

        try
        {
            var configuredMapFile = string.IsNullOrWhiteSpace(_mapFileName)
                ? GameService.DefaultMapFileName
                : _mapFileName.Trim();
            var mapPath = Path.Combine(WebHostEnvironment.ContentRootPath, configuredMapFile);
            if (!File.Exists(mapPath))
            {
                Snackbar.Add($"Map file '{configuredMapFile}' was not found.", Severity.Error);
                return;
            }

            await using var stream = File.OpenRead(mapPath);
            var loadResult = await MapDefinition.LoadAsync(Path.GetFileName(mapPath), stream, CancellationToken.None);
            if (!loadResult.Succeeded || loadResult.Definition is null)
            {
                Snackbar.Add("Unable to load the map for probability generation.", Severity.Error);
                return;
            }

            _cityProbabilityOverrides = MapProbabilityService.GenerateRandomCityProbabilities(loadResult.Definition);
            var randomizedMap = MapProbabilityService.ApplyCityProbabilities(loadResult.Definition, _cityProbabilityOverrides);
            _railroadPriceOverrides = randomizedMap.Railroads
                .Select(railroad => new RailroadPriceOverride
                {
                    RailroadIndex = railroad.Index,
                    PurchasePrice = railroad.PurchasePrice ?? 4_000
                })
                .ToList();
            _regionProbabilityPreview = BuildRegionProbabilityPreview(randomizedMap);
            var regionCount = _cityProbabilityOverrides
                .Select(overrideValue => overrideValue.RegionCode)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .Count();
            _cityProbabilitySummary = $"Randomized {_cityProbabilityOverrides.Count:N0} city probabilities across {regionCount:N0} regions.";
            _validationMessage = null;
            Snackbar.Add("Random city probabilities generated.", Severity.Success);
        }
        catch (Exception exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
        finally
        {
            _generatingRandomCities = false;
        }
    }

    private void ApplyReplayPreset()
    {
        if (string.IsNullOrWhiteSpace(Preset)
            || string.Equals(Preset, _appliedPresetPayload, StringComparison.Ordinal))
        {
            return;
        }

        var replayPreset = ReplayGamePresetSerialization.Deserialize(Preset);
        if (replayPreset is null)
        {
            _validationMessage = "Unable to load the replay setup.";
            return;
        }

        var presetPlayers = replayPreset.Players
            .Where(player => !string.IsNullOrWhiteSpace(player.UserId))
            .Take(Math.Max(2, Math.Min(6, replayPreset.Players.Count)))
            .ToList();

        if (presetPlayers.Count < 2)
        {
            _validationMessage = "Replay setup must include at least two players.";
            return;
        }

        var currentUserIndex = presetPlayers.FindIndex(player =>
            string.Equals(player.UserId, _currentUserId, StringComparison.Ordinal));
        if (currentUserIndex < 0)
        {
            _validationMessage = "Replay setup must include your player seat.";
            return;
        }

        _playerCount = presetPlayers.Count;
        _settings = replayPreset.Settings;
        _mapFileName = string.IsNullOrWhiteSpace(replayPreset.MapFileName)
            ? GameService.DefaultMapFileName
            : replayPreset.MapFileName;
        _cityProbabilityOverrides = replayPreset.CityProbabilityOverrides;
        _railroadPriceOverrides = replayPreset.RailroadPriceOverrides;
        _regionProbabilityPreview = BuildRegionProbabilityPreview(replayPreset.CityProbabilityOverrides);
        _cityProbabilitySummary = _cityProbabilityOverrides.Count == 0
            ? "Using default city probabilities."
            : $"Randomized {_cityProbabilityOverrides.Count:N0} city probabilities loaded from preset.";
        _playerSlots.Clear();

        for (var index = 0; index < presetPlayers.Count; index++)
        {
            var player = presetPlayers[index];
            _playerSlots.Add(new PlayerSlot
            {
                UserId = player.UserId,
                AssignedColor = PlayerColorOptions.NormalizeOrDefault(player.Color),
                IsCreatorSeat = index == currentUserIndex
            });
        }

        _validationMessage = null;
        _appliedPresetPayload = Preset;
    }

    private string ResolveDefaultColor(ApplicationUser? profile, HashSet<string> usedColors)
    {
        var preferredColor = profile is null ? null : PlayerColorOptions.NormalizeOrDefault(profile.PreferredColor, string.Empty);
        if (!string.IsNullOrWhiteSpace(preferredColor)
            && PlayerColorOptions.IsSupported(preferredColor)
            && !usedColors.Contains(preferredColor))
        {
            return preferredColor;
        }

        return ResolveFallbackColor(usedColors);
    }

    private static string ResolveFallbackColor(HashSet<string> usedColors)
    {
        return PlayerColorOptions.Colors.FirstOrDefault(color => !usedColors.Contains(color))
            ?? PlayerColorOptions.Colors[0];
    }

    private static string GetPlayerLabel(ApplicationUser profile)
    {
        if (profile.IsBot)
        {
            return $"{profile.Nickname} [BOT]";
        }

        return string.IsNullOrWhiteSpace(profile.Email)
            ? profile.Nickname
            : $"{profile.Nickname} ({profile.Email})";
    }

    private string GetSelectedPlayerDisplayName(string userId)
    {
        var selectedPlayer = _availablePlayers.FirstOrDefault(player => string.Equals(player.RowKey, userId, StringComparison.Ordinal));
        if (selectedPlayer is null)
        {
            return userId;
        }

        return string.IsNullOrWhiteSpace(selectedPlayer.Nickname)
            ? selectedPlayer.Email
            : selectedPlayer.Nickname;
    }

    private static IReadOnlyList<RegionDistributionPreview> BuildRegionProbabilityPreview(MapDefinition mapDefinition)
    {
        return mapDefinition.Regions
            .Select(region => new RegionDistributionPreview(
                region.Code,
                region.Name,
                Math.Max(0d, region.Probability ?? 0d)))
            .OrderByDescending(region => region.Probability)
            .ThenBy(region => region.RegionName, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static IReadOnlyList<RegionDistributionPreview> BuildRegionProbabilityPreview(IReadOnlyList<CityProbabilityOverride> cityProbabilityOverrides)
    {
        return cityProbabilityOverrides
            .GroupBy(entry => entry.RegionCode, StringComparer.OrdinalIgnoreCase)
            .Select(group => new RegionDistributionPreview(
                group.Key,
                group.Key,
                group.Sum(entry => entry.Probability)))
            .OrderByDescending(region => region.Probability)
            .ThenBy(region => region.RegionName, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private sealed class PlayerSlot
    {
        public Guid SlotId { get; } = Guid.NewGuid();
        public string UserId { get; set; } = string.Empty;
        public string AssignedColor { get; set; } = PlayerColorOptions.Colors[0];
        public bool IsCreatorSeat { get; set; }
    }

    private sealed record RegionDistributionPreview(
        string RegionCode,
        string RegionName,
        double Probability);
}
