@using Boxcars.Data.Maps
@using Boxcars.Data
@using Boxcars.Engine.Data.Maps

@using System.Globalization
@using MudBlazor

<div class="game-map-shell">
	<div class="game-map-host">
		<MapComponent @ref="_mapComponent"
				  MapFileName="@MapFileName"
				  SelectionMode="@SelectionMode"
				  SelectionModeChanged="@SelectionModeChanged"
				  ZoomPercent="@_zoomPercent"
				  ZoomPercentChanged="@OnZoomPercentChangedAsync"
				  PanCenterX="@PanCenterX"
				  PanCenterXChanged="@PanCenterXChanged"
				  PanCenterY="@PanCenterY"
				  PanCenterYChanged="@PanCenterYChanged"
				  PlayerId="@PlayerId"
				  PlayerColor="@PlayerColor"
				  PlayerStates="@PlayerStates"
				  CurrentTurnMovementRemaining="@CurrentTurnMovementRemaining"
				  IsCurrentUserActivePlayer="@IsCurrentUserActivePlayer"
				  MovementType="@MovementType"
				  PlayerOwnedRailroadIndices="@PlayerOwnedRailroadIndices"
				  OtherOwnedRailroadIndices="@OtherOwnedRailroadIndices"
				  RailroadOwnerColors="@RailroadOwnerColors"
				  SelectableRailroadIndices="@SelectableRailroadIndices"
				  SelectedRailroadIndex="@SelectedRailroadIndex"
				  RailroadSelected="@RailroadSelected"
				  RouteSuggestionChanged="@RouteSuggestionChanged"
				  RoutePreviewChanged="@RoutePreviewChanged"
				  DestinationCityChanged="@DestinationCityChanged"
				  StartCityChanged="@StartCityChanged" />


		<MudPaper Class="game-map-zoom-overlay" Outlined="true" Square="false">
			<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="game-map-zoom-overlay-content">
				<MudText Typo="Typo.caption" Class="game-map-zoom-overlay-label">Zoom</MudText>
				<MudText Typo="Typo.caption" Class="game-map-zoom-overlay-readout">@GetZoomPercentLabel()</MudText>
				<div class="game-map-zoom-overlay-slider-host">
					<MudSlider T="double"
							   Min="100"
							   Max="500"
							   Step="50"
							   Color="MudBlazor.Color.Primary"
							   Value="@_zoomPercent"
							   ValueChanged="OnZoomOverlayChangedAsync"
							   Class="game-map-zoom-overlay-slider" />
				</div>
				<div class="game-map-autozoom-toggle">
					<MudCheckBox T="bool"
							 Value="@AutoZoomEnabled"
							 ValueChanged="OnAutoZoomChangedAsync"
							 Label="Auto-zoom"
							 Color="MudBlazor.Color.Primary"
							 Dense="true" />
				</div>
			</MudStack>
		</MudPaper>
	</div>
</div>

@code {
	[Parameter]
	public string MapFileName { get; set; } = "U21MAP.RB3";

	[Parameter]
	public MapSelectionMode SelectionMode { get; set; } = MapSelectionMode.Route;

	[Parameter]
	public EventCallback<MapSelectionMode> SelectionModeChanged { get; set; }

	[Parameter]
	public double ZoomPercent { get; set; } = 100;

	[Parameter]
	public EventCallback<double> ZoomPercentChanged { get; set; }

	[Parameter]
	public double PanCenterX { get; set; }

	[Parameter]
	public EventCallback<double> PanCenterXChanged { get; set; }

	[Parameter]
	public double PanCenterY { get; set; }

	[Parameter]
	public EventCallback<double> PanCenterYChanged { get; set; }

	[Parameter]
	public bool AutoZoomEnabled { get; set; }

	[Parameter]
	public EventCallback<bool> AutoZoomEnabledChanged { get; set; }

	[Parameter]
	public string PlayerId { get; set; } = "mock-player";

	[Parameter]
	public string PlayerColor { get; set; } = "var(--accent-fill-rest)";

	[Parameter]
	public IReadOnlyList<PlayerMapState>? PlayerStates { get; set; }

	[Parameter]
	public int CurrentTurnMovementRemaining { get; set; }

	[Parameter]
	public bool IsCurrentUserActivePlayer { get; set; }

	[Parameter]
	public PlayerMovementType MovementType { get; set; } = PlayerMovementType.TwoDie;

	[Parameter]
	public IReadOnlyCollection<int>? PlayerOwnedRailroadIndices { get; set; }

	[Parameter]
	public IReadOnlyCollection<int>? OtherOwnedRailroadIndices { get; set; }

	[Parameter]
	public IReadOnlyDictionary<int, string>? RailroadOwnerColors { get; set; }

	[Parameter]
	public IReadOnlyCollection<int>? SelectableRailroadIndices { get; set; }

	[Parameter]
	public int? SelectedRailroadIndex { get; set; }

	[Parameter]
	public EventCallback<RailroadSelectionEvent> RailroadSelected { get; set; }

	[Parameter]
	public EventCallback<RouteSuggestionResult> RouteSuggestionChanged { get; set; }

	[Parameter]
	public EventCallback<TurnMovementPreview> RoutePreviewChanged { get; set; }

	[Parameter]
	public EventCallback<string> DestinationCityChanged { get; set; }

	[Parameter]
	public EventCallback<string> StartCityChanged { get; set; }

	private MapComponent? _mapComponent;
	private double _zoomPercent = 100;

	protected override void OnParametersSet()
	{
		if (_mapComponent is null)
		{
			_zoomPercent = ZoomPercent;
		}
	}

	public IReadOnlyList<string> Errors => _mapComponent?.Errors ?? Array.Empty<string>();
	public IReadOnlyList<MapComponent.RouteCityOption> RouteCityOptions => _mapComponent?.RouteCityOptions ?? Array.Empty<MapComponent.RouteCityOption>();
	public string? RouteStartNodeId => _mapComponent?.RouteStartNodeId;
	public string? DestinationNodeId => _mapComponent?.DestinationNodeId;
	public bool CanSuggestRoute => _mapComponent?.CanSuggestRoute == true;
	public RouteSuggestionResult? RouteSuggestion => _mapComponent?.RouteSuggestion;

	public int GetSelectedRouteMoveCount()
	{
		return _mapComponent?.GetSelectedRouteMoveCount() ?? 0;
	}

	public IReadOnlyList<string> GetSelectedRouteNodeIds()
	{
		return _mapComponent?.GetSelectedRouteNodeIds() ?? Array.Empty<string>();
	}

	public IReadOnlyList<string> GetSelectedRouteSegmentKeys()
	{
		return _mapComponent?.GetSelectedRouteSegmentKeys() ?? Array.Empty<string>();
	}

	public int GetSelectedRouteFeeEstimate()
	{
		return _mapComponent?.GetSelectedRouteFeeEstimate() ?? 0;
	}

	public async Task SetZoom(double zoomPercent)
	{
		if (_mapComponent is null)
		{
			return;
		}

		await _mapComponent.SetZoom(zoomPercent);
	}

	public async Task ResetZoom()
	{
		if (_mapComponent is null)
		{
			return;
		}

		await _mapComponent.ResetZoom();
	}

	public async Task ShiftViewportByPixels(double deltaX, double deltaY)
	{
		if (_mapComponent is null)
		{
			return;
		}

		await _mapComponent.ShiftViewportByPixels(deltaX, deltaY);
	}

	public async Task<RailroadSelectionEvent?> GetRailroadClientAnchorAsync(int railroadIndex)
	{
		if (_mapComponent is null)
		{
			return null;
		}

		return await _mapComponent.GetRailroadClientAnchorAsync(railroadIndex);
	}

	public async Task FocusRouteAsync(IReadOnlyList<string>? nodeIds)
	{
		if (_mapComponent is null)
		{
			return;
		}

		await _mapComponent.FocusRouteAsync(nodeIds);
	}

	private async Task OnZoomPercentChangedAsync(double zoomPercent)
	{
		_zoomPercent = zoomPercent;

		if (ZoomPercentChanged.HasDelegate)
		{
			await ZoomPercentChanged.InvokeAsync(zoomPercent);
		}
	}

	private Task OnZoomOverlayChangedAsync(double zoomPercent)
	{
		return SetZoom(zoomPercent);
	}

	private async Task OnAutoZoomChangedAsync(bool enabled)
	{
		if (AutoZoomEnabledChanged.HasDelegate)
		{
			await AutoZoomEnabledChanged.InvokeAsync(enabled);
		}
	}

	private string GetZoomPercentLabel()
	{
		return string.Concat(Math.Round(_zoomPercent).ToString(CultureInfo.InvariantCulture), "%");
	}

	public void SetStartCity(string nodeId)
	{
		_mapComponent?.SetStartCity(nodeId);
	}

		public void RestoreSelectedRoute(IReadOnlyList<string>? nodeIds, IReadOnlyList<string>? segmentKeys)
		{
			_mapComponent?.RestoreSelectedRoute(nodeIds, segmentKeys);
		}

	public void SetDestinationCity(string nodeId)
	{
		_mapComponent?.SetDestinationCity(nodeId);
	}

	public async Task SuggestRouteAsync()
	{
		if (_mapComponent is null)
		{
			return;
		}

		await _mapComponent.SuggestRouteAsync();
	}
}
