    [JSInvokable]
    public async Task OnClientViewportChanged(long sequence, double zoomPercent, double centerX, double centerY, double width, double height)
    {
        if (sequence <= _lastClientViewportSequence)
        {
            return;
        }

        _lastClientViewportSequence = sequence;

        var nextZoom = BoardViewportService.ClampZoom(zoomPercent);

        if (nextZoom <= BoardViewportService.MinZoom && _mapDefinition is not null)
        {
            var fitViewport = BoardViewportService.InitializeFitToBoard(_mapDefinition);
            centerX = fitViewport.CenterX;
            centerY = fitViewport.CenterY;
        }

        var changed = Math.Abs(_viewport.ZoomPercent - nextZoom) > 0.01
            || Math.Abs(_viewport.CenterX - centerX) > 0.01
            || Math.Abs(_viewport.CenterY - centerY) > 0.01;

        _viewport = new BoardViewport
        {
            ZoomPercent = nextZoom,
            CenterX = centerX,
            CenterY = centerY,
            ZoomAnchor = ZoomAnchor.ViewportCenter
        };

        _suspendCameraPush = true;

        var sizeChanged = UpdateViewportRenderSize(new RelativePoint(0, 0, width, height));

        if (changed)
        {
            await NotifyViewportChanged();
        }

        if (!changed && !sizeChanged)
        {
            return;
        }

        await InvokeAsync(StateHasChanged);
    }

    private string GetRailroadSegmentClass(RailroadRenderSegment segment)
    {
        var ownershipClass = segment.IsOwned ? "owned" : "unowned";
        var classes = new List<string> { ownershipClass };

        if (_selectedRailroadIndex == segment.RailroadIndex)
        {
            classes.Add("selected");
        }

        if (SelectionMode == MapSelectionMode.Route && IsRailroadSegmentInSelectedRoute(segment))
        {
            classes.Add(IsCurrentUserActivePlayer ? "route-selected-active" : "route-selected-inactive");
        }

        return string.Join(' ', classes);
    }

