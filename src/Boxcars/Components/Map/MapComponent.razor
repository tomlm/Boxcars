                    suggestion.TotalCost,
                    NodeIds = suggestion.NodeIds
                },
                CancellationToken.None);
        }
        catch
        {
        }
    }

    private RouteSelection? TryFindRouteExtension(string currentEndpoint, RouteNodeRenderItem clickedNode)
    {
        if (_routeContext is null)
        {
            return null;
        }

        var preferredStartingRailroadIndex = _selectedRouteSegments.Count > 0
            ? (int?)_selectedRouteSegments[^1].RailroadIndex
            : null;
        var selectedRailroadIndices = _selectedRouteSegments
            .Select(segment => segment.RailroadIndex)
            .ToHashSet();

        var directExtension = MapRouteService.FindShortestSelection(
            _routeContext,
            currentEndpoint,
            clickedNode.NodeId,
            preferredStartingRailroadIndex,
            selectedRailroadIndices,
            IsRailroadOwnedByPlayer);
        if (directExtension is not null && IsLegalRouteExtension(directExtension.Segments))
        {
            return directExtension;
        }

        var coLocatedNodes = _routeNodes
            .Where(node => !string.Equals(node.NodeId, clickedNode.NodeId, StringComparison.OrdinalIgnoreCase)
                && AreCoLocated(node, clickedNode))
            .OrderBy(node => IsGeneratedDotName(node.Name));

        foreach (var candidateNode in coLocatedNodes)
        {
            var candidateExtension = MapRouteService.FindShortestSelection(
                _routeContext,
                currentEndpoint,
                candidateNode.NodeId,
                preferredStartingRailroadIndex,
                selectedRailroadIndices,
                IsRailroadOwnedByPlayer);
            if (candidateExtension is not null && IsLegalRouteExtension(candidateExtension.Segments))
            {
                return candidateExtension;
            }
        }

        return null;
    }

    private static bool IsRailroadOwnedByPlayer(int railroadIndex)
    {
        _ = railroadIndex;
        return false;
    }

    private static bool AreCoLocated(RouteNodeRenderItem left, RouteNodeRenderItem right)
    {
        const double epsilon = 0.0001;
        return Math.Abs(left.X - right.X) < epsilon
            && Math.Abs(left.Y - right.Y) < epsilon;
    }

    private static bool IsGeneratedDotName(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return false;
        }

        var parts = name.Split('-', 2, StringSplitOptions.TrimEntries);
        return parts.Length == 2
            && int.TryParse(parts[0], out _)
            && int.TryParse(parts[1], out _);
    }

    private double GetRouteNodeHitboxWidth()
    {
        if (_mapDefinition is null)
        {
            return 0;
        }

        var viewBox = BoardViewportService.GetViewBox(_viewport, _mapDefinition);
        var mapUnitsPerPixelX = viewBox.Width / Math.Max(1, _viewportRenderWidth);
        return RouteClickRegionSizePixels * mapUnitsPerPixelX;
    }

    private double GetRouteNodeHitboxHeight()
    {
        if (_mapDefinition is null)
        {
            return 0;
        }

        var viewBox = BoardViewportService.GetViewBox(_viewport, _mapDefinition);
        var mapUnitsPerPixelY = viewBox.Height / Math.Max(1, _viewportRenderHeight);
        return RouteClickRegionSizePixels * mapUnitsPerPixelY;
    }

    private void InitializeRouteSelectionFromPlayerStates()
    {
        var activePlayerState = PlayerStates?.FirstOrDefault(playerState => playerState.IsActiveTurn)
            ?? PlayerStates?.FirstOrDefault(playerState => playerState.IsCurrentUser)
            ?? PlayerStates?.FirstOrDefault();

        if (activePlayerState is null)
        {
            if (!string.IsNullOrWhiteSpace(_routeStartNodeId)
                || !string.IsNullOrWhiteSpace(_destinationNodeId))
            {
                _routeStartNodeId = null;
                _routeStartNodeName = null;
                _destinationNodeId = null;
                _destinationCityName = null;
                _selectedRouteNodeIds.Clear();
                _selectedRouteSegments.Clear();
                _routeSuggestion = null;
                _routeSuggestionHighlights.Clear();
                ResetRouteCycleState();
            }

            return;
        }

        var startNodeId = ResolveNodeIdForCurrentLocation(activePlayerState)
            ?? ResolveNodeIdForPlayerStart(activePlayerState);
        if (!string.IsNullOrWhiteSpace(startNodeId)
            && !string.Equals(startNodeId, _routeStartNodeId, StringComparison.OrdinalIgnoreCase))
        {
            SetRouteStartNode(startNodeId, publishStartCityChanged: false, publishRoutePreviewChanged: false);
        }

        var destinationNodeId = ResolveNodeIdForCityName(activePlayerState.DestinationCityName);
        if (!string.IsNullOrWhiteSpace(destinationNodeId))
        {
            if (!string.Equals(destinationNodeId, _destinationNodeId, StringComparison.OrdinalIgnoreCase))
            {
                _destinationNodeId = destinationNodeId;
                var destinationOption = _routeCityOptions.FirstOrDefault(option =>
                    string.Equals(option.NodeId, destinationNodeId, StringComparison.OrdinalIgnoreCase));
                _destinationCityName = destinationOption.CityName;
            }
        }
        else if (!string.IsNullOrWhiteSpace(_destinationNodeId))
        {
            _destinationNodeId = null;
            _destinationCityName = null;
        }
    }

    private void SetRouteStartNode(string nodeId, bool publishStartCityChanged = true, bool publishRoutePreviewChanged = true)
    {
        var routeNode = _routeNodes.FirstOrDefault(candidate =>
            string.Equals(candidate.NodeId, nodeId, StringComparison.OrdinalIgnoreCase));
        if (routeNode is null)
        {
            return;
        }

        _routeStartNodeId = routeNode.NodeId;
        _routeStartNodeName = routeNode.Name;
        _selectedRouteNodeIds.Clear();
        _selectedRouteNodeIds.Add(routeNode.NodeId);
        _selectedRouteSegments.Clear();
        _routeSuggestion = null;
        _routeSuggestionHighlights.Clear();
        ResetRouteCycleState();

        if (publishStartCityChanged && StartCityChanged.HasDelegate)
        {
            _ = StartCityChanged.InvokeAsync(routeNode.Name);
        }

        if (publishRoutePreviewChanged)
        {
            _ = NotifyRoutePreviewChangedAsync();
        }
    }

    private void ResetRouteCycleState()
    {
        _routeCycleNodeId = null;
        _routeCyclePreviousNodeId = null;
        _routeCycleDefaultSegment = null;
        _routeCycleIndex = 0;
    }

    private void ApplyPendingRestoredRouteSelection()
    {
        if (_routeContext is null || _pendingRestoredRouteNodeIds.Count == 0)
        {
            return;
        }

        var restoredNodeIds = _pendingRestoredRouteNodeIds
            .Where(nodeId => !string.IsNullOrWhiteSpace(nodeId))
            .ToList();
        var restoredSegmentKeys = _pendingRestoredRouteSegmentKeys
            .Where(segmentKey => !string.IsNullOrWhiteSpace(segmentKey))
            .ToList();

        _pendingRestoredRouteNodeIds.Clear();
        _pendingRestoredRouteSegmentKeys.Clear();

        if (restoredNodeIds.Count == 0)
        {
            return;
        }

        ApplyRestoredRouteSelection(restoredNodeIds, restoredSegmentKeys);
        _ = NotifyRoutePreviewChangedAsync();
        StateHasChanged();
    }

    private void ApplyRestoredRouteSelection(IReadOnlyList<string> nodeIds, IReadOnlyList<string> segmentKeys)
    {
        var restoredNodeIds = nodeIds
            .Where(nodeId => !string.IsNullOrWhiteSpace(nodeId))
            .ToList();
        if (restoredNodeIds.Count == 0)
        {
            return;
        }

        var restoredStartNodeId = restoredNodeIds[0];
        SetRouteStartNode(restoredStartNodeId, publishStartCityChanged: false, publishRoutePreviewChanged: false);
        if (_routeContext is null
            || !string.Equals(_routeStartNodeId, restoredStartNodeId, StringComparison.OrdinalIgnoreCase)
            || restoredNodeIds.Count == 1)
        {
            return;
        }

        _selectedRouteSegments.Clear();
        _selectedRouteNodeIds.Clear();
        _selectedRouteNodeIds.Add(restoredStartNodeId);

        for (var index = 1; index < restoredNodeIds.Count; index++)
        {
            var fromNodeId = restoredNodeIds[index - 1];
            var toNodeId = restoredNodeIds[index];
            var encodedSegmentKey = index - 1 < segmentKeys.Count ? segmentKeys[index - 1] : null;

            if (!_routeContext.Adjacency.TryGetValue(fromNodeId, out var adjacentEdges))
            {
                break;
            }

            RouteGraphEdge? selectedEdge = null;

            if (TryParseSelectedSegmentKey(encodedSegmentKey, out var encodedFromNodeId, out var encodedToNodeId, out var railroadIndex))
            {
                selectedEdge = adjacentEdges.FirstOrDefault(edge =>
                    edge.RailroadIndex == railroadIndex
                    && string.Equals(edge.FromNodeId, encodedFromNodeId, StringComparison.OrdinalIgnoreCase)
                    && string.Equals(edge.ToNodeId, encodedToNodeId, StringComparison.OrdinalIgnoreCase));
            }

            selectedEdge ??= adjacentEdges.FirstOrDefault(edge =>
                string.Equals(edge.ToNodeId, toNodeId, StringComparison.OrdinalIgnoreCase));

            if (selectedEdge is null)
            {
                break;
            }

            _selectedRouteSegments.Add(selectedEdge);
            _selectedRouteNodeIds.Add(selectedEdge.ToNodeId);
        }
    }

    private static bool TryParseSelectedSegmentKey(string? encodedSegmentKey, out string fromNodeId, out string toNodeId, out int railroadIndex)
    {
        fromNodeId = string.Empty;
        toNodeId = string.Empty;
        railroadIndex = -1;

        if (string.IsNullOrWhiteSpace(encodedSegmentKey))
        {
            return false;
        }

        var parts = encodedSegmentKey.Split('|');
        if (parts.Length != 3 || !int.TryParse(parts[2], out railroadIndex))
        {
            return false;
        }

        fromNodeId = parts[0];
        toNodeId = parts[1];
        return !string.IsNullOrWhiteSpace(fromNodeId) && !string.IsNullOrWhiteSpace(toNodeId);
    }

    private void PopulateRailroadStrokeColors()
    {
        _railroadStrokeColors.Clear();

        if (_renderModel is null)
