    }

    public IReadOnlyList<string> GetSelectedRouteSegmentKeys()
    {
        return _selectedRouteSegments
            .Select(segment => string.Concat(segment.FromNodeId, "|", segment.ToNodeId, "|", segment.RailroadIndex.ToString(CultureInfo.InvariantCulture)))
            .ToList();
    }

    public int GetSelectedRouteFeeEstimate()
    {
        if (_selectedRouteSegments.Count == 0)
        {
            return 0;
        }

        var movementPointsPerTurn = MovementType == PlayerMovementType.ThreeDie ? 3 : 2;
        var totalCost = 0;
        var pointsUsedInCurrentTurn = 0;
        var lastRailroadIndex = -1;

        foreach (var segment in _selectedRouteSegments)
        {
            var ownershipCategory = ResolveRailroadOwnershipCategory(segment.RailroadIndex);
            var costPerTurn = ownershipCategory == RailroadOwnershipCategory.OwnedByOtherPlayer ? 5000 : 1000;

            var isFirstEdge = lastRailroadIndex < 0;
            var switchedRailroad = lastRailroadIndex >= 0 && lastRailroadIndex != segment.RailroadIndex;
            var exhaustedTurnCapacity = lastRailroadIndex == segment.RailroadIndex && pointsUsedInCurrentTurn >= movementPointsPerTurn;
            var startsNewTurn = isFirstEdge || switchedRailroad || exhaustedTurnCapacity;

            if (startsNewTurn)
            {
                totalCost += costPerTurn;
                pointsUsedInCurrentTurn = 1;
            }
            else
            {
                pointsUsedInCurrentTurn++;
            }

            lastRailroadIndex = segment.RailroadIndex;
        }

        return totalCost;
    }

    private TurnMovementPreview BuildSelectedRoutePreview()
    {
        var moveCount = GetSelectedRouteMoveCount();

        return new TurnMovementPreview
        {
            NodeIds = GetSelectedRouteNodeIds(),
            SegmentKeys = GetSelectedRouteSegmentKeys(),
            MoveCount = moveCount,
            FeeEstimate = GetSelectedRouteFeeEstimate(),
            ExhaustsMovement = CurrentTurnMovementRemaining > 0 && moveCount >= CurrentTurnMovementRemaining
        };
    }

    private bool IsRouteSelectionAtDestination()
    {
        return !string.IsNullOrWhiteSpace(_destinationNodeId)
            && _selectedRouteNodeIds.Count > 0
            && string.Equals(_selectedRouteNodeIds[^1], _destinationNodeId, StringComparison.OrdinalIgnoreCase);
    }

    private Task NotifyRoutePreviewChangedAsync()
    {
        if (!RoutePreviewChanged.HasDelegate)
        {
            return Task.CompletedTask;
        }

        return RoutePreviewChanged.InvokeAsync(BuildSelectedRoutePreview());
    }

