    {
        _destinationMenuVisible = false;
        _destinationMenuCityName = null;
        _destinationMenuNodeId = null;
    }

    private RailroadOwnershipCategory ResolveRailroadOwnershipCategory(int railroadIndex)
    {
        if (OtherOwnedRailroadIndices?.Contains(railroadIndex) == true)
        {
            return RailroadOwnershipCategory.OwnedByOtherPlayer;
        }

        if (PlayerOwnedRailroadIndices?.Contains(railroadIndex) == true)
        {
            return RailroadOwnershipCategory.OwnedByPlayer;
        }

        var hasOwnedSegment = _renderModel?.RailroadSegments.Any(segment =>
            segment.RailroadIndex == railroadIndex && segment.IsOwned) == true;
        return hasOwnedSegment ? RailroadOwnershipCategory.OwnedByPlayer : RailroadOwnershipCategory.Unowned;
    }

    private string ResolveCurrentPlayerNodeId()
    {
        if (_selectedRouteNodeIds.Count > 0)
        {
            return _selectedRouteNodeIds[^1];
        }

        return _routeStartNodeId ?? string.Empty;
    }

    private void ApplySuggestionToSelection(RouteSuggestionResult suggestion)
    {
        if (_routeContext is null || suggestion.Status != RouteSuggestionStatus.Success)
        {
            _selectedRouteSegments.Clear();
            _selectedRouteNodeIds.Clear();

            if (!string.IsNullOrWhiteSpace(_routeStartNodeId))
            {
                _selectedRouteNodeIds.Add(_routeStartNodeId);
            }

            _ = NotifyRoutePreviewChangedAsync();

            return;
        }

        var selectionSegmentLimit = CurrentTurnMovementRemaining > 0
            ? CurrentTurnMovementRemaining
            : int.MaxValue;

        _selectedRouteNodeIds.Clear();
        _selectedRouteNodeIds.Add(suggestion.NodeIds[0]);
        _selectedRouteSegments.Clear();

        for (var index = 0; index < suggestion.NodeIds.Count - 1 && _selectedRouteSegments.Count < selectionSegmentLimit; index++)
        {
            var fromNodeId = suggestion.NodeIds[index];
            var toNodeId = suggestion.NodeIds[index + 1];
            var routeSegment = _routeContext.Adjacency[fromNodeId]
                .FirstOrDefault(edge => string.Equals(edge.ToNodeId, toNodeId, StringComparison.OrdinalIgnoreCase));
            if (routeSegment is not null)
            {
                _selectedRouteSegments.Add(routeSegment);
                _selectedRouteNodeIds.Add(routeSegment.ToNodeId);
            }
        }

        _ = NotifyRoutePreviewChangedAsync();
    }

    private void BuildSuggestionHighlights(RouteSuggestionResult suggestion)
    {
        _routeSuggestionHighlights.Clear();

        if (_routeContext is null || suggestion.Status != RouteSuggestionStatus.Success)
        {
            return;
        }

        var movementRemaining = Math.Max(0, CurrentTurnMovementRemaining);

        for (var index = 1; index < suggestion.NodeIds.Count; index++)
        {
            var nodeId = suggestion.NodeIds[index];
            if (!_routeContext.DotLookup.TryGetValue(nodeId, out var dot))
            {
                continue;
            }

            _routeSuggestionHighlights.Add(new RouteSuggestionHighlight
            {
                NodeId = nodeId,
                X = dot.X,
                Y = dot.Y,
                Color = PlayerColor,
                Radius = 1.8,
                IsDashed = index > movementRemaining
            });
        }
    }

    private bool TryGetCurrentRouteEndpointMarker(out PlayerNodeMarker marker)
    {
        marker = default;

        if (_routeContext is null || _selectedRouteSegments.Count == 0 || _selectedRouteNodeIds.Count == 0)
        {
            return false;
        }

        var endpointNodeId = _selectedRouteNodeIds[^1];
        if (!_routeContext.DotLookup.TryGetValue(endpointNodeId, out var endpointDot))
        {
            return false;
        }

        marker = new PlayerNodeMarker(endpointDot.X, endpointDot.Y, PlayerColor, true);
        return true;
    }

    private void BuildPlayerOverlays()
    {
        _playerDestinationCityMarkers.Clear();
        _playerCurrentLocationMarkers.Clear();
        _playerTraveledSegmentMarkers.Clear();

        if (_routeContext is null || PlayerStates is null || PlayerStates.Count == 0)
        {
            return;
        }

        foreach (var playerState in PlayerStates)
        {
            var color = string.IsNullOrWhiteSpace(playerState.Color)
                ? "var(--accent-fill-rest)"
                : playerState.Color;

            var destinationNodeId = ResolveNodeIdForCityName(playerState.DestinationCityName);
            if (!string.IsNullOrWhiteSpace(destinationNodeId)
                && _routeContext.DotLookup.TryGetValue(destinationNodeId, out var destinationDot))
            {
                _playerDestinationCityMarkers.Add(new PlayerNodeMarker(destinationDot.X, destinationDot.Y, color));
            }

            var currentNodeId = ResolveNodeIdForCurrentLocation(playerState);
            if (!string.IsNullOrWhiteSpace(currentNodeId)
                && _routeContext.DotLookup.TryGetValue(currentNodeId, out var currentDot))
            {
                _playerCurrentLocationMarkers.Add(new PlayerNodeMarker(currentDot.X, currentDot.Y, color, playerState.IsActiveTurn));
            }

            foreach (var segmentKey in playerState.TraveledSegmentKeys)
            {
                if (!TryResolveSegmentMidpoint(segmentKey, out var midpointX, out var midpointY))
                {
                    continue;
                }

                _playerTraveledSegmentMarkers.Add(new PlayerNodeMarker(midpointX, midpointY, color));
            }
        }
    }

    private string? ResolveNodeIdForPlayerStart(PlayerMapState playerState)
    {
        var homeNodeId = ResolveNodeIdForCityName(playerState.HomeCityName);
        if (!string.IsNullOrWhiteSpace(homeNodeId))
        {
            return homeNodeId;
        }

        if (!string.IsNullOrWhiteSpace(playerState.StartNodeId))
        {
            return playerState.StartNodeId;
        }

        return ResolveNodeIdForCurrentLocation(playerState);
    }

    private string? ResolveNodeIdForCurrentLocation(PlayerMapState playerState)
    {
        var hasTraveledForCurrentTrip = playerState.TraveledSegmentKeys.Count > 0;

        if (!hasTraveledForCurrentTrip)
        {
            var currentCityNodeId = ResolveNodeIdForCityName(playerState.CurrentCityName);
            if (!string.IsNullOrWhiteSpace(currentCityNodeId))
            {
                return currentCityNodeId;
            }
        }

        if (!string.IsNullOrWhiteSpace(playerState.CurrentNodeId))
        {
            return playerState.CurrentNodeId;
        }

        var fallbackCurrentCityNodeId = ResolveNodeIdForCityName(playerState.CurrentCityName);
        if (!string.IsNullOrWhiteSpace(fallbackCurrentCityNodeId))
        {
            return fallbackCurrentCityNodeId;
        }

        return ResolveNodeIdForCityName(playerState.HomeCityName);
    }

    private string? ResolveNodeIdForCityName(string? cityName)
    {
        if (string.IsNullOrWhiteSpace(cityName))
        {
            return null;
        }

        var cityOption = _routeCityOptions.FirstOrDefault(option =>
            string.Equals(option.CityName, cityName, StringComparison.OrdinalIgnoreCase));

        return string.IsNullOrWhiteSpace(cityOption.NodeId) ? null : cityOption.NodeId;
    }

    private bool TryResolveSegmentMidpoint(string segmentKey, out double midpointX, out double midpointY)
    {
        midpointX = 0;
        midpointY = 0;

        if (string.IsNullOrWhiteSpace(segmentKey))
        {
            return false;
        }

        var parts = segmentKey.Split('-', 2, StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length != 2)
        {
            return false;
        }

        if (!_routeContext!.Adjacency.TryGetValue(parts[0], out var edges))
        {
            return false;
        }

        var edge = edges.FirstOrDefault(candidate =>
            string.Equals(candidate.ToNodeId, parts[1], StringComparison.OrdinalIgnoreCase));
        if (edge is null)
        {
            return false;
        }

        midpointX = (edge.X1 + edge.X2) / 2.0;
        midpointY = (edge.Y1 + edge.Y2) / 2.0;
        return true;
    }

    private async Task PublishRouteSuggestionUpdateAsync(RouteSuggestionResult suggestion)
