    private void OnCityRightClicked(CityRenderItem city, MouseEventArgs args)
    {
        DismissRouteNodeRailMenu();

        if (SelectionMode != MapSelectionMode.Route || _routeContext is null)
        {
            DismissDestinationMenu();
            return;
        }

        var destinationNode = ResolveRouteNodeForCity(city);
        if (destinationNode is null)
        {
            DismissDestinationMenu();
            return;
        }

        _destinationMenuCityName = city.Name;
        _destinationMenuNodeId = destinationNode.NodeId;
        _destinationMenuClientX = args.ClientX;
        _destinationMenuClientY = args.ClientY;
        _destinationMenuVisible = true;
    }

    private RouteNodeRenderItem? ResolveRouteNodeForCity(CityRenderItem city)
    {
        var exactNameMatch = _routeNodes.FirstOrDefault(node =>
            string.Equals(node.Name, city.Name, StringComparison.OrdinalIgnoreCase));
        if (exactNameMatch is not null)
        {
            return exactNameMatch;
        }

        return _routeNodes
            .OrderBy(node => Math.Abs(node.X - city.X) + Math.Abs(node.Y - city.Y))
            .FirstOrDefault();
    }

    private void BuildRouteCityOptions()
    {
        _routeCityOptions.Clear();

        if (_renderModel is null || _routeNodes.Count == 0)
        {
            return;
        }

        var seenNodeIds = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var city in _renderModel.Cities.OrderBy(candidate => candidate.Name, StringComparer.OrdinalIgnoreCase))
        {
            var routeNode = ResolveRouteNodeForCity(city);
            if (routeNode is null || !seenNodeIds.Add(routeNode.NodeId))
            {
                continue;
            }

            _routeCityOptions.Add(new RouteCityOption(city.Name, routeNode.NodeId));
        }
    }

    private Task OnDestinationMenuSelectedAsync()
    {
        if (string.IsNullOrWhiteSpace(_destinationMenuCityName) || string.IsNullOrWhiteSpace(_destinationMenuNodeId))
        {
            DismissDestinationMenu();
            return Task.CompletedTask;
        }

        _destinationCityName = _destinationMenuCityName;
        _destinationNodeId = _destinationMenuNodeId;
        DismissDestinationMenu();

        if (DestinationCityChanged.HasDelegate)
        {
            return DestinationCityChanged.InvokeAsync(_destinationCityName);
        }

        return Task.CompletedTask;
    }

    private async Task RecalculateRouteSuggestionAsync()
    {
        if (_routeContext is null || string.IsNullOrWhiteSpace(_destinationNodeId))
        {
            return;
        }

        var startNodeId = ResolveCurrentPlayerNodeId();
        if (string.IsNullOrWhiteSpace(startNodeId))
        {
            return;
        }

        var suggestion = MapRouteService.FindCheapestSuggestion(
            _routeContext,
            new RouteSuggestionRequest
            {
                PlayerId = string.IsNullOrWhiteSpace(PlayerId) ? "mock-player" : PlayerId,
                StartNodeId = startNodeId,
                DestinationNodeId = _destinationNodeId,
                MovementType = MovementType,
                PlayerColor = PlayerColor,
                ResolveRailroadOwnership = ResolveRailroadOwnershipCategory
            });

        _routeSuggestion = suggestion;
        ApplySuggestionToSelection(suggestion);
        BuildSuggestionHighlights(suggestion);
        await PublishRouteSuggestionUpdateAsync(suggestion);

        if (RouteSuggestionChanged.HasDelegate)
        {
            await RouteSuggestionChanged.InvokeAsync(suggestion);
        }
    }

