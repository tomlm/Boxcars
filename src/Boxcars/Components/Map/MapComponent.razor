    private bool IsRailroadSegmentInSelectedRoute(RailroadRenderSegment segment)
    {
        var startNodeId = MapRouteService.NodeKey(segment.StartRegionIndex, segment.StartDotIndex);
        var endNodeId = MapRouteService.NodeKey(segment.EndRegionIndex, segment.EndDotIndex);

        foreach (var routeSegment in _selectedRouteSegments)
        {
            if (routeSegment.RailroadIndex != segment.RailroadIndex)
            {
                continue;
            }

            var forwardMatch = string.Equals(routeSegment.FromNodeId, startNodeId, StringComparison.OrdinalIgnoreCase)
                && string.Equals(routeSegment.ToNodeId, endNodeId, StringComparison.OrdinalIgnoreCase);
            if (forwardMatch)
            {
                return true;
            }

            var reverseMatch = string.Equals(routeSegment.FromNodeId, endNodeId, StringComparison.OrdinalIgnoreCase)
                && string.Equals(routeSegment.ToNodeId, startNodeId, StringComparison.OrdinalIgnoreCase);
            if (reverseMatch)
            {
                return true;
            }
        }

        return false;
    }

    public int GetSelectedRouteMoveCount()
    {
        return Math.Max(0, _selectedRouteNodeIds.Count - 1);
    }

