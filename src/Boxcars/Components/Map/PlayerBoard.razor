@using Boxcars.Data
@using MudBlazor

<div class="player-board-scope">
    <MudStack Class="player-board" Spacing="2">
        @foreach (var player in Players)
        {
            <MudTooltip Placement="Placement.Right" Arrow="true" Disabled="@(player.CoverageMetrics.Count == 0)">
                <TooltipContent>
                    <MudPaper Class="player-card-tooltip pa-3" Outlined="true" Elevation="2">
                        <MudText Typo="Typo.subtitle2">@player.Name Coverage</MudText>
                        <MudTable T="RailroadOverlayMetricRow" Items="player.CoverageMetrics" Dense="true" Hover="true" Class="player-card-tooltip-table">
                            <HeaderContent>
                                <MudTh>Area</MudTh>
                                <MudTh>Access</MudTh>
                                <MudTh>Monopoly</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.Label</MudTd>
                                <MudTd>@FormatPercent(context.AccessPercent)</MudTd>
                                <MudTd>@FormatPercent(context.MonopolyPercent)</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudPaper>
                </TooltipContent>
                <ChildContent>
                    <MudPaper Class="@GetCardClass(player)">
                        <MudStack Row="true" Class="player-card-portrait">
                            <div class="player-avatar-shell">
                                <MudAvatar Class="@GetAvatarClass(player)" Size="Size.Large">
                                    @if (HasThumbnail(player))
                                    {
                                        <MudImage Src="@player.ThumbnailUrl" Alt="@player.Name" Class="player-avatar-image" />
                                    }
                                    else
                                    {
                                        @GetInitial(player.Name)
                                    }
                                </MudAvatar>
                                <MudTooltip Text="@(player.IsConnected ? "Connected" : "Disconnected")">
                                    <MudIcon Class="@GetStatusIconClass(player)"
                                             Icon="@(player.IsConnected ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                                             Size="Size.Small" />
                                </MudTooltip>
                            </div>
                            <MudStack>
                                <MudText Typo="Typo.subtitle1" Class="player-card-name">@player.Name</MudText>
                                <MudText Typo="Typo.caption" Class="player-card-subtitle">Home: @player.HomeCity</MudText>
                            </MudStack>
                        </MudStack>

                        <MudStack Class="player-card-info" Spacing="1">
                            <MudText Typo="Typo.caption" Class="player-card-line">
                                @if (player.IsAtDestination)
                                {
                                    <span class="player-card-label">At Destination:</span>
                                    <span>@player.TripDestinationLabel</span>
                                }
                                else
                                {
                                    <span class="player-card-label">Trip:</span>
                                    <span>@player.TripStartLabel @("=>") @player.TripDestinationLabel</span>
                                }
                            </MudText>
                            @if (!player.IsAtDestination)
                            {
                                <MudText Typo="Typo.caption" Class="player-card-line">
                                    <span class="player-card-label">Distance:</span> @player.DistanceToDestination <span class="player-card-label">Payout:</span> $@player.Payoff.ToString("N0")
                                </MudText>
                            }
                            <MudText Typo="Typo.caption" Class="player-card-line">
                                <span class="player-card-label">Engine:</span> @player.LocomotiveLabel
                            </MudText>
                            <MudText Typo="Typo.caption" Class="player-card-line">
                                <span class="player-card-label">Cash:</span> <span class="@GetCashValueClass(player)">@player.GetMoneyDisplay()</span>
                            </MudText>
                            @if (!string.IsNullOrWhiteSpace(player.DelegatedControllerDisplayName))
                            {
                                <MudText Typo="Typo.caption" Class="player-card-line player-card-line-controlled-by">
                                    <span class="player-card-label">Controlled by:</span>
                                    <span class="player-card-controlled-by-value">@player.DelegatedControllerDisplayName</span>
                                </MudText>
                            }
                            @if (!string.IsNullOrWhiteSpace(player.BonusPendingLabel))
                            {
                                <MudText Typo="Typo.caption" Class="player-card-line">
                                    <span class="player-card-status-value player-card-status-value-bonus">@player.BonusPendingLabel</span>
                                </MudText>
                            }
                            @if (player.FeesOwed > 0)
                            {
                                <MudText Typo="Typo.caption" Class="player-card-line">
                                    <span class="player-card-label">Fees Due:</span> <span class="player-card-status-value player-card-status-value-fees">$@player.FeesOwed.ToString("N0")</span>
                                </MudText>
                            }

                            @if (player.CanUseTestControl)
                            {
                                <MudText Typo="Typo.caption" Class="player-card-line player-card-line-test-state">
                                    @(player.IsTestControlled ? "Test mode enabled" : "Mock player")
                                </MudText>
                            }
                        </MudStack>

                        @if (player.CanUseTestControl || player.CanTakeDelegatedControl || player.CanReleaseDelegatedControl)
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Class="player-card-action-row">
                                @if (player.CanToggleConnection)
                                {
                                    <MudButton Variant="Variant.Outlined"
                                               Color="@(player.IsConnected ? MudBlazor.Color.Warning : MudBlazor.Color.Success)"
                                               Size="Size.Small"
                                               OnClick="() => OnToggleConnection.InvokeAsync(player.Index)">
                                        @(player.IsConnected ? "DISCONNECT" : "CONNECT")
                                    </MudButton>
                                }

                                @if (player.CanTakeDelegatedControl || player.CanReleaseDelegatedControl)
                                {
                                    <MudButton Variant="Variant.Outlined"
                                               Color="MudBlazor.Color.Primary"
                                               Size="Size.Small"
                                               OnClick="() => OnToggleDelegatedControl.InvokeAsync(player.Index)">
                                        @(player.CanReleaseDelegatedControl ? "RELEASE" : "TAKE CONTROL")
                                    </MudButton>
                                }
                            </MudStack>
                        }
                    </MudPaper>
                </ChildContent>
            </MudTooltip>
        }

        @if (HasAnyMockPlayers)
        {
            <MudPaper Class="player-board-test-toolbar pa-2" Outlined="true">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.caption">Local mock-player control</MudText>
                    <MudButton Variant="@(IsTestModeEnabled ? Variant.Filled : Variant.Outlined)"
                               Color="MudBlazor.Color.Primary"
                               Size="Size.Small"
                               OnClick="OnToggleTestModeAsync">
                        @(IsTestModeEnabled ? "TEST MODE ON" : "TEST MODE")
                    </MudButton>
                </MudStack>
            </MudPaper>
        }
    </MudStack>
</div>

@code {
    [Parameter]
    public IReadOnlyList<PlayerBoardModel> Players { get; set; } = Array.Empty<PlayerBoardModel>();

    [Parameter]
    public bool IsTestModeEnabled { get; set; }

    [Parameter]
    public EventCallback OnToggleTestMode { get; set; }

    [Parameter]
    public EventCallback<int> OnToggleConnection { get; set; }

    [Parameter]
    public EventCallback<int> OnToggleDelegatedControl { get; set; }

    private bool HasAnyMockPlayers => Players.Any(player => player.CanUseTestControl);

    private static string GetInitial(string name)
    {
        return string.IsNullOrWhiteSpace(name) ? "?" : name[..1].ToUpperInvariant();
    }

    private static string GetCardClass(PlayerBoardModel player)
    {
        var classes = $"player-card {GetColorClass(player.Color)}";
        if (player.IsActiveTurn)
        {
            classes += " player-card-active";
        }

        if (player.IsEliminated)
        {
            classes += " player-card-eliminated";
        }

        return classes;
    }

    private static string GetAvatarClass(PlayerBoardModel player)
    {
        return $"player-avatar {GetColorClass(player.Color)}";
    }

    private static bool HasThumbnail(PlayerBoardModel player)
    {
        return !string.IsNullOrWhiteSpace(player.ThumbnailUrl);
    }

    private static string GetStatusIconClass(PlayerBoardModel player)
    {
        return player.IsConnected
            ? "player-status-connected player-avatar-status"
            : "player-status-disconnected player-avatar-status";
    }

    private static string GetCashValueClass(PlayerBoardModel player)
    {
        if (player.IsCurrentUser || player.IsDelegatedToCurrentUser || player.IsTestControlled)
        {
            return string.Empty;
        }

        return player.Cash >= Boxcars.Engine.Domain.GameEngine.GetRailroadPurchasePrice(0)
            ? "player-card-cash-value player-card-cash-value-affordable"
            : "player-card-cash-value player-card-cash-value-too-expensive";
    }

    private static string FormatPercent(decimal value)
    {
        return $"{value:N1}%";
    }

    private Task OnToggleTestModeAsync()
    {
        return OnToggleTestMode.InvokeAsync();
    }

    private static string GetColorClass(string color)
    {
        return PlayerColorOptions.NormalizeOrDefault(color) switch
        {
            "darkblue" => "player-color-darkblue",
            "blue" => "player-color-blue",
            "cyan" => "player-color-cyan",
            "red" => "player-color-red",
            "darkred" => "player-color-darkred",
            "orange" => "player-color-orange",
            "yellow" => "player-color-yellow",
            "purple" => "player-color-purple",
            "green" => "player-color-green",
            "darkgreen" => "player-color-darkgreen",
            _ => "player-color-default"
        };
    }
}
