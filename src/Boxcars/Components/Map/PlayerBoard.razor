@using Boxcars.Data
@using MudBlazor

<MudStack Class="w-100 pa-0" Style="box-sizing: border-box" Spacing="2">
        @foreach (var player in Players)
        {
            <MudTooltip Placement="Placement.Right" Arrow="true" Disabled="@(player.CoverageMetrics.Count == 0)">
                <TooltipContent>
                    <MudPaper Style="min-width: 16rem" Class="pa-3" Outlined="true" Elevation="2">
                        <MudText Typo="Typo.subtitle2">@player.Name Coverage</MudText>
                        <MudTable T="RailroadOverlayMetricRow" Items="player.CoverageMetrics" Dense="true" Hover="true">
                            <HeaderContent>
                                <MudTh>Area</MudTh>
                                <MudTh>Access</MudTh>
                                <MudTh>Monopoly</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.Label</MudTd>
                                <MudTd>@FormatPercent(context.AccessPercent)</MudTd>
                                <MudTd>@FormatPercent(context.MonopolyPercent)</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudPaper>
                </TooltipContent>
                <ChildContent>
                    <MudPaper Style="@GetCardStyle(player)">
                        <MudStack Row="true" Style="@GetPortraitStyle(player)">
                            <div style="position: absolute; bottom: 0.1rem; right: 0.2rem; z-index: 1; display: flex; align-items: center; gap: 0.15rem">
                                @if (player.ShowDisconnectedControlToggle)
                                {
                                    @if (!string.Equals(player.DisconnectedControlMode, DisconnectedSeatControlModes.Self, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <MudText Typo="Typo.caption" Style="font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; font-size: 0.6rem; opacity: 0.85; text-shadow: 0 1px 2px rgb(0 0 0 / 0.7)">
                                            @player.DisconnectedControlMode
                                        </MudText>
                                    }
                                    <MudMenu Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                        <ActivatorContent>
                                            <MudIconButton Icon="@Icons.Material.Filled.Settings"
                                                           Size="Size.Small"
                                                           Color="Color.Default"
                                                           Style="padding: 2px; min-width: 0; min-height: 0"
                                                           aria-label="@($"Change control mode for {player.Name}")" />
                                        </ActivatorContent>
                                        <ChildContent>
                                            @foreach (var option in player.ControlModeOptions)
                                            {
                                                <MudMenuItem OnClick="@(async () => await OnDisconnectedSeatControlChangedAsync(player, option.Value))">
                                                    @option.Label
                                                </MudMenuItem>
                                            }
                                        </ChildContent>
                                    </MudMenu>
                                }
                                @if (player.OwnedRailroadCount > 0)
                                {
                                    <MudTooltip Text="@(HighlightedPlayerIndex == player.Index ? "Hide network" : "Show network")">
                                        <MudIconButton Icon="@Icons.Material.Filled.Train"
                                                       Size="Size.Small"
                                                       Color="@(HighlightedPlayerIndex == player.Index ? MudBlazor.Color.Warning : MudBlazor.Color.Default)"
                                                       Style="padding: 2px; min-width: 0; min-height: 0"
                                                       OnClick="@(() => OnToggleNetworkHighlight.InvokeAsync(HighlightedPlayerIndex == player.Index ? null : player.Index))" />
                                    </MudTooltip>
                                }
                            </div>
                            <MudStack Class="d-inline-flex flex-shrink-0" Style="position: relative" Spacing="0">
                                @if (player.IsWinner)
                                {
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Style="position: absolute; top: -0.2rem; left: -0.2rem; z-index: 2; background: linear-gradient(135deg, #facc15, #f59e0b); color: #1f2937; font-size: 0.62rem; font-weight: 900; letter-spacing: 0.08em; padding: 0.15rem 0.45rem; border-radius: 0.35rem; box-shadow: 0 2px 8px rgb(0 0 0 / 0.35)">
                                        WINNER
                                    </MudChip>
                                }
                                <MudButton Variant="Variant.Text"
                                           Color="MudBlazor.Color.Inherit"
                                           Style="min-width: 0; padding: 0; border-radius: 999px; line-height: 0; overflow: visible"
                                           OnClick="() => OnFocusPlayer.InvokeAsync(player.Index)"
                                           aria-label="@($"Focus map on {player.Name}")">
                                    <MudBadge Visible="@(!player.IsBotPlayer)"
                                              Color="@(player.IsConnected ? MudBlazor.Color.Success : MudBlazor.Color.Error)"
                                              Dot="true"
                                              Overlap="true"
                                              Bordered="true"
                                              Origin="Origin.BottomRight"
                                              Class="d-inline-flex"
                                              Style="overflow: visible">
                                        <MudAvatar Style="color: var(--player-color-fg, #fff); font-weight: 700; overflow: hidden; flex-shrink: 0; background-color: rgb(255 255 255 / 0.32)" Size="Size.Large">
                                            @if (HasThumbnail(player))
                                            {
                                                <MudImage Src="@player.ThumbnailUrl" Alt="@player.Name" Style="width: 100%; height: 100%; object-fit: cover" />
                                            }
                                            else
                                            {
                                                @GetInitial(player.Name)
                                            }
                                        </MudAvatar>
                                    </MudBadge>
                                </MudButton>
                            </MudStack>
                            <MudStack Class="flex-grow-1" Style="min-width: 0" Spacing="0">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="w-100" Style="min-width: 0">
                                    <MudText Typo="Typo.subtitle1" Style="min-width: 0; text-shadow: 0 1px 2px rgb(0 0 0 / 0.75), 0 0 8px rgb(0 0 0 / 0.28)">@player.Name</MudText>
                                    @if (player.IsBotPlayer)
                                    {
                                        <MudSpacer />
                                        <MudTooltip Text="AI player">
                                            <MudText Typo="Typo.caption" Style="padding-left: 0.5rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; text-shadow: 0 1px 2px rgb(0 0 0 / 0.7)">AI</MudText>
                                        </MudTooltip>
                                    }
                                </MudStack>
                                <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudText Typo="Typo.caption" Style="text-shadow: 0 1px 2px rgb(0 0 0 / 0.7); opacity: 0.92">Home: @player.HomeCity</MudText>
                                </MudStack>
                            </MudStack>
                        </MudStack>

                        <MudStack Class="flex-grow-1" Style="padding: 0.4rem 0.5rem 0.45rem" Spacing="1">
                            <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="1" Style="margin: 0; line-height: 1.1">
                                @if (player.IsAtDestination)
                                {
                                    <MudText Typo="Typo.subtitle2">At Destination:</MudText>
                                    <MudText Typo="Typo.caption">@player.TripDestinationLabel</MudText>
                                }
                                else
                                {
                                    <MudText Typo="Typo.subtitle2">Trip:</MudText>
                                    <MudText Typo="Typo.caption">@player.TripStartLabel @("=>") @player.TripDestinationLabel</MudText>
                                }
                            </MudStack>
                            @if (!player.IsAtDestination)
                            {
                                <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="1" Style="margin: 0; line-height: 1.1">
                                    <MudText Typo="Typo.subtitle2">Distance:</MudText>
                                    <MudText Typo="Typo.caption">@player.DistanceToDestination</MudText>
                                    <MudText Typo="Typo.subtitle2">Payout:</MudText>
                                    <MudText Typo="Typo.caption">$@player.Payoff.ToString("N0")</MudText>
                                </MudStack>
                            }
                            <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="1" Style="margin: 0; line-height: 1.1">
                                <MudText Typo="Typo.subtitle2">Engine:</MudText>
                                <MudText Typo="Typo.caption">@player.LocomotiveLabel</MudText>
                            </MudStack>
                            <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="1" Style="margin: 0; line-height: 1.1">
                                <MudText Typo="Typo.subtitle2">Cash:</MudText>
                                <MudText Typo="Typo.caption" Style="@GetCashValueStyle(player)">@player.GetMoneyDisplay()</MudText>
                            </MudStack>
                            @if (player.HasDeclared)
                            {
                                <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="1" Style="margin: 0; line-height: 1.1">
                                    <MudText Typo="Typo.subtitle2">Declared:</MudText>
                                    <MudText Typo="Typo.caption">@player.HomeCity</MudText>
                                </MudStack>
                                @if (!string.IsNullOrWhiteSpace(player.AlternateCity))
                                {
                                    <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="1" Style="margin: 0; line-height: 1.1">
                                        <MudText Typo="Typo.subtitle2">Alternate City:</MudText>
                                        <MudText Typo="Typo.caption">@player.AlternateCity</MudText>
                                    </MudStack>
                                }
                            }
                            @if (!string.IsNullOrWhiteSpace(player.BonusPendingLabel))
                            {
                                <MudText Typo="Typo.subtitle2" Color="Color.Primary">@player.BonusPendingLabel</MudText>
                            }
                            @if (player.FeesOwed > 0)
                            {
                                <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="1" Style="margin: 0; line-height: 1.1">
                                    <MudText Typo="Typo.subtitle2">Fees Due:</MudText>
                                    <MudText Typo="Typo.subtitle2" Color="Color.Error">$@player.FeesOwed.ToString("N0")</MudText>
                                </MudStack>
                            }

                        </MudStack>

                    </MudPaper>
                </ChildContent>
            </MudTooltip>
        }
    </MudStack>

@code {
    [Parameter]
    public IReadOnlyList<PlayerBoardModel> Players { get; set; } = Array.Empty<PlayerBoardModel>();

    [Parameter]
    public EventCallback<DisconnectedSeatControlRequest> OnSetDisconnectedSeatControl { get; set; }

    [Parameter]
    public EventCallback<int> OnFocusPlayer { get; set; }

    [Parameter]
    public int? HighlightedPlayerIndex { get; set; }

    [Parameter]
    public EventCallback<int?> OnToggleNetworkHighlight { get; set; }

    private static string GetInitial(string name)
    {
        return string.IsNullOrWhiteSpace(name) ? "?" : name[..1].ToUpperInvariant();
    }

    private static string GetCardStyle(PlayerBoardModel player)
    {
        var style = $"{GetColorStyle(player.Color)}; display: flex; flex-direction: column; min-height: 88px; overflow: hidden; border-radius: 0; border: 1px solid transparent; color: var(--mud-palette-text-primary); transition: box-shadow 140ms ease, border-color 140ms ease; margin: 0 0.2rem";

        if (player.IsActiveTurn)
        {
            style += "; border-color: color-mix(in srgb, var(--player-glow-color, var(--player-color, #888)) 42%, white 58%); box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--player-glow-color, var(--player-color, #888)) 30%, white 70%), 0 0 10px 2px color-mix(in srgb, var(--player-glow-color, var(--player-color, #888)) 34%, white 18%), 0 0 18px 4px color-mix(in srgb, var(--player-glow-color, var(--player-color, #888)) 30%, transparent)";
        }

        if (player.IsEliminated)
        {
            style += "; opacity: 0.45; filter: saturate(0.35)";
        }

        return style;
    }

    private static string GetPortraitStyle(PlayerBoardModel player)
    {
        var bg = player.IsEliminated
            ? "background-color: color-mix(in srgb, var(--player-color, #888) 45%, #1b1b1b 55%)"
            : "background-color: var(--player-color, #888)";
        return $"padding: 0.4rem 0.5rem 0.25rem; {bg}; color: var(--player-color-fg, #fff); position: relative";
    }

    private static string GetCashValueStyle(PlayerBoardModel player)
    {
        if (player.CanViewExactCash)
        {
            return string.Empty;
        }

        return player.Cash >= Boxcars.Engine.Domain.GameEngine.GetRailroadPurchasePrice(0)
            ? "font-weight: 700; color: var(--mud-palette-success)"
            : "font-weight: 700; color: var(--mud-palette-error)";
    }

    private static bool HasThumbnail(PlayerBoardModel player)
    {
        return !string.IsNullOrWhiteSpace(player.ThumbnailUrl);
    }

    private static string GetColorStyle(string color)
    {
        return PlayerColorOptions.NormalizeOrDefault(color) switch
        {
            "darkblue" => "--player-color: #0b3d91; --player-glow-color: #7ea7ff; --player-color-fg: #f8fbff",
            "blue" => "--player-color: #2563eb; --player-color-fg: #f8fbff",
            "cyan" => "--player-color: #06b6d4; --player-color-fg: #f8fbff",
            "red" => "--player-color: #dc2626; --player-color-fg: #fff7f7",
            "darkred" => "--player-color: #7f1d1d; --player-glow-color: #ff8a80; --player-color-fg: #fff7f7",
            "orange" => "--player-color: #ea580c; --player-color-fg: #fff7ed",
            "yellow" => "--player-color: #facc15; --player-color-fg: #1f2937",
            "purple" => "--player-color: #9333ea; --player-color-fg: #faf5ff",
            "green" => "--player-color: #16a34a; --player-color-fg: #f7fff9",
            "darkgreen" => "--player-color: #166534; --player-glow-color: #8df5a6; --player-color-fg: #f7fff9",
            _ => "--player-color: #888"
        };
    }

    private Task OnDisconnectedSeatControlChangedAsync(PlayerBoardModel player, string? controlMode)
    {
        return OnSetDisconnectedSeatControl.InvokeAsync(new DisconnectedSeatControlRequest
        {
            PlayerIndex = player.Index,
            ControlMode = string.IsNullOrWhiteSpace(controlMode) ? DisconnectedSeatControlModes.Self : controlMode
        });
    }

    private static string FormatPercent(decimal value)
    {
        return $"{value:N1}%";
    }

}
