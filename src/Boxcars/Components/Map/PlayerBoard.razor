@using Boxcars.Data
@using MudBlazor

<div class="player-board-scope">
<MudStack Class="player-board" Spacing="2">
    @foreach (var player in Players)
    {
        <MudPaper Class="@GetCardClass(player)">
            <MudStack Row="true" Class="player-card-portrait">
                <MudAvatar Class="@GetAvatarClass(player)" Size="Size.Large">
                    @if (HasThumbnail(player))
                    {
                        <MudImage Src="@player.ThumbnailUrl" Alt="@player.Name" Class="player-avatar-image" />
                    }
                    else
                    {
                        @GetInitial(player.Name)
                    }
                </MudAvatar>
                <MudStack>
                    <MudText Typo="Typo.subtitle1">@player.Name</MudText>
                    <MudText Typo="Typo.caption" Class="@(player.IsConnected ? "player-status-connected" : "player-status-disconnected")" Align="Align.Right">
                        @(player.IsConnected ? "Connected" : "Offline")
                    </MudText>
                </MudStack>
            </MudStack>

            <MudStack Class="player-card-info" Spacing="1">
                <MudText Typo="Typo.caption" Class="player-card-line">
                    <span class="player-card-label">Home:</span> @player.HomeCity <span class="player-card-label">Engine:</span> @player.LocomotiveLabel
                </MudText>
                <MudText Typo="Typo.caption" Class="player-card-line">
                    @if (player.IsAtDestination)
                    {
                        <span class="player-card-label">At Destination:</span>
                        <span>@player.TripDestinationLabel</span>
                    }
                    else
                    {
                        <span class="player-card-label">Trip:</span>
                        <span>@player.TripStartLabel @("=>") @player.TripDestinationLabel</span>
                    }
                </MudText>
                @if (!player.IsAtDestination)
                {
                    <MudText Typo="Typo.caption" Class="player-card-line">
                        <span class="player-card-label">Distance:</span> @player.DistanceToDestination <span class="player-card-label">Payout:</span> $@player.Payoff.ToString("N0")
                    </MudText>
                }
                <MudText Typo="Typo.caption" Class="player-card-line">
                    <span class="player-card-label">Cash:</span> @player.GetMoneyDisplay()
                </MudText>

                @if (player.CanUseTestControl)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="player-card-test-row">
                        <MudText Typo="Typo.caption" Class="player-card-label">
                            @(player.IsTestControlled ? "Test control enabled" : "Mock player")
                        </MudText>
                        <MudButton Variant="Variant.Outlined"
                                   Color="MudBlazor.Color.Primary"
                                   Size="Size.Small"
                                   OnClick="() => OnToggleTestPlayer.InvokeAsync(player.Index)">
                            @(player.IsTestControlled ? "TESTING" : "TEST")
                        </MudButton>
                    </MudStack>
                }
            </MudStack>
        </MudPaper>
    }
</MudStack>
</div>

@code {
    [Parameter]
    public IReadOnlyList<PlayerBoardModel> Players { get; set; } = Array.Empty<PlayerBoardModel>();

    [Parameter]
    public EventCallback<int> OnToggleTestPlayer { get; set; }

    private static string GetInitial(string name)
    {
        return string.IsNullOrWhiteSpace(name) ? "?" : name[..1].ToUpperInvariant();
    }

    private static string GetCardClass(PlayerBoardModel player)
    {
        var classes = $"player-card {GetColorClass(player.Color)}";
        if (player.IsActiveTurn)
        {
            classes += " player-card-active";
        }
        return classes;
    }

    private static string GetAvatarClass(PlayerBoardModel player)
    {
        return $"player-avatar {GetColorClass(player.Color)}";
    }

    private static bool HasThumbnail(PlayerBoardModel player)
    {
        return !string.IsNullOrWhiteSpace(player.ThumbnailUrl);
    }

    private static string GetColorClass(string color)
    {
        return color.Trim().ToLowerInvariant() switch
        {
            "blue" => "player-color-blue",
            "red" => "player-color-red",
            "green" => "player-color-green",
            "cyan" => "player-color-cyan",
            "orange" => "player-color-orange",
            "purple" => "player-color-purple",
            _ => "player-color-default"
        };
    }
}
