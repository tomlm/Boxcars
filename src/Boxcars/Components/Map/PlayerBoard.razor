@using Boxcars.Data

<FluentStack Orientation="Orientation.Vertical" Class="player-board">
    @foreach (var player in Players)
    {
        <FluentCard Class="@GetCardClass(player)">
            <div class="player-card-bg @GetColorClass(player)"></div>

            <div class="player-card-train">
                @* SVG train icon — no Fluent equivalent exists *@
                <svg viewBox="0 0 64 32" class="player-train-icon" aria-hidden="true">
                    <rect x="4" y="10" width="36" height="16" rx="2" fill="currentColor" />
                    <rect x="40" y="14" width="14" height="12" rx="1" fill="currentColor" />
                    <rect x="8" y="6" width="8" height="6" rx="1" fill="currentColor" />
                    <circle cx="12" cy="28" r="3" fill="currentColor" />
                    <circle cx="24" cy="28" r="3" fill="currentColor" />
                    <circle cx="36" cy="28" r="3" fill="currentColor" />
                    <circle cx="48" cy="28" r="3" fill="currentColor" />
                    <rect x="54" y="16" width="6" height="4" rx="1" fill="currentColor" />
                </svg>
            </div>

            <div class="player-card-portrait">
                <FluentPersona Name="@player.Name"
                               Image="@(string.IsNullOrWhiteSpace(player.ThumbnailUrl) ? null : player.ThumbnailUrl)"
                               ImageSize="60px"
                               Initials="@GetInitial(player.Name)" />
            </div>

            <FluentStack Orientation="Orientation.Vertical" Class="player-card-info">
                <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold" Class="player-name">
                    #@(player.Index + 1) @player.Name
                </FluentLabel>
                @if (player.IsAtDestination)
                {
                    <FluentLabel Typo="Typography.Body" Class="player-location">At: @player.LocationLabel</FluentLabel>
                }
                else if (!string.IsNullOrWhiteSpace(player.LocationLabel))
                {
                    <FluentLabel Typo="Typography.Body" Class="player-location">@player.DistanceToDestination to @player.LocationLabel</FluentLabel>
                }
                <FluentLabel Typo="Typography.Body" Class="player-payoff">
                    @if (player.IsAtDestination)
                    {
                        @($"Payoff: ${player.Payoff:N0}")
                    }
                    else
                    {
                        @($"Get: ${player.Payoff:N0}")
                    }
                </FluentLabel>
                <FluentLabel Typo="Typography.Body" Class="player-money">@player.GetMoneyDisplay()</FluentLabel>
                <FluentLabel Typo="Typography.Body" Class="player-home">Home: @player.HomeCity</FluentLabel>
            </FluentStack>
        </FluentCard>
    }
</FluentStack>

@code {
    [Parameter]
    public IReadOnlyList<PlayerBoardModel> Players { get; set; } = Array.Empty<PlayerBoardModel>();

    private static string GetInitial(string name)
    {
        return string.IsNullOrWhiteSpace(name) ? "?" : name[..1].ToUpperInvariant();
    }

    private static string GetCardClass(PlayerBoardModel player)
    {
        var classes = $"player-card {GetColorClass(player)}";
        if (player.IsActiveTurn)
        {
            classes += " player-card-active";
        }
        return classes;
    }

    private static string GetColorClass(PlayerBoardModel player)
    {
        return $"player-color-{player.Index}";
    }
}
